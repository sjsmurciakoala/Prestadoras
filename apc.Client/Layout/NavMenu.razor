                        IconCssClass="bi bi-collection"
                        CssClass="@ActiveClass("/facturacion/cobranza")"
                        Attributes="@ItemAttrs("Cobranza")" />
            <DxMenuItem NavigateUrl="/facturacion/cobranza/clientes-cobros"
                        Text="Clientes para cobros"
                        IconCssClass="bi bi-people"
                        CssClass="@ActiveClass("/facturacion/cobranza/clientes-cobros")"
                        Attributes="@ItemAttrs("Clientes para cobros")" />
            <DxMenuItem NavigateUrl="/facturacion/captacion/reverso"
