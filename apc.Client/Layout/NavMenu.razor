            DisplayMode="MenuDisplayMode.Desktop"
            DropDownActionMode="MenuDropDownActionMode.Click"
            CollapseItemToIconMode="MenuCollapseItemToIconMode.None"
            CollapseItemsToHamburgerMenu="false"
            CssClass="custom-dx-menu">
        <Items>
            <DxMenuItem NavigateUrl="/"
                        Text="Home"
                        IconCssClass="bi bi-house"
                        CssClass="@ActiveClass("/")"
                        Attributes="@ItemAttrs("Inicio")" />
        </Items>
    </DxMenu>

    <div class="menu-section-label">OPERACIÓN</div>
    <DxMenu Orientation="Orientation.Vertical"
            DisplayMode="MenuDisplayMode.Desktop"
            DropDownActionMode="MenuDropDownActionMode.Click"
            CollapseItemToIconMode="MenuCollapseItemToIconMode.None"
            CollapseItemsToHamburgerMenu="false"
            CssClass="custom-dx-menu">
        <Items>
            <DxMenuItem NavigateUrl="/clientes"
                        Text="Clientes"
                        IconCssClass="bi bi-people"
                        CssClass="@ActiveClass("/clientes")"
                        Attributes="@ItemAttrs("Clientes")" />
            <DxMenuItem Text="Proveedores"
                        IconCssClass="bi bi-truck"
