            <DxMenuItem NavigateUrl="/rutas"
                        Text="Rutas"
                        IconCssClass="bi bi-map"
                        CssClass="@ActiveClass("/rutas")"
                        Attributes="@ItemAttrs("Rutas")" />
            <DxMenuItem NavigateUrl="/mapa"
                        Text="Mapa"
                        IconCssClass="bi bi-geo-alt"
                        CssClass="@ActiveClass("/mapa")"
