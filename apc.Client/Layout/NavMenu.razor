                        CssClass="@ActiveClass("/mantenimientos/clases-medidor")"
                        Attributes="@ItemAttrs("Clases de medidor")" />
            <DxMenuItem NavigateUrl="/mantenimientos/impuestos"
                        Text="Impuestos"
                        IconCssClass="bi bi-percent"
                        CssClass="@ActiveClass("/mantenimientos/impuestos")"
                        Attributes="@ItemAttrs("Impuestos")" />
        </Items>
    </DxMenu>

    <div class="menu-section-label">SETTINGS</div>
    <DxMenu Orientation="Orientation.Vertical"
            DisplayMode="MenuDisplayMode.Desktop"
            DropDownActionMode="MenuDropDownActionMode.Click"
            CollapseItemToIconMode="MenuCollapseItemToIconMode.None"
            CollapseItemsToHamburgerMenu="false"
            CssClass="custom-dx-menu">
        <Items>
            <DxMenuItem NavigateUrl="/mi-app/usuarios"
                        Text="Lectores App"
                        IconCssClass="bi bi-phone"
                        CssClass="@ActiveClass("/mi-app/usuarios")"
                        Attributes="@ItemAttrs("Lectores App")" />
            <AuthorizeView Context="authContext">
                <Authorized>
                    <DxMenuItem NavigateUrl="Account/Manage"
                                Text="@authContext.User.Identity?.Name"
                                IconCssClass="bi bi-person-circle"
                                CssClass="@ActiveClass("/Account/Manage")"
                                Attributes="@ItemAttrs("Cuenta")" />
                    <DxMenuItem NavigateUrl="Account/Logout"
                                Text="Log out"
                                IconCssClass="bi bi-box-arrow-right"
                                CssClass="@ActiveClass("/Account/Logout")"
                                Attributes="@ItemAttrs("Cerrar sesión")" />
                </Authorized>
                <NotAuthorized>
                    <DxMenuItem NavigateUrl="Account/Login"
                                Text="Log in"
                                IconCssClass="bi bi-box-arrow-in-right"
                                CssClass="@ActiveClass("/Account/Login")"
                                Attributes="@ItemAttrs("Iniciar sesión")" />
                </NotAuthorized>
            </AuthorizeView>
        </Items>
    </DxMenu>
</div>

@code {
    [Parameter] public bool IsCollapsed { get; set; }

    private string CurrentPath => NormalizePath(NavigationManager.ToBaseRelativePath(NavigationManager.Uri));

    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e) => StateHasChanged();

    public void Dispose()
    {
        NavigationManager.LocationChanged -= HandleLocationChanged;
    }

    private Dictionary<string, object> ItemAttrs(string text)
    {
        if (!IsCollapsed)
        {
            return new Dictionary<string, object>();
        }

        return new Dictionary<string, object>
        {
            ["title"] = text,
            ["aria-label"] = text
        };
    }

    private string ActiveClass(string href)
    {
        var current = CurrentPath;
        var target = NormalizePath(href);

        if (target == "/")
        {
            return current == "/" ? "menu-item-active" : string.Empty;
        }

        if (current.Equals(target, StringComparison.OrdinalIgnoreCase) ||
            current.StartsWith(target + "/", StringComparison.OrdinalIgnoreCase))
        {
            return "menu-item-active";
        }

        return string.Empty;
    }

    private string GroupClass(params string[] prefixes)
    {
        foreach (var prefix in prefixes)
        {
            var target = NormalizePath(prefix);
            if (CurrentPath.Equals(target, StringComparison.OrdinalIgnoreCase) ||
                CurrentPath.StartsWith(target + "/", StringComparison.OrdinalIgnoreCase))
            {
                return "menu-group-active";
            }
        }

        return string.Empty;
    }

    private static string NormalizePath(string? path)
    {
        if (string.IsNullOrWhiteSpace(path))
        {
            return "/";
        }

        var cleaned = path.Split('?', '#')[0];
        if (!cleaned.StartsWith("/"))
        {
            cleaned = "/" + cleaned;
        }

        cleaned = cleaned.TrimEnd('/');
        if (string.IsNullOrEmpty(cleaned))
        {
            cleaned = "/";
        }

        return cleaned.ToLowerInvariant();
    }
}
