                                CssClass="@ActiveClass("/contabilidad/empresas")"
                                Attributes="@ItemAttrs("Empresas")" />
                    <DxMenuItem NavigateUrl="/contabilidad/empresas/configuracion"
                                Text="Configuración Sistema"
                                CssClass="@ActiveClass("/contabilidad/empresas/configuracion")"
                                Attributes="@ItemAttrs("Configuración Sistema")" />
                    <DxMenuItem NavigateUrl="/contabilidad/empresas/nueva"
                                Text="Crear empresa"
                                CssClass="@ActiveClass("/contabilidad/empresas/nueva")"
                                Attributes="@ItemAttrs("Crear empresa")" />
                    <DxMenuItem NavigateUrl="/contabilidad/plan-cuentas"
                                Text="Plan de cuentas"
                                CssClass="@ActiveClass("/contabilidad/plan-cuentas")"
                                Attributes="@ItemAttrs("Plan de cuentas")" />
                    <DxMenuItem NavigateUrl="/contabilidad/centros-costo"
                                Text="Centros de costo"
                                CssClass="@ActiveClass("/contabilidad/centros-costo")"
                                Attributes="@ItemAttrs("Centros de costo")" />
                    <DxMenuItem NavigateUrl="/contabilidad/terceros"
                                Text="Terceros"
                                CssClass="@ActiveClass("/contabilidad/terceros")"
                                Attributes="@ItemAttrs("Terceros")" />
                    <DxMenuItem NavigateUrl="/contabilidad/diarios"
                                Text="Diarios contables"
                                CssClass="@ActiveClass("/contabilidad/diarios")"
                                Attributes="@ItemAttrs("Diarios contables")" />
                    <DxMenuItem NavigateUrl="/contabilidad/periodos"
                                Text="Períodos contables"
                                CssClass="@ActiveClass("/contabilidad/periodos")"
                                Attributes="@ItemAttrs("Períodos contables")" />
                    <DxMenuItem NavigateUrl="/contabilidad/tipos-transaccion"
                                Text="Tipos de comprobantes"
                                CssClass="@ActiveClass("/contabilidad/tipos-transaccion")"
                                Attributes="@ItemAttrs("Tipos de comprobantes")" />
                    <DxMenuItem NavigateUrl="/contabilidad/partidas"
                                Text="Partidas"
                                CssClass="@((!string.IsNullOrEmpty(ActiveClass("/contabilidad/partidas")) || !string.IsNullOrEmpty(ActiveClass("/contabilidad/polizas"))) ? "menu-item-active" : string.Empty)"
