    <div class="menu-section-label">CONTABILIDAD</div>
    <DxMenu Orientation="Orientation.Vertical"
            DisplayMode="MenuDisplayMode.Desktop"
            DropDownActionMode="MenuDropDownActionMode.Click"
            CollapseItemToIconMode="MenuCollapseItemToIconMode.None"
            CollapseItemsToHamburgerMenu="false"
            CssClass="custom-dx-menu">
        <Items>
            <DxMenuItem Text="Bancos"
                        IconCssClass="bi bi-bank"
                        CssClass="@GroupClass("/contabilidad/bancos", "/bancos/configuracion_transacciones", "/bancos/configuracion")"
                        Attributes="@ItemAttrs("Bancos")">
                <Items>
                    <DxMenuItem NavigateUrl="/contabilidad/bancos"
                                Text="Gestión de bancos"
                                CssClass="@ActiveClass("/contabilidad/bancos")"
                                Attributes="@ItemAttrs("Gestión de bancos")" />
                    <DxMenuItem NavigateUrl="/bancos/configuracion_transacciones"
                                Text="Configuración de transacciones"
                                CssClass="@ActiveClass("/bancos/configuracion_transacciones")"
                                Attributes="@ItemAttrs("Configuración de transacciones")" />
                    <DxMenuItem NavigateUrl="/bancos/configuracion"
                                Text="Configuración"
                                CssClass="@ActiveClass("/bancos/configuracion")"
                                Attributes="@ItemAttrs("Configuración")" />
                </Items>
            </DxMenuItem>
            <DxMenuItem Text="Contabilidad"
                        IconCssClass="bi bi-journal"
                        CssClass="@GroupClass("/contabilidad/empresas", "/contabilidad/plan-cuentas", "/contabilidad/centros-costo", "/contabilidad/terceros", "/contabilidad/diarios", "/contabilidad/periodos", "/contabilidad/tipos-transaccion", "/contabilidad/polizas", "/contabilidad/partidas")"
                        Attributes="@ItemAttrs("Contabilidad")">
                <Items>
