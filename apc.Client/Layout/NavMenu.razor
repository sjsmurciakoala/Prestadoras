                    <DxMenuItem NavigateUrl="/proveedores/compromisos-proveedor" Text="Compromisos de proveedor" title="Compromisos de proveedor" />
                    <DxMenuItem NavigateUrl="/proveedores/bancos" Text="Bancos de proveedor" title="Bancos de proveedor" />
                    <DxMenuItem NavigateUrl="/proveedores/tipos" Text="Tipos de proveedor" title="Tipos de proveedor" />
