@inherits LayoutComponentBase
@using DevExpress.Blazor
@using apc.Client.Services.Layout
@inject SidebarStateService SidebarState
@implements IDisposable
<DxLayoutBreakpoint DeviceSize="DeviceSize.XSmall"
                    IsActive="@isXSmall"
                    IsActiveChanged="@OnXSmallChanged" />

<AuthorizeView>
    <Authorized>
        <div class="page">
            @if (isXSmall)
            {
                <div class="mobile-topbar">
                    <button type="button" class="mobile-toggle" @onclick="ToggleDrawer" aria-label="Abrir navegación">
                        <i class="bi bi-list"></i>
                    </button>
                    <span class="mobile-topbar__title">HODSOFT</span>
                </div>
            }

            <DxDrawer IsOpen="@IsOpen"
                      IsOpenChanged="@OnIsOpenChanged"
                      Mode="@DrawerMode"
                      Position="DrawerPosition.Left"
                      PanelWidth="@PanelWidth"
                      MiniModeEnabled="@EnableMiniMode"
                      MiniPanelWidth="@MiniPanelWidth"
                      CssClass="app-drawer"
                      OpenCssClass="app-drawer--open"
                      MiniCssClass="app-drawer--mini"
                      ClosedCssClass="app-drawer--closed"
                      CloseOnEscape="true"
                      CloseOnTargetContentClick="@isXSmall"
                      CloseOnOutsideClick="@isXSmall"
                      ApplyBackgroundShading="@isXSmall">

                <HeaderTemplate>
                    @if (isXSmall)
                    {
                        <div class="drawer-header drawer-header--mobile">
                            <span class="drawer-header__title">Menú</span>
                            <button type="button" class="drawer-close" @onclick="ToggleDrawer" aria-label="Cerrar navegación">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="drawer-header">
                            <DxButton RenderStyle="ButtonRenderStyle.Light"
                                      RenderStyleMode="ButtonRenderStyleMode.Text"
                                      CssClass="menu-toggle"
                                      IconCssClass="@(IsOpen ? "bi bi-chevron-left" : "bi bi-list")"
                                      Click="ToggleDrawer"
                                      aria-label="@(IsOpen ? "Colapsar navegación" : "Expandir navegación")"
                                      aria-expanded="@IsOpen" />
                        </div>
                    }
                </HeaderTemplate>

                <BodyTemplate>
                    <SidebarNavigation IsCollapsed="@IsMini" IsMobile="@isXSmall" />
                </BodyTemplate>

                <TargetContent>
                    <div class="main-content">
                        <div class="content">
                            @Body
                        </div>
                    </div>
                </TargetContent>
            </DxDrawer>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="page">
            <div class="main-content">
                <div class="content">
                    @Body
                </div>
            </div>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool isXSmall;

    protected override void OnInitialized()
    {
        SidebarState.Changed += HandleSidebarStateChanged;
    }

    private bool IsOpen => SidebarState.IsOpen;

    private DrawerMode DrawerMode => isXSmall ? DrawerMode.Overlap : DrawerMode.Shrink;
    private bool EnableMiniMode => !isXSmall;
    private bool IsMini => EnableMiniMode && !IsOpen;

    private string PanelWidth => isXSmall ? "80%" : "280px";
    private string MiniPanelWidth => "64px";

    private void ToggleDrawer() => SidebarState.Toggle();

    private void OnXSmallChanged(bool isActive)
    {
        isXSmall = isActive;
        SidebarState.SetBreakpoint(isActive);
    }

    private void OnIsOpenChanged(bool value) => SidebarState.SetOpen(value);

    private void HandleSidebarStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        SidebarState.Changed -= HandleSidebarStateChanged;
    }
}
