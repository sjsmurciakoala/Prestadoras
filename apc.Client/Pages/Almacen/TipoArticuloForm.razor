@using DevExpress.Blazor
@using SIAD.Core.DTOs.Almacen
@using SIAD.Core.DTOs.Contabilidad

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" Context="EditFormContext">
    <DataAnnotationsValidator />

    @if (EditFormContext.GetValidationMessages().Any())
    {
        <div class="alert alert-danger mb-3 shadow-sm">
            <h6 class="alert-heading"><i class="bi bi-exclamation-circle-fill me-2"></i>Atención</h6>
            <DxValidationSummary />
        </div>
    }

    <DxFormLayout>
        <DxFormLayoutItem Caption="Código *" ColSpanMd="4">
            <DxTextBox @bind-Text="Model.Codigo" NullText="Ej. OPER, MANT" MaxLength="10" />
            <ValidationMessage For="() => Model.Codigo" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Nombre *" ColSpanMd="8">
            <DxTextBox @bind-Text="Model.Nombre" NullText="Ej. Inventario de herramientas" MaxLength="100" />
            <ValidationMessage For="() => Model.Nombre" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Descripción" ColSpanMd="12">
            <DxTextBox @bind-Text="Model.Descripcion" NullText="Descripción del tipo" MaxLength="200" />
            <ValidationMessage For="() => Model.Descripcion" />
        </DxFormLayoutItem>

        <DxFormLayoutGroup Caption="Cuentas contables" ColSpanMd="12">
            <DxFormLayoutItem Caption="De inventario" ColSpanMd="6">
                <DxComboBox Data="@CuentasContables" TData="CuentaContableLookupDto" TValue="string"
                            @bind-Value="Model.CuentaInventario"
                            ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                            TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                            FilteringMode="DataGridFilteringMode.Contains"
                            NullText="Seleccione una cuenta..."
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                            Enabled="@(CuentasContables.Count > 0)" />
                <ValidationMessage For="() => Model.CuentaInventario" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="De costo de ventas" ColSpanMd="6">
                <DxComboBox Data="@CuentasContables" TData="CuentaContableLookupDto" TValue="string"
                            @bind-Value="Model.CuentaCostoVentas"
                            ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                            TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                            FilteringMode="DataGridFilteringMode.Contains"
                            NullText="Seleccione una cuenta..."
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                            Enabled="@(CuentasContables.Count > 0)" />
                <ValidationMessage For="() => Model.CuentaCostoVentas" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="De ventas" ColSpanMd="6">
                <DxComboBox Data="@CuentasContables" TData="CuentaContableLookupDto" TValue="string"
                            @bind-Value="Model.CuentaVentas"
                            ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                            TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                            FilteringMode="DataGridFilteringMode.Contains"
                            NullText="Seleccione una cuenta..."
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                            Enabled="@(CuentasContables.Count > 0)" />
                <ValidationMessage For="() => Model.CuentaVentas" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="De ajustes" ColSpanMd="6">
                <DxComboBox Data="@CuentasContables" TData="CuentaContableLookupDto" TValue="string"
                            @bind-Value="Model.CuentaAjustes"
                            ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                            TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                            FilteringMode="DataGridFilteringMode.Contains"
                            NullText="Seleccione una cuenta..."
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                            Enabled="@(CuentasContables.Count > 0)" />
                <ValidationMessage For="() => Model.CuentaAjustes" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="De devoluciones" ColSpanMd="6">
                <DxComboBox Data="@CuentasContables" TData="CuentaContableLookupDto" TValue="string"
                            @bind-Value="Model.CuentaDevoluciones"
                            ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                            TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                            FilteringMode="DataGridFilteringMode.Contains"
                            NullText="Seleccione una cuenta..."
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                            Enabled="@(CuentasContables.Count > 0)" />
                <ValidationMessage For="() => Model.CuentaDevoluciones" />
            </DxFormLayoutItem>
        </DxFormLayoutGroup>

        <DxFormLayoutItem Caption="Maneja inventario" ColSpanMd="8">
            <Template>
                <div class="pt-2">
                    <DxCheckBox @bind-Checked="Model.ManejaInventario" CheckType="CheckType.Switch"
                                LabelText="Maneja inventario" />
                    <div class="form-hint text-muted small mt-1">
                        <i class="bi bi-info-circle me-1"></i>
                        Desactívalo para tipos que no llevan existencias (ej. Servicios): sus artículos
                        no tendrán bodega ni kardex.
                    </div>
                </div>
            </Template>
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Activo" ColSpanMd="4">
            <Template>
                <div class="pt-2">
                    <DxCheckBox @bind-Checked="Model.Activo" CheckType="CheckType.Switch" LabelText="Activo" />
                </div>
            </Template>
        </DxFormLayoutItem>
    </DxFormLayout>

    <ValidationSummary class="text-danger mb-3" />

    <div class="d-flex justify-content-end gap-2">
        <DxButton ButtonType="ButtonType.Submit" RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar" SubmitFormOnClick="true" Enabled="@(!IsBusy)" />
        <DxButton ButtonType="ButtonType.Normal" Text="Cancelar" Enabled="@(!IsBusy)" Click="Cancel" />
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired] public TipoArticuloEditDto Model { get; set; } = default!;
    [Parameter] public IReadOnlyList<CuentaContableLookupDto> CuentasContables { get; set; } = Array.Empty<CuentaContableLookupDto>();
    [Parameter] public EventCallback OnValidSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public bool IsBusy { get; set; }

    private async Task HandleValidSubmit() { if (OnValidSubmit.HasDelegate) await OnValidSubmit.InvokeAsync(); }
    private async Task Cancel() { if (OnCancel.HasDelegate) await OnCancel.InvokeAsync(); }
}
