@using DevExpress.Blazor
@using SIAD.Core.DTOs.Almacen
@using SIAD.Core.DTOs.Contabilidad

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" Context="EditFormContext">
    <DataAnnotationsValidator />

    <DxTabs @bind-ActiveTabIndex="activeTab" CssClass="mb-3">
        <DxTabPage Text="Datos del artículo">
            <ContentTemplate>
                <DxFormLayout>
        <DxFormLayoutGroup Caption="Datos generales" ColSpanXs="12">
            @if (Model.Id.HasValue)
            {
                <DxFormLayoutItem Caption="ID" ColSpanMd="4">
                    <Template>
                        <div class="pt-2"><span class="fw-semibold fs-6">@Model.Id</span></div>
                    </Template>
                </DxFormLayoutItem>

                <DxFormLayoutItem Caption="Código (SIMAFI)" ColSpanMd="8">
                    <DxTextBox @bind-Text="Model.Codigo" ReadOnly="true" NullText="—" MaxLength="20" />
                </DxFormLayoutItem>
            }

            <DxFormLayoutItem Caption="Descripción *" ColSpanMd="12">
                <DxTextBox @bind-Text="Model.Descripcion"
                           NullText="Descripción del artículo"
                           MaxLength="120" />
                <ValidationMessage For="() => Model.Descripcion" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="Unidad de medida" ColSpanMd="4">
                <DxComboBox Data="@UnidadesConCategoria" Value="Model.UnidadMedidaId"
                            ValueChanged="@((int? v) => OnUnidadMedidaChanged(v))"
                            ValueExpression="@(() => Model.UnidadMedidaId)"
                            ValueFieldName="@nameof(UnidadMedidaLookupDto.Id)"
                            TextFieldName="@nameof(UnidadMedidaLookupDto.Display)"
                            FilteringMode="DataGridFilteringMode.Contains"
                            NullText="Seleccione una unidad..."
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                <ValidationMessage For="() => Model.UnidadMedidaId" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="Unidad de almacenaje" ColSpanMd="4">
                <DxComboBox Data="@UnidadesCompatibles" @bind-Value="Model.UnidadAlmacenajeId"
                            ValueFieldName="@nameof(UnidadMedidaLookupDto.Id)"
                            TextFieldName="@nameof(UnidadMedidaLookupDto.Display)"
                            FilteringMode="DataGridFilteringMode.Contains"
                            Enabled="@(CategoriaIdSeleccionada.HasValue)"
                            NullText="@(!CategoriaIdSeleccionada.HasValue ? "Elija primero la unidad de medida" : "Unidad de almacenaje...")"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                <ValidationMessage For="() => Model.UnidadAlmacenajeId" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="Unidad de salidas" ColSpanMd="4">
                <DxComboBox Data="@UnidadesCompatibles" @bind-Value="Model.UnidadSalidaId"
                            ValueFieldName="@nameof(UnidadMedidaLookupDto.Id)"
                            TextFieldName="@nameof(UnidadMedidaLookupDto.Display)"
                            FilteringMode="DataGridFilteringMode.Contains"
                            Enabled="@(CategoriaIdSeleccionada.HasValue)"
                            NullText="@(!CategoriaIdSeleccionada.HasValue ? "Elija primero la unidad de medida" : "Unidad de salidas...")"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                <ValidationMessage For="() => Model.UnidadSalidaId" />
            </DxFormLayoutItem>

            @if (!string.IsNullOrWhiteSpace(CategoriaNombreSeleccionada))
            {
                <DxFormLayoutItem ColSpanMd="12">
                    <Template>
                        <div class="form-hint text-muted small">
                            <i class="bi bi-info-circle me-1"></i>
                            Al elegir la unidad de medida, almacenaje y salida toman la misma unidad (categoría <strong>@CategoriaNombreSeleccionada</strong>). Puedes cambiarlas por otra de la misma categoría.
                        </div>
                    </Template>
                </DxFormLayoutItem>
            }
        </DxFormLayoutGroup>

        <DxFormLayoutGroup Caption="Clasificación" ColSpanXs="12">
            <DxFormLayoutItem Caption="Tipo de artículo" ColSpanMd="4">
                <DxComboBox Data="@Tipos" Value="Model.TipoArticuloId"
                            ValueChanged="@((int? v) => HandleTipoArticuloChanged(v))"
                            ValueExpression="@(() => Model.TipoArticuloId)"
                            ValueFieldName="@nameof(TipoArticuloLookupDto.Id)"
                            TextFieldName="@nameof(TipoArticuloLookupDto.Display)"
                            NullText="Operativo, mantenimiento..."
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                <ValidationMessage For="() => Model.TipoArticuloId" />
            </DxFormLayoutItem>

            @if (!ManejaInventario)
            {
                <DxFormLayoutItem ColSpanMd="12">
                    <Template>
                        <div class="alert alert-info py-2 px-3 mb-0 small">
                            <i class="bi bi-info-circle-fill me-1"></i>
                            Los artículos de tipo <strong>@(TipoSeleccionado?.Nombre)</strong> no manejan existencias:
                            no llevan bodega ni kardex. La pestaña <strong>Existencias</strong> queda deshabilitada.
                        </div>
                    </Template>
                </DxFormLayoutItem>
            }

            <DxFormLayoutItem Caption="Grupo" ColSpanMd="4">
                <DxComboBox Data="@Lineas" @bind-Value="Model.LineaId"
                            ValueFieldName="@nameof(LineaLookupDto.Id)"
                            TextFieldName="@nameof(LineaLookupDto.Display)"
                            FilteringMode="DataGridFilteringMode.Contains"
                            NullText="Seleccione un grupo..."
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                <ValidationMessage For="() => Model.LineaId" />
            </DxFormLayoutItem>

            <DxFormLayoutItem Caption="Categoría" ColSpanMd="4">
                <DxComboBox Data="@GruposFiltrados" @bind-Value="Model.GrupoId"
                            ValueFieldName="@nameof(GrupoLookupDto.Id)"
                            TextFieldName="@nameof(GrupoLookupDto.Display)"
                            FilteringMode="DataGridFilteringMode.Contains"
                            NullText="Seleccione una categoría..."
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                <ValidationMessage For="() => Model.GrupoId" />
            </DxFormLayoutItem>
        </DxFormLayoutGroup>

        <DxFormLayoutGroup Caption="Contabilidad" ColSpanXs="12">
            <DxFormLayoutItem Caption="Cuenta contable" ColSpanMd="12">
                <DxComboBox Data="@CuentasContables"
                            TData="CuentaContableLookupDto"
                            TValue="string"
                            @bind-Value="Model.CuentaContable"
                            ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                            TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                            FilteringMode="DataGridFilteringMode.Contains"
                            NullText="Seleccione una cuenta contable..."
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                            Enabled="@(CuentasContables.Count > 0)" />
                <ValidationMessage For="() => Model.CuentaContable" />
            </DxFormLayoutItem>
        </DxFormLayoutGroup>

                </DxFormLayout>
            </ContentTemplate>
        </DxTabPage>
        @* Tipo sin inventario (ej. Servicios) ⇒ la pestaña se deshabilita: no hay bodega ni kardex. *@
        <DxTabPage Text="Existencias" Enabled="@ManejaInventario">
            <ContentTemplate>
                @if (!ManejaInventario)
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        Los artículos de tipo <strong>@(TipoSeleccionado?.Nombre)</strong> no manejan existencias:
                        no llevan bodega ni kardex.
                    </div>
                }
                else if (Model.Id.HasValue)
                {
                    <ArticuloUbicacionesTab ArticuloId="@Model.Id.Value" />
                }
                else
                {
                    <ArticuloUbicacionesTab @bind-Ubicaciones="Model.Ubicaciones" />
                }
            </ContentTemplate>
        </DxTabPage>
        <DxTabPage Text="Proveedores (UPC)">
            <ContentTemplate>
                @if (Model.Id.HasValue)
                {
                    <ArticuloProveedoresTab ArticuloId="@Model.Id.Value" />
                }
                else
                {
                    <ArticuloProveedoresTab @bind-Proveedores="Model.Proveedores" />
                }
            </ContentTemplate>
        </DxTabPage>
    </DxTabs>

    @if (EditFormContext.GetValidationMessages().Any())
    {
        <div class="alert alert-danger mb-3 shadow-sm">
            <h6 class="alert-heading"><i class="bi bi-exclamation-circle-fill me-2"></i>Atención</h6>
            <ValidationSummary />
        </div>
    }

    <ValidationSummary class="text-danger mb-3" />

    @if (faltanUbicaciones)
    {
        <div class="alert alert-warning mb-3 shadow-sm">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            Debe asignar al menos una bodega en la pestaña <strong>Existencias</strong> antes de guardar el artículo.
        </div>
    }

    <div class="d-flex justify-content-end gap-2">
        <DxButton ButtonType="ButtonType.Submit"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  SubmitFormOnClick="true"
                  Enabled="@(!IsBusy)" />
        <DxButton ButtonType="ButtonType.Normal"
                  Text="Cancelar"
                  Enabled="@(!IsBusy)"
                  Click="Cancel" />
    </div>
</EditForm>

@code {
    private int activeTab;

    [Parameter, EditorRequired]
    public ArticuloEditDto Model { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<UnidadMedidaLookupDto> Unidades { get; set; } = Array.Empty<UnidadMedidaLookupDto>();

    [Parameter]
    public IReadOnlyList<TipoArticuloLookupDto> Tipos { get; set; } = Array.Empty<TipoArticuloLookupDto>();

    [Parameter]
    public IReadOnlyList<LineaLookupDto> Lineas { get; set; } = Array.Empty<LineaLookupDto>();

    [Parameter]
    public IReadOnlyList<GrupoLookupDto> Grupos { get; set; } = Array.Empty<GrupoLookupDto>();

    [Parameter]
    public IReadOnlyList<CuentaContableLookupDto> CuentasContables { get; set; } = Array.Empty<CuentaContableLookupDto>();

    /// <summary>Se dispara cuando cambia el tipo, para que la página anfitriona re-renderice (panel de kardex).</summary>
    [Parameter]
    public EventCallback OnTipoArticuloChanged { get; set; }

    // ── Tipo de artículo: define si el artículo lleva existencias ────────────────
    private TipoArticuloLookupDto? TipoSeleccionado =>
        Tipos.FirstOrDefault(t => t.Id == Model.TipoArticuloId);

    /// <summary>
    /// Sin tipo elegido se asume que SÍ maneja inventario (comportamiento histórico:
    /// tipo_articulo_id es nullable). Es la misma regla que aplica ArticulosService.
    /// </summary>
    private bool ManejaInventario => TipoSeleccionado?.ManejaInventario ?? true;

    private async Task HandleTipoArticuloChanged(int? value)
    {
        Model.TipoArticuloId = value;

        // Si el tipo elegido no maneja inventario, las ubicaciones que el usuario hubiera
        // cargado dejan de tener sentido (un servicio no puede tener bodega) y el servidor
        // las rechazaría. Se limpian y se avisa en la pestaña, que además queda bloqueada.
        if (!ManejaInventario && Model.Ubicaciones is { Count: > 0 })
        {
            Model.Ubicaciones.Clear();
        }

        if (!ManejaInventario)
        {
            faltanUbicaciones = false;
            if (activeTab == 1) activeTab = 0; // no dejar al usuario parado en una pestaña deshabilitada
        }

        if (OnTipoArticuloChanged.HasDelegate)
        {
            await OnTipoArticuloChanged.InvokeAsync();
        }
    }

    // Si hay línea seleccionada, mostrar sólo sus grupos; si no, todos.
    private IReadOnlyList<GrupoLookupDto> GruposFiltrados =>
        Model.LineaId.HasValue ? Grupos.Where(g => g.LineaId == Model.LineaId.Value).ToList() : Grupos;

    // ── Unidades de medida: las tres (medida/almacenaje/salida) deben ser de la
    //    misma categoría. La unidad de medida es el ancla y define la categoría.
    private UnidadMedidaLookupDto? UnidadMedidaSeleccionada =>
        Unidades.FirstOrDefault(u => u.Id == Model.UnidadMedidaId);

    private int? CategoriaIdSeleccionada => UnidadMedidaSeleccionada?.CategoriaId;
    private string? CategoriaNombreSeleccionada => UnidadMedidaSeleccionada?.CategoriaNombre;

    // Sólo se ofrecen unidades con categoría definida (las sin categoría no se usan).
    private IReadOnlyList<UnidadMedidaLookupDto> UnidadesConCategoria =>
        Unidades.Where(u => u.CategoriaId.HasValue).ToList();

    // Almacenaje y salida se filtran a la categoría de la unidad de medida.
    private IReadOnlyList<UnidadMedidaLookupDto> UnidadesCompatibles =>
        CategoriaIdSeleccionada.HasValue
            ? Unidades.Where(u => u.CategoriaId == CategoriaIdSeleccionada).ToList()
            : Array.Empty<UnidadMedidaLookupDto>();

    private void OnUnidadMedidaChanged(int? value)
    {
        Model.UnidadMedidaId = value;

        // Al asignar la unidad de medida, almacenaje y salida toman la MISMA unidad.
        // (Quedan editables: el usuario puede cambiarlas por otra de la misma categoría.)
        // Si se limpia la unidad de medida (value = null), las otras dos también se limpian.
        Model.UnidadAlmacenajeId = value;
        Model.UnidadSalidaId = value;
    }

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private bool faltanUbicaciones;

    private async Task HandleValidSubmit()
    {
        // Al crear, el artículo debe nacer con al menos una bodega (ubicación).
        // Excepción: los tipos que no manejan inventario (ej. Servicios) no llevan bodega.
        if (ManejaInventario && !Model.Id.HasValue && (Model.Ubicaciones is null || Model.Ubicaciones.Count == 0))
        {
            faltanUbicaciones = true;
            activeTab = 1; // salta a la pestaña "Existencias"
            return;
        }

        faltanUbicaciones = false;
        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }
}
