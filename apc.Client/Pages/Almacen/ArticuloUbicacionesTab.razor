@using DevExpress.Blazor
@using SIAD.Core.DTOs.Almacen
@using apc.Client.Services
@using apc.Client.Services.Almacen

@inject ArticulosClient ArticulosClient
@inject BodegasClient BodegasClient
@inject IToastNotificationService ToastService
@inject IJSRuntime JS

<DxToastProvider Name="UbicacionesToast" MaxToastCount="4" />

<div class="modern-card position-relative">
    <DxLoadingPanel Visible="isLoading" IsContentBlocked="true" Text="Cargando..." />

    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <div class="text-muted small">
            <i class="bi bi-geo-alt me-1"></i>
            @if (EnMemoria)
            {
                <text>Asigne las bodegas donde se almacenará el artículo. La primera es la principal. La ubicación física (5 campos) es manual y opcional.</text>
            }
            else
            {
                <text>Bodegas donde se almacena este artículo. Las ubicaciones no se eliminan: se deshabilitan y quedan en el histórico.</text>
            }
        </div>
        <div class="d-flex align-items-center gap-3 flex-wrap">
            @if (!EnMemoria)
            {
                <DxCheckBox Checked="verInactivas" CheckedExpression="@(() => verInactivas)"
                            CheckedChanged="@((bool v) => OnToggleInactivasAsync(v))">
                    Ver histórico
                </DxCheckBox>
            }
            <DxButton Text="Agregar ubicación" IconCssClass="bi bi-plus-lg"
                      RenderStyle="ButtonRenderStyle.Primary" CssClass="btn-modern"
                      Click="AbrirNuevo" />
        </div>
    </div>

    <div class="grid-wrapper">
        <DxGrid @ref="grid" Data="@ubicaciones" KeyFieldName="@nameof(ArticuloUbicacionDto.Id)" PageSize="15"
                PageSizeSelectorVisible="true"
                PageSizeSelectorItems="new int[] { 5, 10, 15, 25, 50, 100 }"
                PagerPosition="GridPagerPosition.Bottom"
                ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
                ShowGroupPanel="false" CssClass="grid-solicitudes"
                LayoutAutoSaving="OnLayoutAutoSaving"
                LayoutAutoLoading="OnLayoutAutoLoading">

            <ToolbarTemplate>
                <div class="d-flex flex-wrap gap-2 align-items-center w-100">
                    <DxButton Text="Columnas" IconCssClass="bi bi-layout-three-columns"
                              RenderStyle="ButtonRenderStyle.Secondary" Click="MostrarColumnChooser" CssClass="me-1" />

                    <div class="ms-auto text-muted small">
                        Total: <span class="fw-bold">@ubicaciones.Count.ToString("N0")</span>
                    </div>
                </div>
            </ToolbarTemplate>

            <Columns>
                <DxGridDataColumn FieldName="@nameof(ArticuloUbicacionDto.BodegaDisplay)" Caption="Bodega" MinWidth="200">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is ArticuloUbicacionDto item)
                        {
                            <span class="@(item.Activo ? "text-dark fw-semibold" : "text-muted text-decoration-line-through")">@item.BodegaDisplay</span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="@nameof(ArticuloUbicacionDto.UbicacionDisplay)" Caption="Ubicación" MinWidth="160">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is ArticuloUbicacionDto item)
                        { <span class="text-muted">@(string.IsNullOrWhiteSpace(item.UbicacionDisplay) ? "—" : item.UbicacionDisplay)</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="@nameof(ArticuloUbicacionDto.Existencia)" Caption="Existencia" Width="105px" TextAlignment="GridTextAlignment.Right">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is ArticuloUbicacionDto item)
                        { <span class="fw-semibold">@item.Existencia.ToString("N2")</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                @* Comprometida, tránsito, costo promedio y último costo los mantiene el motor de
                   movimientos: se muestran atenuados porque NO se editan desde aquí. *@
                <DxGridDataColumn FieldName="@nameof(ArticuloUbicacionDto.ExistenciaComprometida)" Caption="Comprometida" Width="115px" TextAlignment="GridTextAlignment.Right">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is ArticuloUbicacionDto item)
                        { <span class="text-muted" title="La mantiene el motor de movimientos (solo lectura)">@item.ExistenciaComprometida.ToString("N2")</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="@nameof(ArticuloUbicacionDto.ExistenciaTransito)" Caption="Tránsito" Width="100px" TextAlignment="GridTextAlignment.Right">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is ArticuloUbicacionDto item)
                        { <span class="text-muted" title="La mantiene el motor de movimientos (solo lectura)">@item.ExistenciaTransito.ToString("N2")</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="@nameof(ArticuloUbicacionDto.PuntoReorden)" Caption="Punto reorden" Width="115px" TextAlignment="GridTextAlignment.Right">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is ArticuloUbicacionDto item)
                        { <span>@item.PuntoReorden.ToString("N2")</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="@nameof(ArticuloUbicacionDto.ExistenciaMinima)" Caption="Mínimo" Width="100px" TextAlignment="GridTextAlignment.Right">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is ArticuloUbicacionDto item)
                        { <span>@item.ExistenciaMinima.ToString("N2")</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="@nameof(ArticuloUbicacionDto.ExistenciaMaxima)" Caption="Máximo" Width="100px" TextAlignment="GridTextAlignment.Right">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is ArticuloUbicacionDto item)
                        { <span>@item.ExistenciaMaxima.ToString("N2")</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="@nameof(ArticuloUbicacionDto.CostoPromedio)" Caption="Costo prom." Width="110px" TextAlignment="GridTextAlignment.Right">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is ArticuloUbicacionDto item)
                        { <span class="text-muted" title="Lo recalcula el motor de movimientos (solo lectura)">@item.CostoPromedio.ToString("N4")</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="@nameof(ArticuloUbicacionDto.UltimoCosto)" Caption="Último costo" Width="110px" TextAlignment="GridTextAlignment.Right">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is ArticuloUbicacionDto item)
                        { <span class="text-muted" title="Lo registra el motor de movimientos (solo lectura)">@item.UltimoCosto.ToString("N4")</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                <DxGridDataColumn FieldName="@nameof(ArticuloUbicacionDto.Principal)" Caption="Principal" Width="100px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is ArticuloUbicacionDto item)
                        {
                            @if (item.Principal)
                            { <span class="badge-status active"><i class="bi bi-check-lg me-1"></i>Sí</span> }
                            else
                            { <span class="text-muted">—</span> }
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
                @if (!EnMemoria)
                {
                    <DxGridDataColumn FieldName="@nameof(ArticuloUbicacionDto.Activo)" Caption="Estado" Width="110px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is ArticuloUbicacionDto item)
                            {
                                @if (item.Activo)
                                { <span class="badge-status active">Activa</span> }
                                else
                                { <span class="badge bg-secondary">Deshabilitada</span> }
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                }
                <DxGridDataColumn Caption="Acciones" Width="130px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is ArticuloUbicacionDto item)
                        {
                            <div class="d-flex justify-content-center gap-2 flex-wrap">
                                @if (item.Activo)
                                {
                                    <button type="button" class="btn-icon btn-edit" title="Editar"
                                            @onclick="() => AbrirEditar(item)" @onclick:stopPropagation="true">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>
                                    @if (EnMemoria)
                                    {
                                        <button type="button" class="btn-icon btn-delete" title="Quitar"
                                                @onclick="() => QuitarEnMemoriaAsync(item)" @onclick:stopPropagation="true">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button" class="btn-icon btn-delete" title="Deshabilitar"
                                                @onclick="() => ConfirmarDeshabilitar(item)" @onclick:stopPropagation="true">
                                            <i class="bi bi-slash-circle"></i>
                                        </button>
                                    }
                                }
                                else
                                {
                                    <button type="button" class="btn-icon btn-edit" title="Reactivar"
                                            @onclick="() => ReactivarAsync(item)" @onclick:stopPropagation="true">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                }
                            </div>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
            <EmptyDataAreaTemplate><div class="p-4 text-center text-muted">@(EnMemoria ? "Agregue al menos una bodega para poder guardar el artículo." : "Este artículo aún no tiene ubicaciones asignadas.")</div></EmptyDataAreaTemplate>
        </DxGrid>
    </div>
</div>

<DxPopup @bind-Visible="formVisible" Width="min(560px, 95vw)" Height="auto" MaxHeight="90vh"
         Scrollable="true" CssClass="custom-popup" CloseOnOutsideClick="false">
    <HeaderContentTemplate>
        <div class="d-flex align-items-center gap-2">
            <div class="@PopupIconWrapperClass" style="width: 38px; height: 38px;"><i class="@PopupIcon"></i></div>
            <div>
                <div class="fw-bold fs-6 text-dark" style="line-height:1.1;">@PopupTitle</div>
                <div class="small text-muted" style="font-weight: normal; font-size: 0.8rem;">Bodega, ubicación y existencias del artículo</div>
            </div>
        </div>
    </HeaderContentTemplate>
    <BodyContentTemplate>
        <div class="p-1">
            <div class="mb-3">
                <label class="form-label fw-semibold">Bodega *</label>
                <DxComboBox Data="@bodegas" Value="form.BodegaId"
                            ValueChanged="@((int v) => OnBodegaChanged(v))"
                            ValueExpression="@(() => form.BodegaId)"
                            ValueFieldName="@nameof(BodegaLookupDto.Id)"
                            TextFieldName="@nameof(BodegaLookupDto.Display)"
                            FilteringMode="DataGridFilteringMode.Contains"
                            NullText="Seleccione una bodega..."
                            CssClass="w-100" />
            </div>

            <div class="mb-2">
                <label class="form-label fw-semibold mb-1">Ubicación (manual)</label>
                <div class="text-muted small mb-2">Hasta 20 caracteres por campo. Todos son opcionales.</div>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label small text-muted">Ubicación 1</label>
                        <DxTextBox @bind-Text="form.Ubicacion1" MaxLength="20" NullText="—" CssClass="w-100" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label small text-muted">Ubicación 2</label>
                        <DxTextBox @bind-Text="form.Ubicacion2" MaxLength="20" NullText="—" CssClass="w-100" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label small text-muted">Ubicación 3</label>
                        <DxTextBox @bind-Text="form.Ubicacion3" MaxLength="20" NullText="—" CssClass="w-100" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label small text-muted">Ubicación 4</label>
                        <DxTextBox @bind-Text="form.Ubicacion4" MaxLength="20" NullText="—" CssClass="w-100" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label small text-muted">Ubicación 5</label>
                        <DxTextBox @bind-Text="form.Ubicacion5" MaxLength="20" NullText="—" CssClass="w-100" />
                    </div>
                </div>
            </div>

            @* Comprometida y tránsito NO van en el modal: no hay nada que teclear; las
               mantiene el motor de movimientos y sólo se ven en la grilla. *@
            <div class="row g-3 mb-3 mt-1">
                <div class="col-12 col-md-3">
                    <label class="form-label fw-semibold">Existencia</label>
                    <DxSpinEdit @bind-Value="form.Existencia" DisplayFormat="N2" MinValue="0" CssClass="w-100" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label fw-semibold">Existencia mínima</label>
                    <DxSpinEdit @bind-Value="form.ExistenciaMinima" DisplayFormat="N2" MinValue="0" CssClass="w-100" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label fw-semibold">Existencia máxima</label>
                    <DxSpinEdit @bind-Value="form.ExistenciaMaxima" DisplayFormat="N2" MinValue="0" CssClass="w-100" />
                </div>
                <div class="col-12 col-md-3">
                    <label class="form-label fw-semibold">Punto de reorden</label>
                    <DxSpinEdit @bind-Value="form.PuntoReorden" DisplayFormat="N2" MinValue="0" CssClass="w-100" />
                    <div class="form-text small text-muted">Existencia a la que conviene reponer.</div>
                </div>
            </div>

            @* Costo promedio y último costo son SOLO LECTURA: los recalcula el motor de
               movimientos (kardex) en cada ingreso. Se muestran para consulta —el servicio
               los ignora al guardar—; en una ubicación nueva aún son 0. *@
            <div class="row g-3 mb-1">
                <div class="col-12 col-md-6">
                    <label class="form-label fw-semibold">Costo promedio</label>
                    <DxSpinEdit @bind-Value="form.CostoPromedio" DisplayFormat="N4"
                                ReadOnly="true" ShowSpinButtons="false" CssClass="w-100" />
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label fw-semibold">Último costo</label>
                    <DxSpinEdit @bind-Value="form.UltimoCosto" DisplayFormat="N4"
                                ReadOnly="true" ShowSpinButtons="false" CssClass="w-100" />
                </div>
            </div>
            <div class="form-text small text-muted mb-3">
                <i class="bi bi-lock me-1"></i>Los mantiene el motor de movimientos; no se editan aquí.
            </div>

            <div class="mb-3">
                <DxCheckBox @bind-Checked="form.Principal">Marcar como bodega principal</DxCheckBox>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <DxButton Text="Cancelar" RenderStyle="ButtonRenderStyle.Secondary"
                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                          Enabled="@(!isSaving)" Click="CerrarForm" />
                <DxButton Text="Guardar" RenderStyle="ButtonRenderStyle.Primary"
                          IconCssClass="bi bi-check-lg"
                          Enabled="@(!isSaving)" Click="GuardarAsync" />
            </div>
        </div>
    </BodyContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="confirmVisible" Width="min(420px, 90vw)" HeaderText="Confirmar acción" ShowFooter="false">
    <BodyTemplate>
        <div class="text-center p-4">
            <div class="mb-3 text-warning"><i class="bi bi-slash-circle" style="font-size: 3rem;"></i></div>
            <h5 class="fw-bold">¿Deshabilitar ubicación?</h5>
            <p class="text-muted">La ubicación se deshabilita pero se conserva en el histórico del artículo. Podrá reactivarla después.</p>
            @if (paraDeshabilitar is not null)
            {
                <div class="fw-semibold">@paraDeshabilitar.BodegaDisplay</div>
                @if (!string.IsNullOrWhiteSpace(paraDeshabilitar.UbicacionDisplay))
                { <div class="text-muted small">@paraDeshabilitar.UbicacionDisplay</div> }
            }
            <div class="d-flex justify-content-center gap-3 mt-4">
                <DxButton Text="Cancelar" Click="CancelarDeshabilitar" RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Outline" />
                <DxButton Text="Sí, deshabilitar" Click="DeshabilitarConfirmadoAsync" RenderStyle="ButtonRenderStyle.Warning" IconCssClass="bi bi-slash-circle" />
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    /// <summary>Modo HTTP (edición): id del artículo existente. Null = modo en memoria (alta).</summary>
    [Parameter] public int? ArticuloId { get; set; }

    /// <summary>Modo en memoria (alta): lista de ubicaciones enlazada al formulario del artículo.</summary>
    [Parameter] public List<ArticuloUbicacionDto>? Ubicaciones { get; set; }

    [Parameter] public EventCallback<List<ArticuloUbicacionDto>> UbicacionesChanged { get; set; }

    private bool EnMemoria => !ArticuloId.HasValue;

    private DxGrid? grid;

    // La columna "Estado" sólo existe en edición, así que la colección de columnas difiere
    // entre ambos modos. Se usan claves distintas para que el grid no descarte el layout
    // guardado al no coincidir con las columnas declaradas.
    private string GridLayoutStorageKey => EnMemoria
        ? "almacen-articulo-ubicaciones-alta-grid-layout"
        : "almacen-articulo-ubicaciones-grid-layout";

    private Task OnLayoutAutoSaving(GridPersistentLayoutEventArgs e)
        => GridLayoutStorage.SaveAsync(JS, GridLayoutStorageKey, e);

    private Task OnLayoutAutoLoading(GridPersistentLayoutEventArgs e)
        => GridLayoutStorage.LoadAsync(JS, GridLayoutStorageKey, e);

    private void MostrarColumnChooser() => grid?.ShowColumnChooser();

    private List<ArticuloUbicacionDto> ubicaciones = new();
    private List<BodegaLookupDto> bodegas = new();

    private bool isLoading;
    private bool verInactivas;
    private int tempIdSeq;

    private bool formVisible;
    private bool isSaving;
    private ArticuloUbicacionDto form = new();

    private bool confirmVisible;
    private ArticuloUbicacionDto? paraDeshabilitar;

    private string PopupTitle => form.Id.HasValue ? "Editar existencias y ubicación" : "Agregar existencias y ubicación";
    private string PopupIcon => form.Id.HasValue ? "bi bi-pencil-square" : "bi bi-geo-alt";
    private string PopupIconWrapperClass => form.Id.HasValue
        ? "bg-warning bg-opacity-10 text-warning p-2 rounded-circle d-flex justify-content-center align-items-center"
        : "bg-primary bg-opacity-10 text-primary p-2 rounded-circle d-flex justify-content-center align-items-center";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            bodegas = await BodegasClient.GetLookupAsync();

            if (EnMemoria)
            {
                ubicaciones = Ubicaciones ?? new();
                // Asegura una clave única (id temporal negativo) a las filas en memoria.
                foreach (var u in ubicaciones.Where(u => !u.Id.HasValue))
                {
                    u.Id = --tempIdSeq;
                }
            }
            else
            {
                await CargarAsync();
            }
        }
        catch (Exception ex)
        {
            Toast("Error", $"No se pudieron cargar las ubicaciones: {ex.Message}", ToastRenderStyle.Danger);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CargarAsync()
    {
        if (EnMemoria) return;
        try
        {
            isLoading = true;
            ubicaciones = await ArticulosClient.GetUbicacionesAsync(ArticuloId!.Value, verInactivas);
        }
        catch (Exception ex)
        {
            Toast("Error", $"No se pudieron cargar las ubicaciones: {ex.Message}", ToastRenderStyle.Danger);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnToggleInactivasAsync(bool value)
    {
        verInactivas = value;
        await CargarAsync();
    }

    private void AbrirNuevo()
    {
        var hayActivas = ubicaciones.Any(u => u.Activo);
        form = new ArticuloUbicacionDto { Principal = !hayActivas };
        formVisible = true;
    }

    private void AbrirEditar(ArticuloUbicacionDto row)
    {
        form = new ArticuloUbicacionDto
        {
            Id = row.Id,
            BodegaId = row.BodegaId,
            BodegaDisplay = row.BodegaDisplay,
            Ubicacion1 = row.Ubicacion1,
            Ubicacion2 = row.Ubicacion2,
            Ubicacion3 = row.Ubicacion3,
            Ubicacion4 = row.Ubicacion4,
            Ubicacion5 = row.Ubicacion5,
            Existencia = row.Existencia,
            ExistenciaMinima = row.ExistenciaMinima,
            ExistenciaMaxima = row.ExistenciaMaxima,
            PuntoReorden = row.PuntoReorden,
            // Los 4 campos del motor se arrastran tal cual para no perderlos en la fila en
            // memoria; el servicio los ignora al escribir (los mantiene el motor de posteo).
            ExistenciaComprometida = row.ExistenciaComprometida,
            ExistenciaTransito = row.ExistenciaTransito,
            CostoPromedio = row.CostoPromedio,
            UltimoCosto = row.UltimoCosto,
            Principal = row.Principal,
            Activo = row.Activo
        };
        formVisible = true;
    }

    private void OnBodegaChanged(int value) => form.BodegaId = value;

    private void CerrarForm()
    {
        if (isSaving) return;
        formVisible = false;
    }

    private async Task GuardarAsync()
    {
        if (form.BodegaId <= 0)
        {
            Toast("Validación", "Seleccione una bodega.", ToastRenderStyle.Warning);
            return;
        }

        isSaving = true;
        try
        {
            if (EnMemoria)
            {
                await GuardarEnMemoriaAsync();
            }
            else
            {
                await GuardarHttpAsync();
            }
            formVisible = false;
        }
        catch (InvalidOperationException ex)
        {
            Toast("Error", ex.Message, ToastRenderStyle.Danger);
        }
        catch (Exception ex)
        {
            Toast("Error", ex.Message, ToastRenderStyle.Danger);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task GuardarEnMemoriaAsync()
    {
        if (ubicaciones.Any(u => u.BodegaId == form.BodegaId && u.Id != form.Id))
        {
            throw new InvalidOperationException("Ya agregó esa bodega al artículo.");
        }

        form.BodegaDisplay = bodegas.FirstOrDefault(b => b.Id == form.BodegaId)?.Display;
        form.Activo = true;

        if (form.Id.HasValue)
        {
            var idx = ubicaciones.FindIndex(u => u.Id == form.Id);
            if (idx >= 0) ubicaciones[idx] = form;
        }
        else
        {
            form.Id = --tempIdSeq;
            ubicaciones.Add(form);
        }

        if (form.Principal)
        {
            foreach (var u in ubicaciones.Where(u => u.Id != form.Id))
            {
                u.Principal = false;
            }
        }

        await SincronizarMemoriaAsync();
        Toast("Éxito", "Ubicación agregada.", ToastRenderStyle.Success);
    }

    private async Task GuardarHttpAsync()
    {
        if (form.Id.HasValue)
        {
            await ArticulosClient.UpdateUbicacionAsync(ArticuloId!.Value, form.Id.Value, form);
            Toast("Éxito", "Ubicación actualizada.", ToastRenderStyle.Success);
        }
        else
        {
            await ArticulosClient.AddUbicacionAsync(ArticuloId!.Value, form);
            Toast("Éxito", "Ubicación agregada.", ToastRenderStyle.Success);
        }
        await CargarAsync();
    }

    private async Task QuitarEnMemoriaAsync(ArticuloUbicacionDto row)
    {
        ubicaciones.RemoveAll(u => u.Id == row.Id);
        await SincronizarMemoriaAsync();
    }

    /// <summary>Garantiza exactamente una principal y refresca la referencia del grid + el binding al padre.</summary>
    private async Task SincronizarMemoriaAsync()
    {
        if (ubicaciones.Count > 0 && !ubicaciones.Any(u => u.Principal))
        {
            ubicaciones[0].Principal = true;
        }

        ubicaciones = ubicaciones.ToList();
        if (UbicacionesChanged.HasDelegate)
        {
            await UbicacionesChanged.InvokeAsync(ubicaciones);
        }
    }

    private void ConfirmarDeshabilitar(ArticuloUbicacionDto row)
    {
        paraDeshabilitar = row;
        confirmVisible = true;
    }

    private void CancelarDeshabilitar()
    {
        confirmVisible = false;
        paraDeshabilitar = null;
    }

    private async Task DeshabilitarConfirmadoAsync()
    {
        if (paraDeshabilitar?.Id is null)
        {
            confirmVisible = false;
            return;
        }

        try
        {
            var ok = await ArticulosClient.DeshabilitarUbicacionAsync(ArticuloId!.Value, paraDeshabilitar.Id.Value);
            if (!ok) Toast("Error", "No se pudo deshabilitar la ubicación.", ToastRenderStyle.Danger);
            else { Toast("Éxito", "Ubicación deshabilitada.", ToastRenderStyle.Success); await CargarAsync(); }
        }
        catch (Exception ex)
        {
            Toast("Error", ex.Message, ToastRenderStyle.Danger);
        }
        finally
        {
            confirmVisible = false;
            paraDeshabilitar = null;
        }
    }

    private async Task ReactivarAsync(ArticuloUbicacionDto row)
    {
        if (row.Id is null) return;
        try
        {
            var ok = await ArticulosClient.ReactivarUbicacionAsync(ArticuloId!.Value, row.Id.Value);
            if (!ok) Toast("Error", "No se pudo reactivar la ubicación.", ToastRenderStyle.Danger);
            else { Toast("Éxito", "Ubicación reactivada.", ToastRenderStyle.Success); await CargarAsync(); }
        }
        catch (Exception ex)
        {
            Toast("Error", ex.Message, ToastRenderStyle.Danger);
        }
    }

    private void Toast(string title, string text, ToastRenderStyle style)
        => ToastService.ShowToast(new ToastOptions { Title = title, Text = text, RenderStyle = style, ProviderName = "UbicacionesToast" });
}
