@using System.Text.Json
@using SIAD.Core.DTOs.Caja
@using SIAD.Core.DTOs.CaptacionPagos
@using apc.Client.Services.Caja
@inject AbonoClient AbonoClient
@inject IToastNotificationService ToastService
@inject IJSRuntime JS

<div class="generar-recibo-abono">
    <DxToastProvider Name="@ToastProviderName" MaxToastCount="4" />
    <ErrorNotice @ref="errorNotice" />

    <div class="row g-3">
        @* ── Facturas pendientes del cliente ── *@
        <div class="col-md-6">
            <DxCard CssClass="p-3 shadow-sm border-0 h-100">
                <h5 class="fw-bold mb-3 text-secondary">
                    <i class="bi bi-file-text me-2 text-primary"></i>Facturas Pendientes
                </h5>

                @if (isLoading)
                {
                    <div class="text-center p-4">
                        <DxWaitIndicator Visible="true" />
                        <span class="ms-2">Cargando facturas...</span>
                    </div>
                }
                else if (facturas.Count > 0)
                {
                    <div class="list-group max-height-400 overflow-auto">
                        @foreach (var fact in facturas)
                        {
                            <button class="list-group-item list-group-item-action @(selectedFactura?.FacturaId == fact.FacturaId ? "active" : "")"
                                    @onclick="@(() => SeleccionarFactura(fact))">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1 fw-bold">Factura: @fact.NumFactura</h6>
                                    <span class="badge @(fact.Estado == "B" ? "bg-info" : "bg-warning text-dark")">
                                        @(fact.Estado == "B" ? "Parcial" : "Abierta")
                                    </span>
                                </div>
                                <div class="d-flex justify-content-between text-sm mt-1">
                                    <span class="text-muted">Total: @fact.SaldoTotal.ToString("C2")</span>
                                    <span class="fw-bold">Pendiente: @fact.SaldoPendiente.ToString("C2")</span>
                                </div>
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle me-2"></i>
                        Este cliente no tiene facturas con saldo pendiente.
                    </div>
                }
            </DxCard>
        </div>

        @* ── Formulario de generación de recibo ── *@
        <div class="col-md-6">
            <DxCard CssClass="p-3 shadow-sm border-0 h-100">
                <h5 class="fw-bold mb-3 text-secondary">
                    <i class="bi bi-receipt me-2 text-success"></i>Generar Recibo de Pago
                </h5>

                @if (selectedFactura != null)
                {
                    <div class="mb-3 p-3 bg-light rounded border border-light">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Factura:</span>
                            <strong>@selectedFactura.NumFactura</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Emisión:</span>
                            <span>@selectedFactura.FechaEmision.ToString("dd/MM/yyyy")</span>
                        </div>
                        <hr class="my-2" />
                        <div class="d-flex justify-content-between fs-5 fw-bold text-success">
                            <span>Saldo pendiente de la factura:</span>
                            <span>@selectedFactura.SaldoPendiente.ToString("C2")</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-1 small">
                            <span class="text-muted">Saldo total del cliente:</span>
                            <span class="fw-semibold text-primary">
                                @(saldoTotalCliente.HasValue ? saldoTotalCliente.Value.ToString("C2") : "—")
                                <span class="text-muted fw-normal">· referencia</span>
                            </span>
                        </div>
                    </div>

                    <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                        <DxFormLayoutItem ColSpanXs="12" Caption="Monto del Recibo">
                            <Template>
                                <DxSpinEdit T="decimal"
                                            @bind-Value="montoRecibo"
                                            MinValue="0.01m"
                                            MaxValue="@selectedFactura.SaldoPendiente"
                                            DisplayFormat="C2"
                                            InputId="recibo-monto" />
                            </Template>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem ColSpanXs="12" CssClass="mt-3">
                            <Template>
                                <DxButton Text="@(isSaving ? "Generando..." : "Generar Recibo")"
                                          Click="GenerarRecibo"
                                          RenderStyle="ButtonRenderStyle.Primary"
                                          IconCssClass="bi bi-printer"
                                          Enabled="@(!isSaving && montoRecibo > 0)"
                                          CssClass="w-100" />
                            </Template>
                        </DxFormLayoutItem>
                    </DxFormLayout>

                    <div class="mt-3 text-muted small">
                        <i class="bi bi-info-circle me-1"></i>
                        Se generará el recibo en PDF para que el cliente realice el pago
                        en ventanilla o banco. El saldo de la factura <strong>no se modifica</strong>
                        hasta que el cajero procese el pago.
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column align-items-center justify-content-center h-100 py-5 text-muted">
                        <i class="bi bi-arrow-left-circle fs-1 mb-2"></i>
                        <span>Selecciona una factura para generar el recibo.</span>
                    </div>
                }
            </DxCard>
        </div>
    </div>

    @* ── Grid de recibos generados (pendientes) ── *@
    @if (selectedFactura != null)
    {
        <div class="row mt-3">
            <div class="col-12">
                <DxCard CssClass="p-3 shadow-sm border-0">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold mb-0 text-secondary">
                            <i class="bi bi-hourglass-split me-2 text-warning"></i>
                            Recibos Generados — Pendientes de Pago
                        </h6>
                        <DxButton Text="Actualizar"
                                  Click="@(() => CargarRecibosPendientesAsync(selectedFactura.NumFactura))"
                                  RenderStyle="ButtonRenderStyle.Secondary"
                                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                                  IconCssClass="bi bi-arrow-clockwise"
                                  SizeMode="SizeMode.Small" />
                    </div>

                    @if (isLoadingRecibos)
                    {
                        <div class="text-center py-3">
                            <DxWaitIndicator Visible="true" />
                            <span class="ms-2 text-muted small">Cargando recibos...</span>
                        </div>
                    }
                    else if (recibosPendientes.Count > 0)
                    {
                        <DxGrid Data="@recibosPendientes"
                                ShowFilterRow="false"
                                ShowGroupPanel="false"
                                PageSize="10"
                                CssClass="recibos-grid">
                            <Columns>
                                <DxGridDataColumn FieldName="NumRecibo" Caption="Nº Recibo" Width="100px" />
                                <DxGridDataColumn FieldName="NumFactura" Caption="Factura" Width="160px" />
                                <DxGridDataColumn FieldName="Monto" Caption="Monto" Width="110px" DisplayFormat="C2" />
                                <DxGridDataColumn FieldName="FechaGenerado" Caption="Fecha" Width="90px" />
                                <DxGridDataColumn FieldName="Operador" Caption="Generado por" />
                                <DxGridDataColumn Caption="PDF" Width="80px" AllowSort="false">
                                    <CellDisplayTemplate>
                                        @{
                                            var rp = (ReciboPendienteDto)context.DataItem;
                                        }
                                        <DxButton Text="PDF"
                                                  SizeMode="SizeMode.Small"
                                                  RenderStyle="ButtonRenderStyle.Secondary"
                                                  IconCssClass="bi bi-printer"
                                                  Click="@(() => ImprimirRecibo(rp.TransaccionId))" />
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                            </Columns>
                        </DxGrid>
                    }
                    else
                    {
                        <div class="text-muted small py-2">
                            <i class="bi bi-info-circle me-1"></i>
                            No hay recibos pendientes generados para esta factura.
                        </div>
                    }
                </DxCard>
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string ClienteClave { get; set; } = string.Empty;
    [Parameter] public string UsuarioActual { get; set; } = "system";

    private const string ToastProviderName = "GenerarReciboToast";

    private List<FacturaConSaldoDto> facturas = new();
    private FacturaConSaldoDto? selectedFactura;
    private decimal montoRecibo;
    private bool isLoading;
    private bool isSaving;
    private ErrorNotice errorNotice = default!;
    private bool _initialLoadDone;

    private List<ReciboPendienteDto> recibosPendientes = new();
    private bool isLoadingRecibos;

    // Saldo global (corrido) del cliente, informativo. Este flujo no abona: solo
    // genera el recibo; el saldo del cliente se muestra solo como referencia.
    private decimal? saldoTotalCliente;

    protected override async Task OnParametersSetAsync()
    {
        if (!_initialLoadDone && !string.IsNullOrWhiteSpace(ClienteClave))
        {
            _initialLoadDone = true;
            await Task.WhenAll(CargarFacturasAsync(), CargarSaldoClienteAsync());
        }
    }

    private async Task CargarFacturasAsync()
    {
        isLoading = true;
        try
        {
            var res = await AbonoClient.ListarFacturasPendientesPorClienteAsync(ClienteClave);
            facturas = res?.ToList() ?? new();
        }
        catch (Exception ex)
        {
            MostrarToast("Error", "No se pudieron cargar las facturas.", ToastRenderStyle.Danger);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CargarSaldoClienteAsync()
    {
        try
        {
            var res = await AbonoClient.ObtenerSaldoClienteAsync(ClienteClave);
            saldoTotalCliente = res?.SaldoTotal;
        }
        catch
        {
            saldoTotalCliente = null;
        }
    }

    private async Task SeleccionarFactura(FacturaConSaldoDto fact)
    {
        selectedFactura = fact;
        montoRecibo = fact.SaldoPendiente;
        await CargarRecibosPendientesAsync(fact.NumFactura);
    }

    private async Task CargarRecibosPendientesAsync(string numFactura)
    {
        isLoadingRecibos = true;
        try
        {
            var res = await AbonoClient.ListarRecibosPendientesAsync(numFactura);
            recibosPendientes = res?.ToList() ?? new();
        }
        catch
        {
            recibosPendientes = new();
        }
        finally
        {
            isLoadingRecibos = false;
        }
    }

    private async Task ImprimirRecibo(int transaccionId)
        => await JS.InvokeVoidAsync("open", $"/api/abono/recibo-pdf/{transaccionId}", "_blank");

    private async Task GenerarRecibo()
    {
        if (selectedFactura is null || montoRecibo <= 0) return;

        isSaving = true;

        try
        {
            var dto = new GenerarReciboDto
            {
                NumFactura = selectedFactura.NumFactura,
                ClienteClave = selectedFactura.ClienteClave,
                Monto = montoRecibo,
                Usuario = UsuarioActual
            };

            var response = await AbonoClient.GenerarReciboPendienteAsync(dto);
            if (response?.Success == true)
            {
                var dataStr = response.Data?.ToString();
                if (dataStr != null)
                {
                    var result = JsonSerializer.Deserialize<GenerarReciboResponseDto>(
                        dataStr, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });

                    if (result != null)
                    {
                        await JS.InvokeVoidAsync("open", $"/api/abono/recibo-pdf/{result.TransaccionId}", "_blank");
                    }
                }

                MostrarToast("Recibo Generado", response.Message ?? "Recibo generado. Se abrirá el PDF.", ToastRenderStyle.Success);
                montoRecibo = selectedFactura?.SaldoPendiente ?? 0m;
                if (selectedFactura != null)
                    await CargarRecibosPendientesAsync(selectedFactura.NumFactura);
            }
            else
            {
                MostrarToast("Error", response?.Message ?? "No se pudo generar el recibo.", ToastRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            errorNotice.ShowError("No se pudo generar el recibo.", ex);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void MostrarToast(string titulo, string mensaje, ToastRenderStyle estilo) =>
        ToastService.ShowToast(new ToastOptions
        {
            ProviderName = ToastProviderName,
            Title = titulo,
            Text = mensaje,
            RenderStyle = estilo
        });
}
