@page "/facturacion/captacion/caja"
@attribute [Authorize(Policy = PermissionNames.Ventas.View)]
@using System.ComponentModel.DataAnnotations
@inject apc.Client.Services.CaptacionPagos.CaptacionPagosClient CaptacionClient
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Caja</PageTitle>

<div class="page-container">
    <DxToastProvider Name="@ToastName" MaxToastCount="4" />

    <div class="header-section">
        <div>
            <h2 class="page-title">Captación en Caja</h2>
            <p class="page-subtitle">Registro y consulta de pagos</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(error))
    {
        <DxAlert AlertType="AlertType.Danger" CssClass="mb-4">@error</DxAlert>
    }

    @if (!string.IsNullOrWhiteSpace(info))
    {
        <DxAlert AlertType="AlertType.Info" CssClass="mb-4">@info</DxAlert>
    }

    @* --- TARJETA 2: REGISTRO DE PAGOS --- *@
    <DxCard CssClass="custom-dx-card mb-4">
        <HeaderTemplate>
            <div class="d-flex align-items-center w-100">
                <i class="bi bi-layout-three-columns me-2 fs-5"></i>
                <span class="fw-bold">Registro de Pagos por Modalidad</span>
                <span class="ms-auto text-muted small">@($"Periodo: {periodoActual?.Periodo ?? "N/D"}")</span>
            </div>
        </HeaderTemplate>
        <BodyTemplate>
            <DxTabs @bind-ActiveTabIndex="tabActual" RenderStyle="TabsRenderStyle.Default">
                <DxTabPage Text="Lectoras">
                    <div class="p-3">
                        <PosteoLectoras Cajas="@cajas" Bancos="@bancos" UsuarioActual="@usuarioActual" />
                    </div>
                </DxTabPage>
                <DxTabPage Text="Misceláneos">
                    <div class="p-3">
                        <PosteoMiscelaneos Bancos="@bancos" Clientes="@clientes" UsuarioActual="@usuarioActual" />
                    </div>
                </DxTabPage>
                <DxTabPage Text="Manual">
                    <div class="p-3">
                        <PosteoManual Bancos="@bancos" Clientes="@clientes" UsuarioActual="@usuarioActual" PeriodoActual="@periodoActual" />
                    </div>
                </DxTabPage>
                <DxTabPage Text="Abonos Especiales">
                    <div class="p-3">
                        <PosteoAbonos Bancos="@bancos"
                                      Clientes="@clientes"
                                      UsuarioActual="@usuarioActual"
                                      PuedePagarEnBanco="@puedePagarEnBanco"
                                      PeriodoActual="@periodoActual" />
                    </div>
                </DxTabPage>
            </DxTabs>
        </BodyTemplate>
    </DxCard>

@* --- TARJETA 1: LISTADO DE PAGOS --- *@
    <DxCard CssClass="custom-dx-card mb-4">
        <HeaderTemplate>
            <div class="d-flex align-items-center gap-2">
                <i class="bi bi-cash-stack fs-5"></i>
                <span class="fw-bold">Listado de Pagos</span>
            </div>
        </HeaderTemplate>
        <BodyTemplate>
            <DxFormLayout CaptionPosition="CaptionPosition.Vertical" CssClass="mb-3">
                <DxFormLayoutGroup ColSpanXs="12" Decoration="FormLayoutGroupDecoration.None">
                    <DxFormLayoutItem Caption="Desde" ColSpanXs="6" ColSpanMd="4">
                        <DxDateEdit T="DateTime?"
                                    @bind-Date="filtro.FechaInicio"
                                    DisplayFormat="d"
                                    NullText="Fecha inicio" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Hasta" ColSpanXs="6" ColSpanMd="4">
                        <DxDateEdit T="DateTime?"
                                    @bind-Date="filtro.FechaFin"
                                    DisplayFormat="d"
                                    NullText="Fecha fin" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Acciones" ColSpanXs="12" ColSpanMd="4">
                        <Template>
                            <div class="d-flex gap-2 mt-md-4 mt-2">
                                <DxButton Text="Buscar"
                                          RenderStyle="ButtonRenderStyle.Primary"
                                          Enabled="@(!buscandoArqueos)"
                                          Click="BuscarArqueosAsync"
                                          IconCssClass="bi bi-search" />
                                <DxButton Text="Limpiar"
                                          RenderStyle="ButtonRenderStyle.Secondary"
                                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                                          Enabled="@(!buscandoArqueos)"
                                          Click="LimpiarFiltrosAsync"
                                          IconCssClass="bi bi-x-lg" />
                            </div>
                        </Template>
                    </DxFormLayoutItem>
                </DxFormLayoutGroup>
            </DxFormLayout>

            <div class="text-muted small mb-2">@($"Pagos cargados: {totalArqueos}")</div>

            <DxGrid @ref="arqueosGrid"
                    Data="@arqueosDataSource"
                    KeyFieldName="@nameof(ArqueoDto.RowKey)"
                    ShowFilterRow="false"
                    ShowGroupPanel="false"
                    ShowPager="false"
                    PageSize="50"
                    VirtualScrollingEnabled="true"
                    VirtualScrollingMode="GridVirtualScrollingMode.Rows"
                    ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
                    CssClass="grid-modern">
                <Columns>
                    <DxGridDataColumn FieldName="@nameof(ArqueoDto.Fecha)" Caption="Fecha" DisplayFormat="d" Width="120px" />
                    <DxGridDataColumn FieldName="@nameof(ArqueoDto.NumFactura)" Caption="Factura / Recibo" Width="160px" />
                    <DxGridDataColumn FieldName="@nameof(ArqueoDto.ClienteClave)" Caption="Cliente" Width="140px" />
                    <DxGridDataColumn FieldName="@nameof(ArqueoDto.Banco)" Caption="Banco" Width="120px" />
                    <DxGridDataColumn FieldName="@nameof(ArqueoDto.Usuario)" Caption="Usuario" Width="140px" />
                    <DxGridDataColumn FieldName="@nameof(ArqueoDto.Estado)" Caption="Estado" Width="90px">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is ArqueoDto item)
                            {
                                var estado = (item.Estado ?? string.Empty).Trim().ToUpperInvariant();
                                var badgeClass = estado switch
                                {
                                    "C" => "badge bg-success",
                                    "P" => "badge bg-success",
                                    "B" => "badge bg-info",
                                    "A" => "badge bg-warning text-dark",
                                    _ => "badge bg-secondary"
                                };
                                var badgeText = estado switch
                                {
                                    "C" => "Cobrado",
                                    "P" => "Pagado",
                                    "B" => "Parcial",
                                    "A" => "Abierto",
                                    _ => string.IsNullOrWhiteSpace(estado) ? "N/D" : estado
                                };
                                <span class="@badgeClass">@badgeText</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="@nameof(ArqueoDto.Monto)" Caption="Monto" TextAlignment="GridTextAlignment.Right" Width="140px" DisplayFormat="c2" />
                </Columns>
                <EmptyDataAreaTemplate>
                    <div class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                        <span>No hay movimientos para los filtros seleccionados.</span>
                    </div>
                </EmptyDataAreaTemplate>
            </DxGrid>
        </BodyTemplate>
    </DxCard>

    
</div>

@code {
    private const string ToastName = "CaptacionCajaToast";
    private readonly CaptacionArqueoFilterDto filtro = new();

    private List<CajaDto> cajas = new();
    private List<BancoDto> bancos = new();
    private List<ClienteComboDto> clientes = new();
    private PeriodoActualDto? periodoActual;
    private DxGrid? arqueosGrid;
    private ArqueosGridDataSource arqueosDataSource = default!;
    private int totalArqueos;

    private string? error;
    private string? info;
    private string? usuarioActual;
    private bool puedePagarEnBanco;
    private bool buscandoArqueos;
    private int tabActual = 2; // Inicia en tab Manual

    protected override async Task OnInitializedAsync()
    {
        arqueosDataSource = new ArqueosGridDataSource(CaptacionClient, total =>
        {
            totalArqueos = total;
            InvokeAsync(StateHasChanged);
        })
        {
            CajaId = filtro.CajaId,
            FechaInicio = filtro.FechaInicio,
            FechaFin = filtro.FechaFin
        };

        await EstablecerUsuarioAsync();
        await Task.WhenAll(
            CargarCajasAsync(),
            CargarBancosAsync(),
            CargarClientesAsync(),
            CargarPeriodoAsync()
        );
        await BuscarArqueosAsync();
    }

    private async Task EstablecerUsuarioAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        usuarioActual = authState.User?.Identity?.Name ?? "sistema";
        puedePagarEnBanco = authState.User?.HasClaim("permission", PermissionNames.Ventas.Caja.AbonoBanco) ?? false;
    }

    private async Task CargarCajasAsync()
    {
        try
        {
            cajas = (await CaptacionClient.GetCajasAsync()).ToList();
            if (cajas.Count == 0)
            {
                info = null;
            }
        }
        catch (Exception ex)
        {
            error = "No se pudieron cargar las cajas.";
            MostrarToast("Error", error, ToastRenderStyle.Danger);
        }
    }

    private async Task CargarBancosAsync()
    {
        try
        {
            bancos = (await CaptacionClient.GetBancosAsync()).ToList();
        }
        catch (Exception ex)
        {
            error = "No se pudieron cargar los bancos.";
        }
    }

    private async Task CargarClientesAsync()
    {
        try
        {
            clientes = (await CaptacionClient.GetClientesAsync()).ToList();
        }
        catch (Exception ex)
        {
            error = "No se pudieron cargar los clientes.";
        }
    }

    private async Task CargarPeriodoAsync()
    {
        try
        {
            periodoActual = await CaptacionClient.GetPeriodoActualAsync();
        }
        catch (Exception ex)
        {
            error = "No se pudo cargar el periodo.";
        }
    }

    private async Task BuscarArqueosAsync()
    {
        error = null;
        buscandoArqueos = true;

        arqueosDataSource.CajaId = filtro.CajaId;
        arqueosDataSource.FechaInicio = filtro.FechaInicio;
        arqueosDataSource.FechaFin = filtro.FechaFin;
        arqueosGrid?.Reload();

        buscandoArqueos = false;
    }

    private async Task LimpiarFiltrosAsync()
    {
        if (buscandoArqueos) return;

        filtro.CajaId = null;
        filtro.FechaInicio = null;
        filtro.FechaFin = null;
        await BuscarArqueosAsync();
    }

    private void MostrarToast(string titulo, string mensaje, ToastRenderStyle estilo) =>
        ToastService.ShowToast(new ToastOptions
        {
            ProviderName = ToastName,
            Title = titulo,
            Text = mensaje,
            RenderStyle = estilo
        });
}

