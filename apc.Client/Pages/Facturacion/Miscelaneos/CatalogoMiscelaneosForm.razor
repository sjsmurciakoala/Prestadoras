@using DevExpress.Blazor
@using SIAD.Core.DTOs.Contabilidad
@using SIAD.Core.DTOs.FacturacionMiscelaneos

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" Context="editContext">
    <DataAnnotationsValidator />

    @if (editContext.GetValidationMessages().Any())
    {
        <div class="alert alert-danger mb-3 shadow-sm">
            <h6 class="alert-heading"><i class="bi bi-exclamation-circle-fill me-2"></i>Atencion</h6>
            <DxValidationSummary />
        </div>
    }

    <DxFormLayout>
        <DxFormLayoutItem Caption="Codigo *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Codigo"
                       NullText="Codigo del concepto"
                       MaxLength="20" />
            <ValidationMessage For="() => Model.Codigo" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Nombre *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Nombre"
                       NullText="Nombre del concepto"
                       MaxLength="100" />
            <ValidationMessage For="() => Model.Nombre" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Valor unitario" ColSpanMd="6">
            <DxSpinEdit @bind-Value="Model.ValorUnitario"
                        MinValue="0m"
                        MaxValue="9999999m"
                        Increment="1m"
                        DisplayFormat="N2" />
            <ValidationMessage For="() => Model.ValorUnitario" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Cuenta contable" ColSpanMd="6">
            <DxComboBox Data="@CuentasContables"
                        TData="CuentaContableLookupDto"
                        TValue="long?"
                        @bind-Value="Model.ContAccountId"
                        ValueFieldName="@nameof(CuentaContableLookupDto.AccountId)"
                        TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                        NullText="Seleccione cuenta contable"
                        AllowUserInput="true"
                        DropDownStyle="DropDownStyle.DropDown"
                        DropDownTriggerMode="DropDownTriggerMode.Input"
                        SearchMode="ListSearchMode.AutoSearch"
                        SearchFilterCondition="ListSearchFilterCondition.Contains"
                        SearchDelay="200"
                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                        Enabled="@(CuentasContables.Count > 0)" />
        </DxFormLayoutItem>
    </DxFormLayout>

    <div class="d-flex justify-content-end gap-2 mt-3">
        <DxButton ButtonType="ButtonType.Submit"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  SubmitFormOnClick="true"
                  Enabled="@(!IsBusy)" />
        <DxButton ButtonType="ButtonType.Normal"
                  Text="Cancelar"
                  Enabled="@(!IsBusy)"
                  Click="Cancel" />
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public MiscelaneoCatalogoEditDto Model { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<CuentaContableLookupDto> CuentasContables { get; set; } = Array.Empty<CuentaContableLookupDto>();

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private async Task HandleValidSubmit()
    {
        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }
}
