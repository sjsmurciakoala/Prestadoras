@page "/facturacion/cobranza"
@attribute [Authorize]
@using DevExpress.Blazor
@using SIAD.Core.DTOs.Cobranza
@using SIAD.Core.DTOs.CaptacionPagos
@using apc.Client.Services
@using apc.Client.Services.CaptacionPagos
@inject CobranzaClient CobranzaClient
@inject NotasCreditoDebitoClient NotasClient
@inject CaptacionPagosClient CaptacionClient
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IToastNotificationService ToastService
@inject IJSRuntime JS

<PageTitle>SIAD - Cobranza</PageTitle>

<div class="page-container">
    <DxToastProvider Name="@ToastName" MaxToastCount="4" />
    <ErrorNotice @ref="errorNotice" />

    <div class="header-section">
        <div>
            <h2 class="page-title">Cobranza</h2>
            <p class="page-subtitle">Planes de pago, cálculo de cuotas y seguimiento</p>
        </div>
    </div>

    <DxTabs @bind-ActiveTabIndex="tabActivo" CssClass="tabs-modern">
        <DxTabPage Text="Crear plan de pago">
            <ContentTemplate>
                <div class="modern-card mb-4">
                    <div class="section-header">
                        <div>
                            <h6 class="section-title">Búsqueda de cliente</h6>
                            <p class="section-subtitle">Clave, nombre o RTN del cliente</p>
                        </div>
                        @if (clienteSeleccionado is not null)
                        {
                            <span class="status-pill @(bloqueado ? "blocked" : "ok")">
                                @(bloqueado ? "Bloqueado" : "Habilitado")
                            </span>
                        }
                    </div>

                    <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                        <DxFormLayoutItem Caption="Cliente" ColSpanXs="12" ColSpanMd="12">
                            <Template>
                                <ClienteLookup Items="@clientesCombo"
                                               Value="@clienteSeleccionadoClave"
                                               ValueChanged="@OnClienteSeleccionadoAsync"
                                               NullText="Escriba clave o nombre del cliente..."
                                               MinSearchLength="2"
                                               SearchDelay="400" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Clave" ColSpanXs="12" ColSpanMd="3">
                            <Template>
                                <DxTextBox Text="@clienteSeleccionado?.Clave" ReadOnly="true" NullText="N/A" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="RTN" ColSpanXs="12" ColSpanMd="3">
                            <Template>
                                <DxTextBox Text="@clienteSeleccionado?.Rtn" ReadOnly="true" NullText="N/A" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Dirección" ColSpanXs="12" ColSpanMd="6">
                            <Template>
                                <DxTextBox Text="@direccionActual" ReadOnly="true" NullText="N/A" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Ciclo" ColSpanXs="12" ColSpanMd="4">
                            <Template>
                                <DxTextBox Text="@cicloDescripcion" ReadOnly="true" NullText="N/A" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Total deuda" ColSpanXs="12" ColSpanMd="4">
                            <Template>
                                <DxTextBox Text="@($"L. {totalSaldo:n2}")" ReadOnly="true" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Referencia recibo" ColSpanXs="12" ColSpanMd="4">
                            <Template>
                                <DxTextBox Text="@(reciboReferencia?.ToString("N0"))" ReadOnly="true" NullText="N/A" />
                            </Template>
                        </DxFormLayoutItem>
                    </DxFormLayout>
                </div>

                @if (bloqueado)
                {
                    <div class="alert alert-warning mb-3" role="alert">
                        El cliente está bloqueado por cobranza. Revise la situación antes de registrar un plan.
                    </div>
                }

                <div class="modern-card mb-4">
                    <div class="section-header">
                        <div>
                            <h6 class="section-title">Estado de cuenta</h6>
                            <p class="section-subtitle">Detalle de saldos pendientes</p>
                        </div>
                    </div>

                    <div class="grid-wrapper">
                        <DxGrid Data="@saldos"
                                PageSize="20"
                                ShowFilterRow="false"
                                ShowGroupPanel="false"
                                PagerVisible="false"
                                CssClass="grid-solicitudes">
                            <Columns>
                                <DxGridDataColumn FieldName="@nameof(CobranzaSaldoDetalleDto.Descripcion)" Caption="Descripción" />
                                <DxGridDataColumn FieldName="@nameof(CobranzaSaldoDetalleDto.SaldoDetalle)" Caption="Saldo" DisplayFormat="n2" Width="140px" />
                                <DxGridDataColumn FieldName="@nameof(CobranzaSaldoDetalleDto.Periodo)" Caption="Periodo" Width="120px" />
                            </Columns>
                            <TotalSummary>
                                <DxGridSummaryItem FieldName="@nameof(CobranzaSaldoDetalleDto.SaldoDetalle)"
                                                   SummaryType="GridSummaryItemType.Sum" />
                            </TotalSummary>
                            <EmptyDataAreaTemplate>
                                <div class="p-3 text-center text-muted">No hay saldos pendientes.</div>
                            </EmptyDataAreaTemplate>
                        </DxGrid>
                    </div>
                </div>

                <div class="modern-card">
                    <div class="section-header">
                        <div>
                            <h6 class="section-title">Parámetros del plan</h6>
                            <p class="section-subtitle">Configure prima, cuotas y fechas</p>
                        </div>
                    </div>

                    <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                        <DxFormLayoutItem Caption="Meses" ColSpanXs="12" ColSpanMd="3">
                            <Template>
                                <DxSpinEdit @bind-Value="MesesBindable" Min="1" Max="60" Increment="1" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="% Prima" ColSpanXs="12" ColSpanMd="3">
                            <Template>
                                <DxSpinEdit @bind-Value="PorcentajePrimaBindable" Min="0" Max="100" Decimals="2" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Prima" ColSpanXs="12" ColSpanMd="3">
                            <Template>
                                <DxTextBox Text="@($"L. {montoPrima:n2}")" ReadOnly="true" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Monto a financiar" ColSpanXs="12" ColSpanMd="3">
                            <Template>
                                <DxTextBox Text="@($"L. {montoFinanciar:n2}")" ReadOnly="true" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Fecha plan" ColSpanXs="12" ColSpanMd="3">
                            <Template>
                                <DxDateEdit @bind-Date="fechaPlan" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Primer pago" ColSpanXs="12" ColSpanMd="3">
                            <Template>
                                <DxDateEdit @bind-Date="fechaPrimerPago" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Representante" ColSpanXs="12" ColSpanMd="6">
                            <Template>
                                <DxTextBox @bind-Text="representante" Placeholder="Nombre completo" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Identidad representante" ColSpanXs="12" ColSpanMd="3">
                            <Template>
                                <DxMaskedInput @bind-Value="docRepresentante" Mask="0000-0000-00000" NullText="0000-0000-00000" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Contacto" ColSpanXs="12" ColSpanMd="3">
                            <Template>
                                <DxMaskedInput @bind-Value="numRepresentante" Mask="0000-0000" NullText="0000-0000" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Comentario" ColSpanXs="12">
                            <Template>
                                <DxMemo @bind-Text="comentario" Rows="3" />
                            </Template>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem ColSpanXs="12" CssClass="plan-actions">
                            <Template>
                                <DxButton Text="Desglose de cuotas"
                                          IconCssClass="bi bi-list-check"
                                          RenderStyle="ButtonRenderStyle.Primary"
                                          Enabled="@PuedeCalcular"
                                          Click="MostrarPreviewAsync" />
                            </Template>
                        </DxFormLayoutItem>
                    </DxFormLayout>
                </div>
            </ContentTemplate>
        </DxTabPage>

        <DxTabPage Text="Consulta de planes">
            <ContentTemplate>
                <div class="modern-card">
                    @if (cargandoPlanes)
                    {
                        <div class="text-center p-4">
                            <DxLoadingPanel Visible="true" Text="Cargando planes..." />
                            <div style="height:70px"></div>
                        </div>
                    }
                    else
                    {
                        <div class="grid-wrapper">
                            <DxGrid @ref="planesGrid"
                                    Data="@PlanesFiltrados"
                                    PageSize="15"
                                    PageSizeSelectorVisible="true"
                                    PageSizeSelectorItems="new int[] { 5, 10, 15, 25, 50, 100 }"
                                    ShowGroupPanel="false"
                                    ShowFilterRow="false"
                                    CssClass="grid-solicitudes"
                                    LayoutAutoSaving="OnLayoutAutoSaving"
                                    LayoutAutoLoading="OnLayoutAutoLoading">
                                <ToolbarTemplate>
                                    <div class="d-flex flex-wrap gap-2 align-items-center w-100">
                                        <DxTextBox Text="@planesBusqueda"
                                                   TextChanged="OnPlanesBusquedaChanged"
                                                   TextExpression="@(() => planesBusqueda)"
                                                   Placeholder="Buscar por correlativo o cliente"
                                                   InputDelay="500"
                                                   ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                   CssClass="me-1"
                                                   Style="min-width: 260px;" />

                                        <DxButton Text="Recargar" IconCssClass="bi bi-arrow-clockwise"
                                                  RenderStyle="ButtonRenderStyle.Secondary" Click="CargarPlanesAsync" CssClass="me-1" />

                                        <DxButton Text="Columnas" IconCssClass="bi bi-layout-three-columns"
                                                  RenderStyle="ButtonRenderStyle.Secondary" Click="MostrarColumnChooser" CssClass="me-1" />

                                        <div class="ms-auto text-muted small">
                                            Total: <span class="fw-bold">@totalPlanes.ToString("N0")</span>
                                        </div>
                                    </div>
                                </ToolbarTemplate>

                                <Columns>
                                    <DxGridDataColumn FieldName="@nameof(CobranzaPlanResumenDto.Correlativo)" Caption="Correlativo" Width="140px" />
                                    <DxGridDataColumn FieldName="@nameof(CobranzaPlanResumenDto.Cliente)" Caption="Cliente" />
                                    <DxGridDataColumn FieldName="@nameof(CobranzaPlanResumenDto.Fecha)" Caption="Fecha" DisplayFormat="d" Width="140px" />
                                    <DxGridDataColumn Caption="Estado" Width="140px" TextAlignment="GridTextAlignment.Center">
                                        <CellDisplayTemplate Context="cell">
                                            @if (cell.DataItem is CobranzaPlanResumenDto item)
                                            {
                                                <span class="badge-status @EstadoBadge(item.Estado)">@item.Estado</span>
                                            }
                                        </CellDisplayTemplate>
                                    </DxGridDataColumn>
                                    <DxGridDataColumn FieldName="@nameof(CobranzaPlanResumenDto.Total)" Caption="Total" DisplayFormat="n2" Width="120px" />
                                    <DxGridDataColumn Caption="Acciones" Width="140px" TextAlignment="GridTextAlignment.Center">
                                        <CellDisplayTemplate Context="ctx">
                                            <DxButton Text="Detalle"
                                                      ButtonType="ButtonType.Normal"
                                                      SizeMode="SizeMode.Small"
                                                      Click="@(
                                                          async () => await MostrarDetallePlan(
                                                              (CobranzaPlanResumenDto)ctx.DataItem))" />
                                        </CellDisplayTemplate>
                                    </DxGridDataColumn>
                                </Columns>

                                <EmptyDataAreaTemplate>
                                    <div class="p-4 text-center text-muted">No hay planes para mostrar.</div>
                                </EmptyDataAreaTemplate>
                            </DxGrid>
                        </div>
                    }
                </div>
            </ContentTemplate>
        </DxTabPage>
    </DxTabs>
</div>


<DxPopup @bind-Visible="mostrandoPreview"
         Width="min(860px, 95vw)"
         Height="auto"
         MaxHeight="85vh"
         Scrollable="true"
         CssClass="custom-popup"
         CloseOnOutsideClick="false">
    <HeaderContentTemplate>
        <div class="d-flex align-items-center gap-2">
            <div class="bg-success bg-opacity-10 text-success p-2 rounded-circle d-flex justify-content-center align-items-center" style="width: 38px; height: 38px;">
                <i class="bi bi-receipt"></i>
            </div>
            <div>
                <div class="fw-bold fs-6 text-dark" style="line-height:1.1;">Detalle de cuotas</div>
                <div class="small text-muted" style="font-weight: normal; font-size: 0.8rem;">Revise el plan antes de guardar</div>
            </div>
        </div>
    </HeaderContentTemplate>
    <BodyContentTemplate>
        <div class="p-4">
            <div class="preview-summary">
                <div>
                    <div class="summary-label">Cliente</div>
                    <div class="summary-value">@clienteSeleccionado?.Nombre</div>
                </div>
                <div>
                    <div class="summary-label">Meses</div>
                    <div class="summary-value">@meses</div>
                </div>
                <div>
                    <div class="summary-label">Prima</div>
                    <div class="summary-value">@($"{porcentajePrima:n2} %")</div>
                </div>
                <div>
                    <div class="summary-label">Monto financiar</div>
                    <div class="summary-value">@($"L. {montoFinanciar:n2}")</div>
                </div>
                <div>
                    <div class="summary-label">Valor cuota</div>
                    <div class="summary-value">@($"L. {preview.ValorCuota:n2}")</div>
                </div>
            </div>

            <div class="grid-wrapper mb-3">
                <DxGrid Data="@preview.Cuotas"
                        PageSize="10"
                        ShowGroupPanel="false"
                        ShowFilterRow="false"
                        CssClass="grid-solicitudes">
                    <Columns>
                        <DxGridDataColumn FieldName="@nameof(CobranzaCuotaDto.Numero)" Caption="Cuota" Width="90px" />
                        <DxGridDataColumn FieldName="@nameof(CobranzaCuotaDto.Fecha)" Caption="Fecha" DisplayFormat="d" />
                        <DxGridDataColumn FieldName="@nameof(CobranzaCuotaDto.Valor)" Caption="Valor" DisplayFormat="n2" />
                    </Columns>
                </DxGrid>
            </div>

            <div class="preview-actions">
                <DxButton Text="Cancelar"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          Click="CerrarPreview" />
                <DxButton Text="Guardar plan"
                          RenderStyle="ButtonRenderStyle.Success"
                          Enabled="@PuedeGuardar"
                          Click="GuardarPlanAsync" />
            </div>
        </div>
    </BodyContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="mostrandoDetalle"
         Width="min(860px, 95vw)"
         Height="auto"
         MaxHeight="85vh"
         Scrollable="true"
         CssClass="custom-popup">
    <HeaderContentTemplate>
        <div class="d-flex align-items-center gap-2">
            <div class="bg-warning bg-opacity-10 text-warning p-2 rounded-circle d-flex justify-content-center align-items-center" style="width: 38px; height: 38px;">
                <i class="bi bi-journal-text"></i>
            </div>
            <div>
                <div class="fw-bold fs-6 text-dark" style="line-height:1.1;">Plan @detalle?.Correlativo</div>
                <div class="small text-muted" style="font-weight: normal; font-size: 0.8rem;">Detalle del plan de pago</div>
            </div>
        </div>
    </HeaderContentTemplate>
    <BodyContentTemplate>
        @if (detalle is not null)
        {
            <div class="p-4">
                <div class="detail-header">
                    <div>
                        <div class="summary-label">Cliente</div>
                        <div class="summary-value">@detalle.ClienteClave - @detalle.ClienteNombre</div>
                    </div>
                    <div>
                        <div class="summary-label">Monto</div>
                        <div class="summary-value">@($"L. {detalle.Monto:n2}")</div>
                    </div>
                    <div>
                        <div class="summary-label">Meses</div>
                        <div class="summary-value">@detalle.Meses</div>
                    </div>
                    <div>
                        <div class="summary-label">Estado</div>
                        <div class="summary-value">
                            <span class="badge-status @EstadoBadge(detalle.Estado)">@detalle.Estado</span>
                        </div>
                    </div>
                </div>

                <div class="grid-wrapper">
                    <DxGrid Data="@detalle.Cuotas"
                            PageSize="10"
                            ShowFilterRow="false"
                            ShowGroupPanel="false"
                            CssClass="grid-solicitudes">
                        <Columns>
                            <DxGridDataColumn FieldName="@nameof(CobranzaPlanDetalleCuotaDto.Numero)" Caption="Cuota" Width="80px" />
                            <DxGridDataColumn FieldName="@nameof(CobranzaPlanDetalleCuotaDto.Fecha)" Caption="Fecha" DisplayFormat="d" />
                            <DxGridDataColumn FieldName="@nameof(CobranzaPlanDetalleCuotaDto.Valor)" Caption="Valor" DisplayFormat="n2" />
                            <DxGridDataColumn FieldName="@nameof(CobranzaPlanDetalleCuotaDto.Estado)" Caption="Estado" Width="140px" />
                        </Columns>
                    </DxGrid>
                </div>
            </div>
        }
    </BodyContentTemplate>
</DxPopup>

@code {
    private const string ToastName = "cobranza-plan";
    private const string GridLayoutStorageKey = "cobranza-planes-grid-layout";

    private DxGrid? planesGrid;

    private void MostrarColumnChooser() => planesGrid?.ShowColumnChooser();

    private Task OnLayoutAutoSaving(GridPersistentLayoutEventArgs e)
        => GridLayoutStorage.SaveAsync(JS, GridLayoutStorageKey, e);

    private Task OnLayoutAutoLoading(GridPersistentLayoutEventArgs e)
        => GridLayoutStorage.LoadAsync(JS, GridLayoutStorageKey, e);

    private int tabActivo;
    private string? usuarioActual;

    private List<ClienteComboDto> clientesCombo = new();
    private string? clienteSeleccionadoClave;
    private NotaClienteLookupDto? clienteSeleccionado;

    private IReadOnlyList<CobranzaSaldoDetalleDto> saldos = Array.Empty<CobranzaSaldoDetalleDto>();
    private decimal totalSaldo;
    private bool bloqueado;
    private decimal? reciboReferencia;
    private int? cicloIdReferencia;
    private string? direccionActual;
    private string? cicloDescripcion;

    private int meses = 6;
    private int MesesBindable
    {
        get => meses;
        set
        {
            if (meses == value)
            {
                return;
            }

            meses = value;
            ReiniciarPreview();
        }
    }

    private decimal porcentajePrima;
    private decimal PorcentajePrimaBindable
    {
        get => porcentajePrima;
        set
        {
            if (porcentajePrima == value)
            {
                return;
            }

            porcentajePrima = value;
            RecalcularMontos();
        }
    }

    private decimal montoPrima;
    private decimal montoFinanciar;
    private DateTime fechaPlan = DateTime.Today;
    private DateTime fechaPrimerPago = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(1);
    private string? representante;
    private string? docRepresentante;
    private string? numRepresentante;
    private string? comentario;

    private CobranzaPlanPreviewDto preview = new();
    private bool generandoPreview;
    private bool guardandoPlan;
    private bool mostrandoPreview;
    private ErrorNotice errorNotice = default!;

    private List<CobranzaPlanResumenDto> planes = new();
    private string planesBusqueda = string.Empty;
    private int totalPlanes;
    private bool cargandoPlanes;
    private CobranzaPlanDetalleDto? detalle;
    private bool mostrandoDetalle;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        usuarioActual = auth.User.Identity?.Name ?? "system";
        var iniciales = await CaptacionClient.GetClientesAsync(null);
        clientesCombo = iniciales.ToList();
        await CargarPlanesAsync();
    }

    private bool PuedeCalcular =>
        clienteSeleccionado is not null &&
        !bloqueado &&
        meses > 0 &&
        montoFinanciar > 0 &&
        !generandoPreview;

    private bool PuedeGuardar =>
        clienteSeleccionado is not null &&
        preview.Cuotas?.Count > 0 &&
        !guardandoPlan;

    private IEnumerable<CobranzaPlanResumenDto> PlanesFiltrados
    {
        get
        {
            if (string.IsNullOrWhiteSpace(planesBusqueda))
            {
                return planes;
            }

            return planes.Where(p =>
                (!string.IsNullOrWhiteSpace(p.Correlativo) && p.Correlativo.Contains(planesBusqueda, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(p.Cliente) && p.Cliente.Contains(planesBusqueda, StringComparison.OrdinalIgnoreCase)) ||
                (!string.IsNullOrWhiteSpace(p.ClienteClave) && p.ClienteClave.Contains(planesBusqueda, StringComparison.OrdinalIgnoreCase)));
        }
    }

    private async Task OnClienteSeleccionadoAsync(string? clave)
    {
        clienteSeleccionadoClave = clave;
        if (string.IsNullOrWhiteSpace(clave))
        {
            LimpiarPlan();
            return;
        }

        // Construir clienteSeleccionado desde el combo item
        var item = clientesCombo.FirstOrDefault(c =>
            string.Equals(c.Clave, clave, StringComparison.OrdinalIgnoreCase));

        clienteSeleccionado = new NotaClienteLookupDto
        {
            Clave     = clave,
            Nombre    = item?.Nombre ?? clave,
            Direccion = item?.Direccion
        };

        await CargarSaldosAsync();
    }

    private Task OnPlanesBusquedaChanged(string value)
    {
        planesBusqueda = value;
        return Task.CompletedTask;
    }

    private async Task CargarSaldosAsync()
    {
        if (clienteSeleccionado is null)
        {
            return;
        }

        try
        {
            saldos = await CobranzaClient.ObtenerSaldosAsync(clienteSeleccionado.Clave);
            totalSaldo = saldos.Sum(s => s.SaldoDetalle);
            bloqueado = saldos.FirstOrDefault()?.Bloqueado ?? false;
            reciboReferencia = saldos.FirstOrDefault()?.Recibo;
            cicloIdReferencia = saldos.FirstOrDefault()?.CicloId;
            direccionActual = saldos.FirstOrDefault()?.Direccion ?? clienteSeleccionado.Direccion;
            cicloDescripcion = saldos.FirstOrDefault()?.CicloDescripcion;
            RecalcularMontos();
        }
        catch (Exception ex)
        {
            errorNotice.ShowError("No se pudieron obtener los saldos.", ex);
        }
    }

    private void RecalcularMontos()
    {
        montoPrima = Math.Round(totalSaldo * (porcentajePrima / 100m), 2, MidpointRounding.AwayFromZero);
        montoFinanciar = Math.Max(0, totalSaldo - montoPrima);
        ReiniciarPreview();
    }

    private void ReiniciarPreview()
    {
        preview = new CobranzaPlanPreviewDto();
        mostrandoPreview = false;
    }

    private async Task MostrarPreviewAsync()
    {
        if (bloqueado)
        {
            MostrarToast("Cobranza", "El cliente está bloqueado por cobranza.", ToastRenderStyle.Warning);
            return;
        }

        await GenerarPreviewAsync();
        if (preview.Cuotas?.Count > 0)
        {
            mostrandoPreview = true;
        }
    }

    private async Task GenerarPreviewAsync()
    {
        if (!PuedeCalcular)
        {
            return;
        }

        generandoPreview = true;
        try
        {
            preview = await CobranzaClient.CalcularPlanAsync(new CobranzaPlanPreviewRequestDto
            {
                Meses = meses,
                MontoFinanciar = montoFinanciar,
                PorcentajePrima = porcentajePrima,
                Total = totalSaldo,
                FechaPrimerPago = fechaPrimerPago
            });
        }
        catch (Exception ex)
        {
            errorNotice.ShowError("No se pudo calcular el plan.", ex);
        }
        finally
        {
            generandoPreview = false;
        }
    }

    private async Task GuardarPlanAsync()
    {
        if (!PuedeGuardar || clienteSeleccionado is null)
        {
            return;
        }

        if (reciboReferencia is null)
        {
            MostrarToast("Cobranza", "No existe recibo base (transacción 101) para el cliente seleccionado.", ToastRenderStyle.Warning);
            return;
        }

        guardandoPlan = true;
        try
        {
            var dto = new CobranzaPlanGuardarDto
            {
                ClienteClave = clienteSeleccionado.Clave,
                ClienteNombre = clienteSeleccionado.Nombre,
                Direccion = clienteSeleccionado.Direccion ?? string.Empty,
                Meses = meses,
                PorcentajePrima = porcentajePrima,
                Total = totalSaldo,
                ValorPrima = montoPrima,
                MontoFinanciar = montoFinanciar,
                Fecha = fechaPlan,
                FechaPrimerPago = fechaPrimerPago,
                NomRepresentante = representante,
                DocRepresentante = docRepresentante,
                NumRepresentante = numRepresentante,
                Comentario = comentario,
                Recibo = reciboReferencia,
                CicloId = cicloIdReferencia,
                Usuario = usuarioActual ?? "system"
            };

            var respuesta = await CobranzaClient.GuardarPlanAsync(dto);
            if (!respuesta.Success)
            {
                var mensajeError = string.IsNullOrWhiteSpace(respuesta.Message)
                    ? "No se pudo guardar el plan."
                    : respuesta.Message;
                MostrarToast("Cobranza", mensajeError, ToastRenderStyle.Danger);
                return;
            }

            MostrarToast("Cobranza", respuesta.Message ?? "Plan guardado correctamente.", ToastRenderStyle.Success);
            mostrandoPreview = false;
            await CargarPlanesAsync();
            LimpiarPlan();
        }
        catch (Exception ex)
        {
            errorNotice.ShowError("No se pudo guardar el plan.", ex);
        }
        finally
        {
            guardandoPlan = false;
        }
    }

    private async Task CargarPlanesAsync()
    {
        cargandoPlanes = true;
        try
        {
            planes = (await CobranzaClient.ListarPlanesAsync()).ToList();
            totalPlanes = planes.Count;
        }
        catch (Exception ex)
        {
            MostrarToast("Cobranza", "No se pudo cargar el listado de planes.", ToastRenderStyle.Danger);
        }
        finally
        {
            cargandoPlanes = false;
        }
    }

    private async Task MostrarDetallePlan(CobranzaPlanResumenDto resumen)
    {
        try
        {
            detalle = await CobranzaClient.ObtenerPlanAsync(resumen.Correlativo);
            mostrandoDetalle = detalle is not null;
        }
        catch (Exception ex)
        {
            errorNotice.ShowError("No se pudo obtener el detalle del plan.", ex);
        }
    }

    private void CerrarPreview()
    {
        if (guardandoPlan)
        {
            return;
        }

        mostrandoPreview = false;
    }

    private void LimpiarPlan()
    {
        clienteSeleccionadoClave = null;
        clienteSeleccionado = null;
        saldos = Array.Empty<CobranzaSaldoDetalleDto>();
        totalSaldo = 0;
        bloqueado = false;
        porcentajePrima = 0;
        montoPrima = 0;
        montoFinanciar = 0;
        meses = 6;
        comentario = null;
        representante = null;
        docRepresentante = null;
        numRepresentante = null;
        preview = new CobranzaPlanPreviewDto();
        reciboReferencia = null;
        cicloIdReferencia = null;
        direccionActual = null;
        cicloDescripcion = null;
        mostrandoPreview = false;
        fechaPlan = DateTime.Today;
        fechaPrimerPago = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1).AddMonths(1);
    }

    private string EstadoBadge(string? estado)
    {
        if (string.IsNullOrWhiteSpace(estado))
        {
            return "inactive";
        }

        return estado.Trim().ToLowerInvariant() switch
        {
            "pagado" => "paid",
            "cancelado" => "cancelled",
            "pendiente" => "pending",
            "activo" => "active",
            _ => "inactive"
        };
    }

    private void MostrarToast(string titulo, string mensaje, ToastRenderStyle estilo) =>
        ToastService.ShowToast(new ToastOptions
        {
            ProviderName = ToastName,
            Title = titulo,
            Text = mensaje,
            RenderStyle = estilo
        });
}
