@page "/facturacion/periodos-comerciales"
@attribute [Authorize(Policy = PermissionNames.Ventas.View)]

@using DevExpress.Blazor
@using apc.Client.Services.Facturacion
@using apc.Client.Services.Tenant
@using SIAD.Core.Constants
@using SIAD.Core.DTOs.PeriodosComerciales
@inject PeriodosComercialesClient PeriodosClient
@inject TenantState TenantState
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Períodos comerciales</PageTitle>

<div id="periodos-comerciales-superficie" class="contabilidad-page contabilidad-content h-100">
    <DxCard CssClass="shadow-sm border-0 rounded w-100 h-100">
        <HeaderContent>
            <div class="d-flex flex-wrap justify-content-between align-items-center p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-circle bg-primary text-white d-flex align-items-center justify-content-center">
                        <i class="bi bi-calendar-month fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold text-secondary">Períodos comerciales</h5>
                        <small class="text-muted">Mes comercial y ciclos de lectura: apertura y cierres con checklist.</small>
                    </div>
                </div>
                <DxButton Text="Actualizar"
                          IconCssClass="bi bi-arrow-clockwise"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                          Enabled="@(!cargando)"
                          Click="@CargarPeriodosAsync" />
            </div>
        </HeaderContent>

        <ChildContent>
            <div class="p-4">
                <div class="alert alert-info mb-3" role="alert">
                    <i class="bi bi-info-circle-fill me-2"></i>
                    <strong>Abrir ciclo</strong> hace todo el trabajo: valida la secuencia, crea el período y
                    <strong>genera la planilla de lectura</strong> (la fecha límite sale del calendario de facturación).
                    El <strong>cierre de un ciclo</strong> valida que sus rutas tengan facturas emitidas; el
                    <strong>cierre del mes</strong> exige todos los ciclos cerrados y habilita el mes siguiente.
                </div>

                @* ---------------- Abrir ciclo (Fase B: apertura integral) ---------------- *@
                <DxFormLayout ColumnCountMd="12" ColumnCountSm="1" CaptionPosition="CaptionPosition.Vertical" CssClass="mb-1">
                    <DxFormLayoutItem Caption="Año" ColSpanMd="2" ColSpanSm="12">
                        <DxSpinEdit @bind-Value="nuevoAnio" MinValue="2000" MaxValue="2100" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Mes" ColSpanMd="2" ColSpanSm="12">
                        <DxComboBox Data="@meses" TData="MesOption" TValue="int"
                                    ValueFieldName="@nameof(MesOption.Numero)"
                                    TextFieldName="@nameof(MesOption.Nombre)"
                                    @bind-Value="nuevoMes"
                                    DropDownStyle="DropDownStyle.DropDownList" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Ciclo" ColSpanMd="2" ColSpanSm="12">
                        <DxTextBox @bind-Text="nuevoCiclo" NullText="01" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="3" ColSpanSm="12" Caption=" ">
                        <DxButton Text="Abrir ciclo..."
                                  IconCssClass="bi bi-calendar-plus"
                                  RenderStyle="ButtonRenderStyle.Primary"
                                  Enabled="@(!cargando && empresaId > 0)"
                                  Click="@AbrirPreviewAperturaAsync" />
                    </DxFormLayoutItem>
                </DxFormLayout>
                @if (sugerencia is not null)
                {
                    <div class="mb-3">
                        <small class="text-muted">
                            <i class="bi bi-lightbulb me-1"></i>
                            Según el calendario, el próximo ciclo es
                            <a href="" @onclick="UsarSugerencia" @onclick:preventDefault>
                                <strong>@NombreMes((short)sugerencia.Mes) @sugerencia.Anio · ciclo @sugerencia.Ciclo</strong>
                            </a>
                            @if (sugerencia.FechaLectura is not null)
                            {
                                <span> (lectura el @sugerencia.FechaLectura?.ToString("dd/MM/yyyy"))</span>
                            }
                        </small>
                    </div>
                }

                @* ---------------- Períodos ---------------- *@
                @if (periodos.Count == 0 && !cargando)
                {
                    <div class="alert alert-warning" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        No hay períodos comerciales registrados para esta empresa.
                    </div>
                }
                else
                {
                    @foreach (var periodo in periodos)
                    {
                        <div class="card mb-3 shadow-sm">
                            <div class="card-header d-flex flex-wrap justify-content-between align-items-center">
                                <div class="d-flex align-items-center gap-3">
                                    <strong class="fs-6">@NombreMes(periodo.Mes) @periodo.Anio</strong>
                                    <span class="badge @ClaseEstado(periodo.StatusId)">@EtiquetaEstado(periodo.StatusId)</span>
                                    @if (periodo.FechaCierre is not null)
                                    {
                                        <small class="text-muted">Cerrado el @periodo.FechaCierre?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") por @periodo.CerradoPor</small>
                                    }
                                </div>
                                @if (periodo.StatusId == EstadoPeriodoComercial.Abierto)
                                {
                                    <DxButton Text="Cerrar mes"
                                              IconCssClass="bi bi-calendar-check"
                                              RenderStyle="ButtonRenderStyle.Danger"
                                              RenderStyleMode="ButtonRenderStyleMode.Outline"
                                              Enabled="@(!cargando)"
                                              Click="@(() => AbrirChecklistMesAsync(periodo))" />
                                }
                            </div>
                            <div class="card-body py-2">
                                @if (periodo.Ciclos.Count == 0)
                                {
                                    <small class="text-muted">Sin ciclos registrados.</small>
                                }
                                else
                                {
                                    <table class="table table-sm align-middle mb-0">
                                        <thead>
                                            <tr class="text-muted small">
                                                <th style="width:120px">Ciclo</th>
                                                <th style="width:120px">Estado</th>
                                                <th style="width:160px">Fecha límite</th>
                                                <th>Cierre</th>
                                                <th style="width:220px" class="text-end">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var ciclo in periodo.Ciclos)
                                            {
                                                <tr>
                                                    <td><strong>@ciclo.CicloCodigo</strong></td>
                                                    <td><span class="badge @ClaseEstado(ciclo.StatusId)">@EtiquetaEstado(ciclo.StatusId)</span></td>
                                                    <td>@(ciclo.FechaLimite?.ToString("dd/MM/yyyy") ?? "—")</td>
                                                    <td>
                                                        @if (ciclo.FechaCierre is not null)
                                                        {
                                                            <small class="text-muted">@ciclo.FechaCierre?.ToLocalTime().ToString("dd/MM/yyyy HH:mm") — @ciclo.CerradoPor</small>
                                                        }
                                                    </td>
                                                    <td class="text-end">
                                                        <div class="d-inline-flex gap-2">
                                                        <DxButton Text="Planilla"
                                                                  IconCssClass="bi bi-list-ol"
                                                                  RenderStyle="ButtonRenderStyle.Info"
                                                                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                                                                  Enabled="@(!cargando)"
                                                                  title="Ver la planilla de lectura del ciclo"
                                                                  Click="@(() => AbrirPlanillaAsync(periodo, ciclo))" />
                                                        @if (ciclo.StatusId == EstadoPeriodoComercial.Abierto)
                                                        {
                                                            <DxButton Text="Deshacer"
                                                                      IconCssClass="bi bi-arrow-counterclockwise"
                                                                      RenderStyle="ButtonRenderStyle.Danger"
                                                                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                                                                      Enabled="@(!cargando)"
                                                                      title="Deshacer la apertura (solo si el ciclo no tiene lecturas ni facturas)"
                                                                      Click="@(() => PedirDeshacerApertura(periodo, ciclo))" />
                                                            <DxButton Text="Cerrar ciclo"
                                                                      IconCssClass="bi bi-check2-circle"
                                                                      RenderStyle="ButtonRenderStyle.Secondary"
                                                                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                                                                      Enabled="@(!cargando)"
                                                                      Click="@(() => AbrirCierreCicloAsync(periodo, ciclo))" />
                                                        }
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        </ChildContent>
    </DxCard>

    <DxLoadingPanel Visible="@cargando"
                    PositionTarget="#periodos-comerciales-superficie"
                    ApplyBackgroundShading="false"
                    IsContentBlocked="true"
                    Text="Procesando..." />

    <DxMessageBox @bind-Visible="deshacerConfirmVisible"
                  Type="MessageBoxType.Confirmation"
                  Title="Deshacer apertura"
                  Text="@deshacerConfirmTexto"
                  RenderStyle="MessageBoxRenderStyle.Danger"
                  OkButtonText="Sí, deshacer"
                  CancelButtonText="Cancelar"
                  ShowCloseButton="false"
                  CloseOnOutsideClick="false"
                  Closed="OnDeshacerConfirmClosed" />

    @* ---------------- Popup planilla del ciclo (Fase C) ---------------- *@
    <DxPopup @bind-Visible="planillaVisible"
             Width="900px"
             MaxWidth="95vw"
             Scrollable="true"
             CloseOnEscape="true"
             CloseOnOutsideClick="true"
             ShowFooter="false">
        <HeaderContentTemplate>
            <div class="d-flex flex-wrap align-items-center gap-3 p-1 w-100">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-list-ol fs-4 text-info"></i>
                    <strong>Planilla ciclo @cicloPlanilla?.CicloCodigo — @NombreMes(periodoPlanilla?.Mes ?? 0) @periodoPlanilla?.Anio</strong>
                </div>
                <span class="badge text-bg-secondary">@planilla.Count fila(s)</span>
                <span class="badge @(PlanillaPendientes > 0 ? "text-bg-danger" : "text-bg-success")">
                    @PlanillaPendientes pendiente(s)
                </span>
                <DxCheckBox @bind-Checked="planillaSoloPendientes" CheckType="CheckType.Switch">
                    Solo pendientes
                </DxCheckBox>
            </div>
        </HeaderContentTemplate>
        <BodyContentTemplate>
            <div class="p-3">
                @if (planilla.Count == 0)
                {
                    <div class="alert alert-info mb-0">El ciclo no tiene planilla de lectura.</div>
                }
                else
                {
                    <DxGrid Data="@PlanillaFiltrada" PageSize="15" ShowSearchBox="true" CssClass="border-0">
                        <Columns>
                            <DxGridDataColumn FieldName="@nameof(PlanillaCicloFilaDto.Ruta)" Caption="Ruta" Width="90px" />
                            <DxGridDataColumn FieldName="@nameof(PlanillaCicloFilaDto.Secuencia)" Caption="Sec." Width="70px" />
                            <DxGridDataColumn FieldName="@nameof(PlanillaCicloFilaDto.Clave)" Caption="Clave" Width="110px" />
                            <DxGridDataColumn FieldName="@nameof(PlanillaCicloFilaDto.Cliente)" Caption="Cliente" MinWidth="160" />
                            <DxGridDataColumn FieldName="@nameof(PlanillaCicloFilaDto.Contador)" Caption="Medidor" Width="110px" />
                            <DxGridDataColumn FieldName="@nameof(PlanillaCicloFilaDto.LecturaAnterior)" Caption="Lect. ant." Width="95px" />
                            <DxGridDataColumn FieldName="@nameof(PlanillaCicloFilaDto.LecturaActual)" Caption="Lect. act." Width="95px" />
                            <DxGridDataColumn FieldName="@nameof(PlanillaCicloFilaDto.Consumo)" Caption="Consumo" Width="95px" />
                            <DxGridDataColumn FieldName="@nameof(PlanillaCicloFilaDto.Usuario)" Caption="Estado" Width="130px">
                                <CellDisplayTemplate Context="cell">
                                    @{ var fila = (PlanillaCicloFilaDto)cell.DataItem; }
                                    @if (fila.Pendiente)
                                    {
                                        <span class="badge text-bg-danger">Pendiente</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-success" title="@fila.Usuario">Leída</span>
                                        @if (fila.NumeroFactura is not null)
                                        {
                                            <i class="bi bi-receipt ms-1 text-muted" title="Factura @fila.NumeroFactura"></i>
                                        }
                                    }
                                </CellDisplayTemplate>
                            </DxGridDataColumn>
                        </Columns>
                    </DxGrid>
                }
            </div>
        </BodyContentTemplate>
    </DxPopup>

    @* ---------------- Popup apertura integral (Fase B) ---------------- *@
    <DxPopup @bind-Visible="aperturaVisible"
             Width="680px"
             MaxWidth="95vw"
             Scrollable="true"
             CloseOnEscape="true"
             CloseOnOutsideClick="false"
             ShowFooter="true">
        <HeaderContentTemplate>
            <div class="d-flex align-items-center gap-2 p-1">
                <i class="bi bi-calendar-plus fs-4 text-primary"></i>
                <strong>Abrir ciclo @previewApertura?.Ciclo — @NombreMes((short)(previewApertura?.Mes ?? 0)) @previewApertura?.Anio</strong>
            </div>
        </HeaderContentTemplate>
        <BodyContentTemplate>
            <div class="p-3">
                @if (previewApertura is null)
                {
                    <div class="text-muted">Calculando...</div>
                }
                else
                {
                    @if (previewApertura.Bloqueo is not null)
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-x-circle-fill me-2"></i>@EtiquetaBloqueo(previewApertura.Bloqueo)
                        </div>
                    }

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <div class="border rounded p-2 h-100">
                                <small class="text-muted d-block">Planilla de lectura</small>
                                <strong>@previewApertura.ClientesPlanilla cliente(s)</strong>
                                <small class="d-block text-muted">@DescripcionOrigen(previewApertura.OrigenPlanilla)</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded p-2 h-100">
                                <small class="text-muted d-block">Fecha límite (calendario)</small>
                                <strong>@(previewApertura.FechaLimite?.ToString("dd/MM/yyyy") ?? "—")</strong>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded p-2 h-100">
                                <small class="text-muted d-block">Rutas del ciclo</small>
                                <strong>@previewApertura.Rutas.Count</strong>
                                @if (previewApertura.RutasSinLector > 0)
                                {
                                    <small class="d-block text-danger">@previewApertura.RutasSinLector sin lector</small>
                                }
                                else if (previewApertura.Rutas.Count > 0)
                                {
                                    <small class="d-block text-success">todas con lector</small>
                                }
                            </div>
                        </div>
                    </div>

                    @if (previewApertura.Rutas.Count > 0)
                    {
                        <table class="table table-sm mb-3">
                            <thead>
                                <tr class="text-muted small"><th style="width:140px">Ruta</th><th>Lector asignado</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var r in previewApertura.Rutas)
                                {
                                    <tr>
                                        <td><strong>@r.Ruta</strong></td>
                                        <td>
                                            @if (string.IsNullOrWhiteSpace(r.Lector))
                                            {
                                                <span class="badge text-bg-danger">Sin lector</span>
                                            }
                                            else
                                            {
                                                @r.Lector
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                    @foreach (var aviso in previewApertura.Avisos)
                    {
                        <div class="alert alert-warning py-2 mb-2">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@EtiquetaAviso(aviso)
                        </div>
                    }
                }
            </div>
        </BodyContentTemplate>
        <FooterContentTemplate Context="aperturaFooter">
            <div class="p-2 d-flex justify-content-end gap-2">
                <DxButton RenderStyle="ButtonRenderStyle.Secondary" Text="Cancelar"
                          Click="@aperturaFooter.CloseCallback" />
                <DxButton RenderStyle="ButtonRenderStyle.Primary" Text="Abrir ciclo"
                          IconCssClass="bi bi-calendar-plus"
                          Enabled="@(!cargando && previewApertura is not null && previewApertura.Bloqueo is null)"
                          Click="@ConfirmarAperturaAsync" />
            </div>
        </FooterContentTemplate>
    </DxPopup>

    @* ---------------- Popup cierre de ciclo (rutas) ---------------- *@
    <DxPopup @bind-Visible="cierreCicloVisible"
             Width="720px"
             MaxWidth="95vw"
             Scrollable="true"
             CloseOnEscape="true"
             CloseOnOutsideClick="false"
             ShowFooter="true">
        <HeaderContentTemplate>
            <div class="d-flex align-items-center gap-2 p-1">
                <i class="bi bi-check2-circle fs-4 text-primary"></i>
                <strong>Cerrar ciclo @cicloSeleccionado?.CicloCodigo — @NombreMes(periodoSeleccionado?.Mes ?? 0) @periodoSeleccionado?.Anio</strong>
            </div>
        </HeaderContentTemplate>
        <BodyContentTemplate>
            <div class="p-3">
                @if (rutasCiclo.Count == 0)
                {
                    <div class="alert alert-info mb-0">El ciclo no tiene rutas activas con clientes que validar.</div>
                }
                else
                {
                    <p class="mb-2 text-muted">
                        Una ruta está <strong>pendiente</strong> si tiene clientes activos y ninguna factura de lectura
                        emitida en el mes.
                    </p>
                    <DxGrid Data="@rutasCiclo" PageSize="10" CssClass="mb-2">
                        <Columns>
                            <DxGridDataColumn FieldName="@nameof(RutaCicloDto.CodRuta)" Caption="Ruta" Width="120px" />
                            <DxGridDataColumn FieldName="@nameof(RutaCicloDto.ClientesActivos)" Caption="Clientes activos" Width="140px" />
                            <DxGridDataColumn FieldName="@nameof(RutaCicloDto.FacturasMes)" Caption="Facturas del mes" Width="150px" />
                            <DxGridDataColumn FieldName="@nameof(RutaCicloDto.Pendiente)" Caption="Estado" Width="130px">
                                <CellDisplayTemplate Context="cell">
                                    @{ var ruta = (RutaCicloDto)cell.DataItem; }
                                    <span class="badge @(ruta.Pendiente ? "text-bg-danger" : "text-bg-success")">
                                        @(ruta.Pendiente ? "Pendiente" : "Facturada")
                                    </span>
                                </CellDisplayTemplate>
                            </DxGridDataColumn>
                        </Columns>
                    </DxGrid>
                    @if (RutasPendientes > 0)
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            Hay <strong>@RutasPendientes ruta(s) pendiente(s)</strong>. El cierre normal está bloqueado;
                            puede forzarlo bajo su responsabilidad (las rutas quedarán sin facturar en este mes).
                        </div>
                    }
                }
            </div>
        </BodyContentTemplate>
        <FooterContentTemplate Context="cicloFooter">
            <div class="p-2 d-flex justify-content-end gap-2">
                <DxButton RenderStyle="ButtonRenderStyle.Secondary" Text="Cancelar"
                          Click="@cicloFooter.CloseCallback" />
                @if (RutasPendientes > 0)
                {
                    <DxButton RenderStyle="ButtonRenderStyle.Danger" Text="Forzar cierre"
                              Enabled="@(!cargando)"
                              Click="@(() => CerrarCicloAsync(true))" />
                }
                else
                {
                    <DxButton RenderStyle="ButtonRenderStyle.Primary" Text="Cerrar ciclo"
                              Enabled="@(!cargando)"
                              Click="@(() => CerrarCicloAsync(false))" />
                }
            </div>
        </FooterContentTemplate>
    </DxPopup>

    @* ---------------- Popup cierre de mes (checklist) ---------------- *@
    <DxPopup @bind-Visible="cierreMesVisible"
             Width="640px"
             MaxWidth="95vw"
             Scrollable="true"
             CloseOnEscape="true"
             CloseOnOutsideClick="false"
             ShowFooter="true">
        <HeaderContentTemplate>
            <div class="d-flex align-items-center gap-2 p-1">
                <i class="bi bi-calendar-check fs-4 text-danger"></i>
                <strong>Cerrar mes comercial @NombreMes(periodoSeleccionado?.Mes ?? 0) @periodoSeleccionado?.Anio</strong>
            </div>
        </HeaderContentTemplate>
        <BodyContentTemplate>
            <div class="p-3">
                <ul class="list-group mb-3">
                    @foreach (var item in checklistMes)
                    {
                        <li class="list-group-item d-flex align-items-start gap-2">
                            <i class="bi @(item.Ok ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger") mt-1"></i>
                            <div>
                                <div class="fw-semibold">@EtiquetaChecklist(item.Item)</div>
                                <small class="text-muted">@item.Detalle</small>
                            </div>
                        </li>
                    }
                </ul>
                @if (ChecklistMesOk)
                {
                    <div class="alert alert-success mb-0">
                        <i class="bi bi-check-circle-fill me-2"></i>
                        Checklist en verde: el mes puede cerrarse. El cierre habilita abrir el mes siguiente y no se
                        reabre desde esta pantalla.
                    </div>
                }
                else
                {
                    <div class="alert alert-danger mb-0">
                        <i class="bi bi-x-circle-fill me-2"></i>
                        Resuelva los puntos marcados antes de cerrar el mes.
                    </div>
                }
            </div>
        </BodyContentTemplate>
        <FooterContentTemplate Context="mesFooter">
            <div class="p-2 d-flex justify-content-end gap-2">
                <DxButton RenderStyle="ButtonRenderStyle.Secondary" Text="Cancelar"
                          Click="@mesFooter.CloseCallback" />
                <DxButton RenderStyle="ButtonRenderStyle.Danger" Text="Cerrar mes"
                          Enabled="@(ChecklistMesOk && !cargando)"
                          Click="@CerrarMesAsync" />
            </div>
        </FooterContentTemplate>
    </DxPopup>
</div>

@code {
    private long empresaId;
    private bool cargando;

    private IReadOnlyList<PeriodoComercialDto> periodos = Array.Empty<PeriodoComercialDto>();

    private int nuevoAnio = DateTime.Today.Year;
    private int nuevoMes = DateTime.Today.Month;
    private string nuevoCiclo = "01";

    private bool cierreCicloVisible;
    private bool cierreMesVisible;
    private bool aperturaVisible;
    private AperturaCicloResumenDto? previewApertura;
    private SugerenciaAperturaDto? sugerencia;
    private bool deshacerConfirmVisible;
    private string deshacerConfirmTexto = string.Empty;
    private PeriodoComercialCicloDto? cicloADeshacer;
    private bool planillaVisible;
    private bool planillaSoloPendientes;
    private PeriodoComercialDto? periodoPlanilla;
    private PeriodoComercialCicloDto? cicloPlanilla;
    private IReadOnlyList<PlanillaCicloFilaDto> planilla = Array.Empty<PlanillaCicloFilaDto>();

    private int PlanillaPendientes => planilla.Count(f => f.Pendiente);
    private IEnumerable<PlanillaCicloFilaDto> PlanillaFiltrada =>
        planillaSoloPendientes ? planilla.Where(f => f.Pendiente) : planilla;
    private PeriodoComercialDto? periodoSeleccionado;
    private PeriodoComercialCicloDto? cicloSeleccionado;
    private IReadOnlyList<RutaCicloDto> rutasCiclo = Array.Empty<RutaCicloDto>();
    private IReadOnlyList<ChecklistCierreItemDto> checklistMes = Array.Empty<ChecklistCierreItemDto>();

    private int RutasPendientes => rutasCiclo.Count(r => r.Pendiente);
    private bool ChecklistMesOk => checklistMes.Count > 0 && checklistMes.All(i => i.Ok);

    private sealed record MesOption(int Numero, string Nombre);
    private static readonly IReadOnlyList<MesOption> meses =
    [
        new(1, "Enero"), new(2, "Febrero"), new(3, "Marzo"), new(4, "Abril"),
        new(5, "Mayo"), new(6, "Junio"), new(7, "Julio"), new(8, "Agosto"),
        new(9, "Septiembre"), new(10, "Octubre"), new(11, "Noviembre"), new(12, "Diciembre")
    ];

    protected override async Task OnInitializedAsync()
    {
        cargando = true;
        try
        {
            empresaId = await TenantState.EnsureCompanyAsync();
            if (empresaId > 0)
            {
                await CargarPeriodosCoreAsync();
                await CargarSugerenciaAsync();
            }
            else
            {
                MostrarError("Su sesión no tiene una empresa activa; vuelva a iniciar sesión.");
            }
        }
        catch (Exception ex)
        {
            MostrarError($"No fue posible cargar la pantalla: {ex.Message}");
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task CargarPeriodosAsync()
    {
        cargando = true;
        try
        {
            await CargarPeriodosCoreAsync();
        }
        catch (Exception ex)
        {
            MostrarError($"No fue posible cargar los períodos: {ex.Message}");
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task CargarPeriodosCoreAsync()
    {
        periodos = await PeriodosClient.ListarAsync(empresaId);
    }

    private async Task CargarSugerenciaAsync()
    {
        try
        {
            sugerencia = await PeriodosClient.SugerenciaAperturaAsync(empresaId);
            UsarSugerencia();
        }
        catch
        {
            // La sugerencia es informativa: sin calendario simplemente no hay.
            sugerencia = null;
        }
    }

    private void UsarSugerencia()
    {
        if (sugerencia is not null)
        {
            nuevoAnio = sugerencia.Anio;
            nuevoMes = sugerencia.Mes;
            nuevoCiclo = sugerencia.Ciclo;
        }
    }

    private async Task AbrirPreviewAperturaAsync()
    {
        if (empresaId <= 0)
        {
            return;
        }

        cargando = true;
        try
        {
            previewApertura = await PeriodosClient.PreviewAperturaAsync(empresaId, nuevoAnio, nuevoMes, nuevoCiclo);
            aperturaVisible = true;
        }
        catch (Exception ex)
        {
            MostrarError(ex.Message);
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task ConfirmarAperturaAsync()
    {
        if (empresaId <= 0 || previewApertura is null)
        {
            return;
        }

        cargando = true;
        try
        {
            var resumen = await PeriodosClient.AbrirAsync(empresaId,
                new AbrirPeriodoComercialRequest(nuevoAnio, nuevoMes, nuevoCiclo));
            aperturaVisible = false;

            var detalle = resumen.OrigenPlanilla switch
            {
                "ROLL_OVER" => $"planilla de {resumen.ClientesPlanilla} lectura(s) generada desde el mes anterior",
                "DESDE_CLIENTES" => $"planilla de {resumen.ClientesPlanilla} cliente(s) generada desde el maestro",
                "EXISTENTE" => $"la planilla ya existía ({resumen.ClientesPlanilla} fila(s))",
                _ => "sin planilla (no se encontraron clientes)"
            };
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Períodos comerciales",
                Text = $"Ciclo {resumen.Ciclo} de {NombreMes((short)resumen.Mes)} {resumen.Anio} abierto: {detalle}.",
                RenderStyle = resumen.Avisos.Count > 0 ? ToastRenderStyle.Warning : ToastRenderStyle.Success
            });
            await CargarPeriodosCoreAsync();
            await CargarSugerenciaAsync();
        }
        catch (Exception ex)
        {
            MostrarError(ex.Message);
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task AbrirPlanillaAsync(PeriodoComercialDto periodo, PeriodoComercialCicloDto ciclo)
    {
        periodoPlanilla = periodo;
        cicloPlanilla = ciclo;
        cargando = true;
        try
        {
            planilla = await PeriodosClient.PlanillaCicloAsync(empresaId, ciclo.PeriodoCicloId);
            planillaSoloPendientes = false;
            planillaVisible = true;
        }
        catch (Exception ex)
        {
            MostrarError($"No fue posible cargar la planilla: {ex.Message}");
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private void PedirDeshacerApertura(PeriodoComercialDto periodo, PeriodoComercialCicloDto ciclo)
    {
        cicloADeshacer = ciclo;
        deshacerConfirmTexto = $"Se deshará la apertura del ciclo {ciclo.CicloCodigo} de {NombreMes(periodo.Mes)} {periodo.Anio}: " +
            "se elimina su planilla de lectura y el ciclo (y el período si queda vacío). " +
            "Solo procede si el ciclo no tiene lecturas registradas ni facturas.";
        deshacerConfirmVisible = true;
    }

    private async Task OnDeshacerConfirmClosed(bool confirmed)
    {
        var ciclo = cicloADeshacer;
        cicloADeshacer = null;
        deshacerConfirmTexto = string.Empty;

        if (!confirmed || ciclo is null)
        {
            return;
        }

        cargando = true;
        try
        {
            var resultado = await PeriodosClient.DeshacerAperturaAsync(empresaId, ciclo.PeriodoCicloId);
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Períodos comerciales",
                Text = $"Apertura del ciclo {ciclo.CicloCodigo} deshecha ({resultado.PlanillaEliminada} fila(s) de planilla eliminadas).",
                RenderStyle = ToastRenderStyle.Success
            });
            await CargarPeriodosCoreAsync();
            await CargarSugerenciaAsync();
        }
        catch (Exception ex)
        {
            MostrarError(ex.Message);
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private static string EtiquetaBloqueo(string bloqueo) => bloqueo switch
    {
        "PERIODO_ANTERIOR_ABIERTO" => "El mes comercial anterior sigue abierto: ciérrelo antes de abrir este ciclo.",
        "PERIODO_CERRADO" => "El período de este mes ya fue cerrado y no se reabre.",
        "CICLO_CERRADO" => "Este ciclo ya fue cerrado y no se reabre.",
        _ => bloqueo
    };

    private static string EtiquetaAviso(string aviso) => aviso switch
    {
        "SIN_CALENDARIO" => "El calendario de facturación no tiene fechas para este período: la fecha límite será el fin de mes. Cargue el calendario en Facturación → Calendario de facturación.",
        "PLANILLA_EXISTENTE" => "El período ya tiene planilla de lectura; no se generará de nuevo.",
        "SIN_CLIENTES" => "No se encontraron clientes para generar la planilla (revise el catálogo de ciclos y los clientes activos).",
        "RUTAS_SIN_LECTOR" => "Hay rutas del ciclo sin lector asignado: esos libros no podrán descargarse en la app. Asigne lectores en la pantalla Lectores.",
        "OTRO_CICLO_ABIERTO" => "Hay otros ciclos abiertos; recuerde cerrarlos cuando terminen de facturar.",
        "CICLO_YA_ABIERTO" => "El ciclo ya estaba abierto; la operación es idempotente.",
        _ => aviso
    };

    private static string DescripcionOrigen(string origen) => origen switch
    {
        "ROLL_OVER" => "roll-over del mes anterior",
        "DESDE_CLIENTES" => "desde el maestro de clientes",
        "EXISTENTE" => "planilla ya existente",
        "VACIA" => "sin clientes",
        _ => origen
    };

    private async Task AbrirCierreCicloAsync(PeriodoComercialDto periodo, PeriodoComercialCicloDto ciclo)
    {
        periodoSeleccionado = periodo;
        cicloSeleccionado = ciclo;
        cargando = true;
        try
        {
            rutasCiclo = await PeriodosClient.RutasCicloAsync(empresaId, ciclo.PeriodoCicloId);
            cierreCicloVisible = true;
        }
        catch (Exception ex)
        {
            MostrarError($"No fue posible evaluar las rutas del ciclo: {ex.Message}");
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task CerrarCicloAsync(bool forzar)
    {
        if (cicloSeleccionado is null)
        {
            return;
        }

        cargando = true;
        try
        {
            await PeriodosClient.CerrarCicloAsync(empresaId, cicloSeleccionado.PeriodoCicloId, forzar);
            cierreCicloVisible = false;
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Períodos comerciales",
                Text = forzar
                    ? $"Ciclo {cicloSeleccionado.CicloCodigo} cerrado (forzado, con rutas pendientes)."
                    : $"Ciclo {cicloSeleccionado.CicloCodigo} cerrado.",
                RenderStyle = forzar ? ToastRenderStyle.Warning : ToastRenderStyle.Success
            });
            await CargarPeriodosCoreAsync();
        }
        catch (Exception ex)
        {
            MostrarError(ex.Message);
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task AbrirChecklistMesAsync(PeriodoComercialDto periodo)
    {
        periodoSeleccionado = periodo;
        cargando = true;
        try
        {
            checklistMes = await PeriodosClient.ChecklistAsync(empresaId, periodo.PeriodoComercialId);
            cierreMesVisible = true;
        }
        catch (Exception ex)
        {
            MostrarError($"No fue posible evaluar el checklist: {ex.Message}");
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task CerrarMesAsync()
    {
        if (periodoSeleccionado is null)
        {
            return;
        }

        cargando = true;
        try
        {
            await PeriodosClient.CerrarMesAsync(empresaId, periodoSeleccionado.PeriodoComercialId);
            cierreMesVisible = false;
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Períodos comerciales",
                Text = $"Mes comercial {NombreMes(periodoSeleccionado.Mes)} {periodoSeleccionado.Anio} cerrado.",
                RenderStyle = ToastRenderStyle.Success
            });
            await CargarPeriodosCoreAsync();
        }
        catch (Exception ex)
        {
            MostrarError(ex.Message);
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private void MostrarError(string mensaje)
    {
        ToastService.ShowToast(new ToastOptions
        {
            Title = "Períodos comerciales",
            Text = mensaje,
            RenderStyle = ToastRenderStyle.Danger
        });
    }

    private static string NombreMes(short mes) => mes is >= 1 and <= 12 ? meses[mes - 1].Nombre : mes.ToString();
    private static string NombreMes(int mes) => NombreMes((short)mes);

    private static string EtiquetaEstado(short statusId) => statusId switch
    {
        EstadoPeriodoComercial.Abierto => "Abierto",
        EstadoPeriodoComercial.Cerrado => "Cerrado",
        _ => statusId.ToString()
    };

    private static string ClaseEstado(short statusId) => statusId switch
    {
        EstadoPeriodoComercial.Abierto => "text-bg-success",
        EstadoPeriodoComercial.Cerrado => "text-bg-secondary",
        _ => "text-bg-light"
    };

    private static string EtiquetaChecklist(string item) => item switch
    {
        "CICLOS_ABIERTOS" => "Todos los ciclos del mes cerrados",
