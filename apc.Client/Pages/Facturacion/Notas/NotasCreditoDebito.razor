@page "/facturacion/notas"
@attribute [Authorize]

@using DevExpress.Blazor
@using SIAD.Core.DTOs.Common
@using SIAD.Core.DTOs.NotasCreditoDebito
@using apc.Client.Services.Facturacion

@inject NotasCreditoDebitoClient Client
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IToastNotificationService ToastService

<PageTitle>Notas de Crédito y Débito</PageTitle>

<DxToastProvider Name="NotasToast" MaxToastCount="4" />

<div class="notas-page">

    @* ── Encabezado ── *@
    <div class="d-flex align-items-start flex-wrap gap-3 mb-3">
        <div class="flex-grow-1">
            <h4 class="mb-1 fw-bold text-secondary">
                <i class="bi bi-journal-text me-2 text-primary"></i>Notas de Crédito y Débito
            </h4>
            <small class="text-muted">Emisión y consulta de NC/ND conforme SAR Acuerdo 481-2017.</small>
        </div>
        <div class="d-flex flex-wrap gap-2 flex-shrink-0">
            <DxButton Text="Actualizar"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      IconCssClass="bi bi-arrow-clockwise"
                      Click="ReloadAsync"
                      Enabled="@(!isSaving)" />
            <DxButton Text="Emitir nota"
                      RenderStyle="ButtonRenderStyle.Primary"
                      IconCssClass="bi bi-plus-lg"
                      Click="AbrirEmitir" />
        </div>
    </div>

    @* ── Badges filtro por tipo ── *@
    <div class="d-flex flex-wrap gap-2 mb-3">
        <button type="button"
                class="cai-stat-badge @(tipoFiltro is null ? "cai-stat-badge--active" : "")"
                @onclick="@(() => SetTipoFiltro(null))">
            <i class="bi bi-journals"></i> Total: <strong>@(dataSource?.LastTotalCount ?? 0)</strong>
        </button>
        <button type="button"
                class="cai-stat-badge cai-stat-badge--success @(tipoFiltro == "NC" ? "cai-stat-badge--active" : "")"
                @onclick="@(() => SetTipoFiltro("NC"))">
            <i class="bi bi-arrow-down-circle"></i> Notas de crédito
        </button>
        <button type="button"
                class="cai-stat-badge cai-stat-badge--warning @(tipoFiltro == "ND" ? "cai-stat-badge--active" : "")"
                @onclick="@(() => SetTipoFiltro("ND"))">
            <i class="bi bi-arrow-up-circle"></i> Notas de débito
        </button>
        @if (!string.IsNullOrWhiteSpace(dataSource?.LastError))
        {
            <span class="cai-stat-badge cai-stat-badge--danger">@dataSource.LastError</span>
        }
    </div>

    @* ── Grid con carga remota ── *@
    <div class="notas-grid-wrapper shadow-sm">
        <DxGrid @ref="notasGrid"
                Data="@dataSource"
                KeyFieldName="@nameof(NotaEmitidaListDto.NotaId)"
                ShowPager="true"
                PageSize="15"
                PageSizeSelectorVisible="true"
                PageSizeSelectorItems="new int[] { 10, 15, 25, 50 }"
                SizeMode="SizeMode.Medium"
                ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
                CssClass="border-0">
            <ToolbarTemplate>
                <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Contained">
                    <Items>
                        <DxToolbarItem BeginGroup="true" Alignment="ToolbarItemAlignment.Right">
                            <Template Context="t">
                                <DxTextBox @bind-Text="searchText"
                                           BindValueMode="BindValueMode.OnInput"
                                           NullText="Buscar por número, factura origen, cliente..."
                                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                           CssClass="notas-search"
                                           @onkeydown="OnSearchKeyDown" />
                            </Template>
                        </DxToolbarItem>
                        <DxToolbarItem Text="Aplicar"
                                       Alignment="ToolbarItemAlignment.Right"
                                       IconCssClass="bi bi-funnel"
                                       RenderStyle="ButtonRenderStyle.Secondary"
                                       Click="ApplyFilter" />
                        <DxToolbarItem Tooltip="Mostrar/ocultar columnas"
                                       Alignment="ToolbarItemAlignment.Right"
                                       IconCssClass="bi bi-layout-three-columns"
                                       RenderStyle="ButtonRenderStyle.Secondary"
                                       Click="MostrarColumnChooser" />
                    </Items>
                </DxToolbar>
            </ToolbarTemplate>
            <Columns>
                <DxGridDataColumn FieldName="@nameof(NotaEmitidaListDto.TipoNota)" Caption="Tipo" Width="90px"
                                  TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is NotaEmitidaListDto n)
                        {
                            var css = n.TipoNota == "NC" ? "cai-badge--vigente" : "cai-badge--proximo";
                            <span class="cai-badge @css">@n.TipoNota</span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(NotaEmitidaListDto.NumeroDocumento)" Caption="Número" MinWidth="180">
                    <CellDisplayTemplate Context="cell">
                        <span class="fw-bold text-primary">@((cell.DataItem as NotaEmitidaListDto)?.NumeroDocumento)</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(NotaEmitidaListDto.FechaEmision)" Caption="Fecha"
                                  DisplayFormat="{0:dd/MM/yyyy}" Width="110px" />

                <DxGridDataColumn FieldName="@nameof(NotaEmitidaListDto.ClienteNombre)" Caption="Cliente" MinWidth="180" />

                <DxGridDataColumn FieldName="@nameof(NotaEmitidaListDto.FacturaOrigenNumero)" Caption="Factura origen"
                                  MinWidth="160" Visible="false" />

                <DxGridDataColumn FieldName="@nameof(NotaEmitidaListDto.MotivoDescripcion)" Caption="Motivo"
                                  MinWidth="180" Visible="false" />

                <DxGridDataColumn FieldName="@nameof(NotaEmitidaListDto.Monto)" Caption="Monto"
                                  DisplayFormat="C2" Width="120px" TextAlignment="GridTextAlignment.Right" />

                <DxGridDataColumn FieldName="@nameof(NotaEmitidaListDto.TotalNota)" Caption="Total"
                                  DisplayFormat="C2" Width="120px" TextAlignment="GridTextAlignment.Right" Visible="false" />

                <DxGridDataColumn FieldName="@nameof(NotaEmitidaListDto.EstadoDescripcion)" Caption="Estado" Width="110px"
                                  TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is NotaEmitidaListDto n)
                        {
                            <span class="cai-badge @EstadoCss(n.EstadoId)">@EstadoTexto(n.EstadoId)</span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(NotaEmitidaListDto.UsuarioEmisor)" Caption="Usuario" Width="130px" Visible="false" />
            </Columns>
            <EmptyDataAreaTemplate>
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-journal-x fs-1 d-block mb-2"></i>
                    <h5 class="fw-bold text-dark">No hay notas emitidas</h5>
                    <p class="mb-0">Emite la primera nota de crédito o débito con el botón "Emitir nota".</p>
                </div>
            </EmptyDataAreaTemplate>
        </DxGrid>
    </div>
</div>

@* ── Popup emitir NC/ND ── *@
<DxPopup HeaderText="Emitir nota de crédito / débito"
         @bind-Visible="popupVisible"
         Width="min(820px, 96vw)"
         ShowFooter="true"
         CloseOnOutsideClick="false">
    <BodyContentTemplate>
        <DxFormLayout CaptionPosition="CaptionPosition.Vertical">

            @* Cliente *@
            <DxFormLayoutItem Caption="Buscar cliente (clave, nombre o RTN)" ColSpanMd="8">
                <Template Context="t">
                    <div class="d-flex gap-2">
                        <DxTextBox @bind-Text="criterioCliente"
                                   NullText="Escribe y presiona Buscar"
                                   CssClass="flex-grow-1"
                                   @onkeydown="OnCriterioKeyDown" />
                        <DxButton Text="Buscar"
                                  RenderStyle="ButtonRenderStyle.Secondary"
                                  IconCssClass="bi bi-search"
                                  Enabled="@(!buscandoCliente && !string.IsNullOrWhiteSpace(criterioCliente))"
                                  Click="BuscarClientesAsync" />
                    </div>
                </Template>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Cliente" ColSpanMd="4">
                <Template Context="t">
                    <DxComboBox Data="@clientesEncontrados"
                                TextFieldName="@nameof(NotaClienteLookupDto.Nombre)"
                                ValueFieldName="@nameof(NotaClienteLookupDto.Clave)"
                                Value="@clienteClaveSel"
                                ValueChanged="@((string? v) => OnClienteChangeAsync(v))"
                                NullText="Seleccione..."
                                Enabled="@(clientesEncontrados.Count > 0)" />
                </Template>
            </DxFormLayoutItem>

            @* Factura origen *@
            <DxFormLayoutItem Caption="Factura origen" ColSpanMd="12">
                <Template Context="t">
                    <DxComboBox Data="@facturasCliente"
                                TextFieldName="DisplayFactura"
                                ValueFieldName="@nameof(FacturaOrigenLookupDto.FacturaId)"
                                Value="@facturaOrigenSel"
                                ValueChanged="@((int? v) => OnFacturaChange(v))"
                                NullText="@(facturasCliente.Count == 0 ? "Seleccione un cliente primero" : "Seleccione la factura a ajustar")"
                                Enabled="@(facturasCliente.Count > 0)" />
                </Template>
            </DxFormLayoutItem>

            @* Tipo de nota *@
            <DxFormLayoutItem Caption="Tipo de nota" ColSpanMd="4">
                <Template Context="t">
                    <DxComboBox Data="@tiposNota"
                                TextFieldName="Texto"
                                ValueFieldName="Valor"
                                Value="@tipoNotaSel"
                                ValueChanged="@((string v) => OnTipoNotaChangeAsync(v))" />
                </Template>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Motivo" ColSpanMd="8">
                <Template Context="t">
                    <DxComboBox Data="@motivos"
                                TextFieldName="@nameof(MotivoLookupDto.Descripcion)"
                                ValueFieldName="@nameof(MotivoLookupDto.Id)"
                                @bind-Value="motivoSel"
                                NullText="Seleccione un motivo" />
                </Template>
            </DxFormLayoutItem>

            @* CAI *@
            <DxFormLayoutItem Caption="@($"CAI ({(tipoNotaSel == "NC" ? "tipo Nota de Crédito" : "tipo Nota de Débito")})")" ColSpanMd="8">
                <Template Context="t">
                    <DxComboBox Data="@cais"
                                TextFieldName="CodigoCai"
                                ValueFieldName="@nameof(CaiNotaLookupDto.CaiId)"
                                @bind-Value="caiSel"
                                NullText="@(cais.Count == 0 ? "No hay CAI vigente de este tipo" : "Seleccione el CAI")" />
                </Template>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Monto" ColSpanMd="4">
                <Template Context="t">
                    <DxSpinEdit @bind-Value="monto"
                                Decimals="2"
                                MinValue="0"
                                Increment="50" />
                    @if (tipoNotaSel == "NC")
                    {
                        <small class="text-muted d-block mt-1">0 = anular el total de la factura</small>
                    }
                </Template>
            </DxFormLayoutItem>

            @* Detalle *@
            <DxFormLayoutItem Caption="Detalle / observación" ColSpanMd="12">
                <Template Context="t">
                    <DxMemo @bind-Text="motivoDetalle" Rows="2" NullText="Observación adicional (opcional)" />
                </Template>
            </DxFormLayoutItem>

            @if (facturaOrigenInfo is not null)
            {
                <DxFormLayoutItem Caption="" ColSpanMd="12">
                    <Template Context="t">
                        <div class="notas-info-banner">
                            <i class="bi bi-info-circle me-1"></i>
                            Factura <strong>@facturaOrigenInfo.NumeroFactura</strong> ·
                            Periodo @facturaOrigenInfo.Periodo ·
                            Saldo <strong>L. @facturaOrigenInfo.SaldoTotal.ToString("N2")</strong> ·
                            Estado @facturaOrigenInfo.Estado
                        </div>
                    </Template>
                </DxFormLayoutItem>
            }
        </DxFormLayout>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <div class="d-flex gap-2 justify-content-end w-100">
            <DxButton Text="Cancelar"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      Click="@(() => popupVisible = false)" />
            <DxButton Text="Emitir"
                      RenderStyle="ButtonRenderStyle.Primary"
                      Enabled="@(PuedeEmitir && !isSaving)"
                      Click="EmitirAsync" />
        </div>
    </FooterContentTemplate>
</DxPopup>

@code {
    private DxGrid? notasGrid;
    private NotasEmitidasGridDataSource? dataSource;
    private string? searchText;
    private string? tipoFiltro;
    private bool isSaving;
    private string usuarioActual = "system";

    // Popup emisión
    private bool popupVisible;
    private string? criterioCliente;
    private bool buscandoCliente;
    private List<NotaClienteLookupDto> clientesEncontrados = new();
    private string? clienteClaveSel;
    private List<FacturaOrigenViewModel> facturasCliente = new();
    private int? facturaOrigenSel;
    private FacturaOrigenLookupDto? facturaOrigenInfo;
    private string tipoNotaSel = "NC";
    private List<MotivoLookupDto> motivos = new();
    private short? motivoSel;
    private List<CaiNotaLookupDto> cais = new();
    private long? caiSel;
    private decimal monto;
    private string? motivoDetalle;

    private readonly List<TipoNotaOption> tiposNota = new()
    {
        new() { Valor = "NC", Texto = "Nota de crédito" },
        new() { Valor = "ND", Texto = "Nota de débito" }
    };

    private bool PuedeEmitir =>
        facturaOrigenSel.HasValue &&
        motivoSel.HasValue &&
        caiSel.HasValue &&
        (tipoNotaSel == "NC" || monto > 0);

    protected override async Task OnInitializedAsync()
    {
        dataSource = new NotasEmitidasGridDataSource(Client, () => InvokeAsync(StateHasChanged));
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        usuarioActual = authState.User.Identity?.Name ?? "system";
    }

    private async Task ReloadAsync()
    {
        dataSource?.Invalidate();
        notasGrid?.Reload();
        await Task.CompletedTask;
    }

    private void ApplyFilter()
    {
        if (dataSource is null) return;
        dataSource.SearchText = searchText;
        dataSource.TipoNota = tipoFiltro;
        dataSource.Invalidate();
        notasGrid?.Reload();
    }

    private async Task OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") ApplyFilter();
        await Task.CompletedTask;
    }

    private void SetTipoFiltro(string? tipo)
    {
        tipoFiltro = tipo;
        ApplyFilter();
    }

    private void MostrarColumnChooser() => notasGrid?.ShowColumnChooser();

    // ── Popup emisión ──
    private void AbrirEmitir()
    {
        criterioCliente = null;
        clientesEncontrados.Clear();
        clienteClaveSel = null;
        facturasCliente.Clear();
        facturaOrigenSel = null;
        facturaOrigenInfo = null;
        tipoNotaSel = "NC";
        motivos.Clear();
        motivoSel = null;
        cais.Clear();
        caiSel = null;
        monto = 0;
        motivoDetalle = null;
        popupVisible = true;
        _ = CargarMotivosYCaisAsync();
    }

    private async Task OnCriterioKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await BuscarClientesAsync();
    }

    private async Task BuscarClientesAsync()
    {
        if (string.IsNullOrWhiteSpace(criterioCliente)) return;
        buscandoCliente = true;
        try
        {
            clientesEncontrados = (await Client.BuscarClientesAsync(criterioCliente)).ToList();
            if (clientesEncontrados.Count == 0)
            {
                ShowToast("Sin resultados", "No se encontraron clientes con ese criterio.", ToastRenderStyle.Info);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error", ex.Message, ToastRenderStyle.Danger);
        }
        finally
        {
            buscandoCliente = false;
        }
    }

    private async Task OnClienteChangeAsync(string? clave)
    {
        clienteClaveSel = clave;
        facturasCliente.Clear();
        facturaOrigenSel = null;
        facturaOrigenInfo = null;
        if (string.IsNullOrWhiteSpace(clave)) return;

        try
        {
            var facturas = await Client.BuscarFacturasClienteAsync(clave);
            facturasCliente = facturas.Select(f => new FacturaOrigenViewModel(f)).ToList();
        }
        catch (Exception ex)
        {
            ShowToast("Error", ex.Message, ToastRenderStyle.Danger);
        }
    }

    private void OnFacturaChange(int? facturaId)
    {
        facturaOrigenSel = facturaId;
        facturaOrigenInfo = facturasCliente.FirstOrDefault(f => f.FacturaId == facturaId)?.Source;
    }

    private async Task OnTipoNotaChangeAsync(string tipo)
    {
        tipoNotaSel = tipo;
        motivoSel = null;
        caiSel = null;
        await CargarMotivosYCaisAsync();
    }

    private async Task CargarMotivosYCaisAsync()
    {
        try
        {
            if (tipoNotaSel == "NC")
            {
                var motivosTask = Client.ListarMotivosAnulacionAsync();
                var caisTask = Client.ListarCaisNotaAsync(6);
                await Task.WhenAll(motivosTask, caisTask);
                motivos = motivosTask.Result.ToList();
                cais = caisTask.Result.ToList();
            }
            else
            {
                var motivosTask = Client.ListarMotivosAumentoAsync();
                var caisTask = Client.ListarCaisNotaAsync(7);
                await Task.WhenAll(motivosTask, caisTask);
                motivos = motivosTask.Result.ToList();
                cais = caisTask.Result.ToList();
            }
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ShowToast("Error", $"No se pudieron cargar catálogos: {ex.Message}", ToastRenderStyle.Danger);
        }
    }

    private async Task EmitirAsync()
    {
        if (!PuedeEmitir) return;
        isSaving = true;
        try
        {
            EmitirNotaResponseDto resp;
            if (tipoNotaSel == "NC")
            {
                resp = await Client.EmitirNotaCreditoAsync(new EmitirNotaCreditoRequestDto
                {
                    FacturaOrigenId = facturaOrigenSel!.Value,
                    MotivoAnulacionId = motivoSel!.Value,
                    MotivoDetalle = motivoDetalle,
                    MontoDisminuir = monto > 0 ? monto : null,
                    CaiId = caiSel!.Value,
                    Usuario = usuarioActual
                });
            }
            else
            {
                resp = await Client.EmitirNotaDebitoAsync(new EmitirNotaDebitoRequestDto
                {
                    FacturaOrigenId = facturaOrigenSel!.Value,
                    MotivoAumentoId = motivoSel!.Value,
                    MotivoDetalle = motivoDetalle,
                    MontoAumentar = monto,
                    CaiId = caiSel!.Value,
                    Usuario = usuarioActual
                });
            }

            if (resp.Success)
            {
                popupVisible = false;
                ShowToast("Éxito", $"{resp.Mensaje} N° {resp.NumeroDocumento}", ToastRenderStyle.Success);
                await ReloadAsync();
            }
            else
            {
                ShowToast("No se pudo emitir", resp.Mensaje, ToastRenderStyle.Warning);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error", ex.Message, ToastRenderStyle.Danger);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ShowToast(string title, string message, ToastRenderStyle style) =>
        ToastService.ShowToast(new ToastOptions
        {
            ProviderName = "NotasToast",
            Title = title,
            Text = message,
            RenderStyle = style
        });

    // cfg_estado_documento_fiscal: 1=EMITIDA 2=APLICADA 3=ANULADA 4=PENDIENTE
    private static string EstadoCss(short estadoId) => estadoId switch
    {
        1 => "cai-badge--vigente",
        2 => "cai-badge--disponible",
        3 => "cai-badge--vencido",
        4 => "cai-badge--proximo",
        _ => "cai-badge--inactivo"
    };

    private static string EstadoTexto(short estadoId) => estadoId switch
    {
        1 => "Emitido",
        2 => "Aplicado",
        3 => "Anulado",
        4 => "Pendiente",
        _ => "—"
    };

    private sealed class TipoNotaOption
    {
        public string Valor { get; set; } = string.Empty;
        public string Texto { get; set; } = string.Empty;
    }

    private sealed class FacturaOrigenViewModel
    {
        public FacturaOrigenViewModel(FacturaOrigenLookupDto source)
        {
            Source = source;
        }

        public FacturaOrigenLookupDto Source { get; }
        public int FacturaId => Source.FacturaId;
        public string DisplayFactura =>
            $"{Source.NumeroFactura} · {Source.Periodo} · L. {Source.SaldoTotal:N2} · {Source.Estado}";
    }
}
