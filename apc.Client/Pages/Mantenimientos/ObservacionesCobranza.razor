@page "/mantenimientos/observaciones-cobranza"
@attribute [Authorize]
@using DevExpress.Blazor
@using SIAD.Core.DTOs.Cobranza
@using apc.Client.Services.Facturacion

@inject CobranzaClient Client
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Observaciones de Cobranza</PageTitle>

<DxToastProvider Name="ObservacionesToast" MaxToastCount="4" />

<div class="page-container">
    <div class="header-section mb-3">
        <div>
            <h2 class="page-title">Observaciones de cobranza</h2>
            <p class="page-subtitle">Catálogo de resultados/observaciones para las acciones de cobranza.</p>
        </div>
        <div class="header-actions">
            <DxButton Text="Actualizar"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      IconCssClass="bi bi-arrow-clockwise"
                      Click="CargarAsync"
                      Enabled="@(!isSaving)" />
            <DxButton Text="Nueva observación"
                      RenderStyle="ButtonRenderStyle.Primary"
                      IconCssClass="bi bi-plus-lg"
                      Click="AbrirNuevo" />
        </div>
    </div>

    @if (isLoading)
    {
        <DxLoadingPanel Visible="true" Text="Cargando..." />
        <div style="height:60px"></div>
    }
    else
    {
        <div class="modern-card">
            <DxGrid Data="@items"
                    KeyFieldName="@nameof(ObservacionCobranzaCrudDto.Id)"
                    ShowFilterRow="true"
                    PageSize="20"
                    SizeMode="SizeMode.Small"
                    CssClass="border-0">
                <Columns>
                    <DxGridDataColumn FieldName="@nameof(ObservacionCobranzaCrudDto.Id)" Caption="ID" Width="70px"
                                      TextAlignment="GridTextAlignment.Center" />
                    <DxGridDataColumn FieldName="@nameof(ObservacionCobranzaCrudDto.Observacion)" Caption="Observación" MinWidth="200" />
                    <DxGridDataColumn FieldName="@nameof(ObservacionCobranzaCrudDto.Activo)" Caption="Estado" Width="110px"
                                      TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is ObservacionCobranzaCrudDto o)
                            {
                                <span class="cai-badge @(o.Activo ? "cai-badge--vigente" : "cai-badge--inactivo")">
                                    @(o.Activo ? "Activo" : "Inactivo")
                                </span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn Caption="" Width="80px">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is ObservacionCobranzaCrudDto o)
                            {
                                <DxButton RenderStyle="ButtonRenderStyle.Info"
                                          RenderStyleMode="ButtonRenderStyleMode.Text"
                                          SizeMode="SizeMode.Small"
                                          IconCssClass="bi bi-pencil-square fs-5"
                                          Tooltip="Editar"
                                          Click="@(() => AbrirEditar(o))" />
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>
                <EmptyDataAreaTemplate>
                    <div class="text-center p-5 text-muted">
                        <i class="bi bi-chat-square-text fs-1 d-block mb-2"></i>
                        <h5 class="fw-bold text-dark">No hay observaciones registradas</h5>
                    </div>
                </EmptyDataAreaTemplate>
            </DxGrid>
        </div>
    }
</div>

<DxPopup HeaderText="@popupHeader"
         @bind-Visible="popupVisible"
         Width="min(480px, 96vw)"
         ShowFooter="true"
         CloseOnOutsideClick="false">
    <BodyTemplate>
        <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
            <DxFormLayoutItem Caption="Observación" ColSpanMd="12" Context="fi_observacion">
                <DxTextBox @bind-Text="formObservacion"
                           NullText="Texto de la observación"
                           MaxLength="50" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Estado" ColSpanMd="12" Context="fi_activo">
                <DxCheckBox @bind-Checked="formActivo">Activo</DxCheckBox>
            </DxFormLayoutItem>
        </DxFormLayout>
    </BodyTemplate>
    <FooterTemplate>
        <div class="d-flex gap-2 justify-content-end w-100">
            <DxButton Text="Cancelar"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      Click="@(() => popupVisible = false)" />
            <DxButton Text="Guardar"
                      RenderStyle="ButtonRenderStyle.Primary"
                      Enabled="@(PuedeGuardar && !isSaving)"
                      Click="GuardarAsync" />
        </div>
    </FooterTemplate>
</DxPopup>

@code {
    private List<ObservacionCobranzaCrudDto> items = [];
    private bool isLoading = true;
    private bool isSaving;
    private bool popupVisible;
    private string popupHeader = "Nueva observación";

    // Form fields
    private int? formId;
    private string formObservacion = string.Empty;
    private bool formActivo = true;

    private bool PuedeGuardar => !string.IsNullOrWhiteSpace(formObservacion);

    protected override async Task OnInitializedAsync() => await CargarAsync();

    private async Task CargarAsync()
    {
        isLoading = true;
        try
        {
            items = ((await Client.ListarObservacionesCrudAsync()) ?? []).ToList();
        }
        catch (Exception ex)
        {
            ShowToast("Error", $"No se pudieron cargar las observaciones: {ex.Message}", ToastRenderStyle.Danger);
        }
        finally { isLoading = false; }
    }

    private void AbrirNuevo()
    {
        popupHeader = "Nueva observación de cobranza";
        formId = null;
        formObservacion = string.Empty;
        formActivo = true;
        popupVisible = true;
    }

    private void AbrirEditar(ObservacionCobranzaCrudDto o)
    {
        popupHeader = $"Editar observación — {o.Observacion}";
        formId = o.Id;
        formObservacion = o.Observacion;
        formActivo = o.Activo;
        popupVisible = true;
    }

    private async Task GuardarAsync()
    {
        if (!PuedeGuardar) return;
        isSaving = true;
        try
        {
            await Client.GuardarObservacionCrudAsync(new ObservacionCobranzaSaveDto(formId, formObservacion, formActivo));
            popupVisible = false;
            ShowToast("Éxito", "Observación guardada correctamente.", ToastRenderStyle.Success);
            await CargarAsync();
        }
        catch (Exception ex)
        {
            ShowToast("Error", ex.Message, ToastRenderStyle.Danger);
        }
        finally { isSaving = false; }
    }

    private void ShowToast(string title, string message, ToastRenderStyle style) =>
        ToastService.ShowToast(new ToastOptions
        {
            ProviderName = "ObservacionesToast",
            Title = title,
            Text = message,
            RenderStyle = style
        });
}
