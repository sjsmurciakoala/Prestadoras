@page "/mantenimientos/clases-medidor"
@attribute [Authorize]
@using SIAD.Core.DTOs.Catalogos
@using apc.Client.Services.Catalogos
@using DevExpress.Blazor
@inject CatalogosClient CatalogosClient
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Clases de Medidor</PageTitle>

<div class="page-container">
    <div class="header-section mb-3">
        <div>
            <h2 class="page-title">Clases de medidor</h2>
            <p class="page-subtitle">Clasificación metrológica ISO 4064 (A, B, C, D)</p>
        </div>
        <div class="header-actions">
            <DxButton Text="Nueva clase"
                      IconCssClass="bi bi-plus-circle"
                      RenderStyle="ButtonRenderStyle.Primary"
                      Click="AbrirFormNuevo" />
        </div>
    </div>

    <div class="modern-card">
        @if (isLoading)
        {
            <DxLoadingPanel Visible="true" Text="Cargando clases..." />
            <div style="height:60px"></div>
        }
        else
        {
            <DxGrid Data="clases" ShowFilterRow="true" PageSize="20">
                <Columns>
                    <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="80px" />
                    <DxGridDataColumn FieldName="Descripcion" Caption="Descripción" />
                    <DxGridDataColumn FieldName="Estado" Caption="Activo" Width="80px"
                                      TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @{
                                var c = (ClaseMedidorDto)cell.DataItem;
                            }
                            @if (c.Estado)
                            {
                                <span class="badge bg-success">Sí</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">No</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn Caption="" Width="90px">
                        <CellDisplayTemplate Context="cell">
                            @{
                                var c = (ClaseMedidorDto)cell.DataItem;
                            }
                            <div class="d-flex gap-1">
                                <DxButton IconCssClass="bi bi-pencil"
                                          title="Editar"
                                          RenderStyle="ButtonRenderStyle.Secondary"
                                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                                          Click="@(_ => AbrirFormEditar(c))" />
                                <DxButton IconCssClass="bi bi-trash"
                                          title="Eliminar"
                                          RenderStyle="ButtonRenderStyle.Danger"
                                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                                          Click="@(_ => ConfirmarEliminar(c))" />
                            </div>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>
            </DxGrid>
        }
    </div>
</div>

<!-- Popup crear/editar -->
<DxPopup @bind-Visible="mostrarForm"
         HeaderText="@(editando ? $"Editar clase {formCodigo}" : "Nueva clase de medidor")"
         Width="min(500px, 95vw)"
         ShowFooter="true"
         CloseOnOutsideClick="false">
    <BodyTemplate>
        <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
            @if (!editando)
            {
                <DxFormLayoutItem Caption="Código (1 letra)" ColSpanXs="12" Context="fc1">
                    <DxTextBox @bind-Text="formCodigo" CssClass="w-100"
                               Placeholder="Ej: A" MaxLength="1" />
                </DxFormLayoutItem>
            }
            <DxFormLayoutItem Caption="Descripción" ColSpanXs="12" Context="fc2">
                <DxTextBox @bind-Text="formDescripcion" CssClass="w-100" MaxLength="200" />
            </DxFormLayoutItem>
            @if (editando)
            {
                <DxFormLayoutItem Caption="Activo" ColSpanXs="12" Context="fc3">
                    <DxCheckBox @bind-Checked="formEstado" />
                </DxFormLayoutItem>
            }
        </DxFormLayout>
    </BodyTemplate>
    <FooterTemplate>
        <div class="d-flex gap-2 justify-content-end">
            <DxButton Text="Cancelar" RenderStyle="ButtonRenderStyle.Secondary"
                      Click="() => mostrarForm = false" />
            <DxButton Text="Guardar" RenderStyle="ButtonRenderStyle.Primary"
                      Click="GuardarAsync" Enabled="@(!isSaving)" />
        </div>
    </FooterTemplate>
</DxPopup>

<!-- Popup confirmar eliminar -->
<DxPopup @bind-Visible="mostrarConfirmEliminar"
         HeaderText="Confirmar eliminación"
         Width="min(400px, 95vw)"
         ShowFooter="true"
         CloseOnOutsideClick="false">
    <BodyTemplate>
        <p>¿Eliminar la clase <strong>@claseAEliminar?.Codigo — @claseAEliminar?.Descripcion</strong>?</p>
        <p class="text-muted small">No se puede eliminar si tiene medidores asociados.</p>
    </BodyTemplate>
    <FooterTemplate>
        <div class="d-flex gap-2 justify-content-end">
            <DxButton Text="Cancelar" RenderStyle="ButtonRenderStyle.Secondary"
                      Click="() => mostrarConfirmEliminar = false" />
            <DxButton Text="Eliminar" RenderStyle="ButtonRenderStyle.Danger"
                      Click="EjecutarEliminarAsync" Enabled="@(!isSaving)" />
        </div>
    </FooterTemplate>
</DxPopup>

@code {
    private List<ClaseMedidorDto> clases = [];
    private bool isLoading = true;

    private bool mostrarForm = false;
    private bool editando = false;
    private string formCodigo = string.Empty;
    private string formDescripcion = string.Empty;
    private bool formEstado = true;
    private bool isSaving = false;

    private bool mostrarConfirmEliminar = false;
    private ClaseMedidorDto? claseAEliminar;

    protected override async Task OnInitializedAsync() => await CargarAsync();

    private async Task CargarAsync()
    {
        isLoading = true;
        try
        {
            clases = ((await CatalogosClient.GetClasesMedidorCrudAsync()) ?? []).ToList();
        }
        catch (Exception ex) { ToastService.ShowToast(new ToastOptions { Title = "Clases de medidor", Text = $"Error al cargar: {ex.Message}", RenderStyle = ToastRenderStyle.Danger }); }
        finally { isLoading = false; }
    }

    private void AbrirFormNuevo()
    {
        editando = false;
        formCodigo = string.Empty;
        formDescripcion = string.Empty;
        formEstado = true;
        mostrarForm = true;
    }

    private void AbrirFormEditar(ClaseMedidorDto c)
    {
        editando = true;
        formCodigo = c.Codigo;
        formDescripcion = c.Descripcion;
        formEstado = c.Estado;
        mostrarForm = true;
    }

    private async Task GuardarAsync()
    {
        if (string.IsNullOrWhiteSpace(formDescripcion))
        {
            ToastService.ShowToast(new ToastOptions { Title = "Clases de medidor", Text = "La descripción es obligatoria.", RenderStyle = ToastRenderStyle.Danger });
            return;
        }
        if (!editando && string.IsNullOrWhiteSpace(formCodigo))
        {
            ToastService.ShowToast(new ToastOptions { Title = "Clases de medidor", Text = "El código es obligatorio.", RenderStyle = ToastRenderStyle.Danger });
            return;
        }

        isSaving = true;
        try
        {
            if (editando)
                await CatalogosClient.ActualizarClaseMedidorAsync(formCodigo, new ClaseMedidorUpdateDto(formDescripcion, formEstado));
            else
                await CatalogosClient.CrearClaseMedidorAsync(new ClaseMedidorCreateDto(formCodigo, formDescripcion));

            mostrarForm = false;
            ToastService.ShowToast(new ToastOptions { Title = "Clases de medidor", Text = editando ? "Clase actualizada correctamente." : "Clase creada correctamente.", RenderStyle = ToastRenderStyle.Success });
            await CargarAsync();
        }
        catch (Exception ex) { ToastService.ShowToast(new ToastOptions { Title = "Clases de medidor", Text = $"Error: {ex.Message}", RenderStyle = ToastRenderStyle.Danger }); }
        finally { isSaving = false; }
    }

    private void ConfirmarEliminar(ClaseMedidorDto c)
    {
        claseAEliminar = c;
        mostrarConfirmEliminar = true;
    }

    private async Task EjecutarEliminarAsync()
    {
        if (claseAEliminar is null) return;
        isSaving = true;
        try
        {
            var ok = await CatalogosClient.EliminarClaseMedidorAsync(claseAEliminar.Codigo);
            if (ok)
            {
                mostrarConfirmEliminar = false;
                ToastService.ShowToast(new ToastOptions { Title = "Clases de medidor", Text = $"Clase {claseAEliminar.Codigo} eliminada.", RenderStyle = ToastRenderStyle.Success });
                await CargarAsync();
            }
            else
            {
                ToastService.ShowToast(new ToastOptions { Title = "Clases de medidor", Text = "No se pudo eliminar la clase.", RenderStyle = ToastRenderStyle.Danger });
            }
        }
        catch (Exception ex) { ToastService.ShowToast(new ToastOptions { Title = "Clases de medidor", Text = $"Error: {ex.Message}", RenderStyle = ToastRenderStyle.Danger }); }
        finally { isSaving = false; }
    }
}
