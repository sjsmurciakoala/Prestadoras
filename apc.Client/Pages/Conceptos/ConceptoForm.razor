@using DevExpress.Blazor
@using SIAD.Core.DTOs.Conceptos

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" Context="editContext">
    <DataAnnotationsValidator />

    @if (editContext.GetValidationMessages().Any())
    {
        <div class="alert alert-danger mb-3 shadow-sm">
            <h6 class="alert-heading"><i class="bi bi-exclamation-circle-fill me-2"></i>Atencion</h6>
            <DxValidationSummary />
        </div>
    }

    <DxFormLayout>
        <DxFormLayoutItem Caption="Depto *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Depto"
                       NullText="Depto"
                       MaxLength="2" />
            <ValidationMessage For="() => Model.Depto" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Tipo *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Tipo"
                       NullText="Tipo"
                       MaxLength="2" />
            <ValidationMessage For="() => Model.Tipo" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Descripcion *" ColSpanMd="12">
            <DxTextBox @bind-Text="Model.Descripcion"
                       NullText="Descripcion del concepto"
                       MaxLength="80" />
            <ValidationMessage For="() => Model.Descripcion" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Concepto *" ColSpanMd="12">
            <DxTextBox @bind-Text="Model.Concepto"
                       NullText="Concepto"
                       MaxLength="200" />
            <ValidationMessage For="() => Model.Concepto" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Depto AppMiTrabajo *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.DeptoAppMiTrabajo"
                       NullText="Depto app mi trabajo"
                       MaxLength="2" />
            <ValidationMessage For="() => Model.DeptoAppMiTrabajo" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Estado" ColSpanMd="6">
            <Template>
                <div class="pt-2">
                    <DxCheckBox @bind-Checked="Model.Activo"
                                CheckType="CheckType.Switch"
                                LabelText="Activo" />
                </div>
            </Template>
        </DxFormLayoutItem>
    </DxFormLayout>

    <ValidationSummary class="text-danger mb-3" />

    <div class="d-flex justify-content-end gap-2">
        <DxButton ButtonType="ButtonType.Submit"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  SubmitFormOnClick="true"
                  Enabled="@(!IsBusy)" />
        <DxButton ButtonType="ButtonType.Normal"
                  Text="Cancelar"
                  Enabled="@(!IsBusy)"
                  Click="Cancel" />
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public ConceptoEditDto Model { get; set; } = default!;

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private async Task HandleValidSubmit()
    {
        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }
}
