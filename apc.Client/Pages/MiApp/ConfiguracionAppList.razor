@page "/mi-app/configuracion"
@attribute [Authorize]

@using DevExpress.Blazor
@using SIAD.Core.DTOs.AppLectores
@using apc.Client.Pages.MiApp
@using apc.Client.Services.AppLectores

@inject ConfiguracionAppClient ConfiguracionClient
@inject IToastNotificationService ToastService

<div class="page-container">
    <DxToastProvider Name="ConfigAppToast" MaxToastCount="4" />

    <div class="header-section">
        <div>
            <h2 class="page-title">Configuraciones App Lectores</h2>
            <p class="page-subtitle">Parametros usados por la app movil</p>
        </div>

        <DxButton Text="Nueva configuracion"
                  IconCssClass="bi bi-plus-lg"
                  RenderStyle="ButtonRenderStyle.Primary"
                  CssClass="btn-modern"
                  Click="AbrirNuevo" />
    </div>

    @if (mostrarFiltros)
    {
        <div class="modern-card mb-4">
            <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                <DxFormLayoutGroup Caption="Filtros" HeaderIconCssClass="bi bi-funnel" ColSpanXs="12">
                    <DxFormLayoutItem Caption="Busqueda" ColSpanXs="12" ColSpanMd="6">
                        <Template>
                            <DxTextBox Text="@filtroBusqueda"
                                       TextChanged="@((string v) => OnBusquedaChanged(v))"
                                       Placeholder="ID, descripcion o valor en letras..."
                                       ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                       InputDelay="600" />
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanXs="12" ColSpanMd="6" CssClass="align-self-end">
                        <Template>
                            <div class="filters-actions">
                                <DxButton Text="Filtrar"
                                          IconCssClass="bi bi-search"
                                          CssClass="filters-btn filters-btn-primary"
                                          RenderStyle="ButtonRenderStyle.Secondary"
                                          Click="BuscarAsync" />

                                <button type="button" class="filters-link" @onclick="LimpiarFiltrosAsync">
                                    Limpiar
                                </button>
                            </div>
                        </Template>
                    </DxFormLayoutItem>
                </DxFormLayoutGroup>
            </DxFormLayout>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <DxAlert AlertType="AlertType.Danger" CssClass="mb-3">@errorMessage</DxAlert>
    }

    <div class="modern-card position-relative">
        <div class="grid-wrapper">
            <DxGrid @ref="grid" Data="@dataSource" KeyFieldName="@nameof(ConfiguracionAppListItemDto.Id)" PageSize="15"
                    PagerPosition="GridPagerPosition.Bottom" ShowFilterRow="false" ShowSearchBox="false"
                    ColumnResizeMode="GridColumnResizeMode.ColumnsContainer" FocusedRowEnabled="false"
                    ShowGroupPanel="false" CssClass="grid-solicitudes">

                <ToolbarTemplate>
                    <div class="d-flex flex-wrap gap-2 align-items-center w-100">
                        <DxTextBox Text="@filtroBusqueda" TextChanged="@((string v) => OnBusquedaChanged(v))"                                   TextExpression="@(() => filtroBusqueda)"                                   Placeholder="Buscar configuracion..." InputDelay="600"
                                   ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" CssClass="me-1"
                                   Style="min-width: 260px;" />

                        <DxButton Text="Recargar" IconCssClass="bi bi-arrow-clockwise"
                                  RenderStyle="ButtonRenderStyle.Secondary" Click="RecargarGrid" CssClass="me-1" />

                        <DxButton Text="Filtros" IconCssClass="bi bi-funnel" RenderStyle="ButtonRenderStyle.Secondary"
                                  Click="ToggleFiltros" CssClass="me-1" />

                        <DxButton Text="Columnas" IconCssClass="bi bi-layout-three-columns"
                                  RenderStyle="ButtonRenderStyle.Secondary" Click="MostrarColumnChooser" CssClass="me-1" />

                        <div class="ms-auto text-muted small">
                            Total: <span class="fw-bold">@totalConfiguraciones.ToString("N0")</span>
                        </div>
                    </div>
                </ToolbarTemplate>

                <Columns>
                    <DxGridDataColumn FieldName="@nameof(ConfiguracionAppListItemDto.Id)" Caption="ID" Width="100px" />

                    <DxGridDataColumn FieldName="@nameof(ConfiguracionAppListItemDto.Descripcion)" Caption="Descripcion" MinWidth="260">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is ConfiguracionAppListItemDto item)
                            {
                                <div class="text-truncate" title="@item.Descripcion">@item.Descripcion</div>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="@nameof(ConfiguracionAppListItemDto.ValorNumeros)" Caption="Valor numerico" Width="160px" DisplayFormat="N2" />

                    <DxGridDataColumn FieldName="@nameof(ConfiguracionAppListItemDto.ValorLetras)" Caption="Valor letras" MinWidth="200">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is ConfiguracionAppListItemDto item)
                            {
                                <div class="text-truncate" title="@item.ValorLetras">@item.ValorLetras</div>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn Caption="Acciones" Width="160px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is ConfiguracionAppListItemDto item)
                            {
                                var protegido = EsProtegida(item.Id);
                                <div class="d-flex justify-content-center gap-2 flex-wrap">
                                    <button type="button" class="btn-icon btn-edit" title="Editar"
                                            @onclick="() => AbrirEditarAsync(item.Id)" @onclick:stopPropagation="true">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    <button type="button" class="btn-icon btn-delete" title="Eliminar"
                                            disabled="@protegido"
                                            @onclick="() => ConfirmarEliminar(item)" @onclick:stopPropagation="true">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>

                <EmptyDataAreaTemplate>
                    <div class="p-4 text-center text-muted">No hay configuraciones para mostrar.</div>
                </EmptyDataAreaTemplate>
            </DxGrid>
        </div>
    </div>
</div>

<DxPopup @bind-Visible="formVisible"
         Width="min(720px, 95vw)"
         Height="auto"
         MaxHeight="90vh"
         Scrollable="true"
         CssClass="custom-popup"
         CloseOnOutsideClick="false">
    <HeaderContentTemplate>
        <div class="d-flex align-items-center gap-2">
            <div class="@PopupIconWrapperClass" style="width: 38px; height: 38px;">
                <i class="@PopupIcon"></i>
            </div>
            <div>
                <div class="fw-bold fs-6 text-dark" style="line-height:1.1;">@PopupTitle</div>
                <div class="small text-muted" style="font-weight: normal; font-size: 0.8rem;">@PopupSubtitle</div>
            </div>
        </div>
    </HeaderContentTemplate>

    <BodyContentTemplate>
        @if (formLoading)
        {
            <div class="text-center p-4">
                <DxLoadingPanel Visible="true" Text="Cargando configuracion..." />
                <div style="height:80px"></div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(formError))
        {
            <div class="p-3">
                <DxAlert AlertType="AlertType.Danger">@formError</DxAlert>
            </div>
        }
        else
        {
            <ConfiguracionAppForm Model="formModel"
                                  OnValidSubmit="GuardarAsync"
                                  OnCancel="CerrarForm"
                                  IsBusy="isSaving" />
        }
    </BodyContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="confirmVisible" Width="min(420px, 90vw)" HeaderText="Confirmar accion" ShowFooter="false">
    <BodyTemplate>
        <div class="text-center p-4">
            <div class="mb-3 text-warning"><i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i></div>
            <h5 class="fw-bold">Eliminar configuracion?</h5>
            <p class="text-muted">Esta accion eliminara el registro de forma permanente.</p>
            @if (configuracionParaEliminar is not null)
            {
                <div class="fw-semibold">@configuracionParaEliminar.Descripcion</div>
            }
            <div class="d-flex justify-content-center gap-3 mt-4">
                <DxButton Text="Cancelar"
                          Click="CancelarEliminar"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          RenderStyleMode="ButtonRenderStyleMode.Outline" />
                <DxButton Text="Si, eliminar"
                          Click="EliminarConfirmadoAsync"
                          RenderStyle="ButtonRenderStyle.Danger"
                          IconCssClass="bi bi-trash" />
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    private DxGrid? grid;
    private ConfiguracionAppGridDataSource dataSource = default!;

    private string filtroBusqueda = string.Empty;
    private bool mostrarFiltros = true;

    private string? errorMessage;
    private int totalConfiguraciones;

    private bool formVisible;
    private bool formLoading;
    private bool isSaving;
    private string? formError;
    private ConfiguracionAppEditDto formModel = new();

    private bool confirmVisible;
    private ConfiguracionAppListItemDto? configuracionParaEliminar;

    private string PopupTitle => formModel.Id.HasValue ? "Editar configuracion" : "Nueva configuracion";
    private string PopupSubtitle => formModel.Id.HasValue
        ? "Actualice los parametros de la app"
        : "Complete el formulario de registro";
    private string PopupIcon => formModel.Id.HasValue ? "bi bi-pencil-square" : "bi bi-sliders";
    private string PopupIconWrapperClass => formModel.Id.HasValue
        ? "bg-warning bg-opacity-10 text-warning p-2 rounded-circle d-flex justify-content-center align-items-center"
        : "bg-primary bg-opacity-10 text-primary p-2 rounded-circle d-flex justify-content-center align-items-center";

    protected override void OnInitialized()
    {
        dataSource = new ConfiguracionAppGridDataSource(ConfiguracionClient, OnGridStateChanged);
        ApplyFilters();
    }

    private void OnGridStateChanged()
    {
        errorMessage = dataSource.LastError;
        totalConfiguraciones = dataSource.LastTotalCount;
        InvokeAsync(StateHasChanged);
    }

    private void ApplyFilters()
    {
        dataSource.SearchText = filtroBusqueda;
    }

    private async Task OnBusquedaChanged(string valor)
    {
        filtroBusqueda = valor;
        await BuscarAsync();
    }

    private Task BuscarAsync()
    {
        ApplyFilters();
        dataSource.Invalidate();
        grid?.Reload();
        return Task.CompletedTask;
    }

    private async Task LimpiarFiltrosAsync()
    {
        filtroBusqueda = string.Empty;
        await BuscarAsync();
    }

    private void RecargarGrid()
    {
        dataSource.Invalidate();
        grid?.Reload();
    }

    private void ToggleFiltros() => mostrarFiltros = !mostrarFiltros;
    private void MostrarColumnChooser() => grid?.ShowColumnChooser();

    private void AbrirNuevo()
    {
        formError = null;
        formModel = new ConfiguracionAppEditDto();
        formVisible = true;
    }

    private async Task AbrirEditarAsync(int id)
    {
        formError = null;
        formLoading = true;
        formVisible = true;

        try
        {
            var detalle = await ConfiguracionClient.GetByIdAsync(id);
            if (detalle is null)
            {
                formError = "No se encontro la configuracion.";
                formModel = new ConfiguracionAppEditDto();
                return;
            }

            formModel = detalle;
        }
        catch (Exception ex)
        {
            formError = $"Error al cargar la configuracion: {ex.Message}";
        }
        finally
        {
            formLoading = false;
        }
    }

    private void CerrarForm()
    {
        if (isSaving)
        {
            return;
        }

        formVisible = false;
        formError = null;
        formModel = new ConfiguracionAppEditDto();
    }

    private async Task GuardarAsync()
    {
        isSaving = true;

        try
        {
            if (formModel.Id.HasValue)
            {
                await ConfiguracionClient.UpdateAsync(formModel.Id.Value, formModel);
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Exito",
                    Text = "Configuracion actualizada correctamente.",
                    RenderStyle = ToastRenderStyle.Success,
                    ProviderName = "ConfigAppToast"
                });
            }
            else
            {
                await ConfiguracionClient.CreateAsync(formModel);
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Exito",
                    Text = "Configuracion registrada correctamente.",
                    RenderStyle = ToastRenderStyle.Success,
                    ProviderName = "ConfigAppToast"
                });
            }

            formVisible = false;
            formModel = new ConfiguracionAppEditDto();
            dataSource.Invalidate();
            grid?.Reload();
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Error",
                Text = ex.Message,
                RenderStyle = ToastRenderStyle.Danger,
                ProviderName = "ConfigAppToast"
            });
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ConfirmarEliminar(ConfiguracionAppListItemDto configuracion)
    {
        configuracionParaEliminar = configuracion;
        confirmVisible = true;
    }

    private void CancelarEliminar()
    {
        confirmVisible = false;
        configuracionParaEliminar = null;
    }

    private async Task EliminarConfirmadoAsync()
    {
        if (configuracionParaEliminar is null)
        {
            confirmVisible = false;
            return;
        }

        try
        {
            var ok = await ConfiguracionClient.DeleteAsync(configuracionParaEliminar.Id);
            if (!ok)
            {
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Error",
                    Text = "No se pudo eliminar la configuracion.",
                    RenderStyle = ToastRenderStyle.Danger,
                    ProviderName = "ConfigAppToast"
                });
            }
            else
            {
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Exito",
                    Text = "Configuracion eliminada correctamente.",
                    RenderStyle = ToastRenderStyle.Success,
                    ProviderName = "ConfigAppToast"
                });

                dataSource.Invalidate();
                grid?.Reload();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Error",
                Text = ex.Message,
                RenderStyle = ToastRenderStyle.Danger,
                ProviderName = "ConfigAppToast"
            });
        }
        finally
        {
            confirmVisible = false;
            configuracionParaEliminar = null;
        }
    }

    private static bool EsProtegida(int id) => id == 5 || id == 6;
}
