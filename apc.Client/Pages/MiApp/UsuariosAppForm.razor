@using DevExpress.Blazor
@using SIAD.Core.DTOs.AppLectores
@using SIAD.Core.DTOs.Rutas
@using SIAD.Core.DTOs.Ciclos

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" Context="editContext">
    <DataAnnotationsValidator />

    @if (editContext.GetValidationMessages().Any())
    {
        <div class="alert alert-danger mb-3 shadow-sm">
            <h6 class="alert-heading"><i class="bi bi-exclamation-circle-fill me-2"></i>Atencion</h6>
            <DxValidationSummary />
        </div>
    }

    <DxFormLayout>
        <DxFormLayoutItem Caption="Usuario *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Usuario"
                       NullText="Usuario del app"
                       MaxLength="25" />
            <ValidationMessage For="() => Model.Usuario" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Contrasena *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Clave"
                       NullText="Contrasena en texto"
                       MaxLength="30" />
            <ValidationMessage For="() => Model.Clave" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Nombre *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Nombre"
                       NullText="Nombre del lector"
                       MaxLength="50" />
            <ValidationMessage For="() => Model.Nombre" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Ciclo" ColSpanMd="3">
            <Template>
                <DxComboBox TData="CicloListItemDto"
                            TValue="int?"
                            Data="@Ciclos"
                            @bind-Value="Model.CodCiclo"
                            ValueFieldName="@nameof(CicloListItemDto.Id)"
                            TextFieldName="@nameof(CicloListItemDto.Codigo)"
                            NullText="Ciclo"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                <ValidationMessage For="() => Model.CodCiclo" />
            </Template>
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Ruta" ColSpanMd="3">
            <Template>
                <DxComboBox TData="RutaListItemDto"
                            TValue="string"
                            Data="@Rutas"
                            @bind-Value="Model.Ruta"
                            ValueFieldName="@nameof(RutaListItemDto.CodRuta)"
                            TextFieldName="@nameof(RutaListItemDto.CodRuta)"
                            DropDownStyle="DropDownStyle.DropDown"
                            NullText="Ruta" />
                <ValidationMessage For="() => Model.Ruta" />
            </Template>
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Estado" ColSpanMd="6">
            <Template>
                <div class="pt-2">
                    <DxCheckBox @bind-Checked="Model.Activo"
                                CheckType="CheckType.Switch"
                                LabelText="Activo" />
                </div>
            </Template>
        </DxFormLayoutItem>
    </DxFormLayout>

    <ValidationSummary class="text-danger mb-3" />

    <div class="d-flex justify-content-end gap-2">
        <DxButton ButtonType="ButtonType.Submit"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  SubmitFormOnClick="true"
                  Enabled="@(!IsBusy)" />
        <DxButton ButtonType="ButtonType.Normal"
                  Text="Cancelar"
                  Enabled="@(!IsBusy)"
                  Click="Cancel" />
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public UsuarioAppEditDto Model { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<RutaListItemDto> Rutas { get; set; } = Array.Empty<RutaListItemDto>();

    [Parameter]
    public IReadOnlyList<CicloListItemDto> Ciclos { get; set; } = Array.Empty<CicloListItemDto>();

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private async Task HandleValidSubmit()
    {
        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }
}
