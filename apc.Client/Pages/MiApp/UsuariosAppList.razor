@page "/mi-app/usuarios"
@attribute [Authorize]

@using DevExpress.Blazor
@using SIAD.Core.DTOs.AppLectores
@using SIAD.Core.DTOs.Rutas
@using apc.Client.Pages.MiApp
@using apc.Client.Services.AppLectores
@using apc.Client.Services.Rutas

@inject UsuariosAppClient UsuariosClient
@inject RutasClient RutasClient
@inject IToastNotificationService ToastService

<div class="page-container">
    <DxToastProvider Name="UsuariosAppToast" MaxToastCount="4" />

    <div class="header-section">
        <div>
            <h2 class="page-title">Usuarios App Lectores</h2>
            <p class="page-subtitle">Mantenimiento de usuarios y rutas para la app</p>
        </div>

        <DxButton Text="Nuevo usuario"
                  IconCssClass="bi bi-person-plus"
                  RenderStyle="ButtonRenderStyle.Primary"
                  CssClass="btn-modern"
                  Click="AbrirNuevo" />
    </div>

    @if (!string.IsNullOrWhiteSpace(rutasError))
    {
        <DxAlert AlertType="AlertType.Danger" CssClass="mb-3">@rutasError</DxAlert>
    }

    @if (mostrarFiltros)
    {
        <div class="modern-card mb-4">
            <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                <DxFormLayoutGroup Caption="Filtros" HeaderIconCssClass="bi bi-funnel" ColSpanXs="12">
                    <DxFormLayoutItem Caption="Busqueda rapida" ColSpanXs="12" ColSpanMd="5">
                        <Template>
                            <DxTextBox Text="@filtroBusqueda"
                                       TextChanged="@((string v) => OnBusquedaChanged(v))"
                                       Placeholder="Usuario, nombre o ruta..."
                                       ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                       InputDelay="600" />
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Ruta" ColSpanXs="12" ColSpanMd="3">
                        <Template>
                            <DxComboBox TData="RutaListItemDto"
                                        TValue="string"
                                        Data="@rutas"
                                        @bind-Value="filtroRuta"
                                        ValueFieldName="@nameof(RutaListItemDto.CodRuta)"
                                        TextFieldName="@nameof(RutaListItemDto.CodRuta)"
                                        DropDownStyle="DropDownStyle.DropDownList"
                                        NullText="Todas las rutas"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Estado" ColSpanXs="12" ColSpanMd="2">
                        <Template>
                            <div class="pt-md-4 pt-2">
                                <DxCheckBox Checked="@filtroSoloActivos"
                                            CheckedChanged="@((bool v) => OnEstadoChanged(v))"
                                            LabelText=""
                                            CheckType="CheckType.Switch" />
                            </div>
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanXs="12" ColSpanMd="2" CssClass="align-self-end">
                        <Template>
                            <div class="filters-actions">
                                <DxButton Text="Filtrar"
                                          IconCssClass="bi bi-search"
                                          CssClass="filters-btn filters-btn-primary"
                                          RenderStyle="ButtonRenderStyle.Secondary"
                                          Click="BuscarAsync" />

                                <button type="button" class="filters-link" @onclick="LimpiarFiltrosAsync">
                                    Limpiar
                                </button>
                            </div>
                        </Template>
                    </DxFormLayoutItem>
                </DxFormLayoutGroup>
            </DxFormLayout>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <DxAlert AlertType="AlertType.Danger" CssClass="mb-3">@errorMessage</DxAlert>
    }

    <div class="modern-card position-relative">
        <div class="grid-wrapper">
            <DxGrid @ref="grid" Data="@dataSource" KeyFieldName="@nameof(UsuarioAppListItemDto.Id)" PageSize="15"
                    PagerPosition="GridPagerPosition.Bottom" ShowFilterRow="false" ShowSearchBox="false"
                    ColumnResizeMode="GridColumnResizeMode.ColumnsContainer" FocusedRowEnabled="false"
                    ShowGroupPanel="false" CssClass="grid-solicitudes">

                <ToolbarTemplate>
                    <div class="d-flex flex-wrap gap-2 align-items-center w-100">
                        <DxTextBox Text="@filtroBusqueda" TextChanged="@((string v) => OnBusquedaChanged(v))"
                                   TextExpression="@(() => filtroBusqueda)"
                                   Placeholder="Buscar usuario..." InputDelay="600"
                                   ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" CssClass="me-1"
                                   Style="min-width: 260px;" />

                        <DxButton Text="Recargar" IconCssClass="bi bi-arrow-clockwise"
                                  RenderStyle="ButtonRenderStyle.Secondary" Click="RecargarGrid" CssClass="me-1" />

                        <DxButton Text="Filtros" IconCssClass="bi bi-funnel" RenderStyle="ButtonRenderStyle.Secondary"
                                  Click="ToggleFiltros" CssClass="me-1" />

                        <DxButton Text="Columnas" IconCssClass="bi bi-layout-three-columns"
                                  RenderStyle="ButtonRenderStyle.Secondary" Click="MostrarColumnChooser" CssClass="me-1" />

                        <div class="ms-auto text-muted small">
                            Total: <span class="fw-bold">@totalUsuarios.ToString("N0")</span>
                        </div>
                    </div>
                </ToolbarTemplate>

                <Columns>
                    <DxGridDataColumn FieldName="@nameof(UsuarioAppListItemDto.Usuario)" Caption="Usuario" Width="180px">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is UsuarioAppListItemDto item)
                            {
                                <span class="text-dark fw-semibold">@item.Usuario</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="@nameof(UsuarioAppListItemDto.Nombre)" Caption="Nombre" MinWidth="220">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is UsuarioAppListItemDto item)
                            {
                                <div class="text-truncate" title="@item.Nombre">@item.Nombre</div>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="@nameof(UsuarioAppListItemDto.Ruta)" Caption="Ruta" Width="140px">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is UsuarioAppListItemDto item)
                            {
                                <span class="text-muted">@(string.IsNullOrWhiteSpace(item.Ruta) ? "-" : item.Ruta)</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn Caption="Estado" Width="140px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is UsuarioAppListItemDto item)
                            {
                                if (item.Activo)
                                {
                                    <span class="badge-status active">ACTIVO</span>
                                }
                                else
                                {
                                    <span class="badge-status inactive">INACTIVO</span>
                                }
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn Caption="Acciones" Width="160px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is UsuarioAppListItemDto item)
                            {
                                <div class="d-flex justify-content-center gap-2 flex-wrap">
                                    <button type="button" class="btn-icon btn-edit" title="Editar"
                                            @onclick="() => AbrirEditarAsync(item.Id)" @onclick:stopPropagation="true">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    <button type="button" class="btn-icon btn-delete" title="Desactivar"
                                            disabled="@(!item.Activo)"
                                            @onclick="() => ConfirmarDesactivar(item)" @onclick:stopPropagation="true">
                                        <i class="bi bi-slash-circle"></i>
                                    </button>
                                </div>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>

                <EmptyDataAreaTemplate>
                    <div class="p-4 text-center text-muted">No hay usuarios para mostrar.</div>
                </EmptyDataAreaTemplate>
            </DxGrid>
        </div>
    </div>
</div>

<DxPopup @bind-Visible="formVisible"
         Width="min(720px, 95vw)"
         Height="auto"
         MaxHeight="90vh"
         Scrollable="true"
         CssClass="custom-popup"
         CloseOnOutsideClick="false">
    <HeaderContentTemplate>
        <div class="d-flex align-items-center gap-2">
            <div class="@PopupIconWrapperClass" style="width: 38px; height: 38px;">
                <i class="@PopupIcon"></i>
            </div>
            <div>
                <div class="fw-bold fs-6 text-dark" style="line-height:1.1;">@PopupTitle</div>
                <div class="small text-muted" style="font-weight: normal; font-size: 0.8rem;">@PopupSubtitle</div>
            </div>
        </div>
    </HeaderContentTemplate>

    <BodyContentTemplate>
        @if (formLoading)
        {
            <div class="text-center p-4">
                <DxLoadingPanel Visible="true" Text="Cargando usuario..." />
                <div style="height:80px"></div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(formError))
        {
            <div class="p-3">
                <DxAlert AlertType="AlertType.Danger">@formError</DxAlert>
            </div>
        }
        else
        {
            <UsuariosAppForm Model="formModel"
                             Rutas="rutas"
                             OnValidSubmit="GuardarAsync"
                             OnCancel="CerrarForm"
                             IsBusy="isSaving" />
        }
    </BodyContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="confirmVisible" Width="min(420px, 90vw)" HeaderText="Confirmar accion" ShowFooter="false">
    <BodyTemplate>
        <div class="text-center p-4">
            <div class="mb-3 text-warning"><i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i></div>
            <h5 class="fw-bold">Desactivar usuario?</h5>
            <p class="text-muted">El usuario pasara a estado inactivo pero no se eliminara del sistema.</p>
            @if (usuarioParaDesactivar is not null)
            {
                <div class="fw-semibold">@usuarioParaDesactivar.Usuario</div>
            }
            <div class="d-flex justify-content-center gap-3 mt-4">
                <DxButton Text="Cancelar"
                          Click="CancelarDesactivar"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          RenderStyleMode="ButtonRenderStyleMode.Outline" />
                <DxButton Text="Si, desactivar"
                          Click="DesactivarConfirmadoAsync"
                          RenderStyle="ButtonRenderStyle.Danger"
                          IconCssClass="bi bi-slash-circle" />
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    private DxGrid? grid;
    private UsuariosAppGridDataSource dataSource = default!;

    private string filtroBusqueda = string.Empty;
    private string? filtroRuta;
    private bool filtroSoloActivos = true;
    private bool mostrarFiltros = true;

    private string? errorMessage;
    private string? rutasError;
    private int totalUsuarios;

    private bool formVisible;
    private bool formLoading;
    private bool isSaving;
    private string? formError;
    private UsuarioAppEditDto formModel = new();

    private bool confirmVisible;
    private UsuarioAppListItemDto? usuarioParaDesactivar;

    private readonly List<RutaListItemDto> rutas = new();

    private string PopupTitle => formModel.Id.HasValue ? "Editar usuario" : "Nuevo usuario";
    private string PopupSubtitle => formModel.Id.HasValue
        ? "Actualice la informacion del usuario"
        : "Complete el formulario de registro";
    private string PopupIcon => formModel.Id.HasValue ? "bi bi-pencil-square" : "bi bi-person-plus";
    private string PopupIconWrapperClass => formModel.Id.HasValue
        ? "bg-warning bg-opacity-10 text-warning p-2 rounded-circle d-flex justify-content-center align-items-center"
        : "bg-primary bg-opacity-10 text-primary p-2 rounded-circle d-flex justify-content-center align-items-center";

    protected override void OnInitialized()
    {
        dataSource = new UsuariosAppGridDataSource(UsuariosClient, OnGridStateChanged);
        ApplyFilters();
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRutasAsync();
    }

    private void OnGridStateChanged()
    {
        errorMessage = dataSource.LastError;
        totalUsuarios = dataSource.LastTotalCount;
        InvokeAsync(StateHasChanged);
    }

    private void ApplyFilters()
    {
        dataSource.SearchText = filtroBusqueda;
        dataSource.Ruta = filtroRuta;
        dataSource.SoloActivos = filtroSoloActivos;
    }

    private async Task OnBusquedaChanged(string valor)
    {
        filtroBusqueda = valor;
        await BuscarAsync();
    }

    private async Task OnEstadoChanged(bool valor)
    {
        filtroSoloActivos = valor;
        await BuscarAsync();
    }

    private Task BuscarAsync()
    {
        ApplyFilters();
        dataSource.Invalidate();
        grid?.Reload();
        return Task.CompletedTask;
    }

    private async Task LimpiarFiltrosAsync()
    {
        filtroBusqueda = string.Empty;
        filtroRuta = null;
        filtroSoloActivos = true;
        await BuscarAsync();
    }

    private void RecargarGrid()
    {
        dataSource.Invalidate();
        grid?.Reload();
    }

    private void ToggleFiltros() => mostrarFiltros = !mostrarFiltros;
    private void MostrarColumnChooser() => grid?.ShowColumnChooser();

    private void AbrirNuevo()
    {
        formError = null;
        formModel = new UsuarioAppEditDto { Activo = true };
        formVisible = true;
    }

    private async Task AbrirEditarAsync(int id)
    {
        formError = null;
        formLoading = true;
        formVisible = true;

        try
        {
            var detalle = await UsuariosClient.GetByIdAsync(id);
            if (detalle is null)
            {
                formError = "No se encontro el usuario.";
                formModel = new UsuarioAppEditDto { Activo = true };
                return;
            }

            formModel = detalle;
        }
        catch (Exception ex)
        {
            formError = $"Error al cargar el usuario: {ex.Message}";
        }
        finally
        {
            formLoading = false;
        }
    }

    private void CerrarForm()
    {
        if (isSaving)
        {
            return;
        }

        formVisible = false;
        formError = null;
        formModel = new UsuarioAppEditDto();
    }

    private async Task GuardarAsync()
    {
        isSaving = true;

        try
        {
            if (formModel.Id.HasValue)
            {
                await UsuariosClient.UpdateAsync(formModel.Id.Value, formModel);
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Exito",
                    Text = "Usuario actualizado correctamente.",
                    RenderStyle = ToastRenderStyle.Success,
                    ProviderName = "UsuariosAppToast"
                });
            }
            else
            {
                await UsuariosClient.CreateAsync(formModel);
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Exito",
                    Text = "Usuario registrado correctamente.",
                    RenderStyle = ToastRenderStyle.Success,
                    ProviderName = "UsuariosAppToast"
                });
            }

            formVisible = false;
            formModel = new UsuarioAppEditDto();
            dataSource.Invalidate();
            grid?.Reload();
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Error",
                Text = ex.Message,
                RenderStyle = ToastRenderStyle.Danger,
                ProviderName = "UsuariosAppToast"
            });
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ConfirmarDesactivar(UsuarioAppListItemDto usuario)
    {
        usuarioParaDesactivar = usuario;
        confirmVisible = true;
    }

    private void CancelarDesactivar()
    {
        confirmVisible = false;
        usuarioParaDesactivar = null;
    }

    private async Task DesactivarConfirmadoAsync()
    {
        if (usuarioParaDesactivar is null)
        {
            confirmVisible = false;
            return;
        }

        try
        {
            var ok = await UsuariosClient.DeactivateAsync(usuarioParaDesactivar.Id);
            if (!ok)
            {
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Error",
                    Text = "No se pudo desactivar el usuario.",
                    RenderStyle = ToastRenderStyle.Danger,
                    ProviderName = "UsuariosAppToast"
                });
            }
            else
            {
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Exito",
                    Text = "Usuario desactivado correctamente.",
                    RenderStyle = ToastRenderStyle.Success,
                    ProviderName = "UsuariosAppToast"
                });

                dataSource.Invalidate();
                grid?.Reload();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Error",
                Text = ex.Message,
                RenderStyle = ToastRenderStyle.Danger,
                ProviderName = "UsuariosAppToast"
            });
        }
        finally
        {
            confirmVisible = false;
            usuarioParaDesactivar = null;
        }
    }

    private async Task LoadRutasAsync()
    {
        try
        {
            var data = await RutasClient.GetAsync();
            rutas.Clear();
            rutas.AddRange(data.Where(r => r.Activo).OrderBy(r => r.CodRuta));
            rutasError = null;
        }
        catch (Exception ex)
        {
            rutasError = $"No se pudo cargar la lista de rutas: {ex.Message}";
        }
    }
}
