@page "/tarifario/conflictos-v3"
@attribute [Authorize]

@using DevExpress.Blazor
@using Microsoft.AspNetCore.Components
@using SIAD.Core.DTOs.Tarifario
@using apc.Client.Services.Tarifario

@inject TarifarioConflictoClient Client
@inject NavigationManager Navigation
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Conflictos Tarifarios</PageTitle>

<div class="page-container conflictos-v3-page">
    <DxToastProvider Name="ConflictosV3Toast" MaxToastCount="4" />

    <div class="modern-card">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start align-items-lg-center gap-3 mb-3">
            <div>
                <h2 class="page-title mb-1">Conflictos y reprocesos</h2>
                <p class="text-muted mb-0">Seguimiento operativo de conflictos de sincronizacion, CAI y facturacion formal.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <DxButton Text="Cliente servicio"
                          IconCssClass="bi bi-diagram-3"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                          Click='@(() => Navigation.NavigateTo("/tarifario/cliente-servicio-v3"))' />
                <DxButton Text="CAI offline"
                          IconCssClass="bi bi-upc-scan"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                          Click='@(() => Navigation.NavigateTo("/tarifario/cai-offline"))' />
            </div>
        </div>

        <DxFormLayout CaptionPosition="CaptionPosition.Vertical" CssClass="conflictos-v3-filters">
            <DxFormLayoutItem Caption="Buscar" ColSpanXs="12" ColSpanMd="6" ColSpanLg="4">
                <Template>
                    <DxTextBox @bind-Text="searchText"
                               NullText="Factura, cliente, codigo o detalle"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                </Template>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Estado" ColSpanXs="12" ColSpanMd="3" ColSpanLg="2">
                <Template>
                    <DxComboBox Data="@estados"
                                TextFieldName="Label"
                                ValueFieldName="Value"
                                @bind-Value="estadoFiltro"
                                NullText="Todos"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                </Template>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Ruta" ColSpanXs="12" ColSpanMd="3" ColSpanLg="2">
                <Template>
                    <DxTextBox @bind-Text="rutaFiltro"
                               NullText="Ruta"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                </Template>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Cliente Id" ColSpanXs="12" ColSpanMd="3" ColSpanLg="2">
                <Template>
                    <DxSpinEdit @bind-Value="clienteIdFiltro"
                                MinValue="0"
                                NullText="Todos" />
                </Template>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption=" " ColSpanXs="12" ColSpanMd="9" ColSpanLg="2" CssClass="align-self-end">
                <Template>
                    <div class="d-flex gap-2 flex-wrap">
                        <DxButton Text="Aplicar"
                                  IconCssClass="bi bi-funnel"
                                  RenderStyle="ButtonRenderStyle.Primary"
                                  Click="LoadAsync"
                                  Enabled="@(!isLoading)" />
                        <DxButton Text="Limpiar"
                                  IconCssClass="bi bi-x-circle"
                                  RenderStyle="ButtonRenderStyle.Secondary"
                                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                                  Click="ClearFilters" />
                    </div>
                </Template>
            </DxFormLayoutItem>
        </DxFormLayout>

        @if (isLoading)
        {
            <DxLoadingPanel Visible="true" Text="Cargando conflictos..." />
            <div style="height:64px"></div>
        }
        else if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger mt-3 mb-0">@error</div>
        }
        else
        {
            <div class="conflictos-v3-stats mt-3">
                <span class="badge bg-secondary">Total: @items.Count</span>
                <span class="badge bg-danger">Pendientes: @items.Count(i => string.Equals(i.EstadoCodigo, "PENDIENTE", StringComparison.OrdinalIgnoreCase))</span>
                <span class="badge bg-success">Revisados: @items.Count(i => string.Equals(i.EstadoCodigo, "REVISADO", StringComparison.OrdinalIgnoreCase))</span>
            </div>

            <DxGrid Data="@items"
                    PageSize="12"
                    ShowFilterRow="false"
                    ShowGroupPanel="false"
                    CssClass="mt-3">
                <Columns>
                    <DxGridDataColumn FieldName="FechaRegistro" Caption="Fecha" Width="150px" DisplayFormat="dd/MM/yyyy HH:mm" />
                    <DxGridDataColumn FieldName="EstadoCodigo" Caption="Estado" Width="110px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @{
                                var estado = cell.Value?.ToString();
                                var css = string.Equals(estado, "REVISADO", StringComparison.OrdinalIgnoreCase)
                                    ? "bg-success"
                                    : "bg-danger";
                            }
                            <span class="badge @css">@estado</span>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="CodigoConflicto" Caption="Codigo" Width="150px" />
                    <DxGridDataColumn FieldName="NumeroFactura" Caption="Factura" Width="170px" />
                    <DxGridDataColumn FieldName="ClienteClave" Caption="Clave" Width="120px" />
                    <DxGridDataColumn FieldName="ClienteNombre" Caption="Cliente" Width="240px" />
                    <DxGridDataColumn FieldName="RutaCodigo" Caption="Ruta" Width="90px" />
                    <DxGridDataColumn FieldName="Correlativo" Caption="Correlativo" Width="100px" />
                    <DxGridDataColumn FieldName="CodigoCai" Caption="CAI" Width="180px" />
                    <DxGridDataColumn FieldName="DetalleConflicto" Caption="Detalle" Width="320px" />
                    <DxGridDataColumn Caption="Acciones" Width="130px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @{
                                var item = (TarifarioConflictoListDto)cell.DataItem;
                            }
                            <div class="d-flex justify-content-center gap-1">
                                @if (item.ClienteId.HasValue && item.ClienteId.Value > 0)
                                {
                                    <button type="button" class="btn btn-sm btn-outline-primary" title="Ver cliente"
                                            @onclick="() => AbrirCliente(item)">
                                        <i class="bi bi-person-vcard"></i>
                                    </button>
                                }
                                @if (!string.Equals(item.EstadoCodigo, "REVISADO", StringComparison.OrdinalIgnoreCase))
                                {
                                    <button type="button" class="btn btn-sm btn-outline-success" title="Marcar revisado"
                                            @onclick="() => AbrirResolver(item)">
                                        <i class="bi bi-check2-square"></i>
                                    </button>
                                }
                            </div>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>
            </DxGrid>
        }
    </div>
</div>

<DxPopup @bind-Visible="popupResolverVisible"
         Width="min(720px, 96vw)"
         CloseOnOutsideClick="false"
         ShowCloseButton="true"
         HeaderText="Resolver conflicto">
    <BodyContentTemplate Context="resolverBody">
        @if (conflictoSeleccionado is not null)
        {
            <div class="d-flex flex-column gap-3">
                <div class="alert alert-warning mb-0">
                    <div><strong>Factura:</strong> @conflictoSeleccionado.NumeroFactura</div>
                    <div><strong>Cliente:</strong> @conflictoSeleccionado.ClienteClave - @conflictoSeleccionado.ClienteNombre</div>
                    <div><strong>Detalle:</strong> @conflictoSeleccionado.DetalleConflicto</div>
                </div>

                <DxMemo @bind-Text="observacionesResolver"
                        NullText="Observaciones operativas..."
                        Rows="5" />

                <div class="d-flex justify-content-end gap-2">
                    <DxButton Text="Cancelar"
                              RenderStyle="ButtonRenderStyle.Secondary"
                              RenderStyleMode="ButtonRenderStyleMode.Outline"
                              Click="@(() => popupResolverVisible = false)" />
                    <DxButton Text="Marcar revisado"
                              RenderStyle="ButtonRenderStyle.Primary"
                              Enabled="@(!isSaving)"
                              Click="ResolverAsync" />
                </div>
            </div>
        }
    </BodyContentTemplate>
</DxPopup>

@code {
    [Parameter]
    [SupplyParameterFromQuery(Name = "clienteId")]
    public int? ClienteIdFromQuery { get; set; }

    private readonly (string Value, string Label)[] estados =
    [
        ("PENDIENTE", "Pendiente"),
        ("REVISADO", "Revisado")
    ];

    private List<TarifarioConflictoListDto> items = new();
    private string? searchText;
    private string? estadoFiltro;
    private string? rutaFiltro;
    private int? clienteIdFiltro;
    private bool isLoading;
    private bool isSaving;
    private string? error;

    private bool popupResolverVisible;
    private TarifarioConflictoListDto? conflictoSeleccionado;
    private string? observacionesResolver;

    protected override async Task OnInitializedAsync()
    {
        clienteIdFiltro = ClienteIdFromQuery;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        error = null;

        try
        {
            items = (await Client.ObtenerAsync(
                searchText,
                estadoFiltro,
                rutaFiltro,
                clienteIdFiltro,
                default)).ToList();
        }
        catch (Exception ex)
        {
            error = $"No fue posible cargar los conflictos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ClearFilters()
    {
        searchText = null;
        estadoFiltro = null;
        rutaFiltro = null;
        clienteIdFiltro = null;
        _ = LoadAsync();
    }

    private void AbrirCliente(TarifarioConflictoListDto item)
    {
        if (item.ClienteId is > 0)
        {
            Navigation.NavigateTo($"/clientes/{item.ClienteId.Value}");
        }
    }

    private void AbrirResolver(TarifarioConflictoListDto item)
    {
        conflictoSeleccionado = item;
        observacionesResolver = null;
        popupResolverVisible = true;
    }

    private async Task ResolverAsync()
    {
        if (conflictoSeleccionado is null)
        {
            return;
        }

        isSaving = true;
        try
        {
            var response = await Client.ResolverAsync(
                new TarifarioConflictoResolveRequest(conflictoSeleccionado.ConflictoId, observacionesResolver));

            if (response?.Success == true)
            {
                ShowToast("Exito", response.Message, ToastRenderStyle.Success);
                popupResolverVisible = false;
                await LoadAsync();
            }
            else
            {
                ShowToast("Error", response?.Message ?? "No se pudo resolver el conflicto.", ToastRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error", $"No fue posible resolver el conflicto: {ex.Message}", ToastRenderStyle.Danger);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ShowToast(string title, string message, ToastRenderStyle renderStyle)
    {
        ToastService.ShowToast(new ToastOptions
        {
            ProviderName = "ConflictosV3Toast",
            RenderStyle = renderStyle,
            Title = title,
            Text = message
        });
    }
}
