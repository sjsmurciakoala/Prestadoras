@page "/admin/branding"
@using DevExpress.Blazor
@using System.Collections.Generic
@inject apc.Client.Services.BrandingClient BrandingClient
@inject NavigationManager NavigationManager

<h3>Branding del Portal</h3>

<EditForm Model="branding" OnValidSubmit="SaveBranding" Context="formCtx">
    <DataAnnotationsValidator />
    <DxFormLayout>
        <DxFormLayoutItem Caption="Nombre empresa" ColSpanMd="6">
            <DxTextBox @bind-Text="branding.CompanyName" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Nombre corto" ColSpanMd="6">
            <DxTextBox @bind-Text="branding.CompanyShortName" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Logo actual" ColSpanMd="12">
            @if (!string.IsNullOrWhiteSpace(branding.LogoBase64))
            {
                <img src="@($"data:{branding.LogoMime};base64,{branding.LogoBase64}")" alt="Logo" style="max-height:140px;max-width:320px;" />
            }
            else
            {
                <span class="text-muted">Sin logo</span>
            }
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Cargar nuevo logo" ColSpanMd="12">
            <DxUpload Name="file"
                       UploadUrl="@GetLogoUploadUrl()"
                       UploadMode="UploadMode.Instant"
                       ShowFileList="true"
                       AllowMultiFileUpload="false"
                       MaxFileSize="5242880"
                       AllowedFileExtensions="@(new List<string> { ".png", ".jpg", ".jpeg", ".gif", ".svg" })" />
            <div class="text-muted small mt-1">Formatos permitidos: PNG, JPG, GIF o SVG. Tamano maximo 5 MB.</div>
        </DxFormLayoutItem>        <DxFormLayoutItem ColSpanMd="12">
            <div class="d-flex justify-content-end">
                <DxButton SubmitFormOnClick="true" Text="Guardar" CssClass="mr-2" />
                <DxButton RenderStyle="ButtonRenderStyle.Link" Text="Volver" @onclick="GoHome" />
            </div>
        </DxFormLayoutItem>
    </DxFormLayout>
    @if (!string.IsNullOrWhiteSpace(error))
    {
        <DxAlert AlertType="AlertType.Danger" CssClass="mt-2">@error</DxAlert>
    }
    @if (!string.IsNullOrWhiteSpace(success))
    {
        <DxAlert AlertType="AlertType.Success" CssClass="mt-2">@success</DxAlert>
    }
</EditForm>

@code {
    private BrandingForm branding = new();
    private string? error;
    private string? success;

    protected override async Task OnInitializedAsync()
    {
        await LoadBranding();
    }

    private async Task LoadBranding()
    {
        try
        {
            var current = await BrandingClient.GetBrandingAsync();
            if (current is not null)
            {
                branding.CompanyName = current.CompanyName;
                branding.CompanyShortName = current.CompanyShortName;
                branding.LogoBase64 = current.LogoBase64;
                branding.LogoMime = current.LogoMime;
            }
            error = null;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private async Task SaveBranding()
    {
        try
        {
            success = null;
            error = null;
            var result = await BrandingClient.UpsertBrandingAsync(new apc.Client.Services.BrandingClient.BrandingUpdateRequest(
                branding.CompanyName,
                branding.CompanyShortName));

            branding.LogoBase64 = result.LogoBase64;
            branding.LogoMime = result.LogoMime;
            success = "Branding actualizado";
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private string GetLogoUploadUrl()
    {
        var name = Uri.EscapeDataString(branding.CompanyName ?? string.Empty);
        var shortName = Uri.EscapeDataString(branding.CompanyShortName ?? string.Empty);
        return $"api/branding/logo?CompanyName={name}&CompanyShortName={shortName}";
    }

    private void GoHome()
    {
        NavigationManager.NavigateTo("/");
    }

    private sealed class BrandingForm
    {
        public string CompanyName { get; set; } = string.Empty;
        public string CompanyShortName { get; set; } = string.Empty;
        public string? LogoBase64 { get; set; }
        public string? LogoMime { get; set; }
    }
}
