@page "/bancos/cuentas/gestion"
@attribute [Authorize(Policy = PermissionNames.Bancos.View)]

@using apc.Client.Services.Bancos
@using apc.Client.Services.Tenant
@using DevExpress.Blazor
@using Microsoft.AspNetCore.Components.Forms
@using SIAD.Core.DTOs.Bancos
@using SIAD.Core.DTOs.Contabilidad
@using System.Net.Http

@inject CuentasBancosClient CuentasClient
@inject BancosClient BancosClient
@inject BancoConfiguracionClient BancoConfigClient
@inject BanMonedasClient MonedasClient
@inject TenantState TenantState
@inject NavigationManager NavigationManager

<div class="page-container">
    <div class="d-flex justify-content-between align-items-center mb-4 header-section">
        <div>
            <h2 class="page-title">@PageTitle</h2>
            <p class="page-subtitle">Gestion de cuenta bancaria</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <DxButton Text="Volver"
                      IconCssClass="bi bi-arrow-left"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      CssClass="btn-modern shadow-sm"
                      Click="VolverAsync" />
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(alerta))
    {
        <DxMessageBox Type="MessageBoxType.Alert"
                      RenderStyle="@alertaEstilo"
                      ShowIcon="true"
                      Text="@alerta"
                      CssClass="mb-3"
                      Visible="true" />
    }

    <CuentasBancosFormModal Visible="@(!isLoading)"
                            EditContext="editContext"
                            EditModel="editModel"
                            IsSaving="isSaving"
                            Bancos="bancos"
                            BancoSelectionEnabled="false"
                            Monedas="monedas"
                            TipoCuentaOpciones="tipoCuentaOpciones"
                            CuentasContables="cuentasContables"
                            Consolidado="consolidado"
                            PopupTitle="@PageTitle"
                            CuentaIdDisplay="CuentaIdDisplay"
                            OnCancel="VolverAsync"
                            OnSave="SaveAsync" />
</div>

<DxLoadingPanel Visible="isLoading"
                PositionTarget="body"
                ApplyBackgroundShading="true"
                IsContentBlocked="true"
                Text="Cargando..."
                ZIndex="2000" />

@code {
    [SupplyParameterFromQuery(Name = "bancoId")]
    public long? BancoId { get; set; }

    [SupplyParameterFromQuery(Name = "cuentaId")]
    public long? CuentaId { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private readonly List<BancoListDto> bancos = new();
    private readonly string[] tipoCuentaOpciones = new[] { "CHEQUES", "AHORRO", "TARJETA", "CAJA" };
    private List<BanMonedaLookupDto> monedas = new();
    private List<CuentaContableLookupDto> cuentasContables = new();
    private BancoCuentaEditDto editModel = new();
    private EditContext? editContext;
    private bool consolidado;
    private bool isLoading;
    private bool isSaving;
    private long companyId;
    private string? alerta;
    private MessageBoxRenderStyle alertaEstilo = MessageBoxRenderStyle.Info;
    private long? handledCuentaId;
    private long? handledBancoId;

    private string CuentaIdDisplay => editModel.BancoCuentaId > 0 ? editModel.BancoCuentaId.ToString() : string.Empty;

    private string PageTitle => editModel.BancoCuentaId > 0
        ? "Editar cuenta bancaria"
        : BancoId.HasValue && BancoId.Value > 0
            ? "Agregar cuenta bancaria"
            : "Nueva cuenta bancaria";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        if (handledCuentaId == CuentaId && handledBancoId == BancoId && editContext is not null)
        {
            return;
        }

        handledCuentaId = CuentaId;
        handledBancoId = BancoId;

        isLoading = true;
        alerta = null;

        try
        {
            companyId = await TenantState.EnsureCompanyAsync();
            if (companyId <= 0)
            {
                SetAlert("No hay empresa seleccionada.", MessageBoxRenderStyle.Info);
                return;
            }

            await LoadBancosAsync();
            await LoadBancoConfiguracionAsync(companyId);
            await LoadMonedasAsync(companyId);
            await LoadCuentasContablesAsync(companyId);

            if (CuentaId.HasValue && CuentaId.Value > 0)
            {
                await LoadCuentaAsync(CuentaId.Value);
                return;
            }

            await BuildNuevaCuentaAsync(BancoId);
        }
        catch (Exception ex)
        {
            SetAlert($"Error al cargar la cuenta: {ex.Message}", MessageBoxRenderStyle.Danger);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadCuentaAsync(long cuentaId)
    {
        var detail = await CuentasClient.GetByIdAsync(cuentaId);
        if (detail is null)
        {
            SetAlert("No se encontro la cuenta solicitada.", MessageBoxRenderStyle.Info);
            editModel = new BancoCuentaEditDto();
            editContext = new EditContext(editModel);
            return;
        }

        if (!IsBancoActivo(detail.BancoId))
        {
            SetAlert("El banco seleccionado esta inactivo. No se pueden modificar cuentas.", MessageBoxRenderStyle.Warning);
        }

        editModel = detail;
        editContext = new EditContext(editModel);
    }

    private async Task BuildNuevaCuentaAsync(long? bancoIdOverride)
    {
        if (bancos.Count == 0)
        {
            SetAlert("Debe registrar un banco antes de crear cuentas.", MessageBoxRenderStyle.Info);
            editModel = new BancoCuentaEditDto();
            editContext = new EditContext(editModel);
            return;
        }

        var bancoId = bancoIdOverride.HasValue && bancoIdOverride.Value > 0
            ? bancoIdOverride.Value
            : bancos.FirstOrDefault(b => b.Activo)?.BancoId ?? 0;

        if (bancoId <= 0)
        {
            SetAlert("No hay bancos activos disponibles.", MessageBoxRenderStyle.Warning);
            editModel = new BancoCuentaEditDto();
            editContext = new EditContext(editModel);
            return;
        }

        if (!IsBancoActivo(bancoId))
        {
            SetAlert("El banco seleccionado esta inactivo. No se pueden agregar cuentas.", MessageBoxRenderStyle.Warning);
        }

        editModel = new BancoCuentaEditDto
        {
            Activo = true,
            BancoId = bancoId,
            CompanyId = companyId,
            TipoCuenta = tipoCuentaOpciones.FirstOrDefault() ?? string.Empty,
            SaldoActual = null
        };

        editContext = new EditContext(editModel);
    }

    private async Task SaveAsync()
    {
        if (editContext is null)
        {
            return;
        }

        alerta = null;
        NormalizeCuentaContableForSave();

        if (!IsBancoActivo(editModel.BancoId))
        {
            var accion = editModel.BancoCuentaId > 0 ? "modificar" : "agregar";
            SetAlert($"El banco seleccionado esta inactivo. No se pueden {accion} cuentas.", MessageBoxRenderStyle.Warning);
            return;
        }

        if (!editContext.Validate())
        {
            SetAlert("Revisa los campos del formulario.", MessageBoxRenderStyle.Danger);
            return;
        }

        try
        {
            isSaving = true;
            if (editModel.BancoCuentaId > 0)
            {
                await CuentasClient.UpdateAsync(editModel.BancoCuentaId, editModel);
            }
            else
            {
                var createDto = BuildCreateDto(editModel);
                await CuentasClient.CreateAsync(createDto);
            }

            Volver();
        }
        catch (UnauthorizedAccessException ex)
        {
            SetAlert(ex.Message, MessageBoxRenderStyle.Danger);
        }
        catch (HttpRequestException ex)
        {
            SetAlert(ex.Message, MessageBoxRenderStyle.Danger);
        }
        catch (Exception ex)
        {
            SetAlert($"No se pudo guardar la cuenta: {ex.Message}", MessageBoxRenderStyle.Danger);
        }
        finally
        {
            isSaving = false;
        }
    }

    private Task VolverAsync()
    {
        Volver();
        return Task.CompletedTask;
    }

    private void Volver()
    {
        var returnUrl = BuildReturnUrl();
        NavigationManager.NavigateTo(returnUrl);
    }

    private string BuildReturnUrl()
    {
        if (!string.IsNullOrWhiteSpace(ReturnUrl) && ReturnUrl.StartsWith("/", StringComparison.Ordinal))
        {
            return ReturnUrl;
        }

        var bancoId = BancoId.HasValue && BancoId.Value > 0
            ? BancoId.Value
            : editModel.BancoId;

        if (bancoId > 0)
        {
            return $"/bancos/cuentas?bancoId={bancoId}";
        }

        return "/bancos/cuentas";
    }

    private async Task LoadBancosAsync()
    {
        try
        {
            var data = await BancosClient.GetAsync();
            bancos.Clear();
            bancos.AddRange(data);
        }
        catch (UnauthorizedAccessException ex)
        {
            SetAlert(ex.Message, MessageBoxRenderStyle.Danger);
        }
        catch (Exception ex)
        {
            SetAlert($"Error al cargar bancos: {ex.Message}", MessageBoxRenderStyle.Danger);
        }
    }

    private async Task LoadBancoConfiguracionAsync(long targetCompanyId, CancellationToken ct = default)
    {
        if (targetCompanyId <= 0)
        {
            consolidado = false;
            return;
        }

        try
        {
            var config = await BancoConfigClient.ObtenerAsync(targetCompanyId, ct);
            consolidado = config.Consolidado;
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            consolidado = false;
            SetAlert($"Error al cargar configuracion de bancos: {ex.Message}", MessageBoxRenderStyle.Warning);
        }
    }

    private async Task LoadMonedasAsync(long targetCompanyId, CancellationToken ct = default)
    {
        if (targetCompanyId <= 0)
        {
            monedas = new List<BanMonedaLookupDto>();
            return;
        }

        try
        {
            var data = await MonedasClient.GetAsync(targetCompanyId, ct);
            monedas = data
                .OrderBy(m => m.Descripcion, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            monedas = new List<BanMonedaLookupDto>();
            SetAlert($"Error al cargar monedas: {ex.Message}", MessageBoxRenderStyle.Warning);
        }
    }

    private async Task LoadCuentasContablesAsync(long targetCompanyId, CancellationToken ct = default)
    {
        if (targetCompanyId <= 0 || !consolidado)
        {
            cuentasContables = new List<CuentaContableLookupDto>();
            return;
        }

        try
        {
            var data = await CuentasClient.ListarCuentasContablesAsync(targetCompanyId, ct);
            cuentasContables = data
                .OrderBy(c => c.Code, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            cuentasContables = new List<CuentaContableLookupDto>();
            SetAlert($"Error al cargar cuentas contables: {ex.Message}", MessageBoxRenderStyle.Warning);
        }
    }

    private bool IsBancoActivo(long bancoId)
    {
        var banco = bancos.FirstOrDefault(b => b.BancoId == bancoId);
        return banco?.Activo == true;
    }

    private static BancoCuentaCreateDto BuildCreateDto(BancoCuentaEditDto model)
    {
        return new BancoCuentaCreateDto
        {
            BancoId = model.BancoId,
            NumeroCuenta = model.NumeroCuenta,
            TipoCuenta = model.TipoCuenta,
            Moneda = model.Moneda,
            Titular = model.Titular,
            Observaciones = model.Observaciones,
            SaldoActual = model.SaldoActual,
            Activo = model.Activo,
            ContAccountId = model.ContAccountId,
            CtaConc = model.CtaConc
        };
    }

    private void NormalizeCuentaContableForSave()
    {
        if (consolidado)
        {
            editModel.CtaConc = null;
            return;
        }

        editModel.ContAccountId = null;
        if (!string.IsNullOrWhiteSpace(editModel.CtaConc))
        {
            editModel.CtaConc = editModel.CtaConc.Trim();
        }
    }

    private void SetAlert(string message, MessageBoxRenderStyle style)
    {
        alerta = message;
        alertaEstilo = style;
    }
}

