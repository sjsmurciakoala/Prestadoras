@using DevExpress.Blazor
@using SIAD.Core.DTOs.Ciclos

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" Context="editContext">
    <DataAnnotationsValidator />

    @if (editContext.GetValidationMessages().Any())
    {
        <div class="alert alert-danger mb-3 shadow-sm">
            <h6 class="alert-heading"><i class="bi bi-exclamation-circle-fill me-2"></i>Atencion</h6>
            <ValidationSummary />
        </div>
    }

    <DxFormLayout>
        <DxFormLayoutItem Caption="Codigo *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Codigo"
                       NullText="Codigo del ciclo"
                       MaxLength="50" />
            <ValidationMessage For="() => Model.Codigo" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Descripcion corta *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.DescripcionCorta"
                       NullText="Descripcion corta"
                       MaxLength="100" />
            <ValidationMessage For="() => Model.DescripcionCorta" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Descripcion larga *" ColSpanMd="12">
            <DxTextBox @bind-Text="Model.DescripcionLarga"
                       NullText="Descripcion completa"
                       MaxLength="300" />
            <ValidationMessage For="() => Model.DescripcionLarga" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Estado" ColSpanMd="6">
            <Template>
                <div class="pt-2">
                    <DxCheckBox @bind-Checked="Model.Activo"
                                CheckType="CheckType.Switch"
                                LabelText="Activo" />
                </div>
            </Template>
        </DxFormLayoutItem>
    </DxFormLayout>

    <ValidationSummary class="text-danger mb-3" />

    <div class="d-flex justify-content-end gap-2">
        <DxButton ButtonType="ButtonType.Submit"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  SubmitFormOnClick="true"
                  Enabled="@(!IsBusy)" />
        <DxButton ButtonType="ButtonType.Normal"
                  Text="Cancelar"
                  Enabled="@(!IsBusy)"
                  Click="Cancel" />
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public CicloEditDto Model { get; set; } = default!;

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private async Task HandleValidSubmit()
    {
        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }
}
