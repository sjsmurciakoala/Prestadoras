        public string? NombreOrigen { get; set; }
        public string Etiqueta { get; set; } = string.Empty;
        public string TipoDato { get; set; } = ReportesWebConstants.DatasetParameterDataType.Text;
        public string FuenteValor { get; set; } = ReportesWebConstants.DatasetParameterValueSource.Report;
        public string? ValorDefault { get; set; }
        public bool Visible { get; set; } = true;
        public bool PermiteNulo { get; set; }
        public bool Requerido { get; set; }
        public int Orden { get; set; }
    }

