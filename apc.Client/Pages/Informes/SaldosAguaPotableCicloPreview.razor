@page "/informes/medicion/saldos-agua-potable-ciclo"
@attribute [Authorize(Policy = PermissionNames.Reporteria.View)]
@using System.Globalization
@using DevExpress.Blazor.Reporting
@using SIAD.Core.Constants
@using SIAD.Core.DTOs.Rutas
@using apc.Client.Services.Informes
@inject InformesClient InformesClient
@inject NavigationManager NavigationManager

<PageTitle>SIAD - Saldos de agua potable por ciclo</PageTitle>

<div class="page-container reporte-saldos-agua-potable-ciclo">
    <div class="header-section">
        <div>
            <h2 class="page-title">Saldos de agua potable por ciclo</h2>
            <p class="page-subtitle">Configure el rango de fechas, ciclo y genere el reporte de saldos de agua potable.</p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <DxButton Text="Volver"
                      Click="@(() => NavigationManager.NavigateTo("/informes/medicion"))"
                      IconCssClass="bi bi-arrow-left"
                      RenderStyle="ButtonRenderStyle.Secondary" />
            <AuthorizeView Policy="@PermissionNames.Reporteria.Edit">
                <Authorized>
                    <DxButton Text="Diseñar"
                              Click="@(() => NavigationManager.NavigateTo(ReportesWebConstants.BuildDesignerRoute(ReportesWebConstants.CodigoReporteSaldosAguaPotableCiclo)))"
                              IconCssClass="bi bi-pencil-square"
                              RenderStyle="ButtonRenderStyle.Secondary" />
                </Authorized>
            </AuthorizeView>
            <DxButton Text="Limpiar"
                      Click="LimpiarFiltros"
                      IconCssClass="bi bi-eraser"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      Enabled="@(!isLoading)" />
            <DxButton Text="Generar reporte"
                      Click="GenerarReporte"
                      IconCssClass="bi bi-file-earmark-play"
                      RenderStyle="ButtonRenderStyle.Primary"
                      Enabled="@(!isLoading)" />
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <SiadAlert AlertType="AlertType.Danger" CssClass="mb-3">@errorMessage</SiadAlert>
    }

    <div class="modern-card p-4">
        <DxFormLayout ColCountMd="12">
            <DxFormLayoutItem Caption="Fecha desde" ColSpanMd="3">
                <DxDateEdit @bind-Date="filtro.FechaDesde"
                            NullText="Seleccione fecha"
                            DisplayFormat="dd/MM/yyyy" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Fecha hasta" ColSpanMd="3">
                <DxDateEdit @bind-Date="filtro.FechaHasta"
                            NullText="Seleccione fecha"
                            DisplayFormat="dd/MM/yyyy" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Ciclo" ColSpanMd="3">
                <DxComboBox Data="@ciclos"
                            @bind-Value="filtro.CicloId"
                            ValueFieldName="@nameof(CicloLookupDto.Id)"
                            TextFieldName="@nameof(CicloLookupDto.Descripcion)"
                            NullText="Todos"
                            FilteringMode="DataGridFilteringMode.Contains"
                            DropDownStyleMode="DropDownStyleMode.DropDownList" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Reporte" ColSpanMd="3">
                <DxTextBox Text="Saldos de agua potable por ciclo"
                           ReadOnly="true"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never" />
            </DxFormLayoutItem>
        </DxFormLayout>
    </div>

    <div class="modern-card p-3 viewer-shell">
        @if (isLoading)
        {
            <div class="d-flex justify-content-center py-5">
                <DxWaitIndicator Visible="true" />
            </div>
        }
        else if (string.IsNullOrWhiteSpace(reportName))
        {
            <div class="empty-preview">
                <div class="empty-preview__icon">
                    <i class="bi bi-droplet-half"></i>
                </div>
                <h3 class="empty-preview__title">Reporte no generado</h3>
                <p class="empty-preview__description">Defina los filtros y pulse Generar reporte para abrir el layout DevExpress publicado.</p>
            </div>
        }
        else
        {
            <DxDocumentViewer ReportName="@reportName"
                               Height="calc(100vh - 320px)"
                               Width="100%" />
        }
    </div>
</div>

@code {
    private FiltroSaldosAguaPotableCiclo filtro = BuildDefaultFilter();
    private bool isLoading;
    private string? errorMessage;
    private string? reportName;
    private List<CicloLookupDto> ciclos = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var items = await InformesClient.GetCiclosAsync();
            ciclos =
            [
                new CicloLookupDto(0, "Todos"),
                .. items
            ];
        }
        catch (Exception ex)
        {
            errorMessage = $"No fue posible cargar los ciclos: {ex.Message}";
            ciclos = [new CicloLookupDto(0, "Todos")];
        }
    }

    private void GenerarReporte()
    {
        if (!ValidarFiltros())
        {
            reportName = null;
            return;
        }

        isLoading = true;
        errorMessage = null;

        try
        {
            reportName = BuildReportName();
        }
        finally
        {
            isLoading = false;
        }
    }

    private void LimpiarFiltros()
    {
        filtro = BuildDefaultFilter();
        errorMessage = null;
        reportName = null;
    }

    private bool ValidarFiltros()
    {
        if (!filtro.FechaDesde.HasValue)
        {
            errorMessage = "La fecha desde es obligatoria.";
            return false;
        }

        if (!filtro.FechaHasta.HasValue)
        {
            errorMessage = "La fecha hasta es obligatoria.";
            return false;
        }

        if (filtro.FechaDesde.Value.Date > filtro.FechaHasta.Value.Date)
        {
            errorMessage = "La fecha desde no puede ser mayor que la fecha hasta.";
            return false;
        }

        errorMessage = null;
        return true;
    }

    private string BuildReportName()
    {
        var fechaDesde = filtro.FechaDesde!.Value.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);
        var fechaHasta = filtro.FechaHasta!.Value.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture);

        return $"{ReportesWebConstants.CodigoReporteSaldosAguaPotableCiclo}" +
               $"?mode={Uri.EscapeDataString(ReportesWebConstants.LayoutMode.Published)}" +
               $"&FechaDesde={Uri.EscapeDataString(fechaDesde)}" +
               $"&FechaHasta={Uri.EscapeDataString(fechaHasta)}" +
               $"&CicloId={filtro.CicloId.ToString(CultureInfo.InvariantCulture)}";
    }

    private static FiltroSaldosAguaPotableCiclo BuildDefaultFilter()
    {
        var today = DateTime.Today;
        return new FiltroSaldosAguaPotableCiclo
        {
            FechaDesde = new DateTime(today.Year, today.Month, 1),
            FechaHasta = today,
            CicloId = 0
        };
    }

    private sealed class FiltroSaldosAguaPotableCiclo
    {
        public DateTime? FechaDesde { get; set; }

        public DateTime? FechaHasta { get; set; }

        public int CicloId { get; set; }
    }
}
