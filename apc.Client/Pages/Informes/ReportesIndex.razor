@page "/informes/reportes"
@attribute [Authorize(Policy = PermissionNames.Reporteria.View)]
@using apc.Client.Services.Informes
@using SIAD.Core.Constants
@using SIAD.Core.DTOs.Informes
@inject InformesClient InformesClient
@inject NavigationManager NavigationManager
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Reportes Web</PageTitle>

<div class="page-container">
    <div class="header-section">
        <div>
            <h2 class="page-title">Reportes Web</h2>
            <p class="page-subtitle">Diseño y publicación de reportes por empresa.</p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <DxButton Text="Actualizar"
                      Click="LoadAsync"
                      IconCssClass="bi bi-arrow-clockwise"
                      RenderStyle="ButtonRenderStyle.Secondary" />
            <DxButton Text="Datasets"
                      Click="@(() => NavigationManager.NavigateTo("/informes/datasets"))"
                      IconCssClass="bi bi-database"
                      RenderStyle="ButtonRenderStyle.Secondary" />
            <AuthorizeView Policy="@PermissionNames.Reporteria.Create">
                <Authorized>
                    <DxButton Text="Nuevo reporte"
                              Click="OpenCreatePopup"
                              IconCssClass="bi bi-plus-circle"
                              RenderStyle="ButtonRenderStyle.Primary" />
                </Authorized>
            </AuthorizeView>
        </div>
    </div>

    <div class="modern-card p-4">
        @if (isLoading)
        {
            <div class="d-flex justify-content-center py-5">
                <DxWaitIndicator Visible="true" />
            </div>
        }
        else if (items.Count == 0)
        {
            <div class="text-center text-muted py-5">
                No hay reportes web configurados todavía.
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var item in items)
                {
                    <div class="col-12 col-xl-6">
                        <div class="border rounded-3 p-4 h-100 bg-white shadow-sm">
                            <div class="d-flex align-items-start justify-content-between gap-3">
                                <div>
                                    <div class="fw-semibold fs-5">@item.Nombre</div>
                                    <div class="text-muted small">@item.Categoria · @item.Codigo</div>
                                </div>
                                <span class="@GetEstadoCss(item.Estado)">@item.Estado</span>
                            </div>

                            <p class="text-muted mt-3 mb-3">
                                @(string.IsNullOrWhiteSpace(item.Descripcion) ? "Sin descripción configurada." : item.Descripcion)
                            </p>

                            <div class="d-flex flex-wrap gap-3 text-muted small mb-4">
                                <span>Publicado: <strong>@(item.PublishedVersion?.ToString() ?? "N/A")</strong></span>
                                <span>Borrador: <strong>@(item.DraftVersion?.ToString() ?? "N/A")</strong></span>
                            </div>

                            <div class="d-flex flex-wrap gap-2">
                                <DxButton Text="Ver"
                                          Click="@(() => NavigationManager.NavigateTo(item.ViewerRoute))"
                                          IconCssClass="bi bi-eye"
                                          RenderStyle="ButtonRenderStyle.Primary" />

                                <AuthorizeView Policy="@PermissionNames.Reporteria.Edit">
                                    <Authorized>
                                        <DxButton Text="Diseñar"
                                                  Click="@(() => NavigationManager.NavigateTo(item.DesignerRoute))"
                                                  IconCssClass="bi bi-pencil-square"
                                                  RenderStyle="ButtonRenderStyle.Secondary" />
                                        <DxButton Text="Publicar"
                                                  Click="@(() => PublicarGuardedAsync(item.Codigo))"
                                                  Enabled="@CanPublish(item)"
                                                  IconCssClass="bi bi-cloud-arrow-up"
                                                  RenderStyle="ButtonRenderStyle.Secondary" />
                                    </Authorized>
                                </AuthorizeView>

                                <AuthorizeView Policy="@PermissionNames.Reporteria.Delete">
                                    <Authorized>
                                        <DxButton Text="Eliminar"
                                                  Click="@(() => OpenDeletePopupFor(item))"
                                                  Enabled="@CanDelete(item)"
                                                  IconCssClass="bi bi-trash"
                                                  RenderStyle="ButtonRenderStyle.Danger" />
                                    </Authorized>
                                </AuthorizeView>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

<DxPopup @bind-Visible="isCreatePopupVisible"
         Width="620px"
         ShowCloseButton="true"
         HeaderText="Nuevo reporte web">
    <BodyTemplate Context="popupContext">
        <div class="p-2">
            <DxFormLayout ColCountMd="12">
                <DxFormLayoutItem Caption="Código" ColSpanMd="6">
                    <DxTextBox @bind-Text="createModel.Codigo"
                               NullText="ej. estado-cuenta"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Categoría" ColSpanMd="6">
                    <DxTextBox @bind-Text="createModel.Categoria"
                               NullText="General"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Nombre" ColSpanMd="12">
                    <DxTextBox @bind-Text="createModel.Nombre"
                               NullText="Nombre visible del reporte"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Dataset" ColSpanMd="12">
                    <DxComboBox Data="@datasets"
                                TData="ReporteDatasetCatalogoItemDto"
                                TValue="string"
                                ValueFieldName="@nameof(ReporteDatasetCatalogoItemDto.Codigo)"
                                TextFieldName="@nameof(ReporteDatasetCatalogoItemDto.Nombre)"
                                @bind-Value="createModel.DatasetCodigo"
                                NullText="Plantilla en blanco"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Descripción" ColSpanMd="12">
                    <DxMemo @bind-Text="createModel.Descripcion"
                            Rows="4"
                            NullText="Contexto funcional del reporte" />
                </DxFormLayoutItem>
            </DxFormLayout>

            <div class="d-flex justify-content-end gap-2 mt-3">
                <DxButton Text="Cancelar"
                          Click="CloseCreatePopup"
                          RenderStyle="ButtonRenderStyle.Secondary" />
                <DxButton Text="Crear y diseñar"
                          Click="CrearAsync"
                          Enabled="@(!isSaving)"
                          IconCssClass="bi bi-check-circle"
                          RenderStyle="ButtonRenderStyle.Primary" />
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

<DxPopup @bind-Visible="isDeletePopupVisible"
         Width="460px"
         ShowCloseButton="true"
         HeaderText="Eliminar reporte">
    <BodyTemplate Context="popupContext">
        <div class="p-3">
            <p class="mb-3">
                @(deleteCandidate is null
                    ? "No hay reporte seleccionado."
                    : $"Se eliminará el reporte '{deleteCandidate.Nombre}' ({deleteCandidate.Codigo}) y sus layouts asociados. Esta acción no se puede deshacer.")
            </p>

            <div class="d-flex justify-content-end gap-2">
                <DxButton Text="Cancelar"
                          Click="CloseDeletePopupSafe"
                          RenderStyle="ButtonRenderStyle.Secondary" />
                <DxButton Text="Eliminar"
                          Click="DeleteConfirmedAsync"
                          Enabled="@(!isDeleting && deleteCandidate is not null)"
                          IconCssClass="bi bi-trash"
                          RenderStyle="ButtonRenderStyle.Danger" />
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    private List<ReporteDisenoCatalogoItemDto> items = [];
    private List<ReporteDatasetCatalogoItemDto> datasets = [];
    private readonly HashSet<string> publishingCodes = new(StringComparer.OrdinalIgnoreCase);
    private ReporteDisenoCreateDto createModel = new();
    private ReporteDisenoCatalogoItemDto? deleteCandidate;
    private bool isLoading;
    private bool isSaving;
    private bool isCreatePopupVisible;
    private bool isDeletePopupVisible;
    private bool isDeleting;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            isLoading = true;
            items = (await InformesClient.GetReportesDisenoAsync()).OrderBy(x => x.Categoria).ThenBy(x => x.Nombre).ToList();
            datasets = (await InformesClient.GetReportesDatasetsAsync()).Where(x => x.IsActive).OrderBy(x => x.Nombre).ToList();
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions { Title = "Reportes", Text = ex.Message, RenderStyle = ToastRenderStyle.Danger });
            items = [];
            datasets = [];
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreatePopup()
    {
        createModel = new ReporteDisenoCreateDto { Categoria = "General" };
        isCreatePopupVisible = true;
    }

    private void CloseCreatePopup()
    {
        isCreatePopupVisible = false;
    }

    private async Task CrearAsync()
    {
        try
        {
            isSaving = true;
            var created = await InformesClient.CreateReporteDisenoAsync(createModel);
            isCreatePopupVisible = false;
            await LoadAsync();
            ToastService.ShowToast(new ToastOptions { Title = "Reporte creado", Text = $"Reporte '{created.Nombre}' creado con borrador inicial persistido en base de datos.", RenderStyle = ToastRenderStyle.Success });
            NavigationManager.NavigateTo(created.DesignerRoute);
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions { Title = "Reportes", Text = ex.Message, RenderStyle = ToastRenderStyle.Danger });
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task PublicarAsync(string codigo)
    {
        try
        {
            var result = await InformesClient.PublishReporteDisenoAsync(codigo);
            ToastService.ShowToast(new ToastOptions { Title = "Publicación", Text = $"Se publicó la versión {result.PublishedVersion?.ToString() ?? "actual"} de '{result.Nombre}'.", RenderStyle = ToastRenderStyle.Success });
            await LoadAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions { Title = "Publicación", Text = ex.Message, RenderStyle = ToastRenderStyle.Danger });
        }
    }

    private async Task PublicarGuardedAsync(string codigo)
    {
        if (!publishingCodes.Add(codigo))
        {
            return;
        }

        try
        {
            var result = await InformesClient.PublishReporteDisenoAsync(codigo);
            await LoadAsync();
            ToastService.ShowToast(new ToastOptions { Title = "Publicación", Text = $"Se publicó la versión {result.PublishedVersion?.ToString() ?? "actual"} de '{result.Nombre}'.", RenderStyle = ToastRenderStyle.Success });
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions { Title = "Publicación", Text = ex.Message, RenderStyle = ToastRenderStyle.Danger });
        }
        finally
        {
            publishingCodes.Remove(codigo);
        }
    }

    private void OpenDeletePopupFor(ReporteDisenoCatalogoItemDto item)
    {
        if (!CanDelete(item))
        {
            return;
        }

        deleteCandidate = item;
        isDeletePopupVisible = true;
    }

    private async Task DeleteConfirmedAsync()
    {
        if (deleteCandidate is null)
        {
            return;
        }

        try
        {
            isDeleting = true;
            var deletedName = deleteCandidate.Nombre;
            await InformesClient.DeleteReporteDisenoAsync(deleteCandidate.Codigo);
            isDeletePopupVisible = false;
            deleteCandidate = null;
            await LoadAsync();
            ToastService.ShowToast(new ToastOptions { Title = "Reporte eliminado", Text = $"Reporte '{deletedName}' eliminado.", RenderStyle = ToastRenderStyle.Success });
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions { Title = "Eliminar reporte", Text = ex.Message, RenderStyle = ToastRenderStyle.Danger });
        }
        finally
        {
            isDeleting = false;
        }
    }

    private void CloseDeletePopupSafe()
    {
        isDeletePopupVisible = false;
        deleteCandidate = null;
    }

    private static string GetEstadoCss(string estado) => estado switch
    {
        "Publicado" => "badge-status badge-status--success",
        "Borrador pendiente" => "badge-status badge-status--warning",
        "Solo borrador" => "badge-status badge-status--warning",
        "Inactivo" => "badge-status badge-status--danger",
        _ => "badge-status"
    };

    private bool CanPublish(ReporteDisenoCatalogoItemDto item)
        => item.TieneBorrador && !publishingCodes.Contains(item.Codigo);

    private bool CanDelete(ReporteDisenoCatalogoItemDto item)
        => !isDeleting && !publishingCodes.Contains(item.Codigo);
}

