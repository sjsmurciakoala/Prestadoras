@page "/informes/cobranzas/saldo-clientes-antiguedad"
@attribute [Authorize(Policy = PermissionNames.Reporteria.View)]
@using System.Globalization
@using SIAD.Core.DTOs.Rutas
@using apc.Client.Services.Informes
@inject InformesClient InformesClient
@inject NavigationManager NavigationManager
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Saldo de clientes segun antigüedad</PageTitle>

<div class="page-container reporte-saldo-clientes-antiguedad">
    <div class="header-section">
        <div>
            <h2 class="page-title">Saldo de clientes segun antigüedad</h2>
            <p class="page-subtitle">Seleccione corte, antigüedad, estado y ciclo para generar el PDF del reporte DevExpress.</p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <DxButton Text="Volver"
                      Click="@(() => NavigationManager.NavigateTo("/informes/cobranzas"))"
                      IconCssClass="bi bi-arrow-left"
                      RenderStyle="ButtonRenderStyle.Secondary" />
            <DxButton Text="Limpiar"
                      Click="LimpiarFiltros"
                      IconCssClass="bi bi-eraser"
                      RenderStyle="ButtonRenderStyle.Secondary" />
            <DxButton Text="Generar PDF"
                      Click="GenerarPdf"
                      IconCssClass="bi bi-file-earmark-pdf"
                      RenderStyle="ButtonRenderStyle.Primary" />
        </div>
    </div>

    <div class="modern-card p-4">
        <DxFormLayout ColCountMd="12">
            <DxFormLayoutItem Caption="Fecha de corte" ColSpanMd="3">
                <DxDateEdit @bind-Date="fechaCorte"
                            NullText="Seleccione fecha"
                            DisplayFormat="dd/MM/yyyy" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Dias minimos" ColSpanMd="3">
                <DxSpinEdit @bind-Value="diasMinimos"
                            MinValue="1"
                            MaxValue="999"
                            Increment="30" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Estado cliente" ColSpanMd="3">
                <DxComboBox Data="@estadosCliente"
                            @bind-Value="estadoClienteId"
                            ValueFieldName="@nameof(EstadoClienteOption.Id)"
                            TextFieldName="@nameof(EstadoClienteOption.Nombre)"
                            NullText="Todos"
                            DropDownStyleMode="DropDownStyleMode.DropDownList" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Ciclo" ColSpanMd="3">
                <DxComboBox Data="@ciclos"
                            @bind-Value="cicloId"
                            ValueFieldName="@nameof(CicloLookupDto.Id)"
                            TextFieldName="@nameof(CicloLookupDto.Descripcion)"
                            NullText="Todos"
                            FilteringMode="DataGridFilteringMode.Contains"
                            DropDownStyleMode="DropDownStyleMode.DropDownList" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Reporte" ColSpanMd="6">
                <DxTextBox Text="Saldo de clientes segun antigüedad"
                           ReadOnly="true"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never" />
            </DxFormLayoutItem>
        </DxFormLayout>
    </div>

    <div class="modern-card p-3 viewer-shell">
        @if (string.IsNullOrWhiteSpace(pdfUrl))
        {
            <div class="empty-preview">
                <div class="empty-preview__icon">
                    <i class="bi bi-file-earmark-pdf"></i>
                </div>
                <h3 class="empty-preview__title">PDF no generado</h3>
                <p class="empty-preview__description">
                    Defina los filtros y pulse Generar PDF para previsualizar el informe.
                </p>
            </div>
        }
        else
        {
            <iframe class="pdf-frame"
                    src="@pdfUrl"
                    title="Saldo de clientes segun antigüedad"></iframe>
        }
    </div>
</div>

@code {
    private sealed record EstadoClienteOption(int Id, string Nombre);

    private static readonly List<EstadoClienteOption> estadosCliente =
    [
        new(0, "Todos"),
        new(1, "Activos"),
        new(2, "Inactivos")
    ];

    private DateTime? fechaCorte = DateTime.Today;
    private int diasMinimos = 60;
    private int estadoClienteId;
    private int cicloId;
    private string? pdfUrl;
    private List<CicloLookupDto> ciclos = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var items = await InformesClient.GetCiclosAsync();
            ciclos =
            [
                new CicloLookupDto(0, "Todos"),
                .. items
            ];
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions { Title = "Informes", Text = $"No fue posible cargar los ciclos: {ex.Message}", RenderStyle = ToastRenderStyle.Danger });
            ciclos = [new CicloLookupDto(0, "Todos")];
        }
    }

    private void GenerarPdf()
    {
        if (!fechaCorte.HasValue)
        {
            ToastService.ShowToast(new ToastOptions { Title = "Informes", Text = "La fecha de corte es obligatoria.", RenderStyle = ToastRenderStyle.Danger });
            pdfUrl = null;
            return;
        }

        if (diasMinimos <= 0)
        {
            ToastService.ShowToast(new ToastOptions { Title = "Informes", Text = "Los dias minimos deben ser mayores que cero.", RenderStyle = ToastRenderStyle.Danger });
            pdfUrl = null;
            return;
        }

        pdfUrl =
            $"api/informes/reportes/{SIAD.Core.Constants.ReportesWebConstants.CodigoReporteSaldoClientesAntiguedad}/pdf" +
            $"?fechaCorte={Uri.EscapeDataString(fechaCorte.Value.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture))}" +
            $"&diasMinimos={diasMinimos.ToString(CultureInfo.InvariantCulture)}" +
            $"&estadoCliente={estadoClienteId.ToString(CultureInfo.InvariantCulture)}" +
            $"&cicloId={cicloId.ToString(CultureInfo.InvariantCulture)}";
    }

    private void LimpiarFiltros()
    {
        fechaCorte = DateTime.Today;
        diasMinimos = 60;
        estadoClienteId = 0;
        cicloId = 0;
        pdfUrl = null;
    }
}
