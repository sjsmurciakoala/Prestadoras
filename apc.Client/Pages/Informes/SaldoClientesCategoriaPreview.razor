@page "/informes/medicion/saldo-clientes-categoria"
@attribute [Authorize(Policy = PermissionNames.Reporteria.View)]
@using System.Globalization
@using SIAD.Core.DTOs.Informes
@using apc.Client.Services.Informes
@inject InformesClient InformesClient
@inject NavigationManager NavigationManager

<PageTitle>SIAD - Saldo de clientes por categoria</PageTitle>

<div class="page-container reporte-saldo-clientes-categoria">
    <div class="header-section">
        <div>
            <h2 class="page-title">Saldo de clientes por categoria</h2>
            <p class="page-subtitle">Seleccione la fecha de corte y genere el PDF del reporte DevExpress.</p>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <DxButton Text="Volver"
                      Click="@(() => NavigationManager.NavigateTo("/informes/medicion"))"
                      IconCssClass="bi bi-arrow-left"
                      RenderStyle="ButtonRenderStyle.Secondary" />
            <DxButton Text="Limpiar"
                      Click="LimpiarFiltros"
                      IconCssClass="bi bi-eraser"
                      RenderStyle="ButtonRenderStyle.Secondary" />
            <DxButton Text="Generar PDF"
                      Click="GenerarPdf"
                      IconCssClass="bi bi-file-earmark-pdf"
                      RenderStyle="ButtonRenderStyle.Primary" />
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <SiadAlert AlertType="AlertType.Danger" CssClass="mb-3">@errorMessage</SiadAlert>
    }

    <div class="modern-card p-4">
        <DxFormLayout ColCountMd="12">
            <DxFormLayoutItem Caption="Fecha de corte" ColSpanMd="4">
                <DxDateEdit @bind-Date="fechaCorte"
                            NullText="Seleccione fecha"
                            DisplayFormat="dd/MM/yyyy" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Categoria" ColSpanMd="4">
                <DxComboBox Data="@categorias"
                            @bind-Value="categoriaServicioId"
                            ValueFieldName="@nameof(ServicioCategoriaLookupDto.Id)"
                            TextFieldName="@nameof(ServicioCategoriaLookupDto.Nombre)"
                            NullText="Todas"
                            FilteringMode="DataGridFilteringMode.Contains"
                            DropDownStyleMode="DropDownStyleMode.DropDownList" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Estado cliente" ColSpanMd="4">
                <DxComboBox Data="@estadosCliente"
                            @bind-Value="estadoClienteId"
                            ValueFieldName="@nameof(EstadoClienteOption.Id)"
                            TextFieldName="@nameof(EstadoClienteOption.Nombre)"
                            NullText="Todos"
                            DropDownStyleMode="DropDownStyleMode.DropDownList" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Reporte" ColSpanMd="4">
                <DxTextBox Text="Saldo de clientes por categoria"
                           ReadOnly="true"
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never" />
            </DxFormLayoutItem>
        </DxFormLayout>
    </div>

    <div class="modern-card p-3 viewer-shell">
        @if (string.IsNullOrWhiteSpace(pdfUrl))
        {
            <div class="empty-preview">
                <div class="empty-preview__icon">
                    <i class="bi bi-file-earmark-pdf"></i>
                </div>
                <h3 class="empty-preview__title">PDF no generado</h3>
                <p class="empty-preview__description">
                    Defina la fecha de corte y pulse Generar PDF para previsualizar el informe.
                </p>
            </div>
        }
        else
        {
            <iframe class="pdf-frame"
                    src="@pdfUrl"
                    title="Saldo de clientes por categoria"></iframe>
        }
    </div>
</div>

@code {
    private sealed record EstadoClienteOption(int Id, string Nombre);

    private static readonly List<EstadoClienteOption> estadosCliente =
    [
        new(0, "Todos"),
        new(1, "Activos"),
        new(2, "Inactivos")
    ];

    private DateTime? fechaCorte = DateTime.Today;
    private int categoriaServicioId;
    private int estadoClienteId;
    private string? errorMessage;
    private string? pdfUrl;
    private List<ServicioCategoriaLookupDto> categorias = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var items = await InformesClient.GetCategoriasServicioAsync();
            categorias =
            [
                new ServicioCategoriaLookupDto(0, "Todas"),
                .. items
            ];
        }
        catch (Exception ex)
        {
            errorMessage = $"No fue posible cargar las categorias: {ex.Message}";
            categorias = [new ServicioCategoriaLookupDto(0, "Todas")];
        }
    }

    private void GenerarPdf()
    {
        if (!fechaCorte.HasValue)
        {
            errorMessage = "La fecha de corte es obligatoria.";
            pdfUrl = null;
            return;
        }

        errorMessage = null;
        pdfUrl =
            $"api/informes/reportes/{SIAD.Core.Constants.ReportesWebConstants.CodigoReporteSaldoClientesCategoria}/pdf" +
            $"?fechaCorte={Uri.EscapeDataString(fechaCorte.Value.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture))}" +
            $"&categoriaServicioId={categoriaServicioId.ToString(CultureInfo.InvariantCulture)}" +
            $"&estadoCliente={estadoClienteId.ToString(CultureInfo.InvariantCulture)}";
    }

    private void LimpiarFiltros()
    {
        fechaCorte = DateTime.Today;
        categoriaServicioId = 0;
        estadoClienteId = 0;
        errorMessage = null;
        pdfUrl = null;
    }
}
