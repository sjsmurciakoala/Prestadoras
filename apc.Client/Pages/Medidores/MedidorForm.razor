@using DevExpress.Blazor
@using SIAD.Core.DTOs.Medidores
@using SIAD.Core.DTOs.Catalogos

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" Context="editContext">
    <DataAnnotationsValidator />

    @if (editContext.GetValidationMessages().Any())
    {
        <div class="alert alert-danger mb-3 shadow-sm">
            <h6 class="alert-heading"><i class="bi bi-exclamation-circle-fill me-2"></i>Atencion</h6>
            <DxValidationSummary />
        </div>
    }

    <DxFormLayout>
        <DxFormLayoutItem Caption="Numero *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Numero"
                       NullText="Numero del medidor"
                       MaxLength="50" />
            <ValidationMessage For="() => Model.Numero" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Marca" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Marca"
                       NullText="Marca del medidor"
                       MaxLength="50" />
            <ValidationMessage For="() => Model.Marca" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Fecha instalacion" ColSpanMd="4">
            <DxDateEdit T="DateTime?"
                        @bind-Date="Model.FechaInstalacion"
                        DisplayFormat="d"
                        NullText="Seleccione fecha" />
            <ValidationMessage For="() => Model.FechaInstalacion" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Diametro" ColSpanMd="4">
            <DxSpinEdit TValue="decimal?"
                        @bind-Value="Model.Diametro"
                        Min="0"
                        Max="99.99"
                        Increment="0.01m"
                        DisplayFormat="n2" />
            <ValidationMessage For="() => Model.Diametro" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Acueducto" ColSpanMd="4">
            <DxTextBox @bind-Text="Model.Acueducto"
                       NullText="Acueducto"
                       MaxLength="20" />
            <ValidationMessage For="() => Model.Acueducto" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Clase de medidor" ColSpanMd="4">
            <DxComboBox Data="@ClasesMedidor"
                        @bind-Value="Model.ClaseMedidorCodigo"
                        ValueFieldName="@nameof(ClaseMedidorLookupDto.Codigo)"
                        TextFieldName="@nameof(ClaseMedidorLookupDto.Descripcion)"
                        NullText="Sin clasificar"
                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
            <ValidationMessage For="() => Model.ClaseMedidorCodigo" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Empleado instalador" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Empleado"
                       NullText="Nombre del instalador"
                       MaxLength="50" />
            <ValidationMessage For="() => Model.Empleado" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Estado" ColSpanMd="6">
            <Template>
                <div class="pt-2">
                    <DxCheckBox @bind-Checked="Model.Activo"
                                CheckType="CheckType.Switch"
                                LabelText="Activo" />
                </div>
            </Template>
        </DxFormLayoutItem>
    </DxFormLayout>

    <ValidationSummary class="text-danger mb-3" />

    <div class="d-flex justify-content-end gap-2">
        <DxButton ButtonType="ButtonType.Submit"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  SubmitFormOnClick="true"
                  Enabled="@(!IsBusy)" />
        <DxButton ButtonType="ButtonType.Normal"
                  Text="Cancelar"
                  Enabled="@(!IsBusy)"
                  Click="Cancel" />
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public MedidorEditDto Model { get; set; } = default!;

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public IReadOnlyList<ClaseMedidorLookupDto> ClasesMedidor { get; set; } = [];

    private async Task HandleValidSubmit()
    {
        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }
}
