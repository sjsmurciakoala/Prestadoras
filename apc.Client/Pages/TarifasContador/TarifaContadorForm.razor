@using DevExpress.Blazor
@using SIAD.Core.DTOs.TarifasContador
@using SIAD.Core.DTOs.Solicitudes

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" Context="editContext">
    <DataAnnotationsValidator />

    @if (editContext.GetValidationMessages().Any())
    {
        <div class="alert alert-danger mb-3 shadow-sm">
            <h6 class="alert-heading"><i class="bi bi-exclamation-circle-fill me-2"></i>Atencion</h6>
            <DxValidationSummary />
        </div>
    }

    <DxFormLayout>
        <DxFormLayoutItem Caption="Tipo *" ColSpanMd="4">
            <DxComboBox Data="@TiposUso"
                        @bind-Value="Model.Tipo"
                        ValueFieldName="Key"
                        TextFieldName="Value"
                        NullText="Seleccione..."
                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                        @bind-Value:after="NotifyTipoChanged" />
            <ValidationMessage For="() => Model.Tipo" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Categoria" ColSpanMd="4">
            <DxComboBox Data="@Categorias"
                        @bind-Value="Model.CategoriaId"
                        ValueFieldName="Id"
                        TextFieldName="Nombre"
                        NullText="Seleccione..."
                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                        @bind-Value:after="NotifyCategoriaChanged" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Letra" ColSpanMd="4">
            <DxComboBox Data="@CodigosTarifa"
                        @bind-Value="Model.Codigo"
                        AllowUserInput="false"
                        Enabled="@(CodigosTarifa.Count > 0)"
                        NullText="@CodigoNullText"
                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
        </DxFormLayoutItem>

        @if (Model.Tipo > 0 && Model.CategoriaId.HasValue && CodigosTarifa.Count == 0)
        {
            <DxFormLayoutItem ColSpanMd="12">
                <div class="text-warning small">
                    No hay letras base disponibles para la categoria seleccionada.
                </div>
            </DxFormLayoutItem>
        }

        <DxFormLayoutItem Caption="Descripcion" ColSpanMd="12">
            <DxTextBox @bind-Text="Model.Descripcion"
                       NullText="Descripcion"
                       MaxLength="250" />
            <ValidationMessage For="() => Model.Descripcion" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Minimo" ColSpanMd="4">
            <DxSpinEdit TValue="decimal?"
                        @bind-Value="Model.Minimo"
                        Min="0"
                        Increment="1"
                        DisplayFormat="n0" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Maximo" ColSpanMd="4">
            <DxSpinEdit TValue="decimal?"
                        @bind-Value="Model.Maximo"
                        Min="0"
                        Increment="1"
                        DisplayFormat="n0" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Cuota" ColSpanMd="4">
            <DxSpinEdit TValue="decimal?"
                        @bind-Value="Model.Cuota"
                        Min="0"
                        Increment="0.01m"
                        DisplayFormat="n2" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Valor base" ColSpanMd="4">
            <DxSpinEdit TValue="decimal?"
                        @bind-Value="Model.ValorBase"
                        Min="0"
                        Increment="0.01m"
                        DisplayFormat="n2" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Alquiler" ColSpanMd="4">
            <DxSpinEdit TValue="decimal?"
                        @bind-Value="Model.Alquiler"
                        Min="0"
                        Increment="0.01m"
                        DisplayFormat="n2" />
        </DxFormLayoutItem>
    </DxFormLayout>

    <ValidationSummary class="text-danger mb-3" />

    <div class="d-flex justify-content-end gap-2">
        <DxButton ButtonType="ButtonType.Submit"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  SubmitFormOnClick="true"
                  Enabled="@(!IsBusy)" />
        <DxButton ButtonType="ButtonType.Normal"
                  Text="Cancelar"
                  Enabled="@(!IsBusy)"
                  Click="Cancel" />
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public TarifaContadorEditDto Model { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<KeyValuePair<int, string>> TiposUso { get; set; } = Array.Empty<KeyValuePair<int, string>>();

    [Parameter]
    public IReadOnlyList<SolicitudCategoriaDto> Categorias { get; set; } = Array.Empty<SolicitudCategoriaDto>();

    [Parameter]
    public IReadOnlyList<string> CodigosTarifa { get; set; } = Array.Empty<string>();

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnTipoChanged { get; set; }

    [Parameter]
    public EventCallback OnCategoriaChanged { get; set; }

    private string CodigoNullText
        => Model.Tipo <= 0 || !Model.CategoriaId.HasValue
            ? "Seleccione tipo y categoria"
            : CodigosTarifa.Count == 0
                ? "Sin letras base"
                : "Seleccione letra";

    private async Task HandleValidSubmit()
    {
        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }

    private async Task NotifyTipoChanged()
    {
        if (OnTipoChanged.HasDelegate)
        {
            await OnTipoChanged.InvokeAsync();
        }
    }

    private async Task NotifyCategoriaChanged()
    {
        if (OnCategoriaChanged.HasDelegate)
        {
            await OnCategoriaChanged.InvokeAsync();
        }
    }
}
