@using SIAD.Core.DTOs.Catalogos
@using SIAD.Core.DTOs.Clientes
@using SIAD.Core.DTOs.Solicitudes
@using SIAD.Core.Constants
@inject apc.Client.Services.Clientes.ClientesClient ClientesClient
@inject apc.Client.Services.Solicitudes.SolicitudesClient SolicitudesClient
@inject apc.Client.Services.Catalogos.CatalogosClient CatalogosClient
@inject IToastNotificationService ToastService

<div class="cliente-config-tarifa-container">
    <DxToastProvider Name="ConfigTarifaToast" MaxToastCount="3" />
    @if (isLoading)
    {
        <div class="text-center p-4">
            <DxLoadingPanel Visible="true" Text="Cargando configuración..." />
            <div style="height:90px"></div>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(error))
    {
        <DxAlert AlertType="AlertType.Danger">@error</DxAlert>
    }
    else if (header is null)
    {
        <div class="text-muted text-center p-4">No se encontraron datos del cliente.</div>
    }
    else
    {
        <div class="section-header mb-3">
            <i class="bi bi-sliders"></i>
            <h4 class="m-0">Configuración de Tarifas</h4>
        </div>

        <div class="modern-card mb-3">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Cliente</label>
                    <input class="form-control" value="@header.ClienteClave" readonly />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Nombre</label>
                    <input class="form-control" value="@header.ClienteNombre" readonly />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Medidor</label>
                    <input class="form-control" value="@GetMedidorTexto()" readonly />
                </div>
                <div class="col-md-12">
                    <label class="form-label">Dirección</label>
                    <input class="form-control" value="@header.ClienteDireccion" readonly />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Servicio</label>
                    <input class="form-control" value="@GetTipoUsoTexto()" readonly />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Categoría</label>
                    <select class="form-select" @onchange="OnCategoriaChanged" disabled="@isSaving">
                        @foreach (var cat in categorias)
                        {
                            <option value="@cat.Id" selected="@(cat.Id == categoriaSeleccionada)">
                                @cat.Nombre
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Letra</label>
                    <input class="form-control" value="@header.LetraCodigo" readonly />
                </div>
            </div>
        </div>

        <div class="modern-card">
            <AuthorizeView Policy="@PermissionNames.Ventas.Edit">
                <div class="d-flex flex-wrap gap-2 align-items-end mb-3">
                    <div style="min-width: 260px;">
                        <label class="form-label">Agregar servicio</label>
                        <select class="form-select" @bind="servicioSeleccionadoId" disabled="@isSaving">
                            <option value="0">-- Seleccione --</option>
                            @foreach (var s in serviciosCatalogo)
                            {
                                <option value="@s.Id">@s.Codigo - @s.Nombre</option>
                            }
                        </select>
                    </div>
                    <div style="min-width: 160px;">
                        <label class="form-label">Monto</label>
                        <input type="number"
                               class="form-control"
                               step="0.01"
                               @bind="servicioNuevoMonto"
                               disabled="@isSaving" />
                    </div>
                    <div class="form-check mb-1">
                        <input class="form-check-input" type="checkbox" id="servicioAplicable"
                               @bind="servicioNuevoAplicable" disabled="@isSaving" />
                        <label class="form-check-label" for="servicioAplicable">Aplicable</label>
                    </div>
                    <DxButton Text="Agregar"
                              CssClass="btn-icon"
                              RenderStyle="ButtonRenderStyle.Secondary"
                              RenderStyleMode="ButtonRenderStyleMode.Outline"
                              Enabled="@(servicioSeleccionadoId > 0 && !isSaving)"
                              Click="AgregarServicioAsync" />
                </div>
            </AuthorizeView>

            <div class="table-responsive">
                <table class="table table-sm table-bordered table-striped align-middle">
                    <thead>
                        <tr>
                            <th style="width:90px;">Código</th>
                            <th>Descripción</th>
                            <th style="width:110px;">Aplicable</th>
                            <th style="width:140px;" class="text-end">Monto</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in detalles)
                        {
                            <tr>
                                <td>@item.ServicioCodigo</td>
                                <td>@item.DescripcionTasa</td>
                                <td class="text-center">
                                    <DxCheckBox @bind-Checked="item.ConfiguracionTasasDetalleAplicaservicio"
                                                @bind-Checked:after="OnDetalleChanged" />
                                </td>
                                <td class="text-end">
                                    <input type="number"
                                           class="form-control form-control-sm text-end"
                                           step="0.01"
                                           @bind="item.ConfiguracionTasasDetalleMonto"
                                           @bind:after="OnDetalleChanged" />
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Total</td>
                            <td class="text-end fw-bold">@TotalMonto.ToString("N2")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <DxButton Text="Guardar"
                          CssClass="btn-icon"
                          RenderStyle="ButtonRenderStyle.Primary"
                          RenderStyleMode="ButtonRenderStyleMode.Contained"
                          Enabled="@(detalles.Count > 0 && !isSaving)"
                          Click="GuardarAsync" />
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    [EditorRequired]
    public int ClienteId { get; set; }

    private ClienteConfiguracionTarifaHeaderDto? header;
    private List<ClienteConfiguracionTarifaDetalleDto> detalles = new();
    private List<SolicitudCategoriaDto> categorias = new();
    private List<TipoUsoLookupDto> tiposUso = new();
    private List<ServicioLookupDto> serviciosCatalogo = new();
    private int? categoriaSeleccionada;
    private int servicioSeleccionadoId;
    private decimal servicioNuevoMonto;
    private bool servicioNuevoAplicable = true;
    private bool isLoading = true;
    private bool isSaving;
    private string? error;

    private decimal TotalMonto => detalles
        .Where(d => d.ConfiguracionTasasDetalleAplicaservicio)
        .Sum(d => d.ConfiguracionTasasDetalleMonto);

    protected override async Task OnParametersSetAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        isLoading = true;
        error = null;
        detalles.Clear();

        try
        {
            var headerTask = ClientesClient.ObtenerConfiguracionTarifaHeaderAsync(ClienteId);
            var categoriasTask = SolicitudesClient.ObtenerCategoriasAsync();
            var tiposUsoTask = CatalogosClient.ObtenerTiposUsoAsync();
            var serviciosTask = CatalogosClient.ObtenerServiciosAsync();

            await Task.WhenAll(headerTask, categoriasTask, tiposUsoTask, serviciosTask);

            header = headerTask.Result;
            categorias = categoriasTask.Result ?? new List<SolicitudCategoriaDto>();
            tiposUso = tiposUsoTask.Result ?? new List<TipoUsoLookupDto>();
            serviciosCatalogo = serviciosTask.Result ?? new List<ServicioLookupDto>();

            categoriaSeleccionada = header?.ClienteCategoriaId ?? categorias.FirstOrDefault()?.Id;

            await CargarDetalleAsync();
        }
        catch (Exception ex)
        {
            error = $"Error al cargar la configuración: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CargarDetalleAsync()
    {
        if (header is null)
        {
            detalles = new();
            return;
        }

        var data = await ClientesClient.ObtenerConfiguracionTarifaDetalleAsync(ClienteId, categoriaSeleccionada);
        detalles = data.ToList();
        StateHasChanged();
    }

    private async Task OnCategoriaChanged(ChangeEventArgs args)
    {
        if (args.Value is null)
        {
            return;
        }

        if (int.TryParse(args.Value.ToString(), out var id))
        {
            categoriaSeleccionada = id;
            await CargarDetalleAsync();
        }
    }

    private void OnDetalleChanged()
    {
        StateHasChanged();
    }

    private async Task AgregarServicioAsync()
    {
        if (servicioSeleccionadoId <= 0)
        {
            ShowToast("Atención", "Seleccione un servicio.", ToastRenderStyle.Warning);
            return;
        }

        if (detalles.Any(d => d.ServiciosId == servicioSeleccionadoId))
        {
            ShowToast("Atención", "El servicio ya está en la lista.", ToastRenderStyle.Warning);
            return;
        }

        isSaving = true;
        try
        {
            var request = new ClienteConfiguracionTarifaAddRequest(
                servicioSeleccionadoId,
                servicioNuevoMonto,
                servicioNuevoAplicable);

            var response = await ClientesClient.AgregarConfiguracionTarifaServicioAsync(ClienteId, request);
            if (response?.Success == true)
            {
                ShowToast("Éxito", response.Message, ToastRenderStyle.Success);
                servicioSeleccionadoId = 0;
                servicioNuevoMonto = 0m;
                servicioNuevoAplicable = true;
                await CargarDetalleAsync();
            }
            else
            {
                ShowToast("Error", response?.Message ?? "No se pudo agregar el servicio.", ToastRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error", $"Error al agregar: {ex.Message}", ToastRenderStyle.Danger);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task GuardarAsync()
    {
        if (categoriaSeleccionada is null)
        {
            ShowToast("Atención", "Seleccione una categoría válida.", ToastRenderStyle.Warning);
            return;
        }

        isSaving = true;

        try
        {
            var request = new ClienteConfiguracionTarifaUpdateRequest(
                categoriaSeleccionada.Value,
                detalles.Select(d => new ClienteConfiguracionTarifaUpdateItemDto(
                    d.ConfiguracionTasasDetalleId,
                    d.ConfiguracionTasasDetalleMonto,
                    d.ConfiguracionTasasDetalleAplicaservicio)).ToList());

            var response = await ClientesClient.ActualizarConfiguracionTarifaAsync(ClienteId, request);
            if (response?.Success == true)
            {
                ShowToast("Éxito", response.Message, ToastRenderStyle.Success);
            }
            else
            {
                ShowToast("Error", response?.Message ?? "No se pudo guardar la configuración.", ToastRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error", $"Error al guardar: {ex.Message}", ToastRenderStyle.Danger);
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetTipoUsoTexto()
    {
        if (header?.TipoUsoCodigo is null)
        {
            return "-";
        }

        var item = tiposUso.FirstOrDefault(t => t.Codigo == header.TipoUsoCodigo);
        return item is null ? header.TipoUsoCodigo : item.Descripcion;
    }

    private string GetMedidorTexto()
    {
        if (header?.ClienteTieneMedidor == false)
        {
            return "No tiene medidor";
        }

        return header?.MedidorNumero ?? "-";
    }

    private void ShowToast(string title, string message, ToastRenderStyle style)
    {
        ToastService.ShowToast(new ToastOptions
        {
            Title = title,
            Text = message,
            RenderStyle = style,
            ProviderName = "ConfigTarifaToast"
        });
    }
}

