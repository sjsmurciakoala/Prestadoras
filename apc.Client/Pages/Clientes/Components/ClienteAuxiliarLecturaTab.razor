@using System.Globalization
@using SIAD.Core.DTOs.AuxiliarLectura
@using apc.Client.Services.AuxiliarLectura
@inject AuxiliarLecturaClient AuxiliarLecturaClient
@inject IToastNotificationService ToastService

<div class="d-flex flex-column gap-3">
    <!-- Filtros -->
    <DxFormLayout CssClass="mb-3">
        <DxFormLayoutItem Caption="Año">
            <DxSpinEdit @bind-Value="@auxiliarFiltro.Anio" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Mes">
            <DxSpinEdit @bind-Value="@auxiliarFiltro.Mes" Min="1" Max="12" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Ciclo">
            <DxTextBox @bind-Text="@auxiliarFiltro.Ciclo" Placeholder="Opcional" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Solo Pendientes">
            <DxCheckBox @bind-Checked="@auxiliarFiltro.SoloPendientes" />
        </DxFormLayoutItem>
    </DxFormLayout>

    <!-- Botones de acciones -->
    <div class="d-flex gap-2 mb-3">
        <DxButton Text="Cargar" Click="@LoadAuxiliarLecturasAsync" IconCssClass="oi oi-reload" />
        <DxButton Text="Generar Período" Click="@MostrarPopupGenerarPeriodo" IconCssClass="oi oi-plus" />
        <DxButton Text="Carga Masiva" Click="@MostrarPopupCargaMasiva" IconCssClass="oi oi-data-transfer-download" />
        <DxButton Text="Cerrar Período" Click="@CerrarPeriodoAsync" IconCssClass="oi oi-lock-locked" />
        <DxButton Text="Eliminar Período" Click="@EliminarPeriodoAsync" IconCssClass="oi oi-trash" />
    </div>

    <!-- Listado de Auxiliares -->
    @if (auxiliarLoading)
    {
        <DxSkeletonLine />
        <DxSkeletonLine />
    }
    else if (!string.IsNullOrEmpty(auxiliarError))
    {
        <DxAlert AlertType="AlertType.Danger">@auxiliarError</DxAlert>
    }
    else if (auxiliarLecturas.Count == 0)
    {
        <DxAlert AlertType="AlertType.Info">No hay registros de lecturas para el período seleccionado.</DxAlert>
    }
    else
    {
        <DxDataGrid Data="@auxiliarLecturas"
                    ShowSearchBox="true"
                    ShowFilterRow="false"
                    ShowPager="true"
                    PageSize="10"
                    CssClass="w-100">
                        <Columns>
                <DxDataGridColumn Field="@nameof(AuxiliarLecturaDto.Clave)" Caption="Clave" Width="100px" />
                <DxDataGridColumn Field="@nameof(AuxiliarLecturaDto.Cliente)" Caption="Cliente" Width="200px" />
                <DxDataGridColumn Field="@nameof(AuxiliarLecturaDto.Contador)" Caption="Contador" Width="100px" />
                <DxDataGridColumn Field="@nameof(AuxiliarLecturaDto.LecturaActual)" Caption="Lectura" Width="100px" />
                <DxDataGridColumn Field="@nameof(AuxiliarLecturaDto.FechaLectura)" Caption="Fecha" Width="120px" />
                <DxDataGridColumn Field="@nameof(AuxiliarLecturaDto.Usuario)" Caption="Usuario" Width="100px" />
            </Columns>
        </DxDataGrid>
    }

    <!-- Popup: Generar Período -->
    <DxPopup Visible="@generarPopupVisible" 
             VisibleChanged="@(v => generarPopupVisible = v)"
             Width="600px"
             HeaderText="Generar Nuevo Período">
        <BodyTemplate Context="popupContext">
            <DxFormLayout>
                <DxFormLayoutItem Caption="Año">
                    <DxSpinEdit @bind-Value="@generarPeriodoModel.Anio" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Mes">
                    <DxSpinEdit @bind-Value="@generarPeriodoModel.Mes" Min="1" Max="12" />
                </DxFormLayoutItem>
            </DxFormLayout>
        </BodyTemplate>
        <FooterTemplate>
            <DxButton Text="Generar" Click="@GenerarPeriodoAsync" />
            <DxButton Text="Cancelar" Click="@(() => generarPopupVisible = false)" />
        </FooterTemplate>
    </DxPopup>

    <!-- Popup: Carga Masiva -->
    <DxPopup Visible="@cargaMasivaPopupVisible" 
             VisibleChanged="@(v => cargaMasivaPopupVisible = v)"
             Width="800px"
             HeaderText="Carga Masiva de Lecturas">
        <BodyTemplate Context="popupContext">
            @if (!string.IsNullOrEmpty(cargaMasivaError))
            {
                <DxAlert AlertType="AlertType.Danger">@cargaMasivaError</DxAlert>
            }
            <div class="alert alert-info">
                <strong>Formato:</strong> clave;contador;anterior;actual;usuario (separado por punto y coma, una línea por lectura)
            </div>
            <DxFormLayout>
                <DxFormLayoutItem Caption="Año">
                    <DxSpinEdit @bind-Value="@cargaMasivaModel.Anio" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Mes">
                    <DxSpinEdit @bind-Value="@cargaMasivaModel.Mes" Min="1" Max="12" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Ciclo">
                    <DxTextBox @bind-Text="@cargaMasivaModel.Ciclo" Placeholder="Opcional" />
                </DxFormLayoutItem>
            </DxFormLayout>
            <DxFormLayout>
                <DxFormLayoutItem Caption="Contenido">
                    <DxMemo @bind-Text="cargaMasivaModel.Contenido"
                            Rows="10"
                            NullText="Ingresa las lecturas aquí..." />
                </DxFormLayoutItem>
            </DxFormLayout>
        </BodyTemplate>
        <FooterTemplate>
            <DxButton Text="Enviar" Click="@EnviarCargaMasivaAsync" Enabled="@(!cargaMasivaGuardando)" />
            <DxButton Text="Cancelar" Click="@CancelarCargaMasiva" />
        </FooterTemplate>
    </DxPopup>
</div>

@code {
    private AuxiliarLecturaFilterDto auxiliarFiltro = new()
    {
        Anio = DateTime.Now.Year,
        Mes = DateTime.Now.Month,
        SoloPendientes = false
    };

    private List<AuxiliarLecturaDto> auxiliarLecturas = new();
    private bool auxiliarLoading;
    private string? auxiliarError;

    private bool generarPopupVisible;
    private GenerarPeriodoModel generarPeriodoModel = new(DateTime.Now.Year, DateTime.Now.Month);

    private bool cargaMasivaPopupVisible;
    private bool cargaMasivaGuardando;
    private string? cargaMasivaError;
    private CargaMasivaModel cargaMasivaModel = new();

    private class GenerarPeriodoModel
    {
        public int Anio { get; set; }
        public int Mes { get; set; }

        public GenerarPeriodoModel(int anio, int mes)
        {
            Anio = anio;
            Mes = mes;
        }
    }

    private class CargaMasivaModel
    {
        public int Anio { get; set; } = DateTime.Now.Year;
        public int Mes { get; set; } = DateTime.Now.Month;
        public string? Ciclo { get; set; }
        public string Contenido { get; set; } = string.Empty;
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadAuxiliarLecturasAsync();
    }

    private async Task LoadAuxiliarLecturasAsync()
    {
        if (auxiliarLoading)
            return;

        auxiliarLoading = true;
        auxiliarError = null;

        try
        {
            auxiliarLecturas = await AuxiliarLecturaClient.ObtenerListaAsync(
                anio: auxiliarFiltro.Anio,
                mes: auxiliarFiltro.Mes,
                ciclo: auxiliarFiltro.Ciclo,
                soloPendientes: auxiliarFiltro.SoloPendientes ?? false);
        }
        catch (Exception ex)
        {
            auxiliarError = $"Error al cargar lecturas: {ex.Message}";
        }
        finally
        {
            auxiliarLoading = false;
        }
    }

    private void MostrarPopupGenerarPeriodo()
    {
        generarPeriodoModel.Anio = auxiliarFiltro.Anio ?? DateTime.Now.Year;
        generarPeriodoModel.Mes = auxiliarFiltro.Mes ?? DateTime.Now.Month;
        generarPopupVisible = true;
    }

    private void MostrarPopupCargaMasiva()
    {
        cargaMasivaModel = new CargaMasivaModel
        {
            Anio = auxiliarFiltro.Anio ?? DateTime.Now.Year,
            Mes = auxiliarFiltro.Mes ?? DateTime.Now.Month,
            Ciclo = auxiliarFiltro.Ciclo
        };
        cargaMasivaError = null;
        cargaMasivaGuardando = false;
        cargaMasivaPopupVisible = true;
    }

    private void CancelarCargaMasiva()
    {
        cargaMasivaPopupVisible = false;
        cargaMasivaGuardando = false;
        cargaMasivaError = null;
        cargaMasivaModel = new CargaMasivaModel();
    }

    private async Task GenerarPeriodoAsync()
    {
        if (generarPeriodoModel.Anio <= 0 || generarPeriodoModel.Mes <= 0)
        {
            ShowToast("Auxiliar de Lectura", "Indica año y mes válidos.", ToastRenderStyle.Danger);
            return;
        }

        try
        {
            var response = await AuxiliarLecturaClient.GenerarPeriodoAsync(
                generarPeriodoModel.Anio,
                generarPeriodoModel.Mes);

            if (response.IsSuccessStatusCode)
            {
                generarPopupVisible = false;
                ShowToast("Auxiliar de Lectura", "Período generado correctamente.", ToastRenderStyle.Success);
                await LoadAuxiliarLecturasAsync();
            }
            else
            {
                var detail = await response.Content.ReadAsStringAsync();
                ShowToast("Auxiliar de Lectura",
                    string.IsNullOrWhiteSpace(detail) ? "No se pudo generar el período." : detail,
                    ToastRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Auxiliar de Lectura", $"Error: {ex.Message}", ToastRenderStyle.Danger);
        }
    }

    private async Task CerrarPeriodoAsync()
    {
        if (auxiliarFiltro.Anio is null || auxiliarFiltro.Mes is null)
        {
            ShowToast("Auxiliar de Lectura", "Selecciona año y mes antes de cerrar.", ToastRenderStyle.Danger);
            return;
        }

        try
        {
            var response = await AuxiliarLecturaClient.CerrarPeriodoAsync(
                auxiliarFiltro.Anio.Value,
                auxiliarFiltro.Mes.Value);

            if (response.IsSuccessStatusCode)
            {
                ShowToast("Auxiliar de Lectura", "Período cerrado.", ToastRenderStyle.Success);
                await LoadAuxiliarLecturasAsync();
            }
            else
            {
                var detail = await response.Content.ReadAsStringAsync();
                ShowToast("Auxiliar de Lectura",
                    string.IsNullOrWhiteSpace(detail) ? "No se pudo cerrar el período." : detail,
                    ToastRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Auxiliar de Lectura", $"Error: {ex.Message}", ToastRenderStyle.Danger);
        }
    }

    private async Task EliminarPeriodoAsync()
    {
        if (auxiliarFiltro.Anio is null || auxiliarFiltro.Mes is null)
        {
            ShowToast("Auxiliar de Lectura", "Selecciona año y mes antes de eliminar.", ToastRenderStyle.Danger);
            return;
        }

        try
        {
            var response = await AuxiliarLecturaClient.EliminarPeriodoAsync(
                auxiliarFiltro.Anio.Value,
                auxiliarFiltro.Mes.Value);

            if (response.IsSuccessStatusCode)
            {
                auxiliarLecturas.Clear();
                ShowToast("Auxiliar de Lectura", "Período eliminado.", ToastRenderStyle.Success);
            }
            else
            {
                var detail = await response.Content.ReadAsStringAsync();
                ShowToast("Auxiliar de Lectura",
                    string.IsNullOrWhiteSpace(detail) ? "No se pudo eliminar el período." : detail,
                    ToastRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Auxiliar de Lectura", $"Error: {ex.Message}", ToastRenderStyle.Danger);
        }
    }

    private async Task EnviarCargaMasivaAsync()
    {
        if (cargaMasivaGuardando)
            return;

        cargaMasivaError = null;

        if (cargaMasivaModel.Anio <= 0 || cargaMasivaModel.Mes <= 0)
        {
            cargaMasivaError = "Indica año y mes válidos.";
            return;
        }

        var items = ParseLecturasMasivas(cargaMasivaModel.Contenido);
        if (items is null)
            return;

        cargaMasivaGuardando = true;

        try
        {
            var cargaPayload = new AuxiliarLecturaClient.CargaMasivaModel
            {
                Anio = cargaMasivaModel.Anio,
                Mes = cargaMasivaModel.Mes,
                Ciclo = string.IsNullOrWhiteSpace(cargaMasivaModel.Ciclo) ? null : cargaMasivaModel.Ciclo,
                Lecturas = items.Select(i => new AuxiliarLecturaClient.CargaMasivaItemModel
                {
                    Clave = i.Clave,
                    Contador = i.Contador,
                    LecturaAnterior = i.LecturaAnterior,
                    LecturaActual = i.LecturaActual,
                    Usuario = i.Usuario
                }).ToArray()
            };

            var response = await AuxiliarLecturaClient.CargarLecturasMasivasAsync(cargaPayload);

            if (response.IsSuccessStatusCode)
            {
                ShowToast("Auxiliar de Lectura", "Lecturas registradas correctamente.", ToastRenderStyle.Success);
                cargaMasivaPopupVisible = false;
                cargaMasivaModel = new CargaMasivaModel();
                await LoadAuxiliarLecturasAsync();
            }
            else
            {
                var detail = await response.Content.ReadAsStringAsync();
                cargaMasivaError = string.IsNullOrWhiteSpace(detail)
                    ? "Error al cargar las lecturas."
                    : detail;
            }
        }
        catch (Exception ex)
        {
            cargaMasivaError = $"Error: {ex.Message}";
        }
        finally
        {
            cargaMasivaGuardando = false;
        }
    }

    private List<CargaMasivaItem>? ParseLecturasMasivas(string? contenido)
    {
        if (string.IsNullOrWhiteSpace(contenido))
        {
            cargaMasivaError = "Ingresa al menos una línea con lecturas.";
            return null;
        }

        var result = new List<CargaMasivaItem>();
        var lines = contenido.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);

        for (var index = 0; index < lines.Length; index++)
        {
            var line = lines[index].Trim();
            if (string.IsNullOrEmpty(line))
                continue;

            var parts = line.Split(';');
            if (parts.Length < 5)
            {
                cargaMasivaError = $"Línea {index + 1}: formato inválido. Usa clave;contador;anterior;actual;usuario.";
                return null;
            }

            if (!decimal.TryParse(parts[2], NumberStyles.Number, CultureInfo.InvariantCulture, out var anterior))
            {
                cargaMasivaError = $"Línea {index + 1}: lectura anterior inválida.";
                return null;
            }

            if (!decimal.TryParse(parts[3], NumberStyles.Number, CultureInfo.InvariantCulture, out var actual))
            {
                cargaMasivaError = $"Línea {index + 1}: lectura actual inválida.";
                return null;
            }

            result.Add(new CargaMasivaItem(
                parts[0].Trim(),
                parts[1].Trim(),
                anterior,
                actual,
                parts[4].Trim()));
        }

        if (result.Count == 0)
        {
            cargaMasivaError = "No se encontraron lecturas para procesar.";
            return null;
        }

        return result;
    }

    private record CargaMasivaItem(
        string Clave,
        string Contador,
        decimal LecturaAnterior,
        decimal LecturaActual,
        string Usuario);

    private void ShowToast(string title, string message, ToastRenderStyle style)
    {
        ToastService.ShowToast(new ToastOptions
        {
            ProviderName = "MainToast",
            Title = title,
            Text = message,
            RenderStyle = style
        });
    }
}
