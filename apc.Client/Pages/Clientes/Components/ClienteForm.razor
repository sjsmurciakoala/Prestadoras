    private async Task CargarCategoriasPorTipoAsync()
    {
        categoriasPermitidas.Clear();

        if (!int.TryParse(Modelo.TipoUsoCodigo, out var tipo))
        {
            categorias = categoriasTodas;
            return;
        }

        try
        {
            categoriasPermitidas = await CatalogosClient.ObtenerCategoriasPorTipoAsync(tipo);
        }
        catch
        {
            categoriasPermitidas = new();
        }

        categorias = categoriasPermitidas.Count == 0
            ? categoriasTodas
            : categoriasTodas
                .Where(c => categoriasPermitidas.Contains(c.Id))
                .ToList();

        if (categorias.Count == 0)
        {
            Modelo.CategoriaServicioId = null;
            return;
        }


        if (Modelo.CategoriaServicioId is not null && categorias.All(c => c.Id != Modelo.CategoriaServicioId.Value))
        {
            Modelo.CategoriaServicioId = null;
        }
    }

    private async Task OnTipoUsoChanged()
    {
        await CargarCategoriasPorTipoAsync();
    }

    private string ConstruirIndicativoPreview()
    {
        var ciclo = Modelo.CicloId?.ToString()?.Trim() ?? string.Empty;
        var barrio = Modelo.BarrioCodigo?.Trim() ?? string.Empty;
        var libreta = Modelo.Libreta?.Trim() ?? string.Empty;
        var secuencia = string.IsNullOrWhiteSpace(Modelo.Secuencia) ? "----" : Modelo.Secuencia.Trim();

        var tieneValores = !string.IsNullOrWhiteSpace(ciclo)
                           || !string.IsNullOrWhiteSpace(barrio)
                           || !string.IsNullOrWhiteSpace(libreta)
                           || !string.IsNullOrWhiteSpace(Modelo.Secuencia);

        if (!tieneValores)
        {
            return "-";
        }

        // Format: Ciclo-Barrio-Ruta/Libreta-Secuencia. Secuencia uses "----" when empty.
        return $"{ciclo}-{barrio}-{libreta}-{secuencia}";
    }



    private static string NormalizarSegmento(string? valor, int longitud, char relleno, bool padLeft)
    {
        var limpio = new string((valor ?? string.Empty)
            .Where(char.IsLetterOrDigit)
            .Select(char.ToUpperInvariant)
            .ToArray());

        return padLeft
            ? (limpio.Length > longitud ? limpio[^longitud..] : limpio.PadLeft(longitud, relleno))
            : (limpio.Length > longitud ? limpio[..longitud] : limpio.PadRight(longitud, relleno));
    }
    private void EnsureLibretaSeleccionada()
    {
        // Libretas legacy (códigos numéricos viejos) o inactivas: se agregan
        // como opción visible para que el combo muestre lo que el cliente tiene
        // guardado, aunque ya no se ofrezcan para clientes nuevos.
        if (string.IsNullOrWhiteSpace(Modelo.Libreta))
            return;

        if (libretas.Any(l => l.Codigo == Modelo.Libreta))
            return;

        libretas.Insert(0, new RutaOption(Modelo.Libreta, Modelo.Libreta));
    }

    private sealed record RutaOption(string Codigo, string Display);

    // ── No Cortable con confirmación y contraseña ─────────────────────────────

    private bool _mostrarConfirmNoCortable = false;
    private bool _nuevoEstadoNoCortable = false;
    private string? _passwordNoCortable;
    private string? _motivoNoCortable;
    private bool _ejecutandoNoCortable = false;
    private bool? _noCortableCargado;

    private void OnNoCortableChanged(bool nuevoValor)
    {
        // Sin confirmación al crear cliente nuevo
        if (!IsEditMode || string.IsNullOrWhiteSpace(Modelo.Clave))
        {
            Modelo.NoCortable = nuevoValor;
            return;
        }
        // Solo abrir confirmación si el valor cambia respecto al cargado
        if (nuevoValor == (_noCortableCargado ?? false))
        {
            Modelo.NoCortable = nuevoValor;
            return;
        }
        _nuevoEstadoNoCortable = nuevoValor;
        _passwordNoCortable = null;
        _motivoNoCortable = null;
        _mostrarConfirmNoCortable = true;
    }

    private void CancelarNoCortable()
    {
        _mostrarConfirmNoCortable = false;
    }

    private async Task ConfirmarNoCortableAsync()
    {
        if (string.IsNullOrWhiteSpace(_motivoNoCortable))
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "No Cortable",
                Text = "Ingrese el motivo del cambio.",
                RenderStyle = ToastRenderStyle.Danger
            });
            return;
        }

        if (string.IsNullOrWhiteSpace(_passwordNoCortable))
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "No Cortable",
                Text = "Ingrese su contraseña para confirmar.",
                RenderStyle = ToastRenderStyle.Danger
            });
            return;
        }

        _ejecutandoNoCortable = true;
        try
        {
            await ClientesClient.SetNoCortableAsync(Modelo.Clave, _nuevoEstadoNoCortable, _passwordNoCortable, _motivoNoCortable);
            Modelo.NoCortable = _nuevoEstadoNoCortable;
            _noCortableCargado = _nuevoEstadoNoCortable;
            _mostrarConfirmNoCortable = false;
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "No Cortable",
                Text = $"Error: {ex.Message}",
                RenderStyle = ToastRenderStyle.Danger
            });
        }
        finally
        {
            _ejecutandoNoCortable = false;
        }
    }

    // ── Bloqueo / Desbloqueo con confirmación ─────────────────────────────────

    private bool _mostrarConfirmBloqueo = false;
    private bool _nuevoEstadoBloqueo = false;
    private string? _motivoBloqueo;
    private string? _passwordBloqueo;
    private bool _ejecutandoBloqueo = false;
    // Valor de bloqueo tal como llegó del servidor — para detectar cambios reales del usuario.
    private bool? _bloqueadoCargado;

    private void OnBloqueadoChangedAsync(bool nuevoValor)
    {
        // Sin confirmación al crear cliente nuevo
        if (!IsEditMode || string.IsNullOrWhiteSpace(Modelo.Clave))
        {
            Modelo.BloqueadoCobranza = nuevoValor;
            return;
        }
        // Solo abrir confirmación cuando el usuario CAMBIA el valor respecto al que se cargó.
        // Esto evita que DxCheckBox dispare CheckedChanged durante la sincronización inicial
        // del componente (comportamiento observado en DevExpress 25.x con Checked != false).
        if (nuevoValor == (_bloqueadoCargado ?? false))
        {
            Modelo.BloqueadoCobranza = nuevoValor;
            return;
        }
        // En edición y valor realmente modificado: pedir confirmación
        _nuevoEstadoBloqueo = nuevoValor;
        _motivoBloqueo = null;
        _passwordBloqueo = null;
        _mostrarConfirmBloqueo = true;
    }

    private void CancelarBloqueo()
    {
        // Revertir — el checkbox vuelve al estado anterior sin cambiar el modelo
        _mostrarConfirmBloqueo = false;
    }

    private async Task ConfirmarBloqueo()
    {
        if (string.IsNullOrWhiteSpace(_motivoBloqueo))
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Bloqueo de cobro",
                Text = "Ingrese el motivo del bloqueo/desbloqueo.",
                RenderStyle = ToastRenderStyle.Danger
            });
            return;
        }
        if (string.IsNullOrWhiteSpace(_passwordBloqueo))
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Bloqueo de cobro",
                Text = "Ingrese su contraseña para confirmar.",
                RenderStyle = ToastRenderStyle.Danger
            });
            return;
        }

        _ejecutandoBloqueo = true;
        try
        {
            await CobranzaClient.BloquearDesbloquearAsync(
                new BloquearClienteRequest(Modelo.Clave, _nuevoEstadoBloqueo, _motivoBloqueo, _passwordBloqueo));
            Modelo.BloqueadoCobranza = _nuevoEstadoBloqueo;
            _mostrarConfirmBloqueo = false;
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Bloqueo de cobro",
                Text = $"Error: {ex.Message}",
                RenderStyle = ToastRenderStyle.Danger
            });
        }
        finally
        {
            _ejecutandoBloqueo = false;
        }
    }
