@using System.ComponentModel.DataAnnotations
@using SIAD.Core.DTOs.Clientes
@using SIAD.Core.DTOs.Solicitudes
@using apc.Client.Services.Solicitudes
@inject SolicitudesClient SolicitudesClient
@inject IToastNotificationService ToastService

<div class="d-flex flex-column gap-3">
    <!-- Sección: Crear Nueva Solicitud -->
    <DxCard>
        <HeaderTemplate>
            <div class="card-header bg-light">
                <strong>Crear Nueva Solicitud</strong>
            </div>
        </HeaderTemplate>
        <BodyTemplate>
            <DxFormLayout>
                <DxFormLayoutItem Caption="Categoría">
                    @if (categoriasLoading)
                    {
                        <DxSkeletonLine />
                    }
                    else if (!string.IsNullOrEmpty(categoriasError))
                    {
                        <DxAlert AlertType="AlertType.Danger">@categoriasError</DxAlert>
                    }
                    else
                    {
                        <DxComboBox Data="@categorias"
                                    @bind-Value="@nuevaSolicitud.CategoriaServicioId"
                                    ValueFieldName="@nameof(SolicitudCategoriaDto.Id)"
                                    TextFieldName="@nameof(SolicitudCategoriaDto.Nombre)"
                                    DropDownDirection="DropDownDirection.Down" />
                    }
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Teléfono">
                    <DxTextBox @bind-Text="@nuevaSolicitud.Telefono" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Dirección">
                    <DxTextBox @bind-Text="@nuevaSolicitud.Direccion" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Correo">
                    <DxTextBox @bind-Text="@nuevaSolicitud.Correo" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Observación">
                    <DxMemo @bind-Text="nuevaSolicitud.Observacion" Rows="3" />
                </DxFormLayoutItem>
            </DxFormLayout>
            <div class="mt-3 d-flex gap-2">
                <DxButton Text="Crear Solicitud" Click="@CrearSolicitudAsync" IconCssClass="oi oi-plus" />
            </div>
        </BodyTemplate>
    </DxCard>

    <!-- Sección: Listado de Solicitudes -->
    <DxCard>
        <HeaderTemplate>
            <div class="card-header bg-light">
                <strong>Solicitudes del Cliente</strong>
            </div>
        </HeaderTemplate>
        <BodyTemplate>
            @if (solicitudesLoading)
            {
                <DxSkeletonLine />
                <DxSkeletonLine />
            }
            else if (!string.IsNullOrEmpty(solicitudesError))
            {
                <DxAlert AlertType="AlertType.Danger">@solicitudesError</DxAlert>
            }
            else if (solicitudes.Count == 0)
            {
                <DxAlert AlertType="AlertType.Info">Este cliente no tiene solicitudes registradas.</DxAlert>
            }
            else
            {
                <DxGrid Data="@solicitudes" PageSize="10">
                    <Columns>
                        <DxGridDataColumn FieldName="@nameof(SolicitudListDto.Id)" Caption="ID" Width="60px" />
                        <DxGridDataColumn FieldName="@nameof(SolicitudListDto.Fecha)" Caption="Fecha" Width="120px" />
                        <DxGridDataColumn FieldName="@nameof(SolicitudListDto.CategoriaServicioNombre)" Caption="Categoria" />
                        <DxGridDataColumn FieldName="@nameof(SolicitudListDto.Estado)" Caption="Estado" Width="100px" />
                        <DxGridDataColumn Caption="Acciones" Width="80px">
                            <CellDisplayTemplate Context="cellContext">
                                @if (cellContext.DataItem is SolicitudListDto item)
                                {
                                    <DxButton Text="Ver"
                                              Click="@(() => MostrarDetalleSolicitudAsync(item))"
                                              IconCssClass="oi oi-eye"
                                              Size="ButtonSize.Small"
                                              RenderStyle="ButtonRenderStyle.Secondary" />
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                    </Columns>
                </DxGrid>
            }
        </BodyTemplate>
    </DxCard>

    <!-- Popup: Detalle Solicitud -->
    <DxPopup Visible="@detalleSolicitudVisible" 
             VisibleChanged="@(v => { detalleSolicitudVisible = v; if (!v) solicitudSeleccionada = null; })"
             Width="800px"
             HeaderText="Detalle de Solicitud">
        <BodyTemplate Context="popupContext">
            @if (detalleSolicitudCargando)
            {
                <DxSkeletonLine />
            }
            else if (!string.IsNullOrEmpty(detalleSolicitudError))
            {
                <DxAlert AlertType="AlertType.Danger">@detalleSolicitudError</DxAlert>
            }
            else if (solicitudSeleccionada != null)
            {
                <DxFormLayout>
                    <DxFormLayoutItem Caption="ID">@solicitudSeleccionada.Id</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Cliente">@solicitudSeleccionada.NombreCliente</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Categoria">@solicitudSeleccionada.CategoriaServicioNombre</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Telefono">@solicitudSeleccionada.Telefono</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Direccion">@solicitudSeleccionada.Direccion</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Correo">@solicitudSeleccionada.Correo</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Observacion">@solicitudSeleccionada.Observacion</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Fecha">@solicitudSeleccionada.Fecha.ToString("g")</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Estado">@(solicitudSeleccionada.Estado ? "Activa" : "Inactiva")</DxFormLayoutItem>
                </DxFormLayout>
            }
        </BodyTemplate>
        <FooterTemplate>
            <DxButton Text="Cerrar" Click="@(() => detalleSolicitudVisible = false)" />
        </FooterTemplate>
    </DxPopup>
</div>

@code {
    [Parameter]
    [EditorRequired]
    public ClienteDetailDto Cliente { get; set; } = default!;

    private List<SolicitudListDto> solicitudes = new();
    private bool solicitudesLoading = true;
    private string? solicitudesError;

    private List<SolicitudCategoriaDto> categorias = new();
    private bool categoriasLoading = true;
    private string? categoriasError;

    private SolicitudDetailDto? solicitudSeleccionada;
    private bool detalleSolicitudVisible;
    private bool detalleSolicitudCargando;
    private string? detalleSolicitudError;

    private SolicitudCreateModel nuevaSolicitud = new();
    private static readonly EmailAddressAttribute EmailValidator = new();

    private class SolicitudCreateModel
    {
        public string Telefono { get; set; } = string.Empty;
        public string Direccion { get; set; } = string.Empty;
        public string? Correo { get; set; }
        public string? Observacion { get; set; }
        public int CategoriaServicioId { get; set; }
    }

    protected override async Task OnParametersSetAsync()
    {
        await Task.WhenAll(LoadCategoriasAsync(), LoadSolicitudesAsync());
    }

    private async Task LoadCategoriasAsync()
    {
        categoriasLoading = true;
        categoriasError = null;

        try
        {
            var result = await SolicitudesClient.ObtenerCategoriasAsync();
            categorias = result
                .Where(c => c.Activa)
                .OrderBy(c => c.Nombre)
                .ToList();

            categoriasError = categorias.Count == 0
                ? "No hay categorías activas configuradas."
                : null;

            if (categorias.Count > 0)
                nuevaSolicitud.CategoriaServicioId = categorias[0].Id;
        }
        catch (Exception ex)
        {
            categoriasError = $"Error al cargar categorías: {ex.Message}";
            categorias = new List<SolicitudCategoriaDto>();
        }
        finally
        {
            categoriasLoading = false;
        }
    }

    private async Task LoadSolicitudesAsync()
    {
        solicitudesLoading = true;
        solicitudesError = null;

        try
        {
            solicitudes = await SolicitudesClient.ObtenerPorClienteAsync(Cliente.Identidad);
        }
        catch (Exception ex)
        {
            solicitudesError = $"Error al cargar solicitudes: {ex.Message}";
        }
        finally
        {
            solicitudesLoading = false;
        }
    }

    private async Task MostrarDetalleSolicitudAsync(SolicitudListDto item)
    {
        detalleSolicitudError = null;
        detalleSolicitudCargando = true;
        detalleSolicitudVisible = true;

        try
        {
            solicitudSeleccionada = await SolicitudesClient.ObtenerPorIdAsync(item.Id);
        }
        catch (Exception ex)
        {
            detalleSolicitudError = $"Error al cargar detalle: {ex.Message}";
        }
        finally
        {
            detalleSolicitudCargando = false;
        }
    }

    private async Task CrearSolicitudAsync()
    {
        if (!categoriasLoading && (categorias.Count == 0 || nuevaSolicitud.CategoriaServicioId == 0))
        {
            ShowToast("Solicitudes", "Seleccione una categoría válida.", ToastRenderStyle.Danger);
            return;
        }

        var telefono = (nuevaSolicitud.Telefono ?? string.Empty).Trim();
        var direccion = (nuevaSolicitud.Direccion ?? string.Empty).Trim();
        var correo = (nuevaSolicitud.Correo ?? string.Empty).Trim();

        if (string.IsNullOrWhiteSpace(telefono) || string.IsNullOrWhiteSpace(direccion))
        {
            ShowToast("Solicitudes", "Teléfono y dirección son obligatorios.", ToastRenderStyle.Danger);
            return;
        }

        if (string.IsNullOrWhiteSpace(correo) || !EmailValidator.IsValid(correo))
        {
            ShowToast("Solicitudes", "El correo es obligatorio y debe tener formato válido.", ToastRenderStyle.Danger);
            return;
        }

        try
        {
            var categoriaSeleccionada = categorias.FirstOrDefault(c => c.Id == nuevaSolicitud.CategoriaServicioId);
            if (categoriaSeleccionada is null)
            {
                ShowToast("Solicitudes", "Categoría no encontrada.", ToastRenderStyle.Danger);
                return;
            }

            var dto = new SolicitudDetailDto(
                0,
                Cliente.Identidad ?? string.Empty,
                Cliente.Nombre,
                nuevaSolicitud.CategoriaServicioId,
                telefono,
                direccion,
                correo,
                string.IsNullOrWhiteSpace(nuevaSolicitud.Observacion) ? null : nuevaSolicitud.Observacion?.Trim(),
                DateTime.UtcNow,
                true,
                categoriaSeleccionada.Nombre);

            var response = await SolicitudesClient.CrearAsync(dto);
            response.EnsureSuccessStatusCode();

            await LoadSolicitudesAsync();
            var solicitudNueva = solicitudes.OrderByDescending(s => s.Fecha).FirstOrDefault();
            var mensaje = solicitudNueva is not null
                ? $"Solicitud #{solicitudNueva.Id} registrada correctamente."
                : "Solicitud registrada correctamente.";

            ShowToast("Solicitudes", mensaje, ToastRenderStyle.Success);
            nuevaSolicitud = CrearModeloInicial();
        }
        catch (Exception ex)
        {
            ShowToast("Solicitudes", $"Error al registrar: {ex.Message}", ToastRenderStyle.Danger);
        }
    }

    private SolicitudCreateModel CrearModeloInicial() => new()
    {
        Telefono = Cliente.Telefono ?? string.Empty,
        Direccion = Cliente.Direccion ?? string.Empty,
        Correo = string.Empty,
        Observacion = null,
        CategoriaServicioId = categorias.FirstOrDefault()?.Id ?? 0
    };

    private void ShowToast(string title, string message, ToastRenderStyle style)
    {
        ToastService.ShowToast(new ToastOptions
        {
            ProviderName = "MainToast",
            Title = title,
            Text = message,
            RenderStyle = style
        });
    }
}
