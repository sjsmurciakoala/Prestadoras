    private async Task EliminarPeriodoAsync()
    {
        if (auxiliarFiltro.Anio is null || auxiliarFiltro.Mes is null)
        {
            ShowToast("Auxiliar de lectura", "Selecciona anio y mes antes de eliminar.", ToastRenderStyle.Danger);
            return;
        }

        var parameters = new List<string>();
        if (auxiliarFiltro.Anio is { } anio) parameters.Add($"anio={anio}");
        if (auxiliarFiltro.Mes is { } mes) parameters.Add($"mes={mes}");

        var url = parameters.Count > 0
            ? $"api/auxiliarlectura?{string.Join("&", parameters)}"
            : "api/auxiliarlectura";

        var response = await Http.DeleteAsync(url);
        if (response.IsSuccessStatusCode)
        {
            auxiliarLecturas.Clear();
            ShowToast("Auxiliar de lectura", "Periodo eliminado.", ToastRenderStyle.Success);
