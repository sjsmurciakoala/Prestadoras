        var payload = new { Anio = generarPeriodoModel.Anio, Mes = generarPeriodoModel.Mes, Usuario = "sistema" };
        var response = await Http.PostAsJsonAsync("api/auxiliarlectura", payload);

        if (response.IsSuccessStatusCode)
