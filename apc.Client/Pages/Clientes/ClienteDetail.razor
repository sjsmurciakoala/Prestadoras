@page "/clientes/{id:int}"
@attribute [Authorize]
@using DevExpress.Blazor
@using System.Collections.Generic
@using System.Linq
@using System.Globalization
@using System.ComponentModel.DataAnnotations
@using SIAD.Core.DTOs.Clientes
@using SIAD.Core.DTOs.Solicitudes
@using SIAD.Core.DTOs.AuxiliarLectura
@inject HttpClient Http
@inject NavigationManager Navigation
@inject ILogger<ClienteDetail> Logger
@inject IToastNotificationService ToastService

<DxScrollView Height="100%">
    <DxToastProvider Name="MainToast"
                     MaxToastCount="4" />
    <DxToolbar>
        <Items>
            <DxToolbarItem CssClass="m-2" Text="Regresar a la lista" IconCssClass="oi oi-arrow-left"
                Click="BackToList" />
        </Items>
    </DxToolbar>

    @if (isLoading)
    {
        <DxSkeletonLine />
        <DxSkeletonLine />
        <DxSkeletonLine />
    }
    else if (!string.IsNullOrEmpty(error))
    {
        <DxAlert AlertType="AlertType.Danger">@error</DxAlert>
    }
    else if (cliente is null)
    {
        <DxAlert AlertType="AlertType.Warning">Cliente no encontrado.</DxAlert>
    }
    else
    {
        <DxTabs>
            <DxTab Text="Datos generales">
                <DxFormLayout>
                    <DxFormLayoutItem Caption="Código">@cliente.Codigo</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Nombre">@cliente.Nombre</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Identidad">@cliente.Identidad</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="RTN">@cliente.Rtn</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Dirección">@cliente.Direccion</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Teléfono">@cliente.Telefono</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Barrio">@cliente.Barrio</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Ciclo">@cliente.Ciclo</DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Activo">
                        @(cliente.Activo ? "Sí" : "No")
                    </DxFormLayoutItem>
                </DxFormLayout>
            </DxTab>
            <DxTab Text="Tarifas">
                <div class="d-flex flex-column gap-3">
                    @if (!tarifasLoaded)
                    {
                        <DxButton Text="Cargar tarifas" RenderStyle="ButtonRenderStyle.Primary" Click="LoadTarifasAsync" />
                    }
                    @if (!string.IsNullOrEmpty(tarifasError))
                    {
                        <DxAlert AlertType="AlertType.Danger">@tarifasError</DxAlert>
                    }
                    else if (tarifasLoaded && tarifas.Length == 0)
                    {
                        <DxAlert AlertType="AlertType.Info">Sin configuraciones de tarifa.</DxAlert>
                    }
                    else if (tarifasLoaded)
                    {
                        <DxGrid Data="@tarifas" KeyFieldName="@nameof(ClienteTarifaDto.ConfiguracionId)">
                            <Columns>
                                <DxGridDataColumn FieldName="@nameof(ClienteTarifaDto.TarifaNombre)" Caption="Tarifa" />
                                <DxGridDataColumn FieldName="@nameof(ClienteTarifaDto.PrecioBase)" Caption="Precio base" />
                                <DxGridDataColumn FieldName="@nameof(ClienteTarifaDto.CargoFijo)" Caption="Cargo fijo" />
                                <DxGridDataColumn FieldName="@nameof(ClienteTarifaDto.MontoConfigurado)"
                                    Caption="Monto configurado" />
                                <DxGridDataColumn FieldName="@nameof(ClienteTarifaDto.FechaCreacion)" Caption="Creado" />
                                <DxGridDataColumn FieldName="@nameof(ClienteTarifaDto.FechaModificacion)"
                                    Caption="Modificado" />
                                <DxGridDataColumn FieldName="@nameof(ClienteTarifaDto.Activa)" Caption="Activa" />
                            </Columns>
                        </DxGrid>
                    }
                </div>
            </DxTab>
            <DxTab Text="Estado de cuenta">
                <div class="d-flex flex-column gap-3">
                    @if (!estadoCuentaLoaded)
                    {
                        <DxButton Text="Cargar estado de cuenta" RenderStyle="ButtonRenderStyle.Primary"
                            Click="LoadEstadoCuentaAsync" />
                    }
                    @if (!string.IsNullOrEmpty(estadoCuentaError))
                    {
                        <DxAlert AlertType="AlertType.Danger">@estadoCuentaError</DxAlert>
                    }
                    else if (estadoCuentaLoaded && estadoCuenta is not null)
                    {
                        <DxFormLayout>
                            <DxFormLayoutItem Caption="Saldo actual">@((estadoCuenta.SaldoActual ?? 0).ToString("C2"))
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Fecha último pago">@(estadoCuenta.FechaUltimoPago?.ToString("dd/MM/yyyy")
                                                        ?? "-")</DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Monto último pago">@((estadoCuenta.UltimoPagoMonto ?? 0).ToString("C2"))
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Consumo promedio">@((estadoCuenta.ConsumoPromedio ?? 0).ToString("0.##"))
                            </DxFormLayoutItem>
                        </DxFormLayout>
                    }

                    @if (!movimientosLoaded)
                    {
                        <DxButton Text="Cargar movimientos" RenderStyle="ButtonRenderStyle.Secondary"
                            Click="LoadMovimientosAsync" />
                    }
                    @if (!string.IsNullOrEmpty(movimientosError))
                    {
                        <DxAlert AlertType="AlertType.Danger">@movimientosError</DxAlert>
                    }
                    else if (movimientosLoaded && movimientos.Length == 0)
                    {
                        <DxAlert AlertType="AlertType.Info">Sin movimientos registrados.</DxAlert>
                    }
                    else if (movimientosLoaded)
                    {
                        <DxGrid Data="@movimientos" KeyFieldName="@nameof(ClienteMovimientoDto.MovimientoId)">
                            <Columns>
                                <DxGridDataColumn FieldName="@nameof(ClienteMovimientoDto.Fecha)" Caption="Fecha" />
                                <DxGridDataColumn FieldName="@nameof(ClienteMovimientoDto.Tipo)" Caption="Tipo" />
                                <DxGridDataColumn FieldName="@nameof(ClienteMovimientoDto.Descripcion)" Caption="Descripción" />
                                <DxGridDataColumn FieldName="@nameof(ClienteMovimientoDto.Monto)" Caption="Monto" />
                                <DxGridDataColumn FieldName="@nameof(ClienteMovimientoDto.SaldoInline)" Caption="Saldo" />
                            </Columns>
                        </DxGrid>
                    }
                </div>
            </DxTab>
            <DxTab Text="Solicitudes">
                <div class="d-flex flex-column gap-3">
                    <DxButton Text="Cargar solicitudes" SizeMode="SizeMode.Medium" RenderStyle="ButtonRenderStyle.Secondary" Click="LoadSolicitudesAsync"
                        Enabled="@(!solicitudesLoaded)" />

                    @if (!string.IsNullOrEmpty(solicitudesError))
                    {
                        <DxAlert AlertType="AlertType.Danger">@solicitudesError</DxAlert>
                    }
                    else if (solicitudesLoaded && solicitudes.Count == 0)
                    {
                        <DxAlert AlertType="AlertType.Info">Sin solicitudes registradas.</DxAlert>
                    }
                    else if (solicitudesLoaded)
                    {
                        <DxGrid Data="@solicitudes" KeyFieldName="Id">
                            <Columns>
                                <DxGridDataColumn FieldName="Id" Caption="Solicitud #" Width="120" />
                                <DxGridDataColumn FieldName="IdentificacionCliente" Caption="Identidad" />
                                <DxGridDataColumn FieldName="NombreCliente" Caption="Nombre" />
                                <DxGridDataColumn FieldName="CategoriaServicioNombre" Caption="Categoría" />
                                <DxGridDataColumn FieldName="Fecha" Caption="Fecha">
                                    <CellDisplayTemplate Context="cell">
                                        @{
                                            var item = (SolicitudListDto)cell.DataItem;
                                        }
                                        @item.Fecha.ToString("dd/MM/yyyy HH:mm")
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                                <DxGridDataColumn FieldName="Estado" Caption="Activa">
                                    <CellDisplayTemplate Context="cell">
                                        @(((SolicitudListDto)cell.DataItem).Estado ? "Sí" : "No")
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                                <DxGridDataColumn Caption="Acciones">
                                    <CellDisplayTemplate Context="cell">
                                        @{
                                            var item = (SolicitudListDto)cell.DataItem;
                                        }
                                        <DxButton Text="Ver detalle" RenderStyle="ButtonRenderStyle.Link"
                                            Click="@(() => MostrarDetalleSolicitudAsync(item))" />
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                            </Columns>
                        </DxGrid>
                    }

                    <DxCard>
                        <DxCardHeader>Registrar nueva solicitud</DxCardHeader>
                        <DxCardBody>
                            @if (!string.IsNullOrEmpty(categoriasError))
                            {
                                <DxAlert AlertType="AlertType.Danger">@categoriasError</DxAlert>
                            }
                            else if (categoriasLoaded && categorias.Count == 0)
                            {
                                <DxAlert AlertType="AlertType.Warning">No hay categorías activas disponibles para registrar
                                    solicitudes.</DxAlert>
                            }
                            <DxFormLayout CssClass="mb-2">
                                <DxFormLayoutItem Caption="Teléfono *">
                                    <DxTextBox @bind-Text="nuevaSolicitud.Telefono"
                                               NullText="Ingresa un teléfono de contacto" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Dirección *">
                                    <DxTextBox @bind-Text="nuevaSolicitud.Direccion"
                                               NullText="Ingresa una dirección válida" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Correo *">
                                    <DxTextBox @bind-Text="nuevaSolicitud.Correo"
                                               NullText="usuario@dominio.com" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Observación">
                                    <DxMemo @bind-Text="nuevaSolicitud.Observacion" Rows="3" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Categoría">
                                    <DxComboBox TData="SolicitudCategoriaDto" TValue="int" Data="@categorias"
                                        ValueFieldName="Id" TextFieldName="Nombre" NullText="Seleccione una categoría"
                                        @bind-Value="nuevaSolicitud.CategoriaServicioId"
                                        Enabled="@(categorias.Count > 0 && string.IsNullOrEmpty(categoriasError))" />
                                </DxFormLayoutItem>
                            </DxFormLayout>
                            <DxButton renderStyle="ButtonRenderStyle.Primary"
                                RenderStyleMode="ButtonRenderStyleMode.Contained" Text="Guardar solicitud"
                                Click="CrearSolicitudAsync" />
                        </DxCardBody>
                    </DxCard>

                    <DxPopup ShowCloseButton="true" CloseOnOutsideClick="true" Visible="detalleSolicitudVisible"
                        VisibleChanged="@(v => detalleSolicitudVisible = v)">
                        <HeaderContent>Detalle de solicitud</HeaderContent>
                        <BodyContent>
                            @if (detalleSolicitudCargando)
                            {
                                <DxSkeletonLine />
                            }
                            else if (!string.IsNullOrEmpty(detalleSolicitudError))
                            {
                                <DxAlert AlertType="AlertType.Danger">@detalleSolicitudError</DxAlert>
                            }
                            else if (solicitudSeleccionada is not null)
                            {
                                <DxFormLayout>
                                    <DxFormLayoutItem Caption="Solicitud #">@solicitudSeleccionada.Id</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Identidad">@solicitudSeleccionada.IdentificacionCliente
                                    </DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Nombre">@solicitudSeleccionada.NombreCliente</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Teléfono">@solicitudSeleccionada.Telefono</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Dirección">@solicitudSeleccionada.Direccion</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Correo">@solicitudSeleccionada.Correo</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Categoría">
                                        @(solicitudSeleccionada.CategoriaServicioNombre
                                                                        ?? categorias.FirstOrDefault(c => c.Id ==
                                                                        solicitudSeleccionada.CategoriaServicioId)?.Nombre
                                                                        ?? solicitudSeleccionada.CategoriaServicioId.ToString())
                                    </DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Observación">
                                        @(!string.IsNullOrWhiteSpace(solicitudSeleccionada.Observacion) ?
                                                                        solicitudSeleccionada.Observacion : "-")
                                    </DxFormLayoutItem>
                                    @if (!string.IsNullOrWhiteSpace(solicitudSeleccionada.EmpresaNombre))
                                    {
                                        <DxFormLayoutItem Caption="Empresa">@solicitudSeleccionada.EmpresaNombre</DxFormLayoutItem>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(solicitudSeleccionada.EmpresaTelefono))
                                    {
                                        <DxFormLayoutItem Caption="Teléfono empresa">@solicitudSeleccionada.EmpresaTelefono
                                        </DxFormLayoutItem>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(solicitudSeleccionada.EmpresaDireccion))
                                    {
                                        <DxFormLayoutItem Caption="Dirección empresa">@solicitudSeleccionada.EmpresaDireccion
                                        </DxFormLayoutItem>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(solicitudSeleccionada.NegocioNombre))
                                    {
                                        <DxFormLayoutItem Caption="Negocio">@solicitudSeleccionada.NegocioNombre</DxFormLayoutItem>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(solicitudSeleccionada.NegocioTelefono))
                                    {
                                        <DxFormLayoutItem Caption="Teléfono negocio">@solicitudSeleccionada.NegocioTelefono
                                        </DxFormLayoutItem>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(solicitudSeleccionada.NegocioClaveCatastral))
                                    {
                                        <DxFormLayoutItem Caption="Clave catastral">@solicitudSeleccionada.NegocioClaveCatastral
                                        </DxFormLayoutItem>
                                    }
                                    <DxFormLayoutItem Caption="Fecha">@solicitudSeleccionada.Fecha.ToString("dd/MM/yyyy HH:mm")
                                    </DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Activa">@(solicitudSeleccionada.Estado ? "Sí" : "No")
                                    </DxFormLayoutItem>
                                </DxFormLayout>
                            }
                        </BodyContent>
                    </DxPopup>
                </div>
            </DxTab>


            <DxTab Text="Medidores">
                <div class="d-flex flex-column gap-3">
                    <div class="d-flex flex-wrap gap-2">
                        <DxButton Text="Cargar medidores" SizeMode="SizeMode.Medium"
                                  RenderStyle="ButtonRenderStyle.Secondary"
                                  Click="LoadMedidoresAsync"
                                  Enabled="@(cliente is not null && !medidoresLoading)" />
                        <DxButton Text="Asignar medidor" SizeMode="SizeMode.Medium"
                                  RenderStyle="ButtonRenderStyle.Primary"
                                  Click="AsignarMedidorPopupAsync"
                                  Enabled="@(cliente is not null)" />
                        <DxButton Text="Registrar lectura sin medidor" SizeMode="SizeMode.Medium"
                                  RenderStyle="ButtonRenderStyle.Secondary"
                                  Click="AbrirLecturaSinMedidorAsync"
                                  Enabled="@(cliente is not null)" />
                    </div>

                    @if (!string.IsNullOrEmpty(medidoresError))
                    {
                        <DxAlert AlertType="AlertType.Danger">@medidoresError</DxAlert>
                    }
                    else if (medidoresLoading)
                    {
                        <DxSkeletonLine />
                    }
                    else if (medidoresLoaded && medidores.Count == 0)
                    {
                        <DxAlert AlertType="AlertType.Info">Sin medidores asociados.</DxAlert>
                    }
                    else if (medidores.Count > 0)
                    {
                        <DxGrid Data="@medidores" KeyFieldName="Id" ShowFilterRow="true">
                            <Columns>
                                <DxGridDataColumn FieldName="Numero" Caption="N�mero" />
                                <DxGridDataColumn FieldName="Marca" Caption="Marca" />
                                <DxGridDataColumn FieldName="Diametro" Caption="Di�metro" />
                                <DxGridDataColumn FieldName="FechaInstalacion" Caption="Instalado">
                                    <CellDisplayTemplate Context="cell">
                                        @{
                                            var medidor = (MedidorListDto)cell.DataItem;
                                        }
                                        @(medidor.FechaInstalacion?.ToString("dd/MM/yyyy") ?? "-")
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                                <DxGridDataColumn FieldName="Acueducto" Caption="Acueducto" />
                                <DxGridDataColumn FieldName="Estado" Caption="Activo">
                                    <CellDisplayTemplate Context="cell">
                                        @(((MedidorListDto)cell.DataItem).Estado ? "S�" : "No")
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                                <DxGridDataColumn FieldName="ClienteNombre" Caption="Cliente" />
                                <DxGridDataColumn Caption="Acciones">
                                    <CellDisplayTemplate Context="cell">
                                        @{
                                            var item = (MedidorListDto)cell.DataItem;
                                        }
                                        <DxButton Text="Ver detalle" RenderStyle="ButtonRenderStyle.Link"
                                                  Click="@(() => MostrarDetalleMedidorAsync(item))" />
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                            </Columns>
                        </DxGrid>
                    }

                    <DxPopup ShowCloseButton="true" CloseOnOutsideClick="true"
                             Visible="medidorDetalleVisible"
                             VisibleChanged="@(v => medidorDetalleVisible = v)">
                        <HeaderContent>Detalle de medidor</HeaderContent>
                        <BodyContent>
                            @if (medidorDetalleCargando)
                            {
                                <DxSkeletonLine />
                            }
                            else if (!string.IsNullOrEmpty(medidorDetalleError))
                            {
                                <DxAlert AlertType="AlertType.Danger">@medidorDetalleError</DxAlert>
                            }
                            else if (medidorDetalle is not null)
                            {
                                <DxFormLayout>
                                    <DxFormLayoutItem Caption="N�mero">@medidorDetalle.Numero</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Marca">@medidorDetalle.Marca</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Di�metro">@medidorDetalle.Diametro</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Instalado">@(
                                        medidorDetalle.FechaInstalacion?.ToString("dd/MM/yyyy") ?? "-")</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Acueducto">@medidorDetalle.Acueducto</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Activo">@(medidorDetalle.Estado ? "S�" : "No")</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Cliente clave">@medidorDetalle.ClienteClave</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Cliente nombre">@medidorDetalle.ClienteNombre</DxFormLayoutItem>
                                    <DxFormLayoutItem Caption="Barrio">@medidorDetalle.ClienteBarrio</DxFormLayoutItem>
                                </DxFormLayout>

                                <DxGrid Data="@medidorDetalle.Historial" KeyFieldName="Fecha" CssClass="mt-3">
                                    <Columns>
                                        <DxGridDataColumn FieldName="Fecha" Caption="Fecha">
                                            <CellDisplayTemplate Context="cell">
                                                @{
                                                    var historico = (MedidorHistorialDto)cell.DataItem;
                                                }
                                                @(historico.Fecha?.ToString("dd/MM/yyyy") ?? "-")
                                            </CellDisplayTemplate>
                                        </DxGridDataColumn>
                                        <DxGridDataColumn FieldName="LecturaActual" Caption="Lectura actual" />
                                        <DxGridDataColumn FieldName="LecturaAnterior" Caption="Lectura anterior" />
                                        <DxGridDataColumn FieldName="Consumo" Caption="Consumo" />
                                        <DxGridDataColumn FieldName="Condicion" Caption="Condici�n" />
                                        <DxGridDataColumn FieldName="Observaciones" Caption="Observaciones" />
                                        <DxGridDataColumn FieldName="Usuario" Caption="Usuario" />
                                    </Columns>
                                </DxGrid>

                                @if (medidorDetalle.ConfiguracionesApp?.Count > 0)
                                {
                                    <DxAlert CssClass="mt-3" AlertType="AlertType.Info">
                                        <strong>Configuraciones app:</strong>
                                        <ul>
                                            @foreach (var cfg in medidorDetalle.ConfiguracionesApp)
                                            {
                                                <li>@cfg</li>
                                            }
                                        </ul>
                                    </DxAlert>
                                }
                            }
                        </BodyContent>
                    </DxPopup>

                    <DxPopup ShowCloseButton="true" CloseOnOutsideClick="true"
                             Visible="asignacionPopupVisible"
                             VisibleChanged="@(v => asignacionPopupVisible = v)">
                        <HeaderContent>Asignar medidor al cliente</HeaderContent>
                        <BodyContent>
                            @if (!string.IsNullOrEmpty(asignacionError))
                            {
                                <DxAlert AlertType="AlertType.Danger">@asignacionError</DxAlert>
                            }

                            @if (medidoresDisponiblesLoading)
                            {
                                <DxSkeletonLine />
                            }
                            else
                            {
                                @if (!string.IsNullOrEmpty(medidoresDisponiblesError))
                                {
                                    <DxAlert AlertType="AlertType.Danger">@medidoresDisponiblesError</DxAlert>
                                }
                                else if (medidoresDisponibles.Count == 0)
                                {
                                    <DxAlert AlertType="AlertType.Info">No hay medidores disponibles para asignar.</DxAlert>
                                }
                                else
                                {
                                    <DxFormLayout>
                                        <DxFormLayoutItem Caption="Medidor">
                                            <DxComboBox Data="@medidoresDisponibles"
                                                        @bind-Value="asignacionModel.MedidorId"
                                                        ValueFieldName="Id"
                                                        TextFieldName="Numero"
                                                        NullText="Seleccione un medidor"
                                                        DropDownWidth="320px" />
                                        </DxFormLayoutItem>
                                    </DxFormLayout>
                                }
                            }

                            <div class="d-flex gap-2 mt-3">
                                <DxButton Text="Asignar" RenderStyle="ButtonRenderStyle.Primary"
                                          Click="GuardarAsignacionMedidorAsync"
                                          Enabled="@(asignacionModel.MedidorId.HasValue && !asignacionGuardando)" />
                                <DxButton Text="Cancelar" RenderStyle="ButtonRenderStyle.Secondary"
                                          Click="@(() => asignacionPopupVisible = false)" />
                            </div>
                        </BodyContent>
                    </DxPopup>

                    <DxPopup ShowCloseButton="true" CloseOnOutsideClick="true"
                             Visible="lecturaPopupVisible"
                             VisibleChanged="@(v => lecturaPopupVisible = v)">
                        <HeaderContent>Registrar lectura sin medidor</HeaderContent>
                        <BodyContent>
                            @if (!string.IsNullOrEmpty(lecturaError))
                            {
                                <DxAlert AlertType="AlertType.Danger">@lecturaError</DxAlert>
                            }

                            <DxFormLayout>
                                <DxFormLayoutItem Caption="Cuenta *">
                                    <DxTextBox @bind-Text="lecturaModel.Clave" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Fecha *">
                                    <DxDateEdit @bind-Date="lecturaModel.Fecha" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Lectura *">
                                    <DxSpinEdit @bind-Value="lecturaModel.Lectura" Min="0" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Usuario">
                                    <DxTextBox @bind-Text="lecturaModel.Usuario" />
                                </DxFormLayoutItem>
                            </DxFormLayout>

                            <div class="d-flex gap-2 mt-3">
                                <DxButton Text="Registrar" RenderStyle="ButtonRenderStyle.Primary"
                                          Click="RegistrarLecturaSinMedidorAsync"
                                          Enabled="@(lecturaModel.Lectura >= 0 && !lecturaGuardando)" />
                                <DxButton Text="Cancelar" RenderStyle="ButtonRenderStyle.Secondary"
                                          Click="@(() => lecturaPopupVisible = false)" />
                            </div>
                        </BodyContent>
                    </DxPopup>
                </div>
            </DxTab>
            <DxTab Text="Auxiliar de Lectura">
                <DxFormLayout CssClass="mb-3">
                    <DxFormLayoutItem Caption="A\u00f1o">
                        <DxSpinEdit @bind-Value="auxiliarFiltro.Anio" Min="2000" Max="2100" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Mes">
                        <DxSpinEdit @bind-Value="auxiliarFiltro.Mes" Min="1" Max="12" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Ciclo">
                        <DxTextBox @bind-Text="auxiliarFiltro.Ciclo" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Solo pendientes">
                        <DxCheckBox @bind-Checked="auxiliarFiltro.SoloPendientes" />
                    </DxFormLayoutItem>
                </DxFormLayout>
                <div class="d-flex gap-2 mb-3">
                    <DxButton Text="Cargar lecturas" Click="LoadAuxiliarLecturasAsync" />
                    <DxButton Text="Generar periodo" Click="MostrarPopupGenerarPeriodo" RenderStyle="ButtonRenderStyle.Primary" />
                    <DxButton Text="Cerrar periodo" Click="CerrarPeriodoAsync" RenderStyle="ButtonRenderStyle.Secondary" />
                    <DxButton Text="Eliminar periodo" Click="EliminarPeriodoAsync" RenderStyle="ButtonRenderStyle.Danger" />
                    <DxButton Text="Carga masiva" Click="MostrarPopupCargaMasiva" />
                </div>

                @if (auxiliarLoading)
                {
