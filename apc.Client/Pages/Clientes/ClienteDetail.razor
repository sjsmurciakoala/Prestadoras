        {
            lecturaError = "La cuenta es obligatoria.";
            return;
        }

        lecturaGuardando = true;
        lecturaError = null;

        try
        {
            var payload = new
            {
                Clave = lecturaModel.Clave.Trim(),
                Fecha = lecturaModel.Fecha,
                Lectura = lecturaModel.Lectura,
                Usuario = string.IsNullOrWhiteSpace(lecturaModel.Usuario) ? "app" : lecturaModel.Usuario.Trim()
            };

            var response = await Http.PostAsJsonAsync("api/medidores/lecturas-sin-medidor", payload);
            if (response.IsSuccessStatusCode)
            {
                ShowToast("Medidores", "Lectura registrada correctamente.", ToastRenderStyle.Success);
                lecturaPopupVisible = false;
                lecturaModel = new LecturaSinMedidorModel();
            }
            else
            {
                var detail = await response.Content.ReadAsStringAsync();
                lecturaError = string.IsNullOrWhiteSpace(detail)
                    ? "No se pudo registrar la lectura."
                    : detail;
            }
        }
        catch (Exception ex)
        {
            lecturaError = "Error al registrar la lectura. " + ex.Message;
        }
        finally
        {
            lecturaGuardando = false;
        }
    }

