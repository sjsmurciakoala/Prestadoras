    private List<CargaMasivaItem>? ParseLecturasMasivas(string? contenido)
    {
        if (string.IsNullOrWhiteSpace(contenido))
        {
            cargaMasivaError = "Ingresa al menos una linea con lecturas.";
            return null;
        }

        var result = new List<CargaMasivaItem>();
        var lines = contenido.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);

        for (var index = 0; index < lines.Length; index++)
        {
            var line = lines[index].Trim();
            if (string.IsNullOrEmpty(line))
                continue;

            var parts = line.Split(';');
            if (parts.Length < 5)
            {
                cargaMasivaError = $"Linea {index + 1}: formato invalido. Usa clave;contador;anterior;actual;usuario.";
                return null;
            }

            if (!decimal.TryParse(parts[2], NumberStyles.Number, CultureInfo.InvariantCulture, out var anterior))
            {
                cargaMasivaError = $"Linea {index + 1}: lectura anterior invalida.";
                return null;
            }

            if (!decimal.TryParse(parts[3], NumberStyles.Number, CultureInfo.InvariantCulture, out var actual))
            {
                cargaMasivaError = $"Linea {index + 1}: lectura actual invalida.";
                return null;
            }

            result.Add(new CargaMasivaItem(
                parts[0].Trim(),
                parts[1].Trim(),
                anterior,
                actual,
                parts[4].Trim()));
        }

        if (result.Count == 0)
        {
            cargaMasivaError = "No se encontraron lecturas para procesar.";
            return null;
        }

        return result;
    }

    private class CargaMasivaModel
    {
        public int Anio { get; set; } = DateTime.Now.Year;
        public int Mes { get; set; } = DateTime.Now.Month;
        public string? Ciclo { get; set; }
        public string Contenido { get; set; } = string.Empty;
    }

    private record CargaMasivaItem(
        string Clave,
        string Contador,
        decimal LecturaAnterior,
        decimal LecturaActual,
        string Usuario);

    private async Task LoadAuxiliarLecturasAsync()
    {
        if (auxiliarLoading)
            return;

        auxiliarLoading = true;
        auxiliarError = null;

        try
        {
            var queryParts = new List<string>();
            if (auxiliarFiltro.Anio is { } anio) queryParts.Add($"anio={anio}");
            if (auxiliarFiltro.Mes is { } mes) queryParts.Add($"mes={mes}");
            if (!string.IsNullOrWhiteSpace(auxiliarFiltro.Ciclo))
                queryParts.Add($"ciclo={Uri.EscapeDataString(auxiliarFiltro.Ciclo)}");
            if (auxiliarFiltro.SoloPendientes is { } soloPendientes)
                queryParts.Add($"soloPendientes={soloPendientes.ToString().ToLowerInvariant()}");

            var url = queryParts.Count > 0
                ? $"api/auxiliarlectura?{string.Join("&", queryParts)}"
                : "api/auxiliarlectura";

            var result = await Http.GetFromJsonAsync<List<AuxiliarLecturaDto>>(url);
            auxiliarLecturas = result ?? new List<AuxiliarLecturaDto>();
        }
        catch (Exception ex)
        {
            auxiliarError = "Error al cargar lecturas. " + ex.Message;
        }
        finally
        {
            auxiliarLoading = false;
        }
    }

    private async Task LoadSolicitudesAsync()
    {
        if (cliente is null)
            return;

        await EnsureCategoriasAsync();

        if (solicitudesLoaded)
            return;

        try
        {
            var query = string.IsNullOrWhiteSpace(cliente.Identidad)
                ? string.Empty
                : $"?clienteIdentidad={Uri.EscapeDataString(cliente.Identidad)}";
            var url = $"api/solicitudes{query}";
            solicitudes = (await Http.GetFromJsonAsync<List<SolicitudListDto>>(url)) ?? new List<SolicitudListDto>();
            solicitudesError = null;
            solicitudesLoaded = true;
        }
        catch (Exception ex)
        {
            solicitudesError = "Error al cargar las solicitudes del cliente. " + ex.Message;
            solicitudesLoaded = false;
        }
    }

