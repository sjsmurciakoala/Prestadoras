@page "/clientes/{Id:int}"
@attribute [Authorize]

@using Microsoft.AspNetCore.Components
@using SIAD.Core.DTOs.Clientes
@using apc.Client.Services.Clientes
@using apc.Client.Pages.Clientes.Components
@using apc.Client.Services.Facturacion
@using DevExpress.Blazor

@inject ClientesClient ClientesClient
@inject NavigationManager Navigation
@inject ILogger<ClienteDetail> Logger
@inject CobranzaClient CobranzaClient

<div class="page-container cliente-detail-page">
    <DxToastProvider Name="MainToast" MaxToastCount="4" />

    <div class="cliente-detail-scroll">

        <!-- HEADER -->
        <div class="header-section">
            <div>
                <h2 class="page-title">Detalle de Cliente</h2>
                <p class="page-subtitle">
                    Información general, dirección, contacto y opciones del cliente
                </p>
            </div>

            <div class="header-actions">
                <DxButton Text="Volver" Click="BackToList" IconCssClass="bi bi-arrow-left"
                    RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Outline"
                    CssClass="btn-modern" />
            </div>
        </div>

        @if (isLoading)
        {
            <div class="modern-card text-center p-5">
                <DxLoadingPanel Visible="true" Text="Cargando cliente..." />
                <div style="height:80px"></div>
            </div>
        }
        else if (cliente is not null)
        {
            <!-- HERO SECTION -->
            <div class="modern-card">
                <div class="detail-hero">
                    <div class="detail-hero-left">
                        <div class="detail-avatar">@GetInitials(cliente.Nombre)</div>

                        <div class="detail-hero-text">
                            <div class="detail-name">
                                @($"{cliente.Nombre} {cliente.Apellidos}".Trim())
                            </div>

                            <div class="detail-sub">
                                <span class="text-code">@cliente.Codigo</span>
                                <span>&bull;</span>
                                <i class="bi bi-geo-alt"></i>
                                @(cliente.BarrioNombre ?? cliente.BarrioCodigo ?? "Sin barrio")
                            </div>

                            @{
                                var saldo = estadoCuenta?.SaldoActual ?? 0m;
                                var saldoClass = saldo > 0m ? "saldo-debe" : "saldo-al-dia";
                                var saldoTexto = saldo > 0m
                                    ? $"Debe: {saldo.ToString("C2")}"
                                    : saldo < 0m
                                        ? $"A favor: {(-saldo).ToString("C2")}"
                                        : "Sin saldo pendiente";
                            }
                            <div class="detail-saldo @saldoClass">
                                <i class="bi bi-cash-coin me-1"></i>@saldoTexto
                            </div>
                        </div>
                    </div>

                    <div class="detail-hero-right">
                        @if (cliente.Activo)
                        {
                            <span class="status-badge status-active">
                                <i class="bi bi-check-circle-fill me-1"></i> ACTIVO
                            </span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">
                                <i class="bi bi-x-circle-fill me-1"></i> INACTIVO
                            </span>
                        }

                        <div class="client-id">ID: @cliente.Id</div>
                    </div>
                </div>

                @if (cliente.BloqueadoCobranza == true)
                {
                    <div class="alert alert-danger d-flex align-items-center gap-3 mt-3 mb-0"
                         style="font-size:1rem;font-weight:700;border-radius:8px;border-left:6px solid #dc3545;">
                        <i class="bi bi-lock-fill" style="font-size:1.4rem;"></i>
                        <span>🚫 CLIENTE BLOQUEADO PARA COBRANZAS Y FACTURACIÓN</span>
                    </div>
                }
            </div>

            <!-- ACCIONES DEL CLIENTE -->
            <div class="modern-card">
                <div class="section-header">
                    <i class="bi bi-lightning-charge"></i>
                    <h3>Acciones del Cliente</h3>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <DxButton Text="Estado de cuenta" Click="AbrirEstadoCuenta"
                        IconCssClass="bi bi-receipt" RenderStyle="ButtonRenderStyle.Primary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Historial de consumo" Click="AbrirHistoricoConsumo"
                        IconCssClass="bi bi-bar-chart-line" RenderStyle="ButtonRenderStyle.Secondary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Configuración tarifaria" Click="AbrirServiciosTarifario"
                        IconCssClass="bi bi-diagram-3" RenderStyle="ButtonRenderStyle.Primary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Prueba de cálculo" Click="AbrirPruebaCalculo"
                        IconCssClass="bi bi-calculator" RenderStyle="ButtonRenderStyle.Primary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Foto medidor" Click="AbrirFotoMedidor"
                        IconCssClass="bi bi-camera" RenderStyle="ButtonRenderStyle.Secondary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Abono especial" Click="AbrirAbonoEspecial"
                        IconCssClass="bi bi-coin" RenderStyle="ButtonRenderStyle.Secondary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Acción cobranza" Click="AbrirAccionesCobranza"
                        IconCssClass="bi bi-journal-text" RenderStyle="ButtonRenderStyle.Primary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Bitácora Estado" Click="AbrirEstadoLog"
                        IconCssClass="bi bi-clock-history" RenderStyle="ButtonRenderStyle.Secondary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                </div>
            </div>

            <!-- INFORMACIÓN GENERAL CON DxFormLayout -->
            <div class="modern-card">
                <div class="section-header">
                    <i class="bi bi-info-circle"></i>
                    <h3>Información General</h3>
                </div>

                <div class="row g-3">
                    <!-- COLUMNA IZQUIERDA: DATOS PERSONALES -->
                    <div class="col-12 col-lg-6">
                        <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                            <DxFormLayoutGroup Caption="Datos personales" HeaderIconCssClass="bi bi-person-lines-fill"
                                ColSpanXs="12">
                                <DxFormLayoutItem Caption="Clave" ColSpanXs="12" ColSpanMd="6">
                                    <div class="field-value">@MostrarObj(cliente.Codigo)</div>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Nombre" ColSpanXs="12" ColSpanMd="6">
                                    <div class="field-value">@MostrarTexto(cliente.Nombre)</div>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Apellidos" ColSpanXs="12" ColSpanMd="12">
                                    <div class="field-value">@MostrarTexto(cliente.Apellidos)</div>
                                </DxFormLayoutItem>

                                <DxFormLayoutItem Caption="DNI" ColSpanXs="12" ColSpanMd="6">
                                    <div class="field-value">@MostrarTexto(cliente.Dni)</div>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="RTN" ColSpanXs="12" ColSpanMd="6">
                                    <div class="field-value">@MostrarTexto(cliente.Rtn)</div>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Fecha nacimiento" ColSpanXs="12" ColSpanMd="6">
                                    <div class="field-value">@MostrarFecha(cliente.FechaNacimiento)</div>
                                </DxFormLayoutItem>

                                <DxFormLayoutItem Caption="Teléfono" ColSpanXs="12" ColSpanMd="6">
                                    <div class="field-value">@MostrarTexto(cliente.Telefono)</div>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Teléfono móvil" ColSpanXs="12" ColSpanMd="6">
                                    <div class="field-value">@MostrarTexto(cliente.TelefonoMovil)</div>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Email" ColSpanXs="12" ColSpanMd="12">
                                    <div class="field-value">@MostrarTexto(cliente.Email)</div>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Clave catastral" ColSpanXs="12" ColSpanMd="12">
                                    <div class="field-value">@MostrarTexto(cliente.ClaveCatastral)</div>
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>
                        </DxFormLayout>
                    </div>

                    <!-- COLUMNA DERECHA: DIRECCIÓN + INFORMACIÓN ADICIONAL + DATOS EMPRESA -->
                    <div class="col-12 col-lg-6">
                        <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                            <DxFormLayoutGroup Caption="Dirección" HeaderIconCssClass="bi bi-geo-alt-fill"
                                ColSpanXs="12">
                                <DxFormLayoutItem Caption="Barrio" ColSpanXs="12" ColSpanMd="8">
                                    <div class="field-value">@MostrarTexto(cliente.BarrioNombre ?? cliente.BarrioCodigo)</div>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Color casa" ColSpanXs="12" ColSpanMd="4">
                                    <div class="field-value">@MostrarTexto(cliente.ColorCasa)</div>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Dirección" ColSpanXs="12" ColSpanMd="12">
                                    <div class="field-value">@MostrarTexto(cliente.Direccion)</div>
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>

                            <DxFormLayoutGroup Caption="Información adicional" HeaderIconCssClass="bi bi-info-circle"
                                ColSpanXs="12" CssClass="mt-3">
                                <DxFormLayoutItem Caption="Tercera edad" ColSpanXs="12" ColSpanMd="6">
                                    <div class="@GetBooleanClass(cliente.TerceraEdad)">@MostrarBooleano(cliente.TerceraEdad)</div>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Bloqueado cobranza" ColSpanXs="12" ColSpanMd="6">
                                    <div class="@GetBooleanClass(cliente.BloqueadoCobranza)">
                                        @MostrarBooleano(cliente.BloqueadoCobranza)</div>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Abogado" ColSpanXs="12" ColSpanMd="12">
                                    <div class="field-value">@MostrarAbogado(cliente)</div>
                                </DxFormLayoutItem>
                                @if (cliente.DescuentoTerceraEdad.HasValue && cliente.DescuentoTerceraEdad > 0)
                                {
                                    <DxFormLayoutItem Caption="Descuento 3ra edad" ColSpanXs="12" ColSpanMd="6">
                                        <div class="field-value important">@cliente.DescuentoTerceraEdad.Value.ToString("N2")%</div>
                                    </DxFormLayoutItem>
                                }
                            </DxFormLayoutGroup>

                            @if (!string.IsNullOrWhiteSpace(cliente.EmpresaNombre) ||
                                            !string.IsNullOrWhiteSpace(cliente.EmpresaRtn))
                            {
                                <DxFormLayoutGroup Caption="Datos empresa" HeaderIconCssClass="bi bi-building"
                                    ColSpanXs="12" CssClass="mt-3">
                                    @if (!string.IsNullOrWhiteSpace(cliente.EmpresaNombre))
                                    {
                                        <DxFormLayoutItem Caption="Empresa" ColSpanXs="12" ColSpanMd="12">
                                            <div class="field-value">@cliente.EmpresaNombre</div>
                                        </DxFormLayoutItem>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(cliente.EmpresaRtn))
                                    {
                                        <DxFormLayoutItem Caption="RTN / RIF" ColSpanXs="12" ColSpanMd="6">
                                            <div class="field-value">@cliente.EmpresaRtn</div>
                                        </DxFormLayoutItem>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(cliente.EmpresaTelefono))
                                    {
                                        <DxFormLayoutItem Caption="Teléfono" ColSpanXs="12" ColSpanMd="6">
                                            <div class="field-value">@cliente.EmpresaTelefono</div>
                                        </DxFormLayoutItem>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(cliente.EmpresaDireccion))
                                    {
                                        <DxFormLayoutItem Caption="Dirección" ColSpanXs="12" ColSpanMd="12">
                                            <div class="field-value">@cliente.EmpresaDireccion</div>
                                        </DxFormLayoutItem>
                                    }
                                </DxFormLayoutGroup>
                            }
                        </DxFormLayout>
                    </div>
                </div>
            </div>

            <!-- CONFIGURACIÓN DE LECTURA (solo lectura) -->
            <div class="modern-card">
                <div class="section-header">
                    <i class="bi bi-rulers"></i>
                    <h3>Configuración de lectura</h3>
                </div>

                <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                    <DxFormLayoutItem Caption="Ciclo" ColSpanXs="12" ColSpanMd="4" ColSpanLg="3">
                        <div class="field-value">@MostrarTexto(cliente.CicloDescripcion)</div>
                    </DxFormLayoutItem>
                    @if (cliente.TieneMedidor != true)
                    {
                        <DxFormLayoutItem Caption="Letra" ColSpanXs="12" ColSpanMd="4" ColSpanLg="3">
                            <div class="field-value">@MostrarTexto(cliente.LetraCodigo)</div>
                        </DxFormLayoutItem>
                    }
                    <DxFormLayoutItem Caption="Indicativo ruta" ColSpanXs="12" ColSpanMd="4" ColSpanLg="3">
                        <div class="field-value">@MostrarTexto(cliente.IndicativoRuta)</div>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Libreta" ColSpanXs="12" ColSpanMd="4" ColSpanLg="3">
                        <div class="field-value">@MostrarTexto(cliente.Libreta)</div>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Secuencia" ColSpanXs="12" ColSpanMd="4" ColSpanLg="3">
                        <div class="field-value">@MostrarTexto(cliente.Secuencia)</div>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Tipo de uso" ColSpanXs="12" ColSpanMd="4" ColSpanLg="3">
                        <div class="field-value">@MostrarTexto(cliente.TipoUsoCodigo)</div>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Servicio" ColSpanXs="12" ColSpanMd="4" ColSpanLg="3">
                        <div class="field-value">@MostrarTexto(cliente.ServicioNombre)</div>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Categoría" ColSpanXs="12" ColSpanMd="4" ColSpanLg="3">
                        <div class="field-value">@MostrarTexto(cliente.CategoriaServicioNombre)</div>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Tiene medidor" ColSpanXs="12" ColSpanMd="4" ColSpanLg="3">
                        <div class="@GetBooleanClass(cliente.TieneMedidor)">@MostrarBooleano(cliente.TieneMedidor)</div>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="N° medidor" ColSpanXs="12" ColSpanMd="4" ColSpanLg="3">
                        <div class="field-value">@MostrarTexto(cliente.MedidorNumero)</div>
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Clave SURE" ColSpanXs="12" ColSpanMd="4" ColSpanLg="3">
                        <div class="field-value">@MostrarTexto(cliente.ClaveSure)</div>
                    </DxFormLayoutItem>
                </DxFormLayout>
            </div>
            <div class="modern-card" style="padding: 1rem;">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-person-check" style="color: #6c757d; font-size: 1.1rem;"></i>
                        <span style="font-weight: 600; color: #6c757d; font-size: 0.9rem;">AUDITORÍA</span>
                    </div>

                    <div class="d-flex flex-wrap gap-3">
                        <div class="d-flex align-items-center gap-1">
                            <span style="font-size: 0.85rem; color: #6c757d; font-weight: 500;">Usuario:</span>
                            <span
                                style="font-size: 0.9rem; color: #2c3e50; font-weight: 500;">@MostrarTexto(cliente.UsuarioCreacion)</span>
                        </div>

                        <div class="d-flex align-items-center gap-1">
                            <span style="font-size: 0.85rem; color: #6c757d; font-weight: 500;">Fecha creación:</span>
                            <span
                                style="font-size: 0.9rem; color: #2c3e50; font-weight: 500;">@MostrarFecha(cliente.FechaCreacion)</span>
                        </div>
                    </div>
                </div>
            </div>

        }
    </div>

</div>

<!-- Popup histórico consumo -->
<DxPopup Visible="@mostrarHistoricoConsumoModal"
         VisibleChanged="@(v => { mostrarHistoricoConsumoModal = v; })"
         Width="min(1100px, 95vw)"
         MaxHeight="90vh"
         Scrollable="true"
         HeaderText="Histórico de Consumo"
         CssClass="historico-consumo-popup">
    <BodyTemplate>
        <div class="p-2 historico-consumo-body">
            <ClienteHistoricoConsumoTab ClienteId="@Id" MostrarDatosCliente="false" @key="(mostrarHistoricoConsumoModal, Id)" />
        </div>
    </BodyTemplate>
</DxPopup>

<!-- Popup foto medidor -->
<DxPopup Visible="@mostrarFotoMedidorModal"
         VisibleChanged="@(v => { mostrarFotoMedidorModal = v; })"
         Width="min(1000px, 95vw)"
         MaxHeight="90vh"
         Scrollable="true"
         HeaderText="Foto medidor"
         CssClass="historico-consumo-popup">
    <BodyTemplate>
        <div class="p-2 historico-consumo-body">
            <ClienteFotoMedidorTab ClienteId="@Id" @key="(mostrarFotoMedidorModal, Id)" />
        </div>
    </BodyTemplate>
</DxPopup>


<!-- Popup prueba de cálculo -->
<DxPopup Visible="@mostrarPruebaCalculoModal"
         VisibleChanged="@(v => { mostrarPruebaCalculoModal = v; })"
         Width="min(1240px, 96vw)"
         MaxHeight="92vh"
         Scrollable="true"
         HeaderText="Prueba de cálculo"
         ContentLoadMode="PopupContentLoadMode.OnFirstShow"
         CssClass="historico-consumo-popup">
    <BodyTemplate>
        <div class="p-2 historico-consumo-body">
            <ClientePruebaCalculoTab ClienteId="@Id" @key="(mostrarPruebaCalculoModal, Id)" />
        </div>
    </BodyTemplate>
</DxPopup>

<!-- Popup estado de cuenta -->
<DxPopup Visible="@mostrarEstadoCuentaModal"
         VisibleChanged="@(v => { mostrarEstadoCuentaModal = v; })"
         Width="min(900px, 95vw)"
         MaxHeight="90vh"
         Scrollable="true"
         HeaderText="Estado de cuenta"
         CssClass="historico-consumo-popup">
    <BodyContentTemplate>
        <div class="p-2 historico-consumo-body">
            <ClienteEstadoCuentaTab ClienteId="@Id" @key="(mostrarEstadoCuentaModal, Id)" />
        </div>
    </BodyContentTemplate>
</DxPopup>

<!-- Popup acciones de cobranza -->
<DxPopup Visible="@mostrarAccionesCobranzaModal"
         VisibleChanged="@(v => { mostrarAccionesCobranzaModal = v; })"
         Width="min(1100px, 96vw)"
         MaxHeight="90vh"
         Scrollable="true"
         HeaderText="Acciones de cobranza"
         CssClass="historico-consumo-popup">
    <BodyTemplate>
        <div class="p-2 historico-consumo-body">
            @if (cliente is not null)
            {
                <ClienteAccionesCobranzaTab ClienteClave="@cliente.Codigo"
                                            @key="(mostrarAccionesCobranzaModal, cliente.Codigo)" />
            }
        </div>
    </BodyTemplate>
</DxPopup>

<!-- Popup llamadas de cobranza -->
<DxPopup Visible="@mostrarLlamadasCobranzaModal"
         VisibleChanged="@(v => { mostrarLlamadasCobranzaModal = v; })"
         Width="min(900px, 95vw)"
         MaxHeight="90vh"
         Scrollable="true"
         HeaderText="Llamadas de cobranza"
         CssClass="historico-consumo-popup">
    <BodyTemplate>
        <div class="p-2 historico-consumo-body">
            @if (cliente is not null)
            {
                <ClienteLlamadasCobranzaTab ClienteClave="@cliente.Codigo"
                                            @key="(mostrarLlamadasCobranzaModal, cliente.Codigo)" />
            }
        </div>
    </BodyTemplate>
</DxPopup>

<!-- Popup notas de cobro -->
<DxPopup Visible="@mostrarNotasCobroModal"
         VisibleChanged="@(v => { mostrarNotasCobroModal = v; })"
         Width="min(980px, 95vw)"
         MaxHeight="90vh"
         Scrollable="true"
         HeaderText="Notas de cobro"
         CssClass="historico-consumo-popup">
    <BodyTemplate>
        <div class="p-2 historico-consumo-body">
            @if (cliente is not null)
            {
                <ClienteNotasCobroTab ClienteClave="@cliente.Codigo"
                                      @key="(mostrarNotasCobroModal, cliente.Codigo)" />
            }
        </div>
    </BodyTemplate>
</DxPopup>

<!-- Popup bitácora de Estado y Clasificación -->
<DxPopup Visible="@mostrarEstadoLogModal"
         VisibleChanged="@(v => { mostrarEstadoLogModal = v; })"
         Width="min(900px, 95vw)"
         MaxHeight="90vh"
         Scrollable="true"
         HeaderText="Bitácora de Estado y Clasificación"
         CssClass="historico-consumo-popup">
    <BodyTemplate>
        <div class="p-2 historico-consumo-body">
            <ClienteEstadoLogTab ClienteId="@Id" @key="(mostrarEstadoLogModal, Id)" />
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    [Parameter] public int Id { get; set; }
    [Parameter]
    [SupplyParameterFromQuery(Name = "abrirPruebaCalculoV3")]
    public bool AbrirPruebaCalculoV3DesdeQuery { get; set; }

    ClienteDetailDto? cliente;
    bool isLoading = true;
    bool mostrarHistoricoConsumoModal = false;
    bool mostrarFotoMedidorModal = false;
    bool mostrarPruebaCalculoModal = false;
    bool mostrarEstadoCuentaModal = false;
    bool mostrarAccionesCobranzaModal = false;
    bool mostrarLlamadasCobranzaModal = false;
    bool mostrarNotasCobroModal = false;
    bool mostrarEstadoLogModal = false;
    ClienteEstadoCuentaDto? estadoCuenta;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        try
        {
            cliente = await ClientesClient.ObtenerPorIdAsync(Id);
            await LoadSaldoAsync();
            if (AbrirPruebaCalculoV3DesdeQuery)
            {
                mostrarPruebaCalculoModal = true;
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadSaldoAsync()
    {
        try
        {
            estadoCuenta = await ClientesClient.ObtenerEstadoCuentaAsync(Id);
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "No fue posible obtener el estado de cuenta del cliente {ClienteId}.", Id);
            estadoCuenta = null;
        }
    }

    void BackToList() => Navigation.NavigateTo("/clientes");
    void AbrirHistoricoConsumo() => mostrarHistoricoConsumoModal = true;
    void AbrirAbonoEspecial() => Navigation.NavigateTo($"/facturacion/captacion/abono-especial/{Id}");
    void AbrirServiciosTarifario() => Navigation.NavigateTo($"/tarifario/cliente-servicio-v3?clienteId={Id}");
    void AbrirPruebaCalculo() => mostrarPruebaCalculoModal = true;
    void AbrirFotoMedidor() => mostrarFotoMedidorModal = true;
    void AbrirEstadoCuenta() => mostrarEstadoCuentaModal = true;
    void AbrirAccionesCobranza() => mostrarAccionesCobranzaModal = true;
    void AbrirLlamadasCobranza() => mostrarLlamadasCobranzaModal = true;
    void AbrirNotasCobro() => mostrarNotasCobroModal = true;
    void AbrirEstadoLog() => mostrarEstadoLogModal = true;

    string GetInitials(string? name)
    => string.IsNullOrWhiteSpace(name) ? "C" : name.Substring(0, 1).ToUpper();

    private static string MostrarTexto(string? valor)
    => string.IsNullOrWhiteSpace(valor) ? "-" : valor;

    private static string MostrarFecha(DateTime? fecha)
    => fecha.HasValue ? fecha.Value.ToString("d") : "-";

    private static string MostrarBooleano(bool? valor)
    => valor.HasValue ? (valor.Value ? "Sí" : "No") : "-";

    private static string MostrarAbogado(ClienteDetailDto cliente)
    => !string.IsNullOrWhiteSpace(cliente.AbogadoNombre)
    ? cliente.AbogadoNombre!
    : (cliente.AbogadoId?.ToString() ?? "-");

    private static string MostrarObj(object? valor)
    => valor is null ? "-" : (valor.ToString() ?? "-");

    private string GetBooleanClass(bool? valor)
    {
        if (!valor.HasValue) return "field-value empty";
        return valor.Value ? "field-value boolean-yes" : "field-value boolean-no";
    }
}
