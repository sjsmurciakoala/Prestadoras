    }

    private async Task EnviarCargaMasivaAsync()
    {
        if (cargaMasivaGuardando)
            return;

        cargaMasivaError = null;

        if (cargaMasivaModel.Anio <= 0 || cargaMasivaModel.Mes <= 0)
        {
            cargaMasivaError = "Indica anio y mes validos.";
            return;
        }

        var items = ParseLecturasMasivas(cargaMasivaModel.Contenido);
        if (items is null)
            return;

        var payload = new
        {
            Anio = cargaMasivaModel.Anio,
            Mes = cargaMasivaModel.Mes,
            Ciclo = string.IsNullOrWhiteSpace(cargaMasivaModel.Ciclo) ? null : cargaMasivaModel.Ciclo,
            Lecturas = items.Select(i => new
            {
                i.Clave,
                i.Contador,
                i.LecturaAnterior,
                i.LecturaActual,
                i.Usuario
            }).ToArray()
        };

        cargaMasivaGuardando = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auxiliarlectura/masivo", payload);

            if (response.IsSuccessStatusCode)
            {
                ShowToast("Auxiliar de lectura", "Lecturas registradas correctamente.", ToastRenderStyle.Success);
                cargaMasivaPopupVisible = false;
                cargaMasivaModel = new CargaMasivaModel();
                await LoadAuxiliarLecturasAsync();
            }
            else
            {
                var detail = await response.Content.ReadAsStringAsync();
                cargaMasivaError = string.IsNullOrWhiteSpace(detail)
                    ? "No se pudo registrar la carga masiva."
                    : detail;
            }
        }
        catch (Exception ex)
        {
            cargaMasivaError = "Error al enviar la carga masiva. " + ex.Message;
        }
        finally
        {
            cargaMasivaGuardando = false;
        }
    }

    private async Task GenerarPeriodoAsync()
