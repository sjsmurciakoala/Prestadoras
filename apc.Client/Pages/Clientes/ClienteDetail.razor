@attribute [Authorize]

@using SIAD.Core.DTOs.Clientes
@using apc.Client.Services.Clientes
@using apc.Client.Pages.Clientes.Components
@using DevExpress.Blazor

@inject ClientesClient ClientesClient
@inject NavigationManager Navigation
@inject ILogger<ClienteDetail> Logger

<div class="page-container cliente-detail-page">
    <DxToastProvider Name="MainToast" MaxToastCount="4" />

    <div class="cliente-detail-scroll">

        @if (MostrarEncabezado)
        {
            <!-- HEADER -->
            <div class="header-section">
                <div>
                    <h2 class="page-title">Detalle de Cliente</h2>
                    <p class="page-subtitle">
                        Información general, dirección, contacto y opciones del cliente
                    </p>
                </div>

                <div class="header-actions">
                    <DxButton Text="Volver" Click="BackToList" IconCssClass="bi bi-arrow-left"
                        RenderStyle="ButtonRenderStyle.Secondary" RenderStyleMode="ButtonRenderStyleMode.Outline"
                        CssClass="btn-modern" />
                </div>
            </div>
        }

        @if (isLoading)
        {
            <div class="modern-card text-center p-5">
                <DxLoadingPanel Visible="true" Text="Cargando cliente..." />
                <div style="height:80px"></div>
            </div>
        }
        else if (cliente is not null)
        {
            <!-- HERO SECTION -->
            <div class="modern-card">
                <div class="detail-hero">
                    <div class="detail-hero-left">
                        <div class="detail-avatar">@GetInitials(cliente.Nombre)</div>

                        <div class="detail-hero-text">
                            <div class="detail-name">
                                @($"{cliente.Nombre} {cliente.Apellidos}".Trim())
                            </div>

                            <div class="detail-sub">
                                <span class="text-code">@cliente.Codigo</span>
                                <span>•</span>
                                <i class="bi bi-geo-alt"></i>
                                @(cliente.BarrioNombre ?? cliente.BarrioCodigo ?? "Sin barrio")
                            </div>
                        </div>
                    </div>

                    <div class="detail-hero-right">
                        @if (cliente.Activo)
                        {
                            <span class="status-badge status-active">
                                <i class="bi bi-check-circle-fill me-1"></i> ACTIVO
                            </span>
                        }
                        else
                        {
                            <span class="status-badge status-inactive">
                                <i class="bi bi-x-circle-fill me-1"></i> INACTIVO
                            </span>
                        }

                        <div class="client-id">ID: @cliente.Id</div>
                    </div>
                </div>

            </div>

            <!-- ACCIONES DEL CLIENTE -->
            <div class="modern-card">
                <div class="section-header">
                    <i class="bi bi-lightning-charge"></i>
                    <h3>Acciones del Cliente</h3>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <DxButton Text="Historial de consumo" Click="AbrirHistoricoConsumo"
                        IconCssClass="bi bi-bar-chart-line" RenderStyle="ButtonRenderStyle.Secondary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Configurar tasas" Click="AbrirConfigTarifa"
                        IconCssClass="bi bi-gear" RenderStyle="ButtonRenderStyle.Secondary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Foto medidor" Click="AbrirFotoMedidor"
                        IconCssClass="bi bi-camera" RenderStyle="ButtonRenderStyle.Secondary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Historial cortes" Enabled="false"
                        IconCssClass="bi bi-scissors" RenderStyle="ButtonRenderStyle.Secondary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Historial de pagos" Enabled="false"
                        IconCssClass="bi bi-cash-stack" RenderStyle="ButtonRenderStyle.Secondary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Abono especial" Enabled="false"
                        IconCssClass="bi bi-coin" RenderStyle="ButtonRenderStyle.Secondary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                    <DxButton Text="Acción cobranza" Enabled="false"
                        IconCssClass="bi bi-exclamation-triangle" RenderStyle="ButtonRenderStyle.Secondary"
                        RenderStyleMode="ButtonRenderStyleMode.Outline" CssClass="btn-modern" />
                </div>
            </div>

            <!-- INFORMACIÓN GENERAL CON DxFormLayout -->
            <div class="modern-card">
                <div class="section-header">
                    <i class="bi bi-info-circle"></i>
                    <h3>Información General</h3>
                </div>

                <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                    <!-- DATOS PERSONALES Y DIRECCIÓN EN MISMA FILA -->
                    <DxFormLayoutGroup Caption="Datos personales" HeaderIconCssClass="bi bi-person-lines-fill"
                        ColSpanXs="12" ColSpanLg="6">
                        <DxFormLayoutItem Caption="Clave" ColSpanXs="12" ColSpanMd="6">
                            <div class="field-value">@MostrarObj(cliente.Codigo)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Nombre" ColSpanXs="12" ColSpanMd="6">
                            <div class="field-value">@MostrarTexto(cliente.Nombre)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Apellidos" ColSpanXs="12" ColSpanMd="12">
                            <div class="field-value">@MostrarTexto(cliente.Apellidos)</div>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem Caption="DNI" ColSpanXs="12" ColSpanMd="6">
                            <div class="field-value">@MostrarTexto(cliente.Dni)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="RTN" ColSpanXs="12" ColSpanMd="6">
                            <div class="field-value">@MostrarTexto(cliente.Rtn)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Fecha nacimiento" ColSpanXs="12" ColSpanMd="6">
                            <div class="field-value">@MostrarFecha(cliente.FechaNacimiento)</div>
                        </DxFormLayoutItem>

                        <DxFormLayoutItem Caption="Teléfono" ColSpanXs="12" ColSpanMd="6">
                            <div class="field-value">@MostrarTexto(cliente.Telefono)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Teléfono móvil" ColSpanXs="12" ColSpanMd="6">
                            <div class="field-value">@MostrarTexto(cliente.TelefonoMovil)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Email" ColSpanXs="12" ColSpanMd="12">
                            <div class="field-value">@MostrarTexto(cliente.Email)</div>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>
                    <!-- INFORMACIÓN ADICIONAL AL LADO DE DIRECCIÓN (EN OTRA FILA) -->
                    <DxFormLayoutGroup Caption="Información adicional" HeaderIconCssClass="bi bi-info-circle" ColSpanXs="12"
                        ColSpanLg="6" CssClass="mt-2">
                        <DxFormLayoutItem Caption="Tercera edad" ColSpanXs="12" ColSpanMd="6">
                            <div class="@GetBooleanClass(cliente.TerceraEdad)">@MostrarBooleano(cliente.TerceraEdad)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Bloqueado cobranza" ColSpanXs="12" ColSpanMd="6">
                            <div class="@GetBooleanClass(cliente.BloqueadoCobranza)">
                                @MostrarBooleano(cliente.BloqueadoCobranza)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Abogado" ColSpanXs="12" ColSpanMd="12">
                            <div class="field-value">@MostrarAbogado(cliente)</div>
                        </DxFormLayoutItem>
                        @if (cliente.DescuentoTerceraEdad.HasValue && cliente.DescuentoTerceraEdad > 0)
                        {
                            <DxFormLayoutItem Caption="Descuento 3ra edad" ColSpanXs="12" ColSpanMd="6">
                                <div class="field-value important">@cliente.DescuentoTerceraEdad.Value.ToString("N2")%</div>
                            </DxFormLayoutItem>
                        }
                    </DxFormLayoutGroup>

                    <!-- DIRECCIÓN AL LADO DE DATOS PERSONALES -->
                    <DxFormLayoutGroup Caption="Dirección" HeaderIconCssClass="bi bi-geo-alt-fill" ColSpanXs="12"
                        ColSpanLg="6">
                        <DxFormLayoutItem Caption="Barrio" ColSpanXs="12" ColSpanMd="8">
                            <div class="field-value">@MostrarTexto(cliente.BarrioNombre ?? cliente.BarrioCodigo)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Color casa" ColSpanXs="12" ColSpanMd="4">
                            <div class="field-value">@MostrarTexto(cliente.ColorCasa)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Dirección" ColSpanXs="12" ColSpanMd="12">
                            <div class="field-value">@MostrarTexto(cliente.Direccion)</div>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>



                    <!-- DATOS EMPRESA (SI EXISTEN) AL LADO DE INFORMACIÓN ADICIONAL -->
                    @if (!string.IsNullOrWhiteSpace(cliente.EmpresaNombre) ||
                                    !string.IsNullOrWhiteSpace(cliente.EmpresaRtn))
                    {
                        <DxFormLayoutGroup Caption="Datos empresa" HeaderIconCssClass="bi bi-building" ColSpanXs="12"
                            ColSpanLg="6" CssClass="mt-2">
                            @if (!string.IsNullOrWhiteSpace(cliente.EmpresaNombre))
                            {
                                <DxFormLayoutItem Caption="Empresa" ColSpanXs="12" ColSpanMd="12">
                                    <div class="field-value">@cliente.EmpresaNombre</div>
                                </DxFormLayoutItem>
                            }
                            @if (!string.IsNullOrWhiteSpace(cliente.EmpresaRtn))
                            {
                                <DxFormLayoutItem Caption="RTN / RIF" ColSpanXs="12" ColSpanMd="6">
                                    <div class="field-value">@cliente.EmpresaRtn</div>
                                </DxFormLayoutItem>
                            }
                            @if (!string.IsNullOrWhiteSpace(cliente.EmpresaTelefono))
                            {
                                <DxFormLayoutItem Caption="Teléfono" ColSpanXs="12" ColSpanMd="6">
                                    <div class="field-value">@cliente.EmpresaTelefono</div>
                                </DxFormLayoutItem>
                            }
                            @if (!string.IsNullOrWhiteSpace(cliente.EmpresaDireccion))
                            {
                                <DxFormLayoutItem Caption="Dirección" ColSpanXs="12" ColSpanMd="12">
                                    <div class="field-value">@cliente.EmpresaDireccion</div>
                                </DxFormLayoutItem>
                            }
                        </DxFormLayoutGroup>
                    }
                </DxFormLayout>
            </div>

            <!-- DATOS DE SERVICIOS -->
            <div class="modern-card">
                <div class="section-header">
                    <i class="bi bi-gear"></i>
                    <h3>Datos de Servicios</h3>
                </div>

                <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                    <!-- INFORMACIÓN BÁSICA DEL SERVICIO -->
                    <DxFormLayoutGroup Caption="Información básica" HeaderIconCssClass="bi bi-info-circle" ColSpanXs="12"
                        ColSpanLg="6">
                        <DxFormLayoutItem Caption="Servicio" ColSpanXs="12" ColSpanMd="6">
                            <div class="field-value">@MostrarTexto(cliente.ServicioNombre ?? cliente.ServicioId?.ToString())
                            </div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Categoría" ColSpanXs="12" ColSpanMd="6">
                            <div class="field-value">@MostrarTexto(cliente.CategoriaServicioNombre ??
                                                            cliente.CategoriaServicioId?.ToString())</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Tipo uso" ColSpanXs="12" ColSpanMd="4">
                            <div class="field-value">@MostrarTexto(cliente.TipoUsoCodigo)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Ciclo" ColSpanXs="12" ColSpanMd="8">
                            <div class="field-value">@MostrarTexto(cliente.CicloDescripcion ?? cliente.CicloId?.ToString())
                            </div>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>

                    <!-- CONFIGURACIÓN TÉCNICA -->
                    <DxFormLayoutGroup Caption="Configuración técnica" HeaderIconCssClass="bi bi-tools" ColSpanXs="12"
                        ColSpanLg="6">
                        <DxFormLayoutItem Caption="Letra" ColSpanXs="12" ColSpanMd="4">
                            <div class="field-value">@MostrarTexto(cliente.LetraCodigo)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Libreta" ColSpanXs="12" ColSpanMd="4">
                            <div class="field-value">@MostrarTexto(cliente.Libreta)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Secuencia" ColSpanXs="12" ColSpanMd="4">
                            <div class="field-value">@MostrarTexto(cliente.Secuencia)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Indicativo ruta" ColSpanXs="12" ColSpanMd="12">
                            <div class="field-value">@MostrarTexto(cliente.IndicativoRuta)</div>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>

                    <!-- MEDIDORES Y CONTRATOS -->
                    <DxFormLayoutGroup Caption="Medidores y contratos" HeaderIconCssClass="bi bi-speedometer2"
                        ColSpanXs="12" ColSpanLg="6" CssClass="mt-2">
                        <DxFormLayoutItem Caption="Clave catastral" ColSpanXs="12" ColSpanMd="6">
                            <div class="field-value">@MostrarTexto(cliente.ClaveCatastral)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Clave SURE" ColSpanXs="12" ColSpanMd="6">
                            <div class="field-value">@MostrarTexto(cliente.ClaveSure)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Contador" ColSpanXs="12" ColSpanMd="4">
                            <div class="field-value">@MostrarTexto(cliente.Contador)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Tiene medidor" ColSpanXs="12" ColSpanMd="4">
                            <div class="@GetBooleanClass(cliente.TieneMedidor)">@MostrarBooleano(cliente.TieneMedidor)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Medidor" ColSpanXs="12" ColSpanMd="4">
                            <div class="field-value">@MostrarTexto(cliente.MedidorNumero ?? cliente.MedidorId?.ToString())
                            </div>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>

                    <!-- CONVENIOS Y CONTRATOS -->
                    <DxFormLayoutGroup Caption="Convenios y contratos" HeaderIconCssClass="bi bi-file-earmark-text"
                        ColSpanXs="12" ColSpanLg="6" CssClass="mt-2">
                        <DxFormLayoutItem Caption="Tiene convenio" ColSpanXs="12" ColSpanMd="4">
                            <div class="@GetBooleanClass(cliente.TieneConvenio)">@MostrarBooleano(cliente.TieneConvenio)
                            </div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Número convenio" ColSpanXs="12" ColSpanMd="8">
                            <div class="field-value">@MostrarTexto(cliente.NumeroConvenio)</div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Tiene contrato" ColSpanXs="12" ColSpanMd="4">
                            <div class="@GetBooleanClass(cliente.TieneContrato)">@MostrarBooleano(cliente.TieneContrato)
                            </div>
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Número contrato" ColSpanXs="12" ColSpanMd="8">
                            <div class="field-value">@MostrarTexto(cliente.NumeroContrato)</div>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>

                    <!-- OBSERVACIONES -->
                    <DxFormLayoutGroup Caption="Observaciones" HeaderIconCssClass="bi bi-chat-text" ColSpanXs="12"
                        CssClass="mt-2">
                        <DxFormLayoutItem Caption="" ColSpanXs="12">
                            <div class="field-value"
                                style="white-space: pre-line; padding: 1rem; background: #f8f9fa; border-radius: 8px;">
                                @(string.IsNullOrWhiteSpace(cliente.Observaciones) ? "Sin observaciones" :
                                                            cliente.Observaciones)
                            </div>
                        </DxFormLayoutItem>
                    </DxFormLayoutGroup>
                </DxFormLayout>
            </div>

            <!-- AUDITORÍA COMPACTA -->
            <div class="modern-card" style="padding: 1rem;">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-person-check" style="color: #6c757d; font-size: 1.1rem;"></i>
                        <span style="font-weight: 600; color: #6c757d; font-size: 0.9rem;">AUDITORÍA</span>
                    </div>

                    <div class="d-flex flex-wrap gap-3">
                        <div class="d-flex align-items-center gap-1">
                            <span style="font-size: 0.85rem; color: #6c757d; font-weight: 500;">Usuario:</span>
                            <span
                                style="font-size: 0.9rem; color: #2c3e50; font-weight: 500;">@MostrarTexto(cliente.UsuarioCreacion)</span>
                        </div>

                        <div class="d-flex align-items-center gap-1">
                            <span style="font-size: 0.85rem; color: #6c757d; font-weight: 500;">Fecha creación:</span>
                            <span
                                style="font-size: 0.9rem; color: #2c3e50; font-weight: 500;">@MostrarFecha(cliente.FechaCreacion)</span>
                        </div>
                    </div>
                </div>
            </div>

        }
    </div>

</div>

<!-- Popup histórico consumo -->
<DxPopup Visible="@mostrarHistoricoConsumoModal"
         VisibleChanged="@(v => { mostrarHistoricoConsumoModal = v; })"
         Width="min(1100px, 95vw)"
         MaxHeight="90vh"
         Scrollable="true"
         HeaderText="Histórico de Consumo"
         CssClass="historico-consumo-popup">
    <BodyTemplate>
        <div class="p-2 historico-consumo-body">
            <ClienteHistoricoConsumoTab ClienteId="@Id" MostrarDatosCliente="false" @key="(mostrarHistoricoConsumoModal, Id)" />
        </div>
    </BodyTemplate>
</DxPopup>

<!-- Popup configuración de tarifas -->
<DxPopup Visible="@mostrarConfigTarifaModal"
         VisibleChanged="@(v => { mostrarConfigTarifaModal = v; })"
         Width="min(1000px, 95vw)"
         MaxHeight="90vh"
         Scrollable="true"
         HeaderText="Configuración de tarifas"
         CssClass="historico-consumo-popup">
    <BodyTemplate>
        <div class="p-2 historico-consumo-body">
            <ClienteConfiguracionTarifaTab ClienteId="@Id" @key="(mostrarConfigTarifaModal, Id)" />
        </div>
    </BodyTemplate>
</DxPopup>

<!-- Popup foto medidor -->
<DxPopup Visible="@mostrarFotoMedidorModal"
         VisibleChanged="@(v => { mostrarFotoMedidorModal = v; })"
         Width="min(1000px, 95vw)"
         MaxHeight="90vh"
         Scrollable="true"
         HeaderText="Foto medidor"
         CssClass="historico-consumo-popup">
    <BodyTemplate>
        <div class="p-2 historico-consumo-body">
            <ClienteFotoMedidorTab ClienteId="@Id" @key="(mostrarFotoMedidorModal, Id)" />
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    [Parameter] public int Id { get; set; }
    [Parameter] public bool MostrarEncabezado { get; set; } = true;

    ClienteDetailDto? cliente;
    bool isLoading = true;
    bool mostrarHistoricoConsumoModal = false;
    bool mostrarConfigTarifaModal = false;
    bool mostrarFotoMedidorModal = false;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        cliente = await ClientesClient.ObtenerPorIdAsync(Id);
        isLoading = false;
    }

    void BackToList() => Navigation.NavigateTo("/clientes");
    void AbrirHistoricoConsumo() => mostrarHistoricoConsumoModal = true;
    void AbrirConfigTarifa() => mostrarConfigTarifaModal = true;
    void AbrirFotoMedidor() => mostrarFotoMedidorModal = true;

    string GetInitials(string? name)
    => string.IsNullOrWhiteSpace(name) ? "C" : name.Substring(0, 1).ToUpper();

    private static string MostrarTexto(string? valor)
    => string.IsNullOrWhiteSpace(valor) ? "—" : valor;

    private static string MostrarFecha(DateTime? fecha)
    => fecha.HasValue ? fecha.Value.ToString("d") : "—";

    private static string MostrarBooleano(bool? valor)
    => valor.HasValue ? (valor.Value ? "Sí" : "No") : "—";

    private static string MostrarAbogado(ClienteDetailDto cliente)
    => !string.IsNullOrWhiteSpace(cliente.AbogadoNombre)
    ? cliente.AbogadoNombre!
    : (cliente.AbogadoId?.ToString() ?? "—");

    private static string MostrarObj(object? valor)
    => valor is null ? "—" : (valor.ToString() ?? "—");

    private string GetBooleanClass(bool? valor)
    {
        if (!valor.HasValue) return "field-value empty";
        return valor.Value ? "field-value boolean-yes" : "field-value boolean-no";
    }
}
