                            <DxGridDataColumn FieldName="Cliente" Caption="Cliente" />
                            <DxGridDataColumn FieldName="Ruta" Caption="Ruta" />
                            <DxGridDataColumn FieldName="Contador" Caption="Contador" />
                            <DxGridDataColumn FieldName="LecturaAnterior" Caption="Lect. anterior" />
                            <DxGridDataColumn FieldName="LecturaActual" Caption="Lect. actual" />
                            <DxGridDataColumn FieldName="Consumo" Caption="Consumo" />
                            <DxGridDataColumn FieldName="Condicion" Caption="Condici\u00f3n" />
                            <DxGridDataColumn FieldName="FechaLectura" Caption="Fecha">
                                <CellDisplayTemplate Context="cell">
                                    @{
                                        var item = (AuxiliarLecturaDto)cell.DataItem;
                                    }
                                    @(item.FechaLectura?.ToString("dd/MM/yyyy") ?? "-")
                                </CellDisplayTemplate>
                            </DxGridDataColumn>
                            <DxGridDataColumn FieldName="Usuario" Caption="Usuario" />
                        </Columns>
                    </DxGrid>
                }

                <DxPopup Visible="@generarPopupVisible" VisibleChanged="@(v => generarPopupVisible = v)">
                    <HeaderContent>Generar nuevo periodo</HeaderContent>
                    <BodyContent>
                        <DxFormLayout>
                            <DxFormLayoutItem Caption="A\u00f1o">
                                <DxSpinEdit @bind-Value="generarPeriodoModel.Anio" Min="2000" Max="2100" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Mes">
                                <DxSpinEdit @bind-Value="generarPeriodoModel.Mes" Min="1" Max="12" />
                            </DxFormLayoutItem>
                        </DxFormLayout>
                        <div class="mt-3 d-flex gap-2">
                            <DxButton Text="Generar" Click="GenerarPeriodoAsync" RenderStyle="ButtonRenderStyle.Primary" />
                            <DxButton Text="Cancelar" Click="@(() => generarPopupVisible = false)" />
                        </div>
                    </BodyContent>
                </DxPopup>

                <DxPopup Visible="@cargaMasivaPopupVisible" VisibleChanged="@(v => cargaMasivaPopupVisible = v)" Width="600px">
                    <HeaderContent>Carga masiva de lecturas</HeaderContent>
                    <BodyContent>
                        <DxFormLayout>
                            <DxFormLayoutItem Caption="A\u00f1o">
                                <DxSpinEdit @bind-Value="cargaMasivaModel.Anio" Min="2000" Max="2100" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Mes">
                                <DxSpinEdit @bind-Value="cargaMasivaModel.Mes" Min="1" Max="12" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Ciclo">
                                <DxTextBox @bind-Text="cargaMasivaModel.Ciclo" />
                            </DxFormLayoutItem>
                            <DxFormLayoutItem Caption="Lecturas (clave;contador;anterior;actual;usuario)">
                                <DxTextArea Text="@cargaMasivaModel.Contenido"
                                            TextChanged="@OnCargaMasivaContenidoChanged"
                                            Rows="8"
                                            Placeholder="Ejemplo:&#10;CLI-001;MED-001;120;135;LECT01" />
                            </DxFormLayoutItem>
                        </DxFormLayout>

                        @if (!string.IsNullOrEmpty(cargaMasivaError))
                        {
                            <DxAlert AlertType="AlertType.Danger" CssClass="mt-2">@cargaMasivaError</DxAlert>
                        }

                        <div class="mt-3 d-flex gap-2">
                            <DxButton Text="Enviar"
                                      Click="EnviarCargaMasivaAsync"
                                      RenderStyle="ButtonRenderStyle.Primary"
                                      Enabled="@( !cargaMasivaGuardando )" />
                            <DxButton Text="Cancelar"
                                      Click="@CancelarCargaMasiva"
                                      RenderStyle="ButtonRenderStyle.Secondary"
                                      Enabled="@( !cargaMasivaGuardando )" />
                        </div>
                    </BodyContent>
                </DxPopup>
            </DxTab>


        </DxTabs>
    }
</DxScrollView>

