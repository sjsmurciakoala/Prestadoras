    private async Task CrearSolicitudAsync()
    {
        if (cliente is null)
            return;

        await EnsureCategoriasAsync();

        if (!categoriasLoaded || categorias.Count == 0)
        {
            ShowToast("Solicitudes", "No hay categorías activas disponibles para crear solicitudes.", ToastRenderStyle.Danger);
            return;
        }

        var categoriaSeleccionada = categorias.FirstOrDefault(c => c.Id == nuevaSolicitud.CategoriaServicioId);
        if (categoriaSeleccionada is null)
        {
            ShowToast("Solicitudes", "Seleccione una categoría válida.", ToastRenderStyle.Danger);
            return;
        }

        try
        {
            var telefono = (nuevaSolicitud.Telefono ?? string.Empty).Trim();
            var direccion = (nuevaSolicitud.Direccion ?? string.Empty).Trim();
            var correo = (nuevaSolicitud.Correo ?? string.Empty).Trim();

            if (string.IsNullOrWhiteSpace(telefono) || string.IsNullOrWhiteSpace(direccion))
            {
                ShowToast("Solicitudes", "Teléfono y dirección son obligatorios.", ToastRenderStyle.Danger);
                return;
            }

            if (string.IsNullOrWhiteSpace(correo))
            {
                ShowToast("Solicitudes", "El correo es obligatorio.", ToastRenderStyle.Danger);
                return;
            }

            if (!EmailValidator.IsValid(correo))
            {
                ShowToast("Solicitudes", "El correo no tiene un formato válido.", ToastRenderStyle.Danger);
                return;
            }

            var dto = new SolicitudDetailDto(
            0,
            cliente.Identidad ?? string.Empty,
            cliente.Nombre,
            nuevaSolicitud.CategoriaServicioId,
            telefono,
            direccion,
            correo,
            string.IsNullOrWhiteSpace(nuevaSolicitud.Observacion) ? null : nuevaSolicitud.Observacion?.Trim(),
            DateTime.UtcNow,
            true,
            categoriaSeleccionada.Nombre);

            var response = await Http.PostAsJsonAsync("api/solicitudes", dto);
            response.EnsureSuccessStatusCode();

            solicitudesLoaded = false;
            solicitudes.Clear();
            await LoadSolicitudesAsync();

            var solicitudNueva = solicitudes
                .OrderByDescending(s => s.Fecha)
                .FirstOrDefault();
            var mensaje = solicitudNueva is not null
                ? $"Solicitud #{solicitudNueva.Id} registrada correctamente."
                : "Solicitud registrada correctamente.";
            ShowToast("Solicitudes", mensaje, ToastRenderStyle.Success);

            nuevaSolicitud = CrearModeloInicial();
        }
        catch (Exception ex)
        {
            ShowToast("Solicitudes", "Error al registrar la solicitud. " + ex.Message, ToastRenderStyle.Danger);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        error = null;

        try
        {
            cliente = await Http.GetFromJsonAsync<ClienteDetailDto>($"api/clientes/{Id}");
            if (cliente is not null)
            {
                nuevaSolicitud = CrearModeloInicial();
            }
        }
        catch (HttpRequestException ex)
        {
            error = ex.Message;
            Logger.LogError(ex, "Error al cargar cliente {ClienteId}", Id);
        }
        catch (Exception ex)
        {
            error = "Ocurrió un error inesperado.";
            Logger.LogError(ex, "Error inesperado al cargar cliente {ClienteId}", Id);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void BackToList() => Navigation.NavigateTo("/clientes");

