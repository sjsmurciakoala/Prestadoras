@page "/clientes/{id:int}"
@attribute [Authorize]
@using SIAD.Core.DTOs.Clientes
@using apc.Client.Services.Clientes
@using apc.Client.Pages.Clientes.Components
@inject ClientesClient ClientesClient
@inject NavigationManager Navigation
@inject ILogger<ClienteDetail> Logger

<ErrorBoundary>
    <ErrorContent Context="ex">
        <div class="alert alert-danger" role="alert">
            Error en la pantalla de cliente: @ex.Message
        </div>
    </ErrorContent>
    <ChildContent>
        <DxScrollView Height="100%">
            <DxToastProvider Name="MainToast" MaxToastCount="4" />

            <DxToolbar>
                <Items>
                    <DxToolbarItem CssClass="m-2" Text="Regresar a la lista" IconCssClass="oi oi-arrow-left"
                                   Click="BackToList" />
                </Items>
            </DxToolbar>

            @if (isLoading)
            {
                <div class="text-muted mb-2">Cargando cliente @Id...</div>
                <DxSkeletonLine />
                <DxSkeletonLine />
                <DxSkeletonLine />
            }
            else if (!string.IsNullOrEmpty(error))
            {
                <div class="alert alert-danger" role="alert">@error</div>
            }
            else if (cliente is null)
            {
                <div class="alert alert-warning" role="alert">Cliente no encontrado.</div>
            }
            else
            {
                <div class="mb-2">
                    <strong>@cliente.Codigo</strong>
                    <span class="ms-2">@cliente.Nombre</span>
                </div>

                <ErrorBoundary>
                    <ErrorContent Context="ex">
                        <div class="alert alert-danger" role="alert">
                            Error renderizando el detalle del cliente: @ex.Message
                        </div>
                    </ErrorContent>
                    <ChildContent>
                        <DxTabs @bind-ActiveTabIndex="activeTabIndex" CssClass="mb-3">
                            <DxTabPage Text="Datos generales">
                                <ContentTemplate>
                                    @if (activeTabIndex == 0)
                                    {
                                        <ClienteDetailGeneral Cliente="@cliente" />
                                    }
                                </ContentTemplate>
                            </DxTabPage>

                            <DxTabPage Text="Tarifas">
                                <ContentTemplate>
                                    @if (activeTabIndex == 1)
                                    {
                                        <ClienteTarifasTab ClienteId="@cliente.Id" />
                                    }
                                </ContentTemplate>
                            </DxTabPage>

                            <DxTabPage Text="Estado de cuenta">
                                <ContentTemplate>
                                    @if (activeTabIndex == 2)
                                    {
                                        <ClienteEstadoCuentaTab ClienteId="@cliente.Id" />
                                    }
                                </ContentTemplate>
                            </DxTabPage>

                            <DxTabPage Text="Solicitudes">
                                <ContentTemplate>
                                    @if (activeTabIndex == 3)
                                    {
                                        <ClienteSolicitudesTab Cliente="@cliente" />
                                    }
                                </ContentTemplate>
                            </DxTabPage>

                            <DxTabPage Text="Medidores">
                                <ContentTemplate>
                                    @if (activeTabIndex == 4)
                                    {
                                        <ClienteMedidoresTab Cliente="@cliente" />
                                    }
                                </ContentTemplate>
                            </DxTabPage>

                            <DxTabPage Text="Auxiliar de Lectura">
                                <ContentTemplate>
                                    @if (activeTabIndex == 5)
                                    {
                                        <ClienteAuxiliarLecturaTab />
                                    }
                                </ContentTemplate>
                            </DxTabPage>
                        </DxTabs>
                    </ChildContent>
                </ErrorBoundary>
            }
        </DxScrollView>
    </ChildContent>
</ErrorBoundary>

@code {
    [Parameter]
    public int Id { get; set; }

    private ClienteDetailDto? cliente;
    private bool isLoading = true;
    private string? error;
    private int activeTabIndex;

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;
        error = null;

        try
        {
            cliente = await ClientesClient.ObtenerPorIdAsync(Id);
        }
        catch (Exception ex)
        {
            error = ex.Message;
            Logger.LogError(ex, "Error al cargar cliente {ClienteId}", Id);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void BackToList() => Navigation.NavigateTo("/clientes");
}
