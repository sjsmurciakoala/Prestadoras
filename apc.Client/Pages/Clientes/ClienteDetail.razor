    private SolicitudCreateModel CrearModeloInicial() => new()
    {
        Telefono = cliente?.Telefono ?? string.Empty,
        Direccion = cliente?.Direccion ?? string.Empty,
        Correo = string.Empty,
        Observacion = null,
        CategoriaServicioId = categorias.FirstOrDefault()?.Id ?? 0
