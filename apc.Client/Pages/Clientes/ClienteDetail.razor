    private async Task EnsureCategoriasAsync()
    {
        if (categoriasLoaded)
            return;

        try
        {
            var result = await Http.GetFromJsonAsync<List<SolicitudCategoriaDto>>("api/solicitudes/categorias");
            categorias = result?
                .Where(c => c.Activa)
                .OrderBy(c => c.Nombre)
                .ToList()
                ?? new List<SolicitudCategoriaDto>();

            categoriasError = categorias.Count == 0
                ? "No hay categorias activas configuradas en la base de datos."
                : null;

            if (categorias.Count > 0 &&
                (nuevaSolicitud.CategoriaServicioId == 0 ||
                 categorias.All(c => c.Id != nuevaSolicitud.CategoriaServicioId)))
            {
                nuevaSolicitud.CategoriaServicioId = categorias[0].Id;
            }

            categoriasLoaded = true;
        }
        catch (Exception ex)
        {
            categoriasError = "Error al cargar las categorias de servicio. " + ex.Message;
            categorias = new List<SolicitudCategoriaDto>();
            categoriasLoaded = false;
        }
