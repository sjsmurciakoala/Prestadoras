@page "/clientes"
@attribute [Authorize]

@using DevExpress.Blazor
@using SIAD.Core.DTOs.Clientes
@using apc.Client.Services.Clientes
@using apc.Client.Pages.Clientes.Components
@using apc.Client.Pages.Clientes

@inject ClientesClient ClientesClient
@inject NavigationManager Navigation
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Clientes</PageTitle>

<div class="page-container">
    <!-- Header igual a Solicitudes -->
    <div class="header-section">
        <div>
            <h2 class="page-title">Directorio de Clientes</h2>
            <p class="page-subtitle">Gestión centralizada de cartera y expedientes</p>
        </div>

        <DxButton Text="Nuevo Cliente" Click="NuevoCliente" IconCssClass="bi bi-plus-lg"
            RenderStyle="ButtonRenderStyle.Primary" CssClass="btn-modern" />
    </div>

    <!-- Panel de filtros (colapsable) -->
    @if (mostrarFiltros)
    {
        <div class="modern-card mb-4">
            <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                <DxFormLayoutGroup Caption="Filtros" HeaderIconCssClass="bi bi-funnel" ColSpanXs="12">

                    <DxFormLayoutItem Caption="Búsqueda Rápida" ColSpanXs="12" ColSpanMd="5">
                        <Template>
                            <DxTextBox Text="@filtroBusqueda" TextChanged="@((string v) => OnBusquedaChanged(v))"
                                TextExpression="@(() => filtroBusqueda)" Placeholder="Escribe para buscar..."
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" InputDelay="600"
                                InputAttributes="@(new Dictionary<string, object> { ["autocomplete"] = "off" })" />
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Estado" ColSpanXs="12" ColSpanMd="3">
                        <Template>
                            <div class="pt-md-4 pt-2">
                                <DxCheckBox Checked="@filtroSoloActivos" CheckedChanged="@((bool v) => OnEstadoChanged(v))"
                                    LabelText="" CheckType="CheckType.Switch" />
                            </div>
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanXs="12" ColSpanMd="4" CssClass="align-self-end">
                        <Template>
                            <div class="filters-actions">
                                <DxButton Text="Filtrar" IconCssClass="bi bi-search"
                                    CssClass="filters-btn filters-btn-primary" RenderStyle="ButtonRenderStyle.Secondary"
                                    Click="BuscarAsync" />

                                <button type="button" class="filters-link" @onclick="LimpiarFiltrosAsync">
                                    Limpiar
                                </button>
                            </div>
                        </Template>
                    </DxFormLayoutItem>

                </DxFormLayoutGroup>
            </DxFormLayout>
        </div>
    }

    <!-- Grid -->
    <div class="modern-card">
        <div class="grid-wrapper">
            <DxGrid @ref="grid" Data="@dataSource" KeyFieldName="Id" PageSize="50"
                PagerPosition="GridPagerPosition.Bottom" ShowFilterRow="false" ShowSearchBox="false"
                ColumnResizeMode="GridColumnResizeMode.ColumnsContainer" FocusedRowEnabled="false"
                ShowGroupPanel="false" CssClass="grid-solicitudes">

                <ToolbarTemplate>
                    <div class="d-flex flex-wrap gap-2 align-items-center w-100">

                        <!-- Buscador DevExpress (remoto) -->
                        <DxTextBox Text="@filtroBusqueda" TextChanged="@((string v) => OnBusquedaChanged(v))"
                            TextExpression="@(() => filtroBusqueda)"
                            Placeholder="Buscar cliente..." InputDelay="600"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" CssClass="me-1"
                            Style="min-width: 260px;"
                            InputAttributes="@(new Dictionary<string, object> { ["autocomplete"] = "off" })" />

                        <DxButton Text="Recargar" IconCssClass="bi bi-arrow-clockwise"
                            RenderStyle="ButtonRenderStyle.Secondary" Click="RecargarGrid" CssClass="me-1" />

                        <DxButton Text="Filtros" IconCssClass="bi bi-funnel" RenderStyle="ButtonRenderStyle.Secondary"
                            Click="ToggleFiltros" CssClass="me-1" />

                        <DxButton Text="Columnas" IconCssClass="bi bi-layout-three-columns"
                            RenderStyle="ButtonRenderStyle.Secondary" Click="MostrarColumnChooser" CssClass="me-1" />

                        

                        <div class="ms-auto text-muted small">
                            Total: <span class="fw-bold">@totalClientes.ToString("N0")</span>
                        </div>
                    </div>
                </ToolbarTemplate>

                <Columns>
                    <DxGridDataColumn FieldName="Codigo" Caption="Código" Width="140px">
                        <CellDisplayTemplate Context="cell">
                            @{
                                var c = (ClienteListItemDto)cell.DataItem;
                            }
                            <span class="text-dark fw-semibold">@c.Codigo</span>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="Nombre" Caption="Cliente" MinWidth="360">
                        <CellDisplayTemplate Context="cell">
                            @{
                                var c = (ClienteListItemDto)cell.DataItem;
                                var identidad = FormatearIdentidad(c.Identidad);
                                var sub = string.IsNullOrWhiteSpace(identidad) ? c.Codigo : $"DNI: {identidad}";
                            }
                            <div class="client-cell">
                                <div class="client-title" title="@c.Nombre">@c.Nombre</div>
                                <div class="client-sub">
                                    <i class="bi bi-card-text"></i>
                                    <span class="text-truncate" title="@sub">@sub</span>
                                </div>
                            </div>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="Barrio" Caption="Barrio / Zona" Width="220px">
                        <CellDisplayTemplate Context="cell">
                            @{
                                var c = (ClienteListItemDto)cell.DataItem;
                            }
                            <div class="text-truncate text-muted" title="@c.Barrio">@c.Barrio</div>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="CicloCodigo" Caption="Ciclo" Width="110px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @{
                                var c = (ClienteListItemDto)cell.DataItem;
                            }
                            <span class="text-muted">@(string.IsNullOrWhiteSpace(c.CicloCodigo) ? "—" : c.CicloCodigo)</span>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="Ruta" Caption="Ruta" Width="160px">
                        <CellDisplayTemplate Context="cell">
                            @{
                                var c = (ClienteListItemDto)cell.DataItem;
                            }
                            <div class="text-truncate text-muted" title="@c.Ruta">@(string.IsNullOrWhiteSpace(c.Ruta) ? "—" : c.Ruta)</div>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn Caption="Estado" Width="140px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @{
                                var c = (ClienteListItemDto)cell.DataItem;
                            }
                            @if (c.Activo)
                            {
                                <span class="badge-status active">ACTIVO</span>
                            }
                            else
                            {
                                <span class="badge-status inactive">INACTIVO</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn Caption="Acciones" Width="240px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @{
                                var c = (ClienteListItemDto)cell.DataItem;
                            }
                            <div class="d-flex justify-content-center gap-2 flex-wrap">
                                <button type="button" class="btn-icon btn-view" title="Ver"
                                    @onclick="() => VerCliente(c.Id)" @onclick:stopPropagation="true">
                                    <i class="bi bi-eye"></i>
                                </button>

                                <button type="button" class="btn-icon btn-edit" title="Editar"
                                    @onclick="() => EditarCliente(c.Id)" @onclick:stopPropagation="true">
                                    <i class="bi bi-pencil-square"></i>
                                </button>

                                <button type="button" class="btn-icon btn-estado" title="Estado de cuenta"
                                    @onclick="() => AbrirEstadoCuentaModal(c.Id)" @onclick:stopPropagation="true">
                                    <i class="bi bi-receipt"></i>
                                </button>

                                <button type="button" class="btn-icon btn-medidores" title="Medidores"
                                    @onclick="() => AbrirMedidoresModalAsync(c.Id)" @onclick:stopPropagation="true">
                                    <i class="bi bi-speedometer2"></i>
                                </button>
                            </div>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>

                <EmptyDataAreaTemplate>
                    <div class="p-4 text-center text-muted">No hay clientes para mostrar.</div>
                </EmptyDataAreaTemplate>

            </DxGrid>
        </div>
    </div>
</div>

<!-- Popup estado de cuenta -->
<DxPopup Visible="@mostrarEstadoCuentaModal"
         VisibleChanged="@(v => { mostrarEstadoCuentaModal = v; if (!v) clienteAccionId = null; })"
         Width="min(900px, 95vw)"
         MaxHeight="90vh"
         Scrollable="true"
         HeaderText="Estado de cuenta">
    <BodyContentTemplate>
        @if (clienteAccionId.HasValue)
        {
            <div class="p-2">
                <ClienteEstadoCuentaTab ClienteId="@clienteAccionId.Value" @key="(mostrarEstadoCuentaModal, clienteAccionId)" />
            </div>
        }
    </BodyContentTemplate>
</DxPopup>

<!-- Popup medidores -->
<DxPopup Visible="@mostrarMedidoresModal"
         VisibleChanged="@(v => { mostrarMedidoresModal = v; if (!v) { clienteAccionId = null; clienteAccionDetalle = null; clienteAccionLoading = false; } })"
         Width="min(1000px, 95vw)"
         MaxHeight="90vh"
         Scrollable="true"
         HeaderText="Medidores del cliente">
    <BodyTemplate>
        @if (clienteAccionLoading)
        {
            <div class="p-4 text-center">
                <DxLoadingPanel Visible="true" Text="Cargando cliente..." />
                <div style="height:80px"></div>
            </div>
        }
        else if (clienteAccionDetalle is not null)
        {
            <div class="p-2">
                <ClienteMedidoresTab Cliente="@clienteAccionDetalle" @key="(mostrarMedidoresModal, clienteAccionDetalle.Id)" />
            </div>
        }
    </BodyTemplate>
</DxPopup>

@code {
    private DxGrid? grid;
    private ClientesGridDataSource dataSource = default!;

    private bool mostrarEstadoCuentaModal = false;
    private bool mostrarMedidoresModal = false;
    private int? clienteAccionId;
    private ClienteDetailDto? clienteAccionDetalle;
    private bool clienteAccionLoading = false;

    private string filtroBusqueda = "";
    private bool filtroSoloActivos = true;

    private int totalClientes = 0;

    private bool mostrarFiltros = true;
    

    protected override void OnInitialized()
    {
        dataSource = new ClientesGridDataSource(ClientesClient, total =>
        {
            totalClientes = total;
            InvokeAsync(StateHasChanged);
        })
        {
            SearchText = filtroBusqueda,
            SoloActivos = filtroSoloActivos
        };
    }

    private async Task OnBusquedaChanged(string valor)
    {
        filtroBusqueda = valor;
        await BuscarAsync();
    }

    private async Task OnEstadoChanged(bool valor)
    {
        filtroSoloActivos = valor;
        await BuscarAsync();
    }

    private async Task LimpiarFiltrosAsync()
    {
        filtroBusqueda = "";
        filtroSoloActivos = true;
        await BuscarAsync();
    }

    private Task BuscarAsync()
    {
        dataSource.SearchText = filtroBusqueda;
        dataSource.SoloActivos = filtroSoloActivos;
        grid?.Reload(); // Reload() es void en tu versión
        return Task.CompletedTask;
    }

    private void RecargarGrid() => grid?.Reload();
    private void ToggleFiltros() => mostrarFiltros = !mostrarFiltros;
    
    private void MostrarColumnChooser() => grid?.ShowColumnChooser();

    private void NuevoCliente() => Navigation.NavigateTo("/clientes/nuevo");
    private void VerCliente(int id) => Navigation.NavigateTo($"/clientes/{id}");
    private void EditarCliente(int id) => Navigation.NavigateTo($"/clientes/{id}/editar");

    private static string? FormatearIdentidad(string? identidad)
    {
        if (string.IsNullOrWhiteSpace(identidad))
            return null;

        var digits = new string(identidad.Where(char.IsDigit).ToArray());
        if (digits.Length == 13)
            return $"{digits.Substring(0, 4)}-{digits.Substring(4, 4)}-{digits.Substring(8, 5)}";

        return identidad;
    }

    private void AbrirEstadoCuentaModal(int id)
    {
        clienteAccionId = id;
        mostrarEstadoCuentaModal = true;
    }

    private async Task AbrirMedidoresModalAsync(int id)
    {
        clienteAccionId = id;
        clienteAccionDetalle = null;
        clienteAccionLoading = true;
        mostrarMedidoresModal = true;

        try
        {
            clienteAccionDetalle = await ClientesClient.ObtenerPorIdAsync(id);
            if (clienteAccionDetalle is null)
            {
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Clientes",
                    Text = "No se encontró el cliente.",
                    RenderStyle = ToastRenderStyle.Danger
                });
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Clientes",
                Text = $"Error al cargar el cliente: {ex.Message}",
                RenderStyle = ToastRenderStyle.Danger
            });
        }
        finally
        {
            clienteAccionLoading = false;
        }
    }
}
