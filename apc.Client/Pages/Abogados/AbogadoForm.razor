@using DevExpress.Blazor

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" Context="EditFormContext">
    <DataAnnotationsValidator />

    @if (EditFormContext.GetValidationMessages().Any())
    {
        <div class="alert alert-danger mb-3 shadow-sm">
            <h6 class="alert-heading"><i class="bi bi-exclamation-circle-fill me-2"></i>Atención</h6>
            <DxValidationSummary />
        </div>
    }

    <DxFormLayout>
        <DxFormLayoutItem Caption="Código *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Codigo"
                       NullText="Código del abogado"
                       MaxLength="50" />
            <ValidationMessage For="() => Model.Codigo" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Nombre corto *" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.NombreCorto"
                       NullText="Nombre corto"
                       MaxLength="100" />
            <ValidationMessage For="() => Model.NombreCorto" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Nombre largo" ColSpanMd="12">
            <DxTextBox @bind-Text="Model.NombreLargo"
                       NullText="Nombre completo"
                       MaxLength="300" />
            <ValidationMessage For="() => Model.NombreLargo" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Teléfono" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.Telefono"
                       NullText="Teléfono"
                       MaxLength="11" />
            <ValidationMessage For="() => Model.Telefono" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Cuenta contable" ColSpanMd="6">
            <DxTextBox @bind-Text="Model.CodCuenta"
                       NullText="Código cuenta contable"
                       MaxLength="100" />
            <ValidationMessage For="() => Model.CodCuenta" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Estado" ColSpanMd="6">
            <Template>
                <div class="pt-2">
                    <DxCheckBox @bind-Checked="Model.Activo"
                                CheckType="CheckType.Switch"
                                LabelText="Activo" />
                </div>
            </Template>
        </DxFormLayoutItem>
    </DxFormLayout>

    <ValidationSummary class="text-danger mb-3" />

    <div class="d-flex justify-content-end gap-2">
        <DxButton ButtonType="ButtonType.Submit"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  SubmitFormOnClick="true"
                  Enabled="@(!IsBusy)" />
        <DxButton ButtonType="ButtonType.Normal"
                  Text="Cancelar"
                  Enabled="@(!IsBusy)"
                  Click="Cancel" />
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public AbogadoEditDto Model { get; set; } = default!;

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private async Task HandleValidSubmit()
    {
        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }
    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }
}
