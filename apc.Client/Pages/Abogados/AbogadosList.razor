@page "/abogados"
@attribute [Authorize]

@using DevExpress.Blazor
@using SIAD.Core.DTOs.Abogados
@using apc.Client.Services.Abogados

@inject AbogadosClient AbogadosClient
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Abogados</PageTitle>

<div class="page-container">
    <DxToastProvider Name="AbogadosToast" MaxToastCount="4" />

    <div class="header-section">
        <div>
            <h2 class="page-title">Directorio de Abogados</h2>
            <p class="page-subtitle">Mantenimiento y control de abogados registrados</p>
        </div>

        <DxButton Text="Nuevo abogado"
                  IconCssClass="bi bi-plus-lg"
                  RenderStyle="ButtonRenderStyle.Primary"
                  CssClass="btn-modern"
                  Click="AbrirNuevo" />
    </div>

    @if (mostrarFiltros)
    {
        <div class="modern-card mb-4">
            <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                <DxFormLayoutGroup Caption="Filtros" HeaderIconCssClass="bi bi-funnel" ColSpanXs="12">
                    <DxFormLayoutItem Caption="Búsqueda rápida" ColSpanXs="12" ColSpanMd="6">
                        <Template>
                            <DxTextBox Text="@filtroBusqueda"
                                       TextChanged="@((string v) => OnBusquedaChanged(v))"
                                       Placeholder="Código, nombre o teléfono..."
                                       ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                       InputDelay="600" />
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Estado" ColSpanXs="12" ColSpanMd="3">
                        <Template>
                            <div class="pt-md-4 pt-2">
                                <DxCheckBox Checked="@filtroSoloActivos"
                                            CheckedChanged="@((bool v) => OnEstadoChanged(v))"
                                            LabelText=""
                                            CheckType="CheckType.Switch" />
                            </div>
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanXs="12" ColSpanMd="3" CssClass="align-self-end">
                        <Template>
                            <div class="filters-actions">
                                <DxButton Text="Filtrar"
                                          IconCssClass="bi bi-search"
                                          CssClass="filters-btn filters-btn-primary"
                                          RenderStyle="ButtonRenderStyle.Secondary"
                                          Click="BuscarAsync" />

                                <button type="button" class="filters-link" @onclick="LimpiarFiltrosAsync">
                                    Limpiar
                                </button>
                            </div>
                        </Template>
                    </DxFormLayoutItem>
                </DxFormLayoutGroup>
            </DxFormLayout>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <DxAlert AlertType="AlertType.Danger" CssClass="mb-3">@errorMessage</DxAlert>
    }

    <div class="modern-card position-relative">
        <DxLoadingPanel Visible="isLoading" IsContentBlocked="true" Text="Cargando..." />

        <div class="grid-wrapper">
            <DxGrid @ref="grid" Data="@abogados" KeyFieldName="@nameof(AbogadoListItemDto.Id)" PageSize="15"
                    PagerPosition="GridPagerPosition.Bottom" ShowFilterRow="false" ShowSearchBox="false"
                    ColumnResizeMode="GridColumnResizeMode.ColumnsContainer" FocusedRowEnabled="false"
                    ShowGroupPanel="false" CssClass="grid-solicitudes">

                <ToolbarTemplate>
                    <div class="d-flex flex-wrap gap-2 align-items-center w-100">
                        <DxTextBox Text="@filtroBusqueda" TextChanged="@((string v) => OnBusquedaChanged(v))"
                                   TextExpression="@(() => filtroBusqueda)"
                                   Placeholder="Buscar abogado..." InputDelay="600"
                                   ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" CssClass="me-1"
                                   Style="min-width: 260px;" />

                        <DxButton Text="Recargar" IconCssClass="bi bi-arrow-clockwise"
                                  RenderStyle="ButtonRenderStyle.Secondary" Click="RecargarGrid" CssClass="me-1" />

                        <DxButton Text="Filtros" IconCssClass="bi bi-funnel" RenderStyle="ButtonRenderStyle.Secondary"
                                  Click="ToggleFiltros" CssClass="me-1" />

                        <DxButton Text="Columnas" IconCssClass="bi bi-layout-three-columns"
                                  RenderStyle="ButtonRenderStyle.Secondary" Click="MostrarColumnChooser" CssClass="me-1" />

                        <DxButton Text="CSV" IconCssClass="bi bi-filetype-csv"
                                  RenderStyle="ButtonRenderStyle.Secondary" Click="ExportCsvAsync" CssClass="me-1" />

                        <DxButton Text="Excel" IconCssClass="bi bi-file-earmark-excel"
                                  RenderStyle="ButtonRenderStyle.Secondary" Click="ExportExcelAsync" CssClass="me-1" />

                        <DxButton Text="PDF" IconCssClass="bi bi-file-earmark-pdf"
                                  RenderStyle="ButtonRenderStyle.Secondary" Click="ExportPdfAsync" CssClass="me-1" />

                        <div class="ms-auto text-muted small">
                            Total: <span class="fw-bold">@totalAbogados.ToString("N0")</span>
                        </div>
                    </div>
                </ToolbarTemplate>

                <Columns>
                    <DxGridDataColumn FieldName="@nameof(AbogadoListItemDto.Codigo)" Caption="Código" Width="140px">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is AbogadoListItemDto item)
                            {
                                <span class="text-dark fw-semibold">@item.Codigo</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="@nameof(AbogadoListItemDto.NombreCorto)" Caption="Abogado" MinWidth="280">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is AbogadoListItemDto item)
                            {
                                <div class="abogado-cell">
                                    <div class="abogado-title" title="@item.NombreCorto">@item.NombreCorto</div>
                                    <div class="abogado-sub">
                                        <i class="bi bi-person-badge"></i>
                                        <span class="text-truncate" title="@item.NombreLargo">
                                            @(string.IsNullOrWhiteSpace(item.NombreLargo) ? "Sin nombre largo" : item.NombreLargo)
                                        </span>
                                    </div>
                                </div>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="@nameof(AbogadoListItemDto.Telefono)" Caption="Teléfono" Width="150px">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is AbogadoListItemDto item)
                            {
                                <span class="text-muted">@(string.IsNullOrWhiteSpace(item.Telefono) ? "—" : item.Telefono)</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="@nameof(AbogadoListItemDto.CodCuenta)" Caption="Cuenta" Width="170px">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is AbogadoListItemDto item)
                            {
                                <span class="text-muted">@(string.IsNullOrWhiteSpace(item.CodCuenta) ? "—" : item.CodCuenta)</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn Caption="Estado" Width="140px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is AbogadoListItemDto item)
                            {
                                if (item.Activo)
                                {
                                    <span class="badge-status active">ACTIVO</span>
                                }
                                else
                                {
                                    <span class="badge-status inactive">INACTIVO</span>
                                }
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn Caption="Acciones" Width="180px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is AbogadoListItemDto item)
                            {
                                <div class="d-flex justify-content-center gap-2 flex-wrap">
                                    <button type="button" class="btn-icon btn-edit" title="Editar"
                                            @onclick="() => AbrirEditarAsync(item.Id)" @onclick:stopPropagation="true">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    <button type="button" class="btn-icon btn-delete" title="Desactivar"
                                            disabled="@(!item.Activo)"
                                            @onclick="() => ConfirmarDesactivar(item)" @onclick:stopPropagation="true">
                                        <i class="bi bi-slash-circle"></i>
                                    </button>
                                </div>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>

                <EmptyDataAreaTemplate>
                    <div class="p-4 text-center text-muted">No hay abogados para mostrar.</div>
                </EmptyDataAreaTemplate>
            </DxGrid>
        </div>
    </div>
</div>

<DxPopup @bind-Visible="formVisible"
         Width="min(820px, 95vw)"
         Height="auto"
         MaxHeight="90vh"
         Scrollable="true"
         CssClass="custom-popup"
         CloseOnOutsideClick="false">
    <HeaderContentTemplate>
        <div class="d-flex align-items-center gap-2">
            <div class="@PopupIconWrapperClass" style="width: 38px; height: 38px;">
                <i class="@PopupIcon"></i>
            </div>
            <div>
                <div class="fw-bold fs-6 text-dark" style="line-height:1.1;">@PopupTitle</div>
                <div class="small text-muted" style="font-weight: normal; font-size: 0.8rem;">@PopupSubtitle</div>
            </div>
        </div>
    </HeaderContentTemplate>

    <BodyContentTemplate>
        @if (formLoading)
        {
            <div class="text-center p-4">
                <DxLoadingPanel Visible="true" Text="Cargando abogado..." />
                <div style="height:80px"></div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(formError))
        {
            <div class="p-3">
                <DxAlert AlertType="AlertType.Danger">@formError</DxAlert>
            </div>
        }
        else
        {
            <AbogadoForm Model="formModel"
                         OnValidSubmit="GuardarAsync"
                         OnCancel="CerrarForm"
                         IsBusy="isSaving" />
        }
    </BodyContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="confirmVisible" Width="min(420px, 90vw)" HeaderText="Confirmar acción" ShowFooter="false">
    <BodyTemplate>
        <div class="text-center p-4">
            <div class="mb-3 text-warning"><i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i></div>
            <h5 class="fw-bold">¿Desactivar abogado?</h5>
            <p class="text-muted">El abogado pasará a estado inactivo pero no se eliminará del sistema.</p>
            @if (abogadoParaDesactivar is not null)
            {
                <div class="fw-semibold">@abogadoParaDesactivar.Codigo - @abogadoParaDesactivar.NombreCorto</div>
            }
            <div class="d-flex justify-content-center gap-3 mt-4">
                <DxButton Text="Cancelar"
                          Click="CancelarDesactivar"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          RenderStyleMode="ButtonRenderStyleMode.Outline" />
                <DxButton Text="Sí, desactivar"
                          Click="DesactivarConfirmadoAsync"
                          RenderStyle="ButtonRenderStyle.Danger"
                          IconCssClass="bi bi-slash-circle" />
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    private DxGrid? grid;
    private List<AbogadoListItemDto> abogados = new();

    private string filtroBusqueda = string.Empty;
    private bool filtroSoloActivos = true;
    private bool mostrarFiltros = true;

    private bool isLoading;
    private string? errorMessage;
    private int totalAbogados;

    private bool formVisible;
    private bool formLoading;
    private bool isSaving;
    private string? formError;
    private AbogadoEditDto formModel = new();

    private bool confirmVisible;
    private AbogadoListItemDto? abogadoParaDesactivar;

    private string PopupTitle => formModel.Id.HasValue ? "Editar abogado" : "Nuevo abogado";
    private string PopupSubtitle => formModel.Id.HasValue
        ? "Actualice la información del abogado"
        : "Complete el formulario de registro";
    private string PopupIcon => formModel.Id.HasValue ? "bi bi-pencil-square" : "bi bi-briefcase";
    private string PopupIconWrapperClass => formModel.Id.HasValue
        ? "bg-warning bg-opacity-10 text-warning p-2 rounded-circle d-flex justify-content-center align-items-center"
        : "bg-primary bg-opacity-10 text-primary p-2 rounded-circle d-flex justify-content-center align-items-center";

    protected override async Task OnInitializedAsync()
    {
        await CargarAsync();
    }

    private AbogadoFilterDto BuildFilter()
    {
        return new AbogadoFilterDto
        {
            Search = string.IsNullOrWhiteSpace(filtroBusqueda) ? null : filtroBusqueda,
            Activo = filtroSoloActivos ? true : null
        };
    }

    private async Task CargarAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            abogados = await AbogadosClient.GetAsync(BuildFilter());
            totalAbogados = abogados.Count;
        }
        catch (Exception ex)
        {
            errorMessage = $"No se pudieron cargar los abogados: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnBusquedaChanged(string valor)
    {
        filtroBusqueda = valor;
        await BuscarAsync();
    }

    private async Task OnEstadoChanged(bool valor)
    {
        filtroSoloActivos = valor;
        await BuscarAsync();
    }

    private async Task LimpiarFiltrosAsync()
    {
        filtroBusqueda = string.Empty;
        filtroSoloActivos = true;
        await BuscarAsync();
    }

    private Task BuscarAsync()
    {
        return CargarAsync();
    }

    private async Task RecargarGrid() => await CargarAsync();
    private void ToggleFiltros() => mostrarFiltros = !mostrarFiltros;
    private void MostrarColumnChooser() => grid?.ShowColumnChooser();

    private void AbrirNuevo()
    {
        formError = null;
        formModel = new AbogadoEditDto { Activo = true };
        formVisible = true;
    }

    private async Task AbrirEditarAsync(int id)
    {
        formError = null;
        formLoading = true;
        formVisible = true;

        try
        {
            var detalle = await AbogadosClient.GetByIdAsync(id);
            if (detalle is null)
            {
                formError = "No se encontró el abogado.";
                formModel = new AbogadoEditDto { Activo = true };
                return;
            }

            formModel = detalle;
        }
        catch (Exception ex)
        {
            formError = $"Error al cargar el abogado: {ex.Message}";
        }
        finally
        {
            formLoading = false;
        }
    }

    private void CerrarForm()
    {
        if (isSaving)
        {
            return;
        }

        formVisible = false;
        formError = null;
        formModel = new AbogadoEditDto();
    }

    private async Task GuardarAsync()
    {
        isSaving = true;

        try
        {
            if (formModel.Id.HasValue)
            {
                await AbogadosClient.UpdateAsync(formModel.Id.Value, formModel);
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Éxito",
                    Text = "Abogado actualizado correctamente.",
                    RenderStyle = ToastRenderStyle.Success,
                    ProviderName = "AbogadosToast"
                });
            }
            else
            {
                await AbogadosClient.CreateAsync(formModel);
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Éxito",
                    Text = "Abogado registrado correctamente.",
                    RenderStyle = ToastRenderStyle.Success,
                    ProviderName = "AbogadosToast"
                });
            }

            formVisible = false;
            formModel = new AbogadoEditDto();
            await CargarAsync();
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Error",
                Text = ex.Message,
                RenderStyle = ToastRenderStyle.Danger,
                ProviderName = "AbogadosToast"
            });
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ConfirmarDesactivar(AbogadoListItemDto abogado)
    {
        abogadoParaDesactivar = abogado;
        confirmVisible = true;
    }

    private void CancelarDesactivar()
    {
        confirmVisible = false;
        abogadoParaDesactivar = null;
    }

    private async Task DesactivarConfirmadoAsync()
    {
        if (abogadoParaDesactivar is null)
        {
            confirmVisible = false;
            return;
        }

        try
        {
            var ok = await AbogadosClient.DeactivateAsync(abogadoParaDesactivar.Id);
            if (!ok)
            {
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Error",
                    Text = "No se pudo desactivar el abogado.",
                    RenderStyle = ToastRenderStyle.Danger,
                    ProviderName = "AbogadosToast"
                });
            }
            else
            {
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Éxito",
                    Text = "Abogado desactivado correctamente.",
                    RenderStyle = ToastRenderStyle.Success,
                    ProviderName = "AbogadosToast"
                });
                await CargarAsync();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Error",
                Text = ex.Message,
                RenderStyle = ToastRenderStyle.Danger,
                ProviderName = "AbogadosToast"
            });
        }
        finally
        {
            confirmVisible = false;
            abogadoParaDesactivar = null;
        }
    }

    private static string BuildExportFileName(string extension)
    {
        var stamp = DateTime.Now.ToString("yyyyMMdd_HHmm");
        return $"abogados_{stamp}.{extension}";
    }

    private async Task ExportCsvAsync()
    {
        if (grid is null)
        {
            return;
        }

        await grid.ExportToCsvAsync(BuildExportFileName("csv"), new GridCsvExportOptions());
    }

    private async Task ExportExcelAsync()
    {
        if (grid is null)
        {
            return;
        }

        await grid.ExportToXlsxAsync(BuildExportFileName("xlsx"), new GridXlExportOptions());
    }

    private async Task ExportPdfAsync()
    {
        if (grid is null)
        {
            return;
        }

        await grid.ExportToPdfAsync(BuildExportFileName("pdf"), new GridPdfExportOptions());
    }
}
