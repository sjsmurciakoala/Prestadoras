@page "/auditoria/bitacora-maestros"
@attribute [Authorize]

@using System.Text.Json
@using DevExpress.Blazor
@using SIAD.Core.Constants
@using SIAD.Core.DTOs.Auditoria
@using apc.Client.Services.Auditoria

@inject BitacoraMaestrosClient BitacoraClient
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Bitácora de maestros</PageTitle>

<div class="page-container">
    <DxToastProvider Name="BitacoraMaestrosToast" MaxToastCount="4" />

    <div class="header-section mb-3">
        <div>
            <h2 class="page-title">Bitácora de maestros</h2>
            <p class="page-subtitle">Movimientos de los usuarios sobre los maestros</p>
        </div>
    </div>

    <!-- FILTROS -->
    <div class="modern-card mb-4">
        <div class="section-header mb-3">
            <i class="bi bi-funnel"></i>
            <h5 class="m-0">Filtros</h5>
        </div>

        <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
            <DxFormLayoutItem Caption="Desde" ColSpanXs="6" ColSpanMd="2" Context="f1">
                <DxDateEdit @bind-Date="filtro.Desde" CssClass="w-100" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Hasta" ColSpanXs="6" ColSpanMd="2" Context="f2">
                <DxDateEdit @bind-Date="filtro.Hasta" CssClass="w-100" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Módulo" ColSpanXs="12" ColSpanMd="2" Context="f3">
                <DxComboBox Data="modulos"
                            @bind-Value="filtro.Modulo"
                            NullText="— Todos —"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                            CssClass="w-100" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Tabla" ColSpanXs="12" ColSpanMd="2" Context="f4">
                <DxComboBox Data="AuditableMaestros.All"
                            @bind-Value="filtro.Tabla"
                            ValueFieldName="Tabla"
                            TextFieldName="Nombre"
                            NullText="— Todas —"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                            CssClass="w-100" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Acción" ColSpanXs="12" ColSpanMd="2" Context="f5">
                <DxComboBox Data="acciones"
                            @bind-Value="filtro.Accion"
                            ValueFieldName="Valor"
                            TextFieldName="Texto"
                            NullText="— Todas —"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                            CssClass="w-100" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Usuario" ColSpanXs="12" ColSpanMd="2" Context="f6">
                <DxTextBox @bind-Text="filtro.Usuario"
                           NullText="Nombre parcial..."
                           ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                           CssClass="w-100" />
            </DxFormLayoutItem>
        </DxFormLayout>

        <div class="d-flex gap-2 justify-content-end mt-3">
            <DxButton Text="Buscar"
                      IconCssClass="bi bi-search"
                      RenderStyle="ButtonRenderStyle.Primary"
                      Click="BuscarAsync"
                      Enabled="@(!isLoading)" />
        </div>
    </div>

    <!-- RESULTADOS -->
    <div class="modern-card">
        <div class="section-header mb-3">
            <i class="bi bi-clock-history"></i>
            <h5 class="m-0">Resultados@(busquedaRealizada ? $" ({resultados.Count})" : string.Empty)</h5>
            <div class="ms-auto d-flex gap-2">
                <DxButton Text="Excel"
                          IconCssClass="bi bi-file-earmark-excel"
                          RenderStyle="ButtonRenderStyle.Success"
                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                          Click="ExportExcelAsync"
                          Enabled="@(resultados.Count > 0)" />
                <DxButton Text="PDF"
                          IconCssClass="bi bi-file-earmark-pdf"
                          RenderStyle="ButtonRenderStyle.Danger"
                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                          Click="ExportPdfAsync"
                          Enabled="@(resultados.Count > 0)" />
            </div>
        </div>

        @if (resultadoTruncado)
        {
            <div class="alert alert-warning mb-3" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>
                Se alcanzó el límite de @MaxFilas registros. Acote los filtros (rango de fechas, módulo o tabla) para ver el detalle completo.
            </div>
        }

        <div class="grid-wrapper">
            <DxGrid @ref="grid" Data="resultados" PageSize="25"
                    PageSizeSelectorVisible="true"
                    PageSizeSelectorItems="new int[] { 10, 25, 50, 100 }"
                    ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
                    ShowGroupPanel="false" CssClass="grid-solicitudes">
                <Columns>
                    <DxGridDataColumn FieldName="Fecha" Caption="Fecha" Width="150px" DisplayFormat="g" />
                    <DxGridDataColumn FieldName="Usuario" Caption="Usuario" Width="150px" />
                    <DxGridDataColumn FieldName="Modulo" Caption="Módulo" Width="130px" />
                    <DxGridDataColumn FieldName="Tabla" Caption="Tabla" Width="180px">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is BitacoraMaestroListItemDto it)
                            {
                                <span>@AuditableMaestros.NombreDe(it.Tabla)</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="Entidad" Caption="Entidad" MinWidth="180" />
                    <DxGridDataColumn FieldName="Accion" Caption="Acción" Width="140px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is BitacoraMaestroListItemDto it)
                            {
                                var b = AccionBadge(it.Accion);
                                <span class="badge-status" style="background-color:@b.Bg;color:@b.Fg;">@b.Texto</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="RegistroId" Caption="Registro" Width="120px" />
                    <DxGridDataColumn Caption="" Width="80px" TextAlignment="GridTextAlignment.Center"
                                      AllowSort="false" AllowGroup="false">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is BitacoraMaestroListItemDto it)
                            {
                                <button type="button" class="btn-icon btn-edit" title="Ver detalle"
                                        @onclick="() => VerDetalle(it)" @onclick:stopPropagation="true">
                                    <i class="bi bi-eye"></i>
                                </button>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>
                <EmptyDataAreaTemplate>
                    <div class="text-center p-4 text-muted">
                        <i class="bi bi-inbox" style="font-size:2rem;opacity:.5"></i>
                        <p class="mt-2">
                            @(busquedaRealizada
                                ? "Sin movimientos en el rango seleccionado."
                                : "Defina los filtros y presione Buscar.")
                        </p>
                    </div>
                </EmptyDataAreaTemplate>
            </DxGrid>
        </div>
    </div>
</div>

<!-- DETALLE -->
<DxPopup @bind-Visible="detalleVisible" Width="min(680px, 95vw)" Height="auto" MaxHeight="90vh"
         Scrollable="true" CssClass="custom-popup" CloseOnOutsideClick="true" HeaderText="Detalle del movimiento">
    <BodyContentTemplate>
        @if (detalleItem is not null)
        {
            <div class="p-1">
                <div class="mb-3">
                    <div class="small text-muted">Descripción</div>
                    <div class="fw-semibold">
                        @(string.IsNullOrWhiteSpace(detalleItem.Descripcion) ? "—" : detalleItem.Descripcion)
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-3 mb-3 small text-muted">
                    <div><span class="text-dark fw-semibold">Fecha:</span> @detalleItem.Fecha.ToString("g")</div>
                    <div><span class="text-dark fw-semibold">Usuario:</span> @detalleItem.Usuario</div>
                    <div><span class="text-dark fw-semibold">Acción:</span> @AccionBadge(detalleItem.Accion).Texto</div>
                </div>

                @if (cambios.Count == 0)
                {
                    <div class="alert alert-secondary mb-0" role="alert">Sin detalle de cambios.</div>
                }
                else
                {
                    <div style="width:100%;overflow-x:auto;">
                        <table class="table table-sm table-bordered align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th style="width:34%">Campo</th>
                                    <th style="width:33%">Anterior</th>
                                    <th style="width:33%">Nuevo</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in cambios)
                                {
                                    <tr>
                                        <td class="fw-semibold">@c.Campo</td>
                                        <td class="text-muted">@c.Anterior</td>
                                        <td>@c.Nuevo</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        }
    </BodyContentTemplate>
</DxPopup>

@code {
    private const int MaxFilas = 5000;

    private IGrid? grid;
    private BitacoraMaestroFilterDto filtro = new()
    {
        Desde = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1),
        Hasta = DateTime.Today
    };

    private readonly List<string> modulos =
        AuditableMaestros.All.Select(x => x.Modulo).Distinct().ToList();

    private readonly List<AccionOpcion> acciones =
    [
        new(AccionesBitacora.Creacion, "Creación"),
        new(AccionesBitacora.Actualizacion, "Actualización"),
        new(AccionesBitacora.Eliminacion, "Eliminación")
    ];

    private List<BitacoraMaestroListItemDto> resultados = [];
    private bool isLoading;
    private bool busquedaRealizada;
    private bool resultadoTruncado;

    private bool detalleVisible;
    private BitacoraMaestroListItemDto? detalleItem;
    private List<CambioDetalle> cambios = [];

    private sealed record AccionOpcion(string Valor, string Texto);
    private sealed record CambioDetalle(string Campo, string Anterior, string Nuevo);

    protected override async Task OnInitializedAsync() => await BuscarAsync();

    private async Task BuscarAsync()
    {
        if (filtro.Desde is { } d && filtro.Hasta is { } h && d.Date > h.Date)
        {
            Toast("Bitácora de maestros", "Rango de fechas inválido: 'Desde' debe ser menor o igual a 'Hasta'.", ToastRenderStyle.Danger);
            return;
        }

        isLoading = true;
        resultadoTruncado = false;
        try
        {
            resultados = await BitacoraClient.BuscarAsync(filtro);
            resultadoTruncado = resultados.Count >= MaxFilas;
            busquedaRealizada = true;
        }
        catch (Exception ex)
        {
            Toast("Bitácora de maestros", $"No se pudo consultar la bitácora: {ex.Message}", ToastRenderStyle.Danger);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void VerDetalle(BitacoraMaestroListItemDto item)
    {
        detalleItem = item;
        cambios = ConstruirCambios(item);
        detalleVisible = true;
    }

    private static List<CambioDetalle> ConstruirCambios(BitacoraMaestroListItemDto item)
    {
        var ant = Deserializar(item.ValoresAnteriores);
        var nue = Deserializar(item.ValoresNuevos);

        var claves = new SortedSet<string>(StringComparer.OrdinalIgnoreCase);
        foreach (var k in ant.Keys) claves.Add(k);
        foreach (var k in nue.Keys) claves.Add(k);

        var lista = new List<CambioDetalle>();
        foreach (var k in claves)
        {
            var a = ant.TryGetValue(k, out var av) ? FormatValor(av) : "—";
            var n = nue.TryGetValue(k, out var nv) ? FormatValor(nv) : "—";
            lista.Add(new CambioDetalle(k, a, n));
        }
        return lista;
    }

    private static Dictionary<string, JsonElement> Deserializar(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return new();
        try
        {
            return JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(json) ?? new();
        }
        catch
        {
            return new();
        }
    }

    private static string FormatValor(JsonElement el) => el.ValueKind switch
    {
        JsonValueKind.Null => "—",
        JsonValueKind.Undefined => "—",
        JsonValueKind.String => string.IsNullOrEmpty(el.GetString()) ? "—" : el.GetString()!,
        JsonValueKind.True => "Sí",
        JsonValueKind.False => "No",
        _ => el.ToString()
    };

    private static (string Bg, string Fg, string Texto) AccionBadge(string accion) => accion switch
    {
        AccionesBitacora.Creacion => ("#d1e7dd", "#0f5132", "Creación"),
        AccionesBitacora.Actualizacion => ("#cfe2ff", "#084298", "Actualización"),
        AccionesBitacora.Eliminacion => ("#f8d7da", "#842029", "Eliminación"),
        _ => ("#e2e3e5", "#41464b", accion)
    };

    private static string BuildExportFileName(string extension)
        => $"bitacora-maestros_{DateTime.Now:yyyyMMdd_HHmm}.{extension}";

    private async Task ExportExcelAsync()
    {
        if (grid is null) return;
        await grid.ExportToXlsxAsync(BuildExportFileName("xlsx"), new GridXlExportOptions());
    }

    private async Task ExportPdfAsync()
    {
        if (grid is null) return;
        await grid.ExportToPdfAsync(BuildExportFileName("pdf"), new GridPdfExportOptions());
    }

    private void Toast(string title, string text, ToastRenderStyle style)
        => ToastService.ShowToast(new ToastOptions { Title = title, Text = text, RenderStyle = style, ProviderName = "BitacoraMaestrosToast" });
}
