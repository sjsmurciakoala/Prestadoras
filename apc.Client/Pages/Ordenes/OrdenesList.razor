    private async Task RecargarUsuariosAsync(string? texto)
    {
        try
        {
            var tipoNumerico = MapearTipoNumerico(tabIndex);
            var lista = await OrdenesClient.GetUsuariosAsync(tipoNumerico);

            if (!string.IsNullOrWhiteSpace(texto))
            {
                lista = lista
                    .Where(u => (!string.IsNullOrWhiteSpace(u.Nombre) && u.Nombre.Contains(texto, StringComparison.OrdinalIgnoreCase))
                        || (!string.IsNullOrWhiteSpace(u.Usuario) && u.Usuario.Contains(texto, StringComparison.OrdinalIgnoreCase)))
                    .ToList();
            }

            usuarios = lista;
            empleadoCrearTexto = string.IsNullOrWhiteSpace(nuevo.Empleado)
                ? string.Empty
                : ResolverNombreEmpleado(nuevo.Empleado) ?? nuevo.Empleado;

            if (!string.IsNullOrWhiteSpace(usuarioAsignacion) && usuarios.All(u => u.Usuario != usuarioAsignacion))
            {
                usuarioAsignacion = usuarios.FirstOrDefault()?.Usuario ?? usuarioActual;
            }

            if (string.IsNullOrWhiteSpace(empleadoAsignacion) && !string.IsNullOrWhiteSpace(usuarioAsignacion))
            {
                empleadoAsignacion = usuarios.FirstOrDefault(u => u.Usuario == usuarioAsignacion)?.Nombre;
            }

            usuarioAsignacionTexto = usuarios.FirstOrDefault(u => u.Usuario == usuarioAsignacion)?.Nombre ?? string.Empty;
            empleadoAsignacionTexto = string.IsNullOrWhiteSpace(empleadoAsignacion)
                ? string.Empty
                : ResolverNombreEmpleado(empleadoAsignacion) ?? empleadoAsignacion;

            await InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            ManejarErrorCatalogo("cargar usuarios", ex);
        }
    }

    private static string GetEstadoBadgeCss(string? estado)
    {
        var codigo = NormalizarEstadoCodigo(estado);
        return codigo switch
        {
            "P" => "estado-badge-warning",
            "A" => "estado-badge-info",
            "E" => "estado-badge-success",
            "C" => "estado-badge-dark",
            _ => "estado-badge-default"
        };
    }

    private static string GetEstadoDisplayText(OrdenTrabajoListItemDto item)
    {
        if (!string.IsNullOrWhiteSpace(item.EstadoDescripcion))
        {
            return item.EstadoDescripcion;
        }

        return NormalizarEstadoCodigo(item.Estado) switch
        {
            "P" => "Pendiente",
            "A" => "Asignada",
            "E" => "Ejecutada",
            "C" => "Cancelada",
            _ => string.IsNullOrWhiteSpace(item.Estado) ? "Sin estado" : item.Estado.Trim()
        };
    }

    private void ShowToast(string title, string message, ToastRenderStyle style)
    {
        ToastService.ShowToast(new ToastOptions
        {
            ProviderName = ToastProviderName,
            Title = title,
            Text = message,
            RenderStyle = style
        });
    }

    private string? ResolverNombreEmpleado(string? texto)
    {
        var normalizado = NormalizarTextoLibre(texto);
        if (string.IsNullOrWhiteSpace(normalizado))
        {
            return null;
        }

        var coincidencia = usuarios.FirstOrDefault(u =>
            (!string.IsNullOrWhiteSpace(u.Nombre) && u.Nombre.Equals(normalizado, StringComparison.OrdinalIgnoreCase))
            || (!string.IsNullOrWhiteSpace(u.Usuario) && u.Usuario.Equals(normalizado, StringComparison.OrdinalIgnoreCase)));

        return string.IsNullOrWhiteSpace(coincidencia?.Nombre)
            ? normalizado
            : coincidencia.Nombre;
    }

    private static string? NormalizarTextoLibre(string? texto)
    {
        return string.IsNullOrWhiteSpace(texto) ? null : texto.Trim();
    }

    private static string? NormalizarEstadoCodigo(string? estado)
    {
        return string.IsNullOrWhiteSpace(estado) ? null : estado.Trim().ToUpperInvariant();
    }

    private static int? MapearTipoNumerico(int indice)
    {
        return indice switch
        {
            0 => 1,
            1 => 2,
            2 => 3,
            _ => null
        };
    }

    private void ManejarErrorCatalogo(string contexto, Exception ex)
    {
        var mensajeError = $"No se pudo {contexto}. {ex.Message}";
        ShowToast("Órdenes de trabajo", mensajeError, ToastRenderStyle.Danger);
    }
