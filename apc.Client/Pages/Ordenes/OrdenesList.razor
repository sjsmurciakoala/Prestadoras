@page "/ordenes"
@attribute [Authorize]
@inject apc.Client.Services.Ordenes.OrdenesClient OrdenesClient
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IToastNotificationService ToastService
@inject IJSRuntime JS
@using DevExpress.Blazor
@using apc.Client.Services

<PageTitle>SIAD - Órdenes de Trabajo</PageTitle>

<DxScrollView Height="100%">
    <DxToastProvider Name="OrdenesToast" MaxToastCount="4" />

    <div class="page-container">
        <div class="d-flex justify-content-between align-items-center mb-4 header-section">
            <div>
                <h2 class="page-title">Órdenes de trabajo</h2>
                <p class="page-subtitle">Gestión y asignación de órdenes</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <DxButton Text="Nueva orden"
                          RenderStyle="ButtonRenderStyle.Primary"
                          Click="AbrirCrear"
                          IconCssClass="bi bi-plus-lg"
                          CssClass="btn-modern shadow-sm" />
                <DxButton Text="Asignar órdenes seleccionadas"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          Click="AbrirAsignacion"
                          CssClass="btn-modern shadow-sm" />
            </div>
        </div>

        <div class="modern-card mb-4">
            <DxTabs ActiveTabIndex="@tabIndex" ActiveTabIndexChanged="OnTabChanged" CssClass="mb-3">
                <Tabs>
                    <DxTab Text="Órdenes de Trabajo Agua" />
                    <DxTab Text="Órdenes de Corte" />
                    <DxTab Text="Órdenes Alcantarillado" />
                </Tabs>
            </DxTabs>

            <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                <DxFormLayoutItem Caption="Búsqueda" ColSpanMd="12">
                    <DxTextBox @bind-Text="filtro.Busqueda" NullText="Concepto, usuario o empleado" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Cliente" ColSpanMd="6">
                    <DxComboBox TData="OrdenTrabajoPropietarioDto"
                                TValue="string"
                                Data="@propietarios"
                                ValueFieldName="@nameof(OrdenTrabajoPropietarioDto.Clave)"
                                TextFieldName="@nameof(OrdenTrabajoPropietarioDto.Nombre)"
                                DropDownStyle="DropDownStyle.DropDown"
                                AllowUserInput="true"
                                @bind-Value="filtro.ClienteClave"
                                Text="@clienteFiltroTexto"
                                TextChanged="OnClienteFiltroTextChanged"
                                NullText="Escribe el nombre…"
                                FilterCondition="DataEditorFilterCondition.Contains"
                                FilterMinLength="0"
                                FilterDelay="250"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto">
                        <ItemTemplate Context="propietario">
                            <div class="combo-item">
                                <span class="combo-item-text">@propietario.Nombre</span>
                                <small class="combo-item-hint">@propietario.Clave</small>
                            </div>
                        </ItemTemplate>
                    </DxComboBox>
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Clave" ColSpanMd="6">
                    <DxTextBox @bind-Text="filtro.Clave" NullText="Clave del cliente" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Estado" ColSpanMd="6">
                    <DxComboBox TData="OrdenTrabajoEstadoDto"
                                TValue="string"
                                Data="@estados"
                                ValueFieldName="@nameof(OrdenTrabajoEstadoDto.Codigo)"
                                TextFieldName="@nameof(OrdenTrabajoEstadoDto.Nombre)"
                                DropDownStyle="DropDownStyle.DropDown"
                                AllowUserInput="true"
                                @bind-Value="filtro.Estado"
                                Text="@estadoFiltroTexto"
                                TextChanged="OnEstadoFiltroTextChanged"
                                NullText="Todos los estados"
                                FilterCondition="DataEditorFilterCondition.Contains"
                                FilterMinLength="0"
                                FilterDelay="250"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Tipo" ColSpanMd="6">
                    <DxComboBox TData="OrdenTrabajoTipoDto"
                                TValue="string"
                                Data="@tipos"
                                ValueFieldName="@nameof(OrdenTrabajoTipoDto.Tipo)"
                                TextFieldName="@nameof(OrdenTrabajoTipoDto.Descripcion)"
                                DropDownStyle="DropDownStyle.DropDown"
                                AllowUserInput="true"
                                @bind-Value="filtro.Tipo"
                                Text="@tipoFiltroTexto"
                                TextChanged="OnTipoFiltroTextChanged"
                                NullText="Todos los tipos"
                                FilterCondition="DataEditorFilterCondition.Contains"
                                FilterMinLength="0"
                                FilterDelay="250"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto">
                        <ItemTemplate Context="tipo">
                            <div class="combo-item">
                                <span class="combo-item-text">@tipo.Descripcion</span>
                                <small class="combo-item-hint">@tipo.Tipo</small>
                            </div>
                        </ItemTemplate>
                    </DxComboBox>
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Fecha desde" ColSpanMd="6">
                    <DxDateEdit @bind-Date="filtro.FechaDesde" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Fecha hasta" ColSpanMd="6">
                    <DxDateEdit @bind-Date="filtro.FechaHasta" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Acciones" ColSpanMd="12">
                    <DxButton Text="Buscar" RenderStyle="ButtonRenderStyle.Primary" Click="BuscarAsync" />
                    <DxButton Text="Limpiar" CssClass="ms-2" Click="LimpiarAsync" />
                </DxFormLayoutItem>
            </DxFormLayout>
        </div>

        <div class="modern-card position-relative" style="min-height: 300px;">
            <div class="grid-wrapper">
                <DxGrid @ref="grid" Data="@ordenes" @bind-SelectedDataItems="seleccionadasObjetos"
                        SelectionMode="GridSelectionMode.Multiple"
                        KeyboardNavigationEnabled="true"
                        PageSize="15"
                        PageSizeSelectorVisible="true"
                        PageSizeSelectorItems="new int[] { 5, 10, 15, 25, 50, 100 }"
                        CssClass="grid-modern"
                        LayoutAutoSaving="OnLayoutAutoSaving"
                        LayoutAutoLoading="OnLayoutAutoLoading">
                    <ToolbarTemplate>
                        <div class="d-flex w-100">
                            <DxButton Text="Columnas" IconCssClass="bi bi-layout-three-columns"
                                      RenderStyle="ButtonRenderStyle.Secondary" Click="MostrarColumnChooser" />
                        </div>
                    </ToolbarTemplate>
                    <Columns>
                        <DxGridSelectionColumn Width="45px" />
                        <DxGridDataColumn FieldName="@nameof(OrdenTrabajoListItemDto.Numero)" Caption="Orden">
                            <CellDisplayTemplate Context="cell">
                                @if (cell.DataItem is OrdenTrabajoListItemDto item)
                                {
                                    <NavLink href="@($"/ordenes/{item.Id}")">@item.Numero</NavLink>
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn FieldName="@nameof(OrdenTrabajoListItemDto.ClienteClave)" Caption="Clave cliente" />
                        <DxGridDataColumn FieldName="@nameof(OrdenTrabajoListItemDto.Propietario)" Caption="Propietario" />
                        <DxGridDataColumn FieldName="@nameof(OrdenTrabajoListItemDto.Direccion)" Caption="Dirección" />
                        <DxGridDataColumn FieldName="@nameof(OrdenTrabajoListItemDto.Fecha)" Caption="Fecha" DisplayFormat="d" />
                        <DxGridDataColumn FieldName="@nameof(OrdenTrabajoListItemDto.FechaCreacion)" Caption="Creación"
                                          DisplayFormat="g" />
                        <DxGridDataColumn FieldName="@nameof(OrdenTrabajoListItemDto.Concepto)" Caption="Concepto" />
                        <DxGridDataColumn FieldName="@nameof(OrdenTrabajoListItemDto.TipoDescripcion)" Caption="Tipo" />
                        <DxGridDataColumn FieldName="@nameof(OrdenTrabajoListItemDto.EstadoDescripcion)" Caption="Estado">
                            <CellDisplayTemplate Context="cell">
                                @if (cell.DataItem is OrdenTrabajoListItemDto item)
                                {
                                    <span class="@($"estado-badge {GetEstadoBadgeCss(item.Estado)}")">@GetEstadoDisplayText(item)</span>
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn FieldName="@nameof(OrdenTrabajoListItemDto.UsuarioAsignado)" Caption="Usuario asignado" />
                    </Columns>
                </DxGrid>
            </div>
        </div>
    </div>
</DxScrollView>

<DxPopup @bind-Visible="mostrarCrear" Width="640px" ShowCloseButton="true" HeaderText="Nueva orden de trabajo">
    <TemplateContext>
        <DxFormLayout>
            <DxFormLayoutItem Caption="Cliente *">
                <DxComboBox TData="OrdenTrabajoPropietarioDto"
                            TValue="string"
                            Data="propietarios"
                            ValueFieldName="@nameof(OrdenTrabajoPropietarioDto.Clave)"
                            TextFieldName="@nameof(OrdenTrabajoPropietarioDto.Nombre)"
                            DropDownStyle="DropDownStyle.DropDown"
                            AllowUserInput="true"
                            @bind-Value="nuevo.ClienteClave"
                            Text="@clienteCrearTexto"
                            TextChanged="OnClienteCrearTextChanged"
                            NullText="Escribe para buscar"
                            FilterCondition="DataEditorFilterCondition.Contains"
                            FilterMinLength="0"
                            FilterDelay="250"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto">
                    <ItemTemplate Context="propietario">
                        <div class="combo-item">
                            <span class="combo-item-text">@propietario.Nombre</span>
                            <small class="combo-item-hint">@propietario.Clave</small>
                        </div>
                    </ItemTemplate>
                </DxComboBox>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Fecha *">
                <DxDateEdit @bind-Date="nuevo.Fecha"
                            MinDate="@DateTime.Today"
                            AllowUserInput="false" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Tipo *">
                <DxComboBox TData="OrdenTrabajoTipoDto"
                            TValue="string"
                            Data="tipos"
                            ValueFieldName="@nameof(OrdenTrabajoTipoDto.Tipo)"
                            TextFieldName="@nameof(OrdenTrabajoTipoDto.Descripcion)"
                            DropDownStyle="DropDownStyle.DropDown"
                            AllowUserInput="true"
                            @bind-Value="nuevo.Tipo"
                            Text="@tipoCrearTexto"
                            TextChanged="OnTipoCrearTextChanged"
                            NullText="Selecciona o escribe"
                            FilterCondition="DataEditorFilterCondition.Contains"
                            FilterMinLength="0"
                            FilterDelay="250"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto">
                    <ItemTemplate Context="tipo">
                        <div class="combo-item">
                            <span class="combo-item-text">@tipo.Descripcion</span>
                            <small class="combo-item-hint">@tipo.Tipo</small>
                        </div>
                    </ItemTemplate>
                </DxComboBox>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Concepto *">
                <DxMemo @bind-Text="nuevo.Concepto" Rows="3" @ref="conceptoMemo" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Personas">
                <DxTextBox @bind-Text="nuevo.Personas" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Empleado">
                <DxComboBox TData="UsuarioMiOrdenDto"
                            TValue="string"
                            Data="usuarios"
                            ValueFieldName="@nameof(UsuarioMiOrdenDto.Nombre)"
                            TextFieldName="@nameof(UsuarioMiOrdenDto.Nombre)"
                            DropDownStyle="DropDownStyle.DropDown"
                            AllowUserInput="true"
                            @bind-Value="nuevo.Empleado"
                            Text="@empleadoCrearTexto"
                            TextChanged="OnEmpleadoCrearTextChanged"
                            NullText="Seleccione o escriba un empleado"
                            FilterCondition="DataEditorFilterCondition.Contains"
                            FilterMinLength="0"
                            FilterDelay="250"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto">
                    <ItemTemplate Context="usuario">
                        <div class="combo-item">
                            <span class="combo-item-text">@usuario.Nombre</span>
                            <small class="combo-item-hint">@usuario.Usuario</small>
                        </div>
                    </ItemTemplate>
                </DxComboBox>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Usuario">
                <DxTextBox @bind-Text="nuevo.Usuario" ReadOnly="true" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Saldo estimado">
                <DxSpinEdit @bind-Value="nuevo.Saldo" Increment="0.10m" DisplayFormat="n2" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Acciones" ColSpanMd="12">
                <DxButton Text="Guardar" RenderStyle="ButtonRenderStyle.Primary" Click="GuardarNuevaOrdenAsync" />
                <DxButton Text="Cancelar" CssClass="ms-2" Click="CerrarCrear" />
            </DxFormLayoutItem>
        </DxFormLayout>
    </TemplateContext>
</DxPopup>

<DxPopup @bind-Visible="mostrarAsignar" Width="500px" ShowCloseButton="true" HeaderText="Asignar órdenes seleccionadas">
    <TemplateContext>
        <DxFormLayout>
            <DxFormLayoutItem Caption="Usuario">
                <DxComboBox TData="UsuarioMiOrdenDto"
                            TValue="string"
                            Data="usuarios"
                            ValueFieldName="@nameof(UsuarioMiOrdenDto.Usuario)"
                            TextFieldName="@nameof(UsuarioMiOrdenDto.Nombre)"
                            DropDownStyle="DropDownStyle.DropDown"
                            AllowUserInput="true"
                            @bind-Value="usuarioAsignacion"
                            Text="@usuarioAsignacionTexto"
                            TextChanged="OnUsuarioAsignacionTextChanged"
                            NullText="Escribe para buscar"
                            FilterCondition="DataEditorFilterCondition.Contains"
                            FilterMinLength="0"
                            FilterDelay="250"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Estado">
                <DxComboBox TData="OrdenTrabajoEstadoDto"
                            TValue="string"
                            Data="@estadosAsignacion"
                            ValueFieldName="@nameof(OrdenTrabajoEstadoDto.Codigo)"
                            TextFieldName="@nameof(OrdenTrabajoEstadoDto.Nombre)"
                            DropDownStyle="DropDownStyle.DropDown"
                            AllowUserInput="true"
                            @bind-Value="estadoAsignacion"
                            Text="@estadoAsignacionTexto"
                            TextChanged="OnEstadoAsignacionTextChanged"
                            NullText="Selecciona un estado"
                            FilterCondition="DataEditorFilterCondition.Contains"
                            FilterMinLength="0"
                            FilterDelay="250"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Empleado">
                <DxComboBox TData="UsuarioMiOrdenDto"
                            TValue="string"
                            Data="usuarios"
                            ValueFieldName="@nameof(UsuarioMiOrdenDto.Nombre)"
                            TextFieldName="@nameof(UsuarioMiOrdenDto.Nombre)"
                            DropDownStyle="DropDownStyle.DropDown"
                            AllowUserInput="true"
                            @bind-Value="empleadoAsignacion"
                            Text="@empleadoAsignacionTexto"
                            TextChanged="OnEmpleadoAsignacionTextChanged"
                            NullText="Seleccione o escriba un empleado"
                            FilterCondition="DataEditorFilterCondition.Contains"
                            FilterMinLength="0"
                            FilterDelay="250"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto">
                    <ItemTemplate Context="usuario">
                        <div class="combo-item">
                            <span class="combo-item-text">@usuario.Nombre</span>
                            <small class="combo-item-hint">@usuario.Usuario</small>
                        </div>
                    </ItemTemplate>
                </DxComboBox>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Resumen">
                <p>@($"Se asignarán {SeleccionadasOrdenes.Count()} orden(es).")</p>
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Acciones" ColSpanMd="12">
                <DxButton Text="Asignar" RenderStyle="ButtonRenderStyle.Primary" Click="ConfirmarAsignacionAsync" />
                <DxButton Text="Cancelar" CssClass="ms-2" Click="CerrarAsignacion" />
            </DxFormLayoutItem>
        </DxFormLayout>
    </TemplateContext>
</DxPopup>

@code {
    private const string ToastProviderName = "OrdenesToast";
    private const string GridLayoutStorageKey = "ordenes-list-grid-layout";

    private DxGrid? grid;

    private void MostrarColumnChooser() => grid?.ShowColumnChooser();

    private Task OnLayoutAutoSaving(GridPersistentLayoutEventArgs e)
        => GridLayoutStorage.SaveAsync(JS, GridLayoutStorageKey, e);

    private Task OnLayoutAutoLoading(GridPersistentLayoutEventArgs e)
        => GridLayoutStorage.LoadAsync(JS, GridLayoutStorageKey, e);

    private readonly OrdenTrabajoFilterDto filtro = new();
    private IReadOnlyList<OrdenTrabajoListItemDto> ordenes = Array.Empty<OrdenTrabajoListItemDto>();
    private IReadOnlyList<object> seleccionadasObjetos = Array.Empty<object>();
    private IEnumerable<OrdenTrabajoListItemDto> SeleccionadasOrdenes =>
    seleccionadasObjetos.OfType<OrdenTrabajoListItemDto>();
    private IReadOnlyList<UsuarioMiOrdenDto> usuarios = Array.Empty<UsuarioMiOrdenDto>();
    private IReadOnlyList<OrdenTrabajoEstadoDto> estados = Array.Empty<OrdenTrabajoEstadoDto>();
    private IReadOnlyList<OrdenTrabajoEstadoDto> estadosAsignacion = Array.Empty<OrdenTrabajoEstadoDto>();
    private IReadOnlyList<OrdenTrabajoTipoDto> tipos = Array.Empty<OrdenTrabajoTipoDto>();
    private IReadOnlyList<OrdenTrabajoPropietarioDto> propietarios = Array.Empty<OrdenTrabajoPropietarioDto>();
    private CrearOrdenTrabajoDto nuevo = new();
    private bool mostrarCrear;
    private bool mostrarAsignar;
    private int tabIndex;
    private string departamentoActivo = "01";
    private string? usuarioActual;
    private string? usuarioAsignacion;
    private string? empleadoAsignacion;
    private string? estadoAsignacion;
    private string tipoFiltroTexto = string.Empty;
    private string clienteFiltroTexto = string.Empty;
    private string estadoFiltroTexto = string.Empty;
    private string clienteCrearTexto = string.Empty;
    private string tipoCrearTexto = string.Empty;
    private string empleadoCrearTexto = string.Empty;
    private string usuarioAsignacionTexto = string.Empty;
    private string empleadoAsignacionTexto = string.Empty;
    private string estadoAsignacionTexto = string.Empty;

    private bool clienteInvalido;
    private bool tipoInvalido;
    private bool fechaInvalida;
    private bool conceptoInvalido;
    private DxMemo? conceptoMemo;

    private CancellationTokenSource? tiposFiltroCts;
    private CancellationTokenSource? clientesFiltroCts;
    private CancellationTokenSource? estadosFiltroCts;

    protected override async Task OnInitializedAsync()
    {
        await CargarUsuarioActualAsync();
        await CargarCatalogosInicialesAsync();
        await BuscarAsync();
    }

    private async Task CargarUsuarioActualAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        usuarioActual = authState.User.Identity?.Name;
    }

    private async Task CargarCatalogosInicialesAsync()
    {
        try
        {
            filtro.Departamento = departamentoActivo;

            estados = await OrdenesClient.BuscarEstadosAsync(null, 20);
            estadosAsignacion = estados.Where(e => e.PermiteAsignacion).Any()
            ? estados.Where(e => e.PermiteAsignacion).ToList()
            : estados;

            if (string.IsNullOrWhiteSpace(estadoAsignacion) || !estadosAsignacion.Any(e => e.Codigo == estadoAsignacion))
            {
                estadoAsignacion = estadosAsignacion.FirstOrDefault()?.Codigo;
            }

            tipos = await OrdenesClient.BuscarTiposAsync(departamentoActivo, null, 20);
            propietarios = await OrdenesClient.BuscarPropietariosAsync(null, 20);
            usuarios = await OrdenesClient.GetUsuariosAsync(MapearTipoNumerico(tabIndex));
        }
        catch (Exception ex)
        {
            ManejarErrorCatalogo("cargar catálogos iniciales", ex);
            estados = Array.Empty<OrdenTrabajoEstadoDto>();
            estadosAsignacion = Array.Empty<OrdenTrabajoEstadoDto>();
            tipos = Array.Empty<OrdenTrabajoTipoDto>();
            propietarios = Array.Empty<OrdenTrabajoPropietarioDto>();
            usuarios = Array.Empty<UsuarioMiOrdenDto>();
        }
    }

    private async Task BuscarAsync()
    {
        try
        {
            filtro.Departamento = departamentoActivo;
            ordenes = await OrdenesClient.GetOrdenesAsync(filtro);
        }
        catch (Exception ex)
        {
            ShowToast("Órdenes de trabajo", ex.Message, ToastRenderStyle.Danger);
            ordenes = Array.Empty<OrdenTrabajoListItemDto>();
        }
    }

    private async Task LimpiarAsync()
    {
        filtro.Busqueda = null;
        filtro.Estado = null;
        filtro.Tipo = null;
        filtro.FechaDesde = null;
        filtro.FechaHasta = null;
        filtro.ClienteClave = null;
        filtro.Clave = null;
        filtro.ClienteNombre = null;
        tipoFiltroTexto = string.Empty;
        clienteFiltroTexto = string.Empty;
        estadoFiltroTexto = string.Empty;
        await BuscarAsync();
    }

    private void AbrirCrear()
    {
        clienteInvalido = false;
        tipoInvalido = false;
        fechaInvalida = false;
        conceptoInvalido = false;

        nuevo = new CrearOrdenTrabajoDto
        {
            Fecha = DateTime.Today,
            Usuario = usuarioActual ?? string.Empty,
            Tipo = string.Empty,
            Estado = "P"
        };
        clienteCrearTexto = string.Empty;
        tipoCrearTexto = string.Empty;
        empleadoCrearTexto = string.Empty;

        mostrarCrear = true;
    }

    private async Task GuardarNuevaOrdenAsync()
    {
        if (!await ValidarNuevaOrdenAsync())
        {
            return;
        }

        var resultado = await OrdenesClient.CrearOrdenAsync(nuevo);
        if (resultado.Exitoso)
        {
            mostrarCrear = false;
            ShowToast("Órdenes de trabajo", resultado.Mensaje, ToastRenderStyle.Success);
            await BuscarAsync();
        }
        else
        {
            ShowToast("Órdenes de trabajo", resultado.Mensaje, ToastRenderStyle.Danger);
        }
    }

    private void CerrarCrear()
    {
        mostrarCrear = false;
    }

    private void AbrirAsignacion()
    {
        if (!SeleccionadasOrdenes.Any())
        {
            ShowToast("Órdenes de trabajo", "Seleccione al menos una orden para asignar.", ToastRenderStyle.Danger);
            return;
        }

        usuarioAsignacion = usuarios.FirstOrDefault()?.Usuario ?? usuarioActual;
        empleadoAsignacion = usuarios.FirstOrDefault(u => u.Usuario == usuarioAsignacion)?.Nombre;
        estadoAsignacion ??= estadosAsignacion.FirstOrDefault()?.Codigo;
        usuarioAsignacionTexto = usuarios.FirstOrDefault(u => u.Usuario == usuarioAsignacion)?.Nombre ?? string.Empty;
        empleadoAsignacionTexto = empleadoAsignacion ?? string.Empty;
        estadoAsignacionTexto = estadosAsignacion.FirstOrDefault(e => e.Codigo == estadoAsignacion)?.Nombre ?? string.Empty;
        mostrarAsignar = true;
    }

    private async Task ConfirmarAsignacionAsync()
    {
        var dto = new OrdenTrabajoAsignacionDto
        {
            NumerosOrden = SeleccionadasOrdenes.Select(o => o.Numero).Distinct().ToList(),
            Usuario = usuarioAsignacion ?? usuarioActual ?? string.Empty,
            Estado = estadoAsignacion,
            Empleado = empleadoAsignacion
        };

        var resultado = await OrdenesClient.AsignarOrdenesAsync(dto);
        if (resultado.Exitoso)
        {
            mostrarAsignar = false;
            ShowToast("Órdenes de trabajo", resultado.Mensaje, ToastRenderStyle.Success);
            await BuscarAsync();
        }
        else
        {
            ShowToast("Órdenes de trabajo", resultado.Mensaje, ToastRenderStyle.Danger);
        }
    }

    private void CerrarAsignacion()
    {
        mostrarAsignar = false;
    }

    private async Task OnTabChanged(int index)
    {
        tabIndex = index;
        departamentoActivo = index switch
        {
            0 => "01",
            1 => "03",
            2 => "02",
            _ => "01"
        };

        await CargarCatalogosInicialesAsync();
        await BuscarAsync();
    }

    private async Task<bool> ValidarNuevaOrdenAsync()
    {
        var clienteExiste = !string.IsNullOrWhiteSpace(nuevo.ClienteClave) && propietarios.Any(p => p.Clave == nuevo.ClienteClave);
        var tipoExiste = !string.IsNullOrWhiteSpace(nuevo.Tipo) && tipos.Any(t => t.Tipo == nuevo.Tipo);

        clienteInvalido = !clienteExiste;
        tipoInvalido = !tipoExiste;
        fechaInvalida = nuevo.Fecha == default;
        conceptoInvalido = string.IsNullOrWhiteSpace(nuevo.Concepto);

        if (!clienteInvalido && !tipoInvalido && !fechaInvalida && !conceptoInvalido)
        {
            return true;
        }

        var faltantes = new List<string>();
        if (clienteInvalido)
        {
            faltantes.Add("cliente");
        }

        if (tipoInvalido)
        {
            faltantes.Add("tipo");
        }

        if (fechaInvalida)
        {
            faltantes.Add("fecha");
        }

        if (conceptoInvalido)
        {
            faltantes.Add("concepto");
        }

        ShowToast("Órdenes de trabajo", $"Completa los campos obligatorios: {string.Join(", ", faltantes)}.",
        ToastRenderStyle.Danger);

        if (conceptoInvalido && conceptoMemo is not null)
        {
            await conceptoMemo.FocusAsync();
        }

        return false;
    }

