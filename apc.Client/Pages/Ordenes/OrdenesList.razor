    private async Task RecargarEstadosAsync(string? texto)
    {
        estadosFiltroCts?.Cancel();
        estadosFiltroCts = new CancellationTokenSource();
        var token = estadosFiltroCts.Token;

        try
        {
            var catalogo = await OrdenesClient.BuscarEstadosAsync(texto, 20, token);
            if (!token.IsCancellationRequested)
            {
                estados = catalogo;
                estadosAsignacion = catalogo.Where(e => e.PermiteAsignacion).Any()
                    ? catalogo.Where(e => e.PermiteAsignacion).ToList()
                    : catalogo;

                if (!string.IsNullOrWhiteSpace(filtro.Estado) && !estados.Any(e => e.Codigo == filtro.Estado))
                {
                    filtro.Estado = null;
                    estadoFiltroTexto = string.Empty;
                }

                if (!string.IsNullOrWhiteSpace(estadoAsignacion) && !estadosAsignacion.Any(e => e.Codigo == estadoAsignacion))
                {
                    estadoAsignacion = null;
                }

                if (string.IsNullOrWhiteSpace(estadoAsignacion))
                {
                    estadoAsignacion = estadosAsignacion.FirstOrDefault()?.Codigo;
                }

                estadoAsignacionTexto = estadosAsignacion
                    .FirstOrDefault(e => e.Codigo == estadoAsignacion)?.Nombre ?? string.Empty;

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            ManejarErrorCatalogo("cargar estados", ex);
        }
    }

    private async Task RecargarTiposAsync(string? texto)
    {
        tiposFiltroCts?.Cancel();
        tiposFiltroCts = new CancellationTokenSource();
        var token = tiposFiltroCts.Token;

        try
        {
            var catalogo = await OrdenesClient.BuscarTiposAsync(departamentoActivo, texto, 20, token);
            if (!token.IsCancellationRequested)
            {
                tipos = catalogo;
                if (!string.IsNullOrWhiteSpace(filtro.Tipo) && tipos.All(t => t.Tipo != filtro.Tipo))
                {
                    filtro.Tipo = null;
                    tipoFiltroTexto = string.Empty;
                }

                if (!string.IsNullOrWhiteSpace(nuevo.Tipo) && tipos.All(t => t.Tipo != nuevo.Tipo))
                {
                    nuevo.Tipo = null;
                    tipoCrearTexto = string.Empty;
                }

                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
        catch (Exception ex)
        {
            ManejarErrorCatalogo("cargar tipos", ex);
        }
    }

