@page "/auxiliares/auxiliar-lectura"
@using System.Globalization
@using Microsoft.AspNetCore.Components.Web
@using SIAD.Core.DTOs.AuxiliarLectura
@using apc.Client.Services.AuxiliarLectura
@inject AuxiliarLecturaClient AuxiliarLecturaClient
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Auxiliar de Lectura</PageTitle>

<div class="page-container">

    <!-- Header -->
    <div class="header-section">
        <div class="header-left">
            <h2 class="page-title">Auxiliar de Lectura</h2>
            <p class="page-subtitle">Gestión de períodos y lecturas de medidores</p>
        </div>

        <div class="header-right">
            @if (periodoActual is not null)
            {
                <div class="period-widget">
                    <i class="bi bi-calendar3"></i>
                    <div class="period-info">
                        <strong>Período Abierto</strong>
                        <span>
                            @periodoActual.Mes.ToString("00")/@periodoActual.Anio
                            · Ciclo @(periodoActual.Ciclo ?? "N/A")
                            @if (periodoActual.FechaCierre.HasValue)
                            {
                                <span class="ms-1">· Cierre: @periodoActual.FechaCierre.Value.ToString("dd/MM/yyyy")</span>
                            }
                        </span>
                    </div>
                </div>
            }
            else
            {
                <div class="period-widget warning">
                    <i class="bi bi-exclamation-triangle"></i>
                    <div class="period-info">
                        <strong>Sin Período Abierto</strong>
                        <span>Debes generar un período antes de registrar lecturas.</span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Filtros -->
    <div class="modern-card mb-4">
        <div class="card-header-custom">
            <i class="bi bi-funnel"></i>
            <span>Filtros de Búsqueda</span>
        </div>

        <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
            <DxFormLayoutGroup ColSpanXs="12">
                <DxFormLayoutItem Caption="Año" ColSpanXs="12" ColSpanMd="3">
                    <DxSpinEdit @bind-Value="@auxiliarFiltro.Anio"
                                Min="2020"
                                Max="2099"
                                NullText="Actual" />
                </DxFormLayoutItem>

                <DxFormLayoutItem Caption="Mes" ColSpanXs="12" ColSpanMd="3">
                    <DxSpinEdit @bind-Value="@auxiliarFiltro.Mes"
                                Min="1"
                                Max="12"
                                NullText="Actual" />
                </DxFormLayoutItem>

                <DxFormLayoutItem Caption="Ciclo" ColSpanXs="12" ColSpanMd="3">
                    <DxTextBox @bind-Text="@auxiliarFiltro.Ciclo"
                               NullText="Ej: 01"
                               maxlength="2"
                               @onkeydown="OnCicloKeyDown" />
                </DxFormLayoutItem>

                <DxFormLayoutItem Caption="Estado" ColSpanXs="12" ColSpanMd="3">
                    <div class="pt-2">
                        <DxCheckBox @bind-Checked="@auxiliarFiltro.SoloPendientes"
                                    LabelText="Solo pendientes"
                                    CheckType="CheckType.Switch" />
                    </div>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanXs="12">
                    <Template>
                        <div class="action-bar">
                            <DxButton Text="Cargar"
                                      Click="@LoadAuxiliarLecturasAsync"
                                      IconCssClass="bi bi-search"
                                      RenderStyle="ButtonRenderStyle.Primary"
                                      CssClass="action-btn" />

                            <DxButton Text="Generar Período"
                                      Click="@MostrarPopupGenerarPeriodo"
                                      IconCssClass="bi bi-plus-lg"
                                      RenderStyle="ButtonRenderStyle.Success"
                                      CssClass="action-btn" />

                            <DxButton Text="Carga Masiva"
                                      Click="@MostrarPopupCargaMasiva"
                                      IconCssClass="bi bi-file-earmark-arrow-down"
                                      RenderStyle="ButtonRenderStyle.Info"
                                      CssClass="action-btn" />

                            <DxButton Text="Cerrar Período"
                                      Click="@CerrarPeriodoAsync"
                                      IconCssClass="bi bi-lock"
                                      RenderStyle="ButtonRenderStyle.Warning"
                                      CssClass="action-btn" />

                            <DxButton Text="Eliminar Período"
                                      Click="@EliminarPeriodoAsync"
                                      IconCssClass="bi bi-trash"
                                      RenderStyle="ButtonRenderStyle.Danger"
                                      CssClass="action-btn" />
                        </div>
                    </Template>
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
        </DxFormLayout>
    </div>

    <!-- Grid -->
    <div class="modern-card">
        <div class="card-header-custom">
            <i class="bi bi-table"></i>
            <span>Listado de Lecturas — @(auxiliarFiltro.Anio?.ToString("0000") ?? "-")/@(auxiliarFiltro.Mes?.ToString("00") ?? "-")</span>
        </div>

        @{ var gridError = dataSource?.LastError ?? auxiliarError; }

        @if (!string.IsNullOrEmpty(gridError))
        {
            <div class="alert alert-danger" role="alert">
                <strong class="me-1">Error</strong>
                @gridError
            </div>
        }

        <div class="grid-wrapper">
            <DxGrid @ref="grid"
                    Data="@dataSource"
                    ShowSearchBox="true"
                    ShowFilterRow="false"
                    ShowPager="true"
                    PageSize="15"
                    CssClass="grid-modern">

                <Columns>
                    <DxGridDataColumn FieldName="@nameof(AuxiliarLecturaDto.Ruta)" Caption="Ruta" Width="80px" />
                    <DxGridDataColumn FieldName="@nameof(AuxiliarLecturaDto.Clave)" Caption="Clave" Width="110px" />
                    <DxGridDataColumn FieldName="@nameof(AuxiliarLecturaDto.Cliente)" Caption="Cliente" Width="240px" />
                    <DxGridDataColumn FieldName="@nameof(AuxiliarLecturaDto.Secuencia)" Caption="Sec." Width="70px" TextAlignment="GridTextAlignment.Right" />
                    <DxGridDataColumn FieldName="@nameof(AuxiliarLecturaDto.Contador)" Caption="Contador" Width="110px" />
                    <DxGridDataColumn FieldName="@nameof(AuxiliarLecturaDto.LecturaAnterior)" Caption="Lec. Ant." Width="120px" TextAlignment="GridTextAlignment.Right" DisplayFormat="N2" />
                    <DxGridDataColumn FieldName="@nameof(AuxiliarLecturaDto.LecturaActual)" Caption="Lec. Act." Width="120px" TextAlignment="GridTextAlignment.Right" DisplayFormat="N2" />
                    <DxGridDataColumn FieldName="@nameof(AuxiliarLecturaDto.Consumo)" Caption="Consumo" Width="110px" TextAlignment="GridTextAlignment.Right" DisplayFormat="N2" />
                    <DxGridDataColumn FieldName="@nameof(AuxiliarLecturaDto.FechaLectura)" Caption="Fecha" Width="120px" DisplayFormat="dd/MM/yyyy" />
                    <DxGridDataColumn FieldName="@nameof(AuxiliarLecturaDto.Usuario)" Caption="Usuario" Width="120px" />
                </Columns>

                <ToolbarTemplate>
                    <div class="grid-toolbar action-bar action-bar--tight">
                        <DxButton Text="Copiar" IconCssClass="bi bi-files" RenderStyle="ButtonRenderStyle.Light" CssClass="action-btn action-btn--sm" />
                        <DxButton Text="Excel" IconCssClass="bi bi-file-earmark-excel" RenderStyle="ButtonRenderStyle.Light" CssClass="action-btn action-btn--sm" />
                        <DxButton Text="PDF" IconCssClass="bi bi-file-earmark-pdf" RenderStyle="ButtonRenderStyle.Light" CssClass="action-btn action-btn--sm" />
                        <DxButton Text="Imprimir" IconCssClass="bi bi-printer" RenderStyle="ButtonRenderStyle.Light" CssClass="action-btn action-btn--sm" />
                    </div>
                </ToolbarTemplate>

                <EmptyDataAreaTemplate>
                    @if (string.IsNullOrEmpty(gridError) && dataSource?.HasLoaded == true && (dataSource?.LastTotalCount ?? 0) == 0)
                    {
                        <div class="p-3 text-center text-muted">
                            No hay registros de lecturas para el período y filtros seleccionados.
                            <div class="mt-2 small text-muted">Tip: genera un período o ajusta filtros.</div>
                        </div>
                    }
                </EmptyDataAreaTemplate>
            </DxGrid>
        </div>
    </div>

    <!-- Popup: Generar Período -->
    <DxPopup Visible="@generarPopupVisible"
             VisibleChanged="@(v => generarPopupVisible = v)"
             Width="min(520px, 95vw)"
             HeaderText="Nuevo Período"
             CloseOnOutsideClick="true"
             ShowCloseButton="true"
             ShowFooter="false">

        <BodyTemplate Context="popupContext">
            <div class="popup-body">
                <div class="alert alert-info mb-3" role="alert">
                    Se cerrará automáticamente el período anterior abierto y se prepararán lecturas base clonando del período previo.
                </div>

                <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                    <DxFormLayoutItem Caption="Año *" ColSpanXs="12" ColSpanMd="4">
                        <DxSpinEdit @bind-Value="@generarPeriodoModel.Anio"
                                    Min="2020"
                                    Max="2099"
                                    NullText="Selecciona año"
                                    Enabled="!generarGuardando" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Mes *" ColSpanXs="12" ColSpanMd="4">
                        <DxSpinEdit @bind-Value="@generarPeriodoModel.Mes"
                                    Min="1"
                                    Max="12"
                                    NullText="Selecciona mes"
                                    Enabled="!generarGuardando" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem Caption="Ciclo *" ColSpanXs="12" ColSpanMd="4">
                        <DxTextBox @bind-Text="@generarPeriodoModel.Ciclo"
                                   NullText="Ej: 01"
                                   maxlength="2"
                                   Enabled="!generarGuardando" />
                    </DxFormLayoutItem>


                    <DxFormLayoutItem ColSpanXs="12">
                        <div class="popup-actions">
                            <DxButton Text="@(generarGuardando ? "Generando..." : "Generar Período")"
                                      Click="@GenerarPeriodoAsync"
                                      RenderStyle="ButtonRenderStyle.Primary"
                                      Enabled="@(!generarGuardando && generarPeriodoModel.Anio > 0 && generarPeriodoModel.Mes > 0 && !string.IsNullOrWhiteSpace(generarPeriodoModel.Ciclo))"
                                      CssClass="popup-btn" />

                            <DxButton Text="Cancelar"
                                      Click="@(() => generarPopupVisible = false)"
                                      RenderStyle="ButtonRenderStyle.None"
                                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                                      CssClass="popup-btn" />
                        </div>
                    </DxFormLayoutItem>
                </DxFormLayout>
            </div>
        </BodyTemplate>
    </DxPopup>

    <!-- Popup: Carga Masiva -->
    <DxPopup Visible="@cargaMasivaPopupVisible"
             VisibleChanged="@(v => cargaMasivaPopupVisible = v)"
             Width="min(980px, 95vw)"
             HeaderText="Carga Masiva de Lecturas"
             CloseOnOutsideClick="true"
             ShowCloseButton="true"
             ShowFooter="false">

        <BodyTemplate Context="popupContext2">
            <div class="popup-body popup-body--wide">
                <div class="alert alert-info mb-3" role="alert">
                    <div class="fw-bold mb-2">Formato (CSV con punto y coma)</div>
                    <div class="small">CLAVE;CONTADOR;LECTURA_ANTERIOR;LECTURA_ACTUAL;USUARIO</div>
                    <div class="small text-muted mt-2">Ejemplo: CLI-001;MED-001;100;120;JUAN</div>
                </div>

                <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                    <DxFormLayoutItem Caption="Año *" ColSpanXs="12" ColSpanMd="4">
                        <DxSpinEdit @bind-Value="@cargaMasivaModel.Anio"
                                    Min="2020"
                                    Max="2099"
                                    Enabled="!cargaMasivaGuardando" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Mes *" ColSpanXs="12" ColSpanMd="4">
                        <DxSpinEdit @bind-Value="@cargaMasivaModel.Mes"
                                    Min="1"
                                    Max="12"
                                    Enabled="!cargaMasivaGuardando" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Ciclo (Opcional)" ColSpanXs="12" ColSpanMd="4">
                        <DxTextBox @bind-Text="@cargaMasivaModel.Ciclo"
                                   NullText="Ej: 01"
                                   maxlength="2"
                                   Enabled="!cargaMasivaGuardando" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Lecturas *" ColSpanXs="12">
                        <DxMemo @bind-Text="@cargaMasivaModel.Contenido"
                                Rows="10"
                                NullText="Pega aquí tus datos (una lectura por línea)..."
                                Enabled="!cargaMasivaGuardando"
                                ResizeMode="MemoResizeMode.Vertical" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanXs="12">
                        <div class="popup-actions">
                            <DxButton Text="@(cargaMasivaGuardando ? "Procesando..." : "Procesar Lecturas")"
                                      Click="@EnviarCargaMasivaAsync"
                                      RenderStyle="ButtonRenderStyle.Primary"
                                      Enabled="@(!cargaMasivaGuardando && !string.IsNullOrWhiteSpace(cargaMasivaModel.Contenido))"
                                      CssClass="popup-btn" />

                            <DxButton Text="Cancelar"
                                      Click="@CancelarCargaMasiva"
                                      RenderStyle="ButtonRenderStyle.None"
                                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                                      CssClass="popup-btn" />
                        </div>
                    </DxFormLayoutItem>
                </DxFormLayout>
            </div>
        </BodyTemplate>
    </DxPopup>
</div>

@code {
    private AuxiliarLecturaPeriodoDto? periodoActual;
    private bool filtrosSincronizados;
    private bool pendingReload;

    private DxGrid? grid;
    private AuxiliarLecturaGridDataSource? dataSource;

    private AuxiliarLecturaFilterDto auxiliarFiltro = new()
    {
        Anio = DateTime.Now.Year,
        Mes = DateTime.Now.Month,
        SoloPendientes = false
    };

    private string? auxiliarError;

    private bool generarPopupVisible;
    private GenerarPeriodoModel generarPeriodoModel = new(DateTime.Now.Year, DateTime.Now.Month, "01");
    private bool generarGuardando;

    private bool cargaMasivaPopupVisible;
    private bool cargaMasivaGuardando;
    private CargaMasivaModel cargaMasivaModel = new();

    private class GenerarPeriodoModel
    {
        public int Anio { get; set; }
        public int Mes { get; set; }
        public string Ciclo { get; set; } = "01";
        public GenerarPeriodoModel(int anio, int mes, string ciclo) { Anio = anio; Mes = mes; Ciclo = ciclo; }
    }

    private class CargaMasivaModel
    {
        public int Anio { get; set; } = DateTime.Now.Year;
        public int Mes { get; set; } = DateTime.Now.Month;
        public string? Ciclo { get; set; }
        public string Contenido { get; set; } = string.Empty;
    }

    protected override async Task OnInitializedAsync()
    {
        dataSource = new AuxiliarLecturaGridDataSource(AuxiliarLecturaClient, () => InvokeAsync(StateHasChanged));
        await CargarPeriodoActualAsync(sincronizarFiltros: true);
        await LoadAuxiliarLecturasAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (pendingReload && grid is not null)
        {
            pendingReload = false;
            await ReloadGridAsync();
        }
    }

    private async Task CargarPeriodoActualAsync(bool sincronizarFiltros = false)
    {
        try
        {
            periodoActual = await AuxiliarLecturaClient.ObtenerPeriodoActualAsync();
            if (sincronizarFiltros && periodoActual is not null && !filtrosSincronizados)
            {
                auxiliarFiltro.Anio = periodoActual.Anio;
                auxiliarFiltro.Mes = periodoActual.Mes;
                auxiliarFiltro.SoloPendientes = false;
                filtrosSincronizados = true;
            }
        }
        catch (Exception ex)
        {
            auxiliarError = $"Error al cargar período actual: {ex.Message}";
        }
    }

    private async Task LoadAuxiliarLecturasAsync()
    {
        auxiliarError = null;

        try
        {
            ApplyFiltersToDataSource();

            if (grid is not null)
                await ReloadGridAsync();
            else
                pendingReload = true;
        }
        catch (Exception ex)
        {
            auxiliarError = $"Error al cargar lecturas: {ex.Message}";
        }
    }

    private void ApplyFiltersToDataSource()
    {
        if (dataSource is null)
            return;

        auxiliarFiltro.Anio = auxiliarFiltro.Anio is > 0 ? auxiliarFiltro.Anio : null;
        auxiliarFiltro.Mes = auxiliarFiltro.Mes is >= 1 and <= 12 ? auxiliarFiltro.Mes : null;
        dataSource.Anio = auxiliarFiltro.Anio is > 0 ? auxiliarFiltro.Anio : null;
        dataSource.Mes = auxiliarFiltro.Mes is > 0 ? auxiliarFiltro.Mes : null;
        dataSource.Ciclo = string.IsNullOrWhiteSpace(auxiliarFiltro.Ciclo) ? null : auxiliarFiltro.Ciclo;
        dataSource.SoloPendientes = auxiliarFiltro.SoloPendientes ?? false;
    }

    private Task ReloadGridAsync()
    {
        if (grid is null || dataSource is null)
            return Task.CompletedTask;

        grid.Reload();
        return Task.CompletedTask;
    }

    private async Task OnCicloKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == "NumpadEnter")
            await LoadAuxiliarLecturasAsync();
    }

    private void MostrarPopupGenerarPeriodo()
    {
        generarPeriodoModel.Anio = auxiliarFiltro.Anio ?? DateTime.Now.Year;
        generarPeriodoModel.Mes = auxiliarFiltro.Mes ?? DateTime.Now.Month;
        generarPeriodoModel.Ciclo = !string.IsNullOrWhiteSpace(auxiliarFiltro.Ciclo) ? auxiliarFiltro.Ciclo : "01";
        generarPopupVisible = true;
    }

    private void MostrarPopupCargaMasiva()
    {
        cargaMasivaModel = new CargaMasivaModel
        {
            Anio = auxiliarFiltro.Anio ?? DateTime.Now.Year,
            Mes = auxiliarFiltro.Mes ?? DateTime.Now.Month,
            Ciclo = auxiliarFiltro.Ciclo
        };
        cargaMasivaGuardando = false;
        cargaMasivaPopupVisible = true;
    }

    private void CancelarCargaMasiva()
    {
        cargaMasivaPopupVisible = false;
        cargaMasivaGuardando = false;
        cargaMasivaModel = new CargaMasivaModel();
    }

    private async Task GenerarPeriodoAsync()
    {
        if (generarPeriodoModel.Anio < 2020 || generarPeriodoModel.Anio > 2099)
        {
            ShowToast("Validación", "El año debe estar entre 2020 y 2099.", ToastRenderStyle.Danger);
            return;
        }

        if (generarPeriodoModel.Mes <= 0 || generarPeriodoModel.Mes > 12)
        {
            ShowToast("Validación", "El mes debe estar entre 1 y 12.", ToastRenderStyle.Danger);
            return;
        }

        var ciclo = (generarPeriodoModel.Ciclo ?? string.Empty).Trim();
        if (string.IsNullOrEmpty(ciclo))
        {
            ShowToast("Validación", "El ciclo es requerido.", ToastRenderStyle.Danger);
            return;
        }

        generarGuardando = true;

        try
        {
            var response = await AuxiliarLecturaClient.GenerarPeriodoAsync(generarPeriodoModel.Anio, generarPeriodoModel.Mes, ciclo);

            if (response.IsSuccessStatusCode)
            {
                generarPopupVisible = false;
                ShowToast("Éxito", "Período generado correctamente.", ToastRenderStyle.Success);
                filtrosSincronizados = false;
                await CargarPeriodoActualAsync(sincronizarFiltros: true);
                await LoadAuxiliarLecturasAsync();
            }
            else
            {
                var detail = await response.Content.ReadAsStringAsync();
                var mensajeError = !string.IsNullOrWhiteSpace(detail)
                    ? $"Error: {detail}"
                    : "No se pudo generar el período. Verifica que no exista.";
                ShowToast("Error", mensajeError, ToastRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error", $"Error: {ex.Message}", ToastRenderStyle.Danger);
        }
        finally
        {
            generarGuardando = false;
        }
    }

    private async Task CerrarPeriodoAsync()
    {
        if (auxiliarFiltro.Anio is null || auxiliarFiltro.Mes is null)
        {
            ShowToast("Atención", "Selecciona año y mes antes de cerrar.", ToastRenderStyle.Warning);
            return;
        }

        try
        {
            var response = await AuxiliarLecturaClient.CerrarPeriodoAsync(auxiliarFiltro.Anio.Value, auxiliarFiltro.Mes.Value);

            if (response.IsSuccessStatusCode)
            {
                ShowToast("Éxito", "Período cerrado correctamente.", ToastRenderStyle.Success);
                await CargarPeriodoActualAsync();
                await LoadAuxiliarLecturasAsync();
            }
            else
            {
                var detail = await response.Content.ReadAsStringAsync();
                ShowToast("Error", string.IsNullOrWhiteSpace(detail) ? "No se pudo cerrar el período." : detail, ToastRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error", $"Error: {ex.Message}", ToastRenderStyle.Danger);
        }
    }

    private async Task EliminarPeriodoAsync()
    {
        if (auxiliarFiltro.Anio is null || auxiliarFiltro.Mes is null)
        {
            ShowToast("Atención", "Selecciona año y mes antes de eliminar.", ToastRenderStyle.Warning);
            return;
        }

        try
        {
            var response = await AuxiliarLecturaClient.EliminarPeriodoAsync(auxiliarFiltro.Anio.Value, auxiliarFiltro.Mes.Value);

            if (response.IsSuccessStatusCode)
            {
                ShowToast("Éxito", "Período eliminado correctamente.", ToastRenderStyle.Success);
                await CargarPeriodoActualAsync();
                await LoadAuxiliarLecturasAsync();
            }
            else
            {
                var detail = await response.Content.ReadAsStringAsync();
                ShowToast("Error", string.IsNullOrWhiteSpace(detail) ? "No se pudo eliminar el período." : detail, ToastRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error", $"Error: {ex.Message}", ToastRenderStyle.Danger);
        }
    }

    private async Task EnviarCargaMasivaAsync()
    {
        if (cargaMasivaGuardando) return;

        if (cargaMasivaModel.Anio <= 0 || cargaMasivaModel.Mes <= 0)
        {
            ShowToast("Validación", "Indica año y mes válidos.", ToastRenderStyle.Danger);
            return;
        }

        var items = ParseLecturasMasivas(cargaMasivaModel.Contenido);
        if (items is null) return;

        cargaMasivaGuardando = true;

        try
        {
            var cargaPayload = new AuxiliarLecturaClient.CargaMasivaModel
            {
                Anio = cargaMasivaModel.Anio,
                Mes = cargaMasivaModel.Mes,
                Ciclo = string.IsNullOrWhiteSpace(cargaMasivaModel.Ciclo) ? null : cargaMasivaModel.Ciclo,
                Lecturas = items.Select(i => new AuxiliarLecturaClient.CargaMasivaItemModel
                {
                    Clave = i.Clave,
                    Contador = i.Contador,
                    LecturaAnterior = i.LecturaAnterior,
                    LecturaActual = i.LecturaActual,
                    Usuario = i.Usuario
                }).ToArray()
            };

            var response = await AuxiliarLecturaClient.CargarLecturasMasivasAsync(cargaPayload);

            if (response.IsSuccessStatusCode)
            {
                ShowToast("Éxito", $"{items.Count} lecturas registradas correctamente.", ToastRenderStyle.Success);
                cargaMasivaPopupVisible = false;
                cargaMasivaModel = new CargaMasivaModel();
                await LoadAuxiliarLecturasAsync();
            }
            else
            {
                var detail = await response.Content.ReadAsStringAsync();
                ShowToast("Error", string.IsNullOrWhiteSpace(detail) ? "Error al cargar las lecturas." : detail, ToastRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            ShowToast("Error", $"Error: {ex.Message}", ToastRenderStyle.Danger);
        }
        finally
        {
            cargaMasivaGuardando = false;
        }
    }

    private List<CargaMasivaItem>? ParseLecturasMasivas(string? contenido)
    {
        if (string.IsNullOrWhiteSpace(contenido))
        {
            ShowToast("Validación", "Ingresa al menos una línea con lecturas.", ToastRenderStyle.Danger);
            return null;
        }

        var result = new List<CargaMasivaItem>();
        var lines = contenido.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);

        for (var index = 0; index < lines.Length; index++)
        {
            var line = lines[index].Trim();
            if (string.IsNullOrEmpty(line)) continue;

            var parts = line.Split(';');
            if (parts.Length < 5)
            {
                ShowToast("Validación", $"Línea {index + 1}: formato inválido. Usa clave;contador;anterior;actual;usuario.", ToastRenderStyle.Danger);
                return null;
            }

            if (!decimal.TryParse(parts[2], NumberStyles.Number, CultureInfo.InvariantCulture, out var anterior))
            {
                ShowToast("Validación", $"Línea {index + 1}: lectura anterior no es número válido.", ToastRenderStyle.Danger);
                return null;
            }

            if (!decimal.TryParse(parts[3], NumberStyles.Number, CultureInfo.InvariantCulture, out var actual))
            {
                ShowToast("Validación", $"Línea {index + 1}: lectura actual no es número válido.", ToastRenderStyle.Danger);
                return null;
            }

            result.Add(new CargaMasivaItem(
                parts[0].Trim(),
                parts[1].Trim(),
                anterior,
                actual,
                parts[4].Trim()));
        }

        if (result.Count == 0)
        {
            ShowToast("Validación", "No se encontraron lecturas para procesar.", ToastRenderStyle.Danger);
            return null;
        }

        return result;
    }

    private record CargaMasivaItem(
        string Clave,
        string Contador,
        decimal LecturaAnterior,
        decimal LecturaActual,
        string Usuario);

    private void ShowToast(string title, string message, ToastRenderStyle style)
    {
        ToastService.ShowToast(new ToastOptions
        {
            Title = title,
            Text = message,
            RenderStyle = style
        });
    }
}
