@page "/presupuesto/configuraciones/{IdPresupuesto}/detalles/{CuentaContable}/editar"
@attribute [Authorize(Policy = AuthorizationPolicies.Contabilidad)]

@using DevExpress.Blazor
@using System.ComponentModel.DataAnnotations
@using SIAD.Core.DTOs.Presupuesto
@using apc.Client.Services.Presupuesto

@inject ConfiguracionPresupuestoClient ConfiguracionPresupuestoClient
@inject NavigationManager Navigation
@inject IToastNotificationService ToastService
@inject ILogger<PresupuestoDetalleEdit> Logger

<PageTitle>SIAD - Editar detalle de presupuesto</PageTitle>

<div class="page-container position-relative">
    <DxToastProvider Name="PresupuestoDetalleEditToast" MaxToastCount="4" />

    <DxLoadingPanel Visible="@IsBusy"
                    IsContentBlocked="true"
                    ApplyBackgroundShading="true"
                    Text="Procesando..." />

    <div class="header-section">
        <div>
            <h2 class="page-title">Editar detalle de presupuesto</h2>
            <p class="page-subtitle">Actualice el valor de proyección del detalle seleccionado.</p>
        </div>
        <DxButton Text="Volver"
                  IconCssClass="bi bi-arrow-left"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  CssClass="btn-modern"
                  Click="VolverALista" />
    </div>

    <div class="modern-card mb-3">
        <div class="context-grid">
            <div class="context-item">
                <div class="context-label">Número de cuenta</div>
                <div class="context-value">@CuentaNumeroDisplay</div>
            </div>
            <div class="context-item">
                <div class="context-label">Descripción de cuenta</div>
                <div class="context-value">@CuentaDescripcionDisplay</div>
            </div>
        </div>
    </div>

    <div class="modern-card">
        <h5 class="mb-3">Actualización de detalle</h5>
        @if (isLoading)
        {
            <div class="small text-muted mb-3">Cargando detalle...</div>
        }
        else if (detalle is null)
        {
            <div class="alert alert-warning" role="alert">
                No se encontró el detalle solicitado.
            </div>
        }
        else
        {
            @if (!presupuestoVigente)
            {
                <div class="alert alert-warning mb-3" role="alert">
                    @GetMensajeBloqueoPorRango()
                </div>
            }

            @if (presupuestoAprobado)
            {
                <div class="alert alert-warning mb-3" role="alert">
                    Este presupuesto ya está aprobado. No se permite editar el detalle.
                </div>
            }

            <EditForm Model="form" OnValidSubmit="GuardarAsync" Context="detalleEditFormContext">
                <DataAnnotationsValidator />

                <DxFormLayout>
                    <DxFormLayoutItem Caption="Valor real" ColSpanMd="6">
                        <DxSpinEdit TValue="decimal"
                                    Value="@detalle.ValorReal"
                                    ReadOnly="true"
                                    InputCssClass="text-end"
                                    Decimals="2"
                                    DisplayFormat="n2"
                                    ValidationEnabled="false" />
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Valor proyección *" ColSpanMd="6">
                        <DxSpinEdit TValue="decimal"
                                    @bind-Value="form.ValorProyeccion"
                                    Min="0"
                                    Increment="0.01m"
                                    InputCssClass="text-end"
                                    Decimals="2"
                                    DisplayFormat="n2"
                                    Enabled="@(!isSaving && !presupuestoAprobado && presupuestoVigente)" />
                        <ValidationMessage For="() => form.ValorProyeccion" />
                    </DxFormLayoutItem>
                </DxFormLayout>

                <ValidationSummary class="text-danger mb-2" />

                <div class="d-flex justify-content-end mt-2 gap-2">
                    <DxButton ButtonType="ButtonType.Submit"
                              RenderStyle="ButtonRenderStyle.Primary"
                              Text="Guardar cambios"
                              SubmitFormOnClick="true"
                              Enabled="@(!isSaving && !presupuestoAprobado && presupuestoVigente)" />
                    <DxButton Text="Cancelar"
                              RenderStyle="ButtonRenderStyle.Secondary"
                              Enabled="@(!isSaving)"
                              Click="VolverALista" />
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter]
    public string? IdPresupuesto { get; set; }

    [Parameter]
    public string? CuentaContable { get; set; }

    private bool isLoading = true;
    private bool isSaving;

    // Splash de página: visible mientras hay una llamada al servidor en curso.
    private bool IsBusy => isLoading || isSaving;
    private ConfiguracionPresupuestoDetalleListItemDto? detalle;
    private DetalleEditForm form = new();
    private string? cuentaContableDisplay;
    private bool presupuestoAprobado;
    private bool presupuestoVigente = true;
    private decimal presupuestoHdr;
    private DateOnly currentServerDate = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly? fechaIniciaPresupuesto;
    private DateOnly? fechaFinalizaPresupuesto;

    private string PresupuestoDisplay => string.IsNullOrWhiteSpace(IdPresupuesto)
        ? "-"
        : IdPresupuesto.Trim();

    private string CuentaNumeroDisplay => string.IsNullOrWhiteSpace(CuentaContable)
        ? "-"
        : AccountCodeFormatter.Format(CuentaContable);

    private string CuentaDisplay => string.IsNullOrWhiteSpace(cuentaContableDisplay)
        ? CuentaNumeroDisplay
        : cuentaContableDisplay;

    private string CuentaDescripcionDisplay => ExtractCuentaDescripcion(CuentaDisplay, CuentaNumeroDisplay);

    protected override async Task OnParametersSetAsync()
    {
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        isLoading = true;
        detalle = null;
        form = new DetalleEditForm();
        cuentaContableDisplay = null;
        presupuestoAprobado = false;
        presupuestoVigente = true;
        presupuestoHdr = 0m;
        fechaIniciaPresupuesto = null;
        fechaFinalizaPresupuesto = null;

        try
        {
            if (string.IsNullOrWhiteSpace(IdPresupuesto) || string.IsNullOrWhiteSpace(CuentaContable))
            {
                ShowToast("Error", "Debe indicar el presupuesto y la cuenta contable del detalle.", ToastRenderStyle.Danger);
                return;
            }

            var id = IdPresupuesto.Trim();
            var cuenta = CuentaContable.Trim();
            detalle = await ConfiguracionPresupuestoClient.GetDetailByIdAsync(id, cuenta);
            cuentaContableDisplay = FormatCuentaContableDisplay(detalle?.CuentaContable);

            if (detalle is null)
            {
                ShowToast("Error", "No se encontró el detalle del presupuesto solicitado.", ToastRenderStyle.Danger);
                return;
            }

            var header = await ConfiguracionPresupuestoClient.GetByIdAsync(id);
            if (header is null)
            {
                ShowToast("Error", "No se encontró el encabezado del presupuesto.", ToastRenderStyle.Danger);
                return;
            }

            presupuestoAprobado = header.EstadoAprobado;
            presupuestoHdr = header.ValorGlobal;
            fechaIniciaPresupuesto = header.FechaInicia;
            fechaFinalizaPresupuesto = header.FechaFinaliza;

            try
            {
                currentServerDate = await ConfiguracionPresupuestoClient.GetServerDateAsync();
            }
            catch
            {
                currentServerDate = DateOnly.FromDateTime(DateTime.Today);
            }

            presupuestoVigente = header.FechaInicia <= currentServerDate && header.FechaFinaliza >= currentServerDate;

            form.ValorProyeccion = detalle.ValorProyeccion;
        }
        catch (Exception ex)
        {
            ShowToast("Error", $"No se pudo cargar el detalle: {ex.Message}", ToastRenderStyle.Danger);
            Logger.LogError(ex, "Error al cargar detalle de presupuesto {IdPresupuesto}/{CuentaContable}", IdPresupuesto, CuentaContable);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GuardarAsync()
    {
        if (detalle is null || string.IsNullOrWhiteSpace(detalle.IdPresupuesto) || string.IsNullOrWhiteSpace(detalle.CuentaContableCodigo))
        {
            ShowToast("Error", "No existe un detalle válido para actualizar.", ToastRenderStyle.Danger);
            return;
        }

        if (presupuestoAprobado)
        {
            ShowToast("Validación", "El presupuesto está aprobado y no permite editar el detalle.", ToastRenderStyle.Warning);
            return;
        }

        if (!presupuestoVigente)
        {
            ShowToast("Validación", GetMensajeBloqueoPorRango(), ToastRenderStyle.Warning);
            return;
        }

        if (form.ValorProyeccion > presupuestoHdr)
        {
            const string message = "El valor proyectado del detalle no puede ser mayor al presupuesto del encabezado.";
            ShowToast("Validación", message, ToastRenderStyle.Warning);
            return;
        }

        try
        {
            isSaving = true;

            var updated = await ConfiguracionPresupuestoClient.UpdateDetailAsync(
                detalle.IdPresupuesto,
                detalle.CuentaContableCodigo,
                new ConfiguracionPresupuestoDetalleUpdateDto
                {
                    ValorProyeccion = form.ValorProyeccion
                });

            detalle = updated;
            cuentaContableDisplay = FormatCuentaContableDisplay(updated.CuentaContable);
            form.ValorProyeccion = updated.ValorProyeccion;
            ShowToast("Éxito", "Detalle actualizado correctamente.", ToastRenderStyle.Success);
            Navigation.NavigateTo("/presupuesto/configuraciones");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al actualizar detalle de presupuesto {IdPresupuesto}/{CuentaContable}", detalle.IdPresupuesto, detalle.CuentaContableCodigo);
            ShowToast("Error", ex.Message, ToastRenderStyle.Danger);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void VolverALista() => Navigation.NavigateTo("/presupuesto/configuraciones");

    private string GetMensajeBloqueoPorRango()
    {
        if (fechaIniciaPresupuesto.HasValue && fechaFinalizaPresupuesto.HasValue)
        {
            return
                $"El presupuesto está fuera del rango de fechas ({fechaIniciaPresupuesto.Value:yyyy-MM-dd} al {fechaFinalizaPresupuesto.Value:yyyy-MM-dd}). Fecha actual: {currentServerDate:yyyy-MM-dd}.";
        }

        return "El presupuesto está fuera del rango de fechas vigente.";
    }

    private void ShowToast(string title, string message, ToastRenderStyle style)
    {
        ToastService.ShowToast(new ToastOptions
        {
            Title = title,
            Text = message,
            RenderStyle = style,
            ProviderName = "PresupuestoDetalleEditToast"
        });
    }

    private static string FormatCuentaContableDisplay(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        var parts = value.Split(" - ", 2, StringSplitOptions.TrimEntries);
        return parts.Length == 2
            ? AccountCodeFormatter.FormatDisplay(parts[0], parts[1])
            : AccountCodeFormatter.Format(value);
    }

    private static string ExtractCuentaDescripcion(string? cuentaDisplay, string? cuentaCodigo)
    {
        var display = cuentaDisplay?.Trim() ?? string.Empty;
        var code = cuentaCodigo?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(display))
        {
            return "-";
        }

        if (!string.IsNullOrWhiteSpace(code))
        {
            var prefix = $"{code} - ";
            if (display.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
            {
                var descripcion = display[prefix.Length..].Trim();
                return string.IsNullOrWhiteSpace(descripcion) ? "-" : descripcion;
            }

            if (string.Equals(display, code, StringComparison.OrdinalIgnoreCase))
            {
                return "-";
            }
        }

        var separatorIndex = display.IndexOf(" - ", StringComparison.Ordinal);
        if (separatorIndex >= 0 && separatorIndex + 3 < display.Length)
        {
            var descripcion = display[(separatorIndex + 3)..].Trim();
            return string.IsNullOrWhiteSpace(descripcion) ? "-" : descripcion;
        }

        return "-";
    }

    private sealed class DetalleEditForm
    {
        [Range(typeof(decimal), "0", "99999999999999.9999", ErrorMessage = "El valor de proyección no es válido.")]
        public decimal ValorProyeccion { get; set; }
    }
}
