@page "/presupuesto/configuraciones/nuevo"
@page "/presupuesto/configuraciones/{IdPresupuesto}/editar"
@page "/presupuesto/configuraciones/{IdPresupuesto}/{CuentaContable}/editar"
@attribute [Authorize(Policy = AuthorizationPolicies.Contabilidad)]

@using DevExpress.Blazor
@using SIAD.Core.DTOs.Presupuesto
@using apc.Client.Services.Presupuesto

@inject ConfiguracionPresupuestoClient ConfiguracionPresupuestoClient
@inject NavigationManager Navigation
@inject IToastNotificationService ToastService
@inject ILogger<PresupuestoConfiguracionEdit> Logger

<PageTitle>SIAD - Configuración de Presupuesto</PageTitle>

<div class="page-container">
    <DxToastProvider Name="PresupuestoEditToast" MaxToastCount="4" />

    <div class="header-section">
        <div>
            <h2 class="page-title">@TituloPagina</h2>
            <p class="page-subtitle">@SubtituloPagina</p>
        </div>
        <DxButton Text="Volver"
                  Click="Volver"
                  IconCssClass="bi bi-arrow-left"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  CssClass="btn-modern" />
    </div>

    <div class="modern-card mb-3">
        <div class="context-grid">
            <div class="context-item">
                <div class="context-label">ID Presupuesto</div>
                <div class="context-value">@IdPresupuestoDisplay</div>
            </div>
            <div class="context-item">
                <div class="context-label">Aprobación</div>
                <div class="context-value">@AprobacionDisplay</div>
            </div>
        </div>
    </div>

    <div class="modern-card">
        <h5 class="mb-3">@TituloSeccion</h5>
        @if (isLoading)
        {
            <div class="small text-muted mb-3">Cargando datos...</div>
        }
        else if (isGeneratingId)
        {
            <div class="small text-muted mb-3">Generando ID de presupuesto...</div>
        }

        <PresupuestoConfiguracionForm Model="model"
                                      IsCreateMode="@(!IsEdit)"
                                      MinFechaInicia="@fechaServidorActual"
                                      OnValidSubmit="GuardarAsync"
                                      OnCancel="Volver"
                                      IsBusy="@(isSaving || isLoading || isGeneratingId)" />
    </div>
</div>

@code {
    [Parameter]
    public string? IdPresupuesto { get; set; }

    [Parameter]
    public string? CuentaContable { get; set; }

    private ConfiguracionPresupuestoEditDto model = CrearModeloNuevo(DateOnly.FromDateTime(DateTime.Today));
    private DateOnly fechaServidorActual = DateOnly.FromDateTime(DateTime.Today);
    private bool isLoading = true;
    private bool isSaving;
    private bool isGeneratingId;

    private bool IsEdit => !string.IsNullOrWhiteSpace(IdPresupuesto);

    private string SubtituloPagina => IsEdit
        ? "Actualice la información de la configuración de presupuesto."
        : "Registre una nueva configuración de presupuesto.";

    private string TituloSeccion => IsEdit
        ? "Actualización de configuración"
        : "Nueva configuración";

    private string IdPresupuestoDisplay => string.IsNullOrWhiteSpace(model.IdPresupuesto)
        ? "-"
        : model.IdPresupuesto.Trim();

    private string AprobacionDisplay => GetAprobacionDisplay(model.EstadoAprobado);

    private string TituloPagina
    {
        get
        {
            if (!IsEdit)
            {
                return "Nueva configuración de presupuesto";
            }

            return "Editar configuración de presupuesto";
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        isLoading = true;

        try
        {
            fechaServidorActual = await ObtenerFechaServidorActualAsync();

            if (!IsEdit)
            {
                model = CrearModeloNuevo(fechaServidorActual);
                await AsignarSiguienteIdAsync();
                return;
            }

            var id = IdPresupuesto!.Trim();
            var detail = await ConfiguracionPresupuestoClient.GetByIdAsync(id);

            if (detail is null)
            {
                ShowToast("Error", "No se encontró la configuración de presupuesto solicitada.", ToastRenderStyle.Danger);
                model = CrearModeloNuevo(fechaServidorActual);
                return;
            }

            model = detail;
        }
        catch (Exception ex)
        {
            ShowToast("Error", $"No se pudo cargar la configuración: {ex.Message}", ToastRenderStyle.Danger);
            Logger.LogError(ex, "Error al cargar configuración de presupuesto {IdPresupuesto}", IdPresupuesto);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task GuardarAsync()
    {
        try
        {
            isSaving = true;
            fechaServidorActual = await ObtenerFechaServidorActualAsync();

            if (model.ValorGlobal <= 0m)
            {
                const string message = "El presupuesto debe ser mayor a cero.";
                ShowToast("Error", message, ToastRenderStyle.Danger);
                return;
            }

            if (model.FechaInicia < fechaServidorActual)
            {
                var message = $"La fecha inicial debe ser igual o mayor que la fecha actual del servidor ({fechaServidorActual:yyyy-MM-dd}).";
                ShowToast("Error", message, ToastRenderStyle.Danger);
                return;
            }

            if (IsEdit)
            {
                await ConfiguracionPresupuestoClient.UpdateAsync(model.IdPresupuesto, model);
                ShowToast("Éxito", "Configuración actualizada correctamente.", ToastRenderStyle.Success);
            }
            else
            {
                if (string.IsNullOrWhiteSpace(model.IdPresupuesto))
                {
                    model.IdPresupuesto = await ConfiguracionPresupuestoClient.GetNextIdAsync();
                }

                await ConfiguracionPresupuestoClient.CreateAsync(model);
                ShowToast("Éxito", "Configuración registrada correctamente.", ToastRenderStyle.Success);
            }

            Navigation.NavigateTo("/presupuesto/configuraciones");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al guardar configuración de presupuesto {IdPresupuesto}", IdPresupuesto);
            ShowToast("Error", ex.Message, ToastRenderStyle.Danger);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void Volver() => Navigation.NavigateTo("/presupuesto/configuraciones");

    private static ConfiguracionPresupuestoEditDto CrearModeloNuevo(DateOnly fechaBase)
    {
        return new ConfiguracionPresupuestoEditDto
        {
            EstadoAprobado = false,
            ValorGlobal = 0m,
            RangoPeriodo = 12,
            FechaInicia = fechaBase,
            FechaFinaliza = fechaBase
        };
    }

    private async Task AsignarSiguienteIdAsync()
    {
        try
        {
            isGeneratingId = true;
            model.IdPresupuesto = await ConfiguracionPresupuestoClient.GetNextIdAsync();
        }
        catch (Exception ex)
        {
            model.IdPresupuesto = string.Empty;
            ShowToast("Error", $"No se pudo generar el ID de presupuesto: {ex.Message}", ToastRenderStyle.Danger);
            Logger.LogError(ex, "Error al generar ID de presupuesto.");
        }
        finally
        {
            isGeneratingId = false;
        }
    }

    private void ShowToast(string title, string message, ToastRenderStyle style)
    {
        ToastService.ShowToast(new ToastOptions
        {
            Title = title,
            Text = message,
            RenderStyle = style,
            ProviderName = "PresupuestoEditToast"
        });
    }

    private async Task<DateOnly> ObtenerFechaServidorActualAsync()
    {
        try
        {
            return await ConfiguracionPresupuestoClient.GetServerDateAsync();
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "No se pudo obtener la fecha actual del servidor para configuración de presupuesto.");
            return DateOnly.FromDateTime(DateTime.Today);
        }
    }

    private static string GetAprobacionDisplay(bool estadoAprobado) => estadoAprobado ? "APROBADO" : "PENDIENTE";
}
