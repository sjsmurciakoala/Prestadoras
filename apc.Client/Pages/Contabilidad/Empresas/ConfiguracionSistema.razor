    protected override async Task OnInitializedAsync()
    {
        editContext = new EditContext(modelo);
        await RecargarAsync();
    }

    private async Task RecargarAsync()
    {
        cargando = true;
        alerta = null;
        alertaEstilo = MessageBoxRenderStyle.Info;
        configuracionExiste = false;
        formatoCuentasSugerido = null;
        ResetBalancePreview();
        try
        {
            empresas = (await TenantCompaniesClient.ObtenerAsync())?.ToList() ?? new List<TenantCompanyDto>();
            empresaSeleccionadaId = empresaSeleccionadaId > 0 ? empresaSeleccionadaId : empresas.FirstOrDefault()?.CompanyId ?? 0;
            if (empresaSeleccionadaId > 0)
            {
                await CargarConfiguracionAsync(empresaSeleccionadaId);
            }
            else
            {
                modelo = CrearModeloPorDefecto();
                cuentasDisponibles = Array.Empty<CuentaContableLookupDto>();
                PrepararEditContext();
            }
        }
        catch (Exception ex)
        {
            alerta = $"No fue posible cargar la empresa o configuración: {ex.Message}";
            alertaEstilo = MessageBoxRenderStyle.Danger;
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private async Task CargarConfiguracionAsync(long companyId)
    {
        var dto = await ConfiguracionClient.ObtenerAsync(companyId);
        modelo = dto ?? CrearModeloPorDefecto();
        configuracionExiste = (modelo.EstadoSituacionFinanciera?.Seleccionadas ?? 0) > 0
            || (modelo.CuentasUtilidad?.Seleccionadas ?? 0) > 0
            || (modelo.LineasBalance?.Count ?? 0) > 0
            || (modelo.LineasResultado?.Count ?? 0) > 0
            || (modelo.Correlativos?.Count ?? 0) > 0;
        modelo.EstadoSituacionFinanciera ??= new EstadoSituacionFinancieraDto();
        modelo.LineasResultado ??= new List<LineaResultadoDto>();
        modelo.LineasBalance ??= new List<BalanceSheetLineDto>();
        foreach (var linea in modelo.LineasResultado)
        {
            if (linea.RowId == Guid.Empty)
            {
                linea.RowId = Guid.NewGuid();
            }
        }
        CalcularMeses();
        await CargarCuentasAsync(companyId);
        ActualizarFormatoSugerido();
        AplicarFormatoSugeridoSiConviene();
        SincronizarBalancePreviewDesdeModelo();
        PrepararEditContext();
    }

    private void PrepararEditContext()
    {
        editContext = new EditContext(modelo);
        editContext.OnFieldChanged += (_, args) =>
        {
            var fieldName = args.FieldIdentifier.FieldName;
            if (fieldName == nameof(ConfiguracionPrincipalDto.FechaInicioEjercicio) || fieldName == nameof(ConfiguracionPrincipalDto.FechaFinEjercicio))
            {
                CalcularMeses();
            }
            else if (fieldName == nameof(ConfiguracionPrincipalDto.SeparadorCodigo))
            {
                ActualizarFormatoSugerido();
            }
            alerta = null;
            StateHasChanged();
        };
    }

    private async Task GuardarAsync()
    {
        if (editContext is null)
        {
            return;
        }

        CalcularMeses();
        SincronizarModeloDesdeBalancePreview();

        var guardarSoloPrincipal = PuedeGuardarSoloConfiguracionPrincipal();
        if (guardarSoloPrincipal)
        {
            var erroresPrincipal = ValidarConfiguracionPrincipal();
            if (erroresPrincipal.Count > 0)
            {
                alerta = $"Errores de validación: {string.Join(", ", erroresPrincipal)}";
                alertaEstilo = MessageBoxRenderStyle.Danger;
                StateHasChanged();
                return;
            }
        }
        else if (!editContext.Validate())
        {
            var errores = editContext.GetValidationMessages().ToList();
            alerta = errores.Count > 0 ? $"Errores de validación: {string.Join(", ", errores)}" : "Hay datos incompletos o inválidos.";
            alertaEstilo = MessageBoxRenderStyle.Danger;
            StateHasChanged();
            return;
        }

        cargando = true;
        alerta = null;
        try
        {
            var dtoParaGuardar = guardarSoloPrincipal ? CrearDtoSoloPrincipal(modelo) : modelo;
            var resultado = await ConfiguracionClient.GuardarAsync(empresaSeleccionadaId, dtoParaGuardar);
            modelo = resultado;
            configuracionExiste = true;
            CalcularMeses();
            SincronizarBalancePreviewDesdeModelo();
            PrepararEditContext();
            await PrepararMensajeGuardadoAsync();
            popupGuardadoVisible = true;
        }
        catch (Exception ex)
        {
            alertaEstilo = MessageBoxRenderStyle.Danger;
            alerta = $"No fue posible guardar: {ex.Message}";
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

