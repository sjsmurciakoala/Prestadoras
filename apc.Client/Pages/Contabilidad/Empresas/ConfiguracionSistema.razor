    private void SincronizarModeloDesdeBalancePreview()
    {
        modelo.EstadoSituacionFinanciera ??= new EstadoSituacionFinancieraDto();

        string? BuscarCodigo(string key) =>
            balancePreviewData.FirstOrDefault(r => !r.EsTitulo && r.Key == key)?.Codigo?.Trim();

        modelo.EstadoSituacionFinanciera.CodigoActivoCortoPlazo1 = BuscarCodigo(BalanceRowKeys.ActivoCP1);
        modelo.EstadoSituacionFinanciera.CodigoActivoCortoPlazo2 = BuscarCodigo(BalanceRowKeys.ActivoCP2);
        modelo.EstadoSituacionFinanciera.CodigoActivoLargoPlazo1 = BuscarCodigo(BalanceRowKeys.ActivoLP1);
        modelo.EstadoSituacionFinanciera.CodigoActivoLargoPlazo2 = BuscarCodigo(BalanceRowKeys.ActivoLP2);
        modelo.EstadoSituacionFinanciera.CodigoPasivoCortoPlazo1 = BuscarCodigo(BalanceRowKeys.PasivoCP1);
        modelo.EstadoSituacionFinanciera.CodigoPasivoCortoPlazo2 = BuscarCodigo(BalanceRowKeys.PasivoCP2);
        modelo.EstadoSituacionFinanciera.CodigoPasivoLargoPlazo1 = BuscarCodigo(BalanceRowKeys.PasivoLP1);
        modelo.EstadoSituacionFinanciera.CodigoPasivoLargoPlazo2 = BuscarCodigo(BalanceRowKeys.PasivoLP2);
        modelo.EstadoSituacionFinanciera.CodigoPasivoyCapital = BuscarCodigo(BalanceRowKeys.PasivoCapital);
        modelo.EstadoSituacionFinanciera.CodigoCapitalAportado = BuscarCodigo(BalanceRowKeys.CapitalAportado);
        modelo.EstadoSituacionFinanciera.CodigoResultadosAcumulados = BuscarCodigo(BalanceRowKeys.ResultadosAcumulados);
        modelo.EstadoSituacionFinanciera.CodigoUtilidadPerdidaEjercicio = BuscarCodigo(BalanceRowKeys.UtilidadPerdidaEjercicio);
        modelo.EstadoSituacionFinanciera.CodigoSobrevaluaciones = BuscarCodigo(BalanceRowKeys.Sobrevaluaciones);
        modelo.EstadoSituacionFinanciera.MostrarOrden = !string.IsNullOrWhiteSpace(BuscarCodigo(BalanceRowKeys.Orden));
        modelo.EstadoSituacionFinanciera.MostrarPercontra = !string.IsNullOrWhiteSpace(BuscarCodigo(BalanceRowKeys.Percontra));

        var lineas = balancePreviewData
            .Where(r => !r.EsTitulo && !string.IsNullOrWhiteSpace(r.Codigo))
            .Select(r =>
            {
                var descripcion = r.Descripcion?.Trim();
                if (string.IsNullOrWhiteSpace(descripcion))
                {
                    descripcion = cuentasDisponibles.FirstOrDefault(c => c.Code == r.Codigo)?.Description ?? string.Empty;
                }

                return new BalanceSheetLineDto
                {
                    RowId = Guid.NewGuid(),
                    Clase = r.Clase,
                    CodigoCuenta = r.Codigo?.Trim(),
                    Descripcion = descripcion ?? string.Empty,
                    MostrarEnReporte = true
                };
            })
            .ToList();

        modelo.LineasBalance = lineas;
    }

    private void SincronizarBalancePreviewDesdeModelo()
    {
        ResetBalancePreview();

        if (modelo.LineasBalance is { Count: > 0 })
        {
            var grupos = modelo.LineasBalance
                .GroupBy(l => l.Clase)
                .ToDictionary(g => g.Key, g => g.ToList());

            var indices = new Dictionary<byte, int>();

            foreach (var row in balancePreviewData.Where(r => !r.EsTitulo))
            {
                if (!grupos.TryGetValue(row.Clase, out var lineas))
                {
                    continue;
                }

                if (!indices.TryGetValue(row.Clase, out var idx))
                {
                    idx = 0;
                }

                if (idx >= lineas.Count)
                {
                    indices[row.Clase] = idx;
                    continue;
                }

                var linea = lineas[idx];
                row.Codigo = linea.CodigoCuenta ?? string.Empty;
                row.Descripcion = linea.Descripcion ?? string.Empty;
                indices[row.Clase] = idx + 1;
            }

            return;
        }

        AsignarCodigoPreview(BalanceRowKeys.ActivoCP1, modelo.EstadoSituacionFinanciera.CodigoActivoCortoPlazo1);
        AsignarCodigoPreview(BalanceRowKeys.ActivoCP2, modelo.EstadoSituacionFinanciera.CodigoActivoCortoPlazo2);
        AsignarCodigoPreview(BalanceRowKeys.ActivoLP1, modelo.EstadoSituacionFinanciera.CodigoActivoLargoPlazo1);
        AsignarCodigoPreview(BalanceRowKeys.ActivoLP2, modelo.EstadoSituacionFinanciera.CodigoActivoLargoPlazo2);
        AsignarCodigoPreview(BalanceRowKeys.PasivoCP1, modelo.EstadoSituacionFinanciera.CodigoPasivoCortoPlazo1);
        AsignarCodigoPreview(BalanceRowKeys.PasivoCP2, modelo.EstadoSituacionFinanciera.CodigoPasivoCortoPlazo2);
        AsignarCodigoPreview(BalanceRowKeys.PasivoLP1, modelo.EstadoSituacionFinanciera.CodigoPasivoLargoPlazo1);
        AsignarCodigoPreview(BalanceRowKeys.PasivoLP2, modelo.EstadoSituacionFinanciera.CodigoPasivoLargoPlazo2);
        AsignarCodigoPreview(BalanceRowKeys.PasivoCapital, modelo.EstadoSituacionFinanciera.CodigoPasivoyCapital);
        AsignarCodigoPreview(BalanceRowKeys.CapitalAportado, modelo.EstadoSituacionFinanciera.CodigoCapitalAportado);
        AsignarCodigoPreview(BalanceRowKeys.ResultadosAcumulados, modelo.EstadoSituacionFinanciera.CodigoResultadosAcumulados);
        AsignarCodigoPreview(BalanceRowKeys.UtilidadPerdidaEjercicio, modelo.EstadoSituacionFinanciera.CodigoUtilidadPerdidaEjercicio);
        AsignarCodigoPreview(BalanceRowKeys.Sobrevaluaciones, modelo.EstadoSituacionFinanciera.CodigoSobrevaluaciones);
    }

    private void AsignarCodigoPreview(string key, string? codigo)
    {
        var row = balancePreviewData.FirstOrDefault(r => !r.EsTitulo && r.Key == key);
        if (row is null)
        {
            return;
        }
        row.Codigo = codigo?.Trim() ?? string.Empty;
        if (!string.IsNullOrWhiteSpace(row.Codigo))
        {
            var cuenta = cuentasDisponibles.FirstOrDefault(c => c.Code == row.Codigo);
            row.Descripcion = cuenta?.Description ?? row.Descripcion;
        }
    }

    private void OnCuentaSeleccionada(BalancePreviewRow? row, string? codigo)
    {
        if (row is null || row.EsTitulo)
        {
            return;
        }
        row.Codigo = codigo ?? string.Empty;
        if (string.IsNullOrWhiteSpace(row.Descripcion))
        {
            var cuenta = cuentasDisponibles?.FirstOrDefault(c => c.Code == codigo);
            row.Descripcion = cuenta?.Description ?? string.Empty;
        }
        InvokeAsync(StateHasChanged);
    }

    private static class BalanceRowKeys
    {
        public const string ActivoCP1 = "ActivoCP1";
        public const string ActivoCP2 = "ActivoCP2";
        public const string ActivoLP1 = "ActivoLP1";
        public const string ActivoLP2 = "ActivoLP2";
        public const string PasivoCP1 = "PasivoCP1";
        public const string PasivoCP2 = "PasivoCP2";
        public const string PasivoLP1 = "PasivoLP1";
        public const string PasivoLP2 = "PasivoLP2";
        public const string PasivoCapital = "PasivoCapital";
        public const string CapitalAportado = "CapitalAportado";
        public const string ResultadosAcumulados = "ResultadosAcumulados";
        public const string UtilidadPerdidaEjercicio = "UtilidadPerdidaEjercicio";
        public const string Sobrevaluaciones = "Sobrevaluaciones";
        public const string Orden = "Orden";
        public const string Percontra = "Percontra";
    }

    private sealed class BalancePreviewRow
    {
        public string Categoria { get; set; } = string.Empty;
        public string Cuenta { get; set; } = string.Empty;
        public string Key { get; set; } = string.Empty;
        public byte Clase { get; set; }
        public string Codigo { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
        public bool EsTitulo { get; set; }
    }

    // Métodos originales para manejar el orden y previsualización del balance se mantienen sin cambios
    // Para eliminar una línea de resultado se utiliza el método de la columna personalizada
    private void EliminarLineaResultado(Guid rowId)
    {
        var existente = modelo.LineasResultado.FirstOrDefault(e => e.RowId == rowId);
        if (existente is not null)
        {
            modelo.LineasResultado.Remove(existente);
        }
    }
