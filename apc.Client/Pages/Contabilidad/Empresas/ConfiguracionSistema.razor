    private static List<BalancePreviewRow> CrearBalancePreview()
    {
        var lista = new List<BalancePreviewRow>();

        void AgregarSeccion(string categoria, int filasDetalle)
        {
            lista.Add(new BalancePreviewRow
            {
                Categoria = categoria,
                Cuenta = categoria.ToUpperInvariant(),
                Codigo = string.Empty,
                Descripcion = string.Empty,
                EsTitulo = true
            });

            for (var i = 0; i < filasDetalle; i++)
            {
                lista.Add(new BalancePreviewRow
                {
                    Categoria = categoria,
                    Cuenta = string.Empty,
                    Codigo = string.Empty,
                    Descripcion = string.Empty,
                    EsTitulo = false
                });
            }
        }

        // Activos, Pasivos, Capital: 1 fila título + 3 filas detalle
        AgregarSeccion("Activos", 3);
        AgregarSeccion("Pasivos", 3);
        AgregarSeccion("Capital", 3);

        // Pasivo y Capital: solo fila título (manual)
        lista.Add(new BalancePreviewRow
        {
            Categoria = "Pasivo y Capital",
            Cuenta = "PASIVO Y CAPITAL",
            Codigo = string.Empty,
            Descripcion = string.Empty,
            EsTitulo = true
        });

        // Orden: fila título + dos filas (Orden, Percontra) con código y descripción de la cuenta
        lista.Add(new BalancePreviewRow
        {
            Categoria = "Orden",
            Cuenta = "ORDEN",
            Codigo = string.Empty,
            Descripcion = string.Empty,
            EsTitulo = true
        });

        lista.Add(new BalancePreviewRow
        {
            Categoria = "Orden",
            Cuenta = "ORDEN",
            Codigo = string.Empty,
            Descripcion = string.Empty,
            EsTitulo = false
        });

        lista.Add(new BalancePreviewRow
        {
            Categoria = "Orden",
            Cuenta = "PERCONTRA",
            Codigo = string.Empty,
            Descripcion = string.Empty,
            EsTitulo = false
        });

        return lista;
    }

    private void ResetBalancePreview()
    {
        balancePreviewData = CrearBalancePreview();
    }

    private void OnCuentaSeleccionada(BalancePreviewRow? row, string? codigo)
    {
        if (row is null || row.EsTitulo)
        {
            return;
        }

        row.Codigo = codigo ?? string.Empty;
        if (row.Categoria.Equals("Orden", StringComparison.OrdinalIgnoreCase))
        {
            var cuenta = cuentasDisponibles?.FirstOrDefault(c => c.Code == codigo);
            row.Descripcion = cuenta?.Description ?? string.Empty;
        }
        InvokeAsync(StateHasChanged);
    }

    private sealed class BalancePreviewRow
    {
        public string Categoria { get; set; } = string.Empty;
        public string Cuenta { get; set; } = string.Empty;
        public string Codigo { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
        public bool EsTitulo { get; set; }
    }
