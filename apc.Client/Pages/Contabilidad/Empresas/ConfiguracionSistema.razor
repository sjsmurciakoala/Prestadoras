    private List<string> ValidarConfiguracionPrincipal()
    {
        var resultados = new List<ValidationResult>();
        var contexto = new ValidationContext(modelo.Principal);

        Validator.TryValidateObject(modelo.Principal, contexto, resultados, validateAllProperties: true);

        return resultados
            .Select(r => r.ErrorMessage)
            .Where(m => !string.IsNullOrWhiteSpace(m))
            .Cast<string>()
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();
    }

