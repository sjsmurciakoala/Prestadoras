    private async Task PrepararMensajeGuardadoAsync()
    {
        popupGuardadoMensaje = "La configuración se guardó correctamente.";

        if (empresaSeleccionadaId <= 0)
        {
            return;
        }

        var periodoActivo = await PeriodosClient.ObtenerPeriodoActivoAsync(empresaSeleccionadaId);
        if (periodoActivo is null)
        {
            popupGuardadoMensaje = "La configuración se guardó correctamente. No fue posible confirmar el período abierto desde esta pantalla.";
            return;
        }

        var fechaInicioLocal = ConvertirFechaPeriodoALocal(periodoActivo.StartDate);
        var fechaFinLocal = ConvertirFechaPeriodoALocal(periodoActivo.EndDate);
        popupGuardadoMensaje =
            $"La configuración se guardó correctamente. El período abierto es {periodoActivo.Code} ({fechaInicioLocal:dd/MM/yyyy} - {fechaFinLocal:dd/MM/yyyy}).";
    }

    private static DateTime ConvertirFechaPeriodoALocal(DateTime value)
    {
        return value.Kind switch
        {
            DateTimeKind.Utc => value.ToLocalTime(),
            DateTimeKind.Unspecified => DateTime.SpecifyKind(value, DateTimeKind.Utc).ToLocalTime(),
            _ => value
        };
    }

    private static string NormalizeCodigo(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value.Where(char.IsLetterOrDigit).ToArray());
    }

    private static string? InferirFormatoCuentas(IEnumerable<string> codigos, string? separadorPreferido)
    {
        var lista = codigos.Where(c => !string.IsNullOrWhiteSpace(c)).ToList();
        if (lista.Count == 0)
        {
            return null;
        }

        var separador = NormalizarSeparador(separadorPreferido) ?? ObtenerSeparadorMasComun(lista);
        var patrones = ObtenerPatronesSegmentos(lista);
        if (patrones.Count > 0)
        {
            var mejor = patrones.OrderByDescending(p => p.Value).First().Key;
            var segmentos = mejor.Split('|').Select(int.Parse).ToList();
            return ConstruirMascara(segmentos, separador ?? "-");
        }

        var segmentosPorCeros = ObtenerSegmentosPorRecorteCeros(lista);
        if (segmentosPorCeros.Count > 0)
        {
            return ConstruirMascara(segmentosPorCeros, separador ?? "-");
        }

        var longitudes = lista
            .Select(NormalizeCodigo)
            .Where(c => c.Length > 0)
            .Select(c => c.Length)
            .Distinct()
            .OrderBy(n => n)
            .ToList();

        if (longitudes.Count == 0)
        {
            return null;
        }

        var segmentosFallback = new List<int>();
        var prev = 0;
        foreach (var len in longitudes)
        {
            var delta = len - prev;
            if (delta <= 0)
            {
                continue;
            }
            segmentosFallback.Add(delta);
            prev = len;
        }

        if (segmentosFallback.Count == 0)
        {
            return null;
        }

        return ConstruirMascara(segmentosFallback, separador ?? "-");
    }

    private static IReadOnlyList<int> ObtenerSegmentosPorRecorteCeros(IEnumerable<string> codigos)
    {
        var normalizados = codigos
            .Select(NormalizeCodigo)
            .Where(c => c.Length > 0 && c.All(char.IsDigit))
            .ToList();

        if (normalizados.Count == 0)
        {
            return Array.Empty<int>();
        }

        var longitudes = normalizados
            .GroupBy(c => c.Length)
            .Select(g => new { Length = g.Key, Count = g.Count() })
            .OrderByDescending(g => g.Count)
            .ThenByDescending(g => g.Length)
            .ToList();

        var dominante = longitudes.FirstOrDefault();
        if (dominante is null || dominante.Count < 2)
        {
            return Array.Empty<int>();
        }

        var candidatos = normalizados
            .Where(c => c.Length == dominante.Length)
            .ToList();

        var acumulados = candidatos
            .Select(c =>
            {
                var trimmed = c.TrimEnd('0');
                return trimmed.Length == 0 ? 1 : trimmed.Length;
            })
            .Distinct()
            .OrderBy(n => n)
            .ToList();

        if (acumulados.Count <= 1 || acumulados[^1] != dominante.Length)
        {
            return Array.Empty<int>();
        }

        var segmentos = new List<int>();
        var previo = 0;
        foreach (var acumulado in acumulados)
        {
            var delta = acumulado - previo;
            if (delta <= 0)
            {
                continue;
            }

            segmentos.Add(delta);
            previo = acumulado;
        }

        return segmentos;
    }

    private static string? ObtenerSeparadorMasComun(IEnumerable<string> codigos)
    {
        var counts = new Dictionary<char, int>();
        foreach (var code in codigos)
        {
            foreach (var ch in code)
            {
                if (EsSeparadorPermitido(ch))
                {
                    counts[ch] = counts.TryGetValue(ch, out var value) ? value + 1 : 1;
                }
            }
        }

        if (counts.Count == 0)
        {
            return null;
        }

        return counts.OrderByDescending(kvp => kvp.Value).First().Key.ToString();
    }

    private static Dictionary<string, int> ObtenerPatronesSegmentos(IEnumerable<string> codigos)
    {
        var patrones = new Dictionary<string, int>();
        foreach (var code in codigos)
        {
            var segmentos = new List<int>();
            var actual = 0;
            foreach (var ch in code)
            {
                if (char.IsLetterOrDigit(ch))
                {
                    actual++;
                }
                else
                {
                    if (actual > 0)
                    {
                        segmentos.Add(actual);
                        actual = 0;
                    }
                }
            }
            if (actual > 0)
            {
                segmentos.Add(actual);
            }

            if (segmentos.Count < 2)
            {
                continue;
            }

            var key = string.Join("|", segmentos);
            patrones[key] = patrones.TryGetValue(key, out var count) ? count + 1 : 1;
        }

        return patrones;
    }

    private static string? NormalizarSeparador(string? separador)
    {
        if (string.IsNullOrWhiteSpace(separador))
        {
            return null;
        }

        var ch = separador.Trim()[0];
        return EsSeparadorPermitido(ch) ? ch.ToString() : null;
    }

    private static bool EsSeparadorPermitido(char ch)
    {
        return ch == '.' || ch == '-' || ch == '/';
    }

    private static string ConstruirMascara(IEnumerable<int> segmentos, string separador)
    {
        var sep = string.IsNullOrWhiteSpace(separador) ? "-" : separador;
        return string.Join(sep, segmentos.Select(len => new string('#', len)));
    }

