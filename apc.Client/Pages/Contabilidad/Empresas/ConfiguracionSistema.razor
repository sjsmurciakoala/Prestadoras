        catch (Exception ex)
        {
            alerta = $"No fue posible cambiar de empresa: {ex.Message}";
            alertaEstilo = MessageBoxRenderStyle.Danger;
        }
        finally
        {
            cargando = false;
            StateHasChanged();
        }
    }

    private void CalcularMeses()
    {
        if (modelo.Principal.FechaInicioEjercicio.HasValue && modelo.Principal.FechaFinEjercicio.HasValue)
        {
            var inicio = modelo.Principal.FechaInicioEjercicio.Value;
            var fin = modelo.Principal.FechaFinEjercicio.Value;
            if (fin < inicio)
            {
                modelo.Principal.MesesCalculados = 0;
                return;
            }
            var meses = (fin.Year - inicio.Year) * 12 + (fin.Month - inicio.Month);
            if (fin.Day < inicio.Day)
            {
                meses--;
            }
            modelo.Principal.MesesCalculados = Math.Max(1, meses + 1);
        }
        else
        {
            modelo.Principal.MesesCalculados = 0;
        }
    }

    private async Task CargarCuentasAsync(long companyId)
    {
        if (companyId <= 0)
        {
            cuentasDisponibles = Array.Empty<CuentaContableLookupDto>();
            return;
        }
        cuentasDisponibles = await ConfiguracionClient.ListarCuentasAsync(companyId);
    }

