    private void EliminarLineaResultado(Guid rowId)
    {
        var existente = modelo.LineasResultado.FirstOrDefault(e => e.RowId == rowId);
        if (existente is not null)
        {
            modelo.LineasResultado.Remove(existente);
        }
    }

