    private void OnCodigoResultadoChanged(LineaResultadoDto linea, string? codigoCuenta)
    {
        if (linea is null)
        {
            return;
        }

        var descripcionAnterior = ObtenerDescripcionCuenta(linea.CodigoCuenta);
        linea.CodigoCuenta = codigoCuenta;

        if (string.IsNullOrWhiteSpace(linea.Descripcion) ||
            string.Equals(linea.Descripcion, descripcionAnterior, StringComparison.OrdinalIgnoreCase))
        {
            linea.Descripcion = ObtenerDescripcionCuenta(codigoCuenta) ?? string.Empty;
        }
    }

    private string? ObtenerDescripcionCuenta(string? codigoCuenta)
    {
        return cuentasDisponibles.FirstOrDefault(c => string.Equals(c.Code, codigoCuenta, StringComparison.OrdinalIgnoreCase))?.Description;
    }

