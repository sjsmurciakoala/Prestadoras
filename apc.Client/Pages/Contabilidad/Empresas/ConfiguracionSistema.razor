@page "/contabilidad/empresas/configuracion"
@attribute [Authorize(Policy = PermissionNames.Contabilidad.View)]

@using DevExpress.Blazor
@using System.ComponentModel.DataAnnotations
@using Microsoft.Extensions.Configuration
@using Microsoft.AspNetCore.Components.Forms
@using apc.Client.Services.Contabilidad
@using apc.Client.Services.Tenant
@using SIAD.Core.Constants
@using SIAD.Core.DTOs.Contabilidad
@using SIAD.Core.DTOs.Tenant
@inject ConfiguracionSistemaClient ConfiguracionClient
@inject PeriodosContablesClient PeriodosClient
@inject TenantCompaniesClient TenantCompaniesClient
@inject IConfiguration Configuration

<PageTitle>SIAD - Configuración del Sistema Contable</PageTitle>

<div id="configuracion-sistema-superficie" class="configuracion-modern-page contabilidad-page contabilidad-content h-100">
    <DxCard CssClass="shadow-sm border-0 rounded w-100 h-100">
        <HeaderContent>
            <div class="d-flex flex-wrap justify-content-between align-items-center p-3">
                <div class="d-flex align-items-center gap-3">
                    <div class="icon-circle bg-primary text-white d-flex align-items-center justify-content-center">
                        <i class="bi bi-gear-fill fs-4"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold text-secondary">Configuración del sistema contable</h5>
                        <small class="text-muted">Define parámetros base para la empresa seleccionada.</small>
                    </div>
                </div>
            </div>
        </HeaderContent>

        <ChildContent>
            <div class="p-4 configuracion-loading-target">
                @if (!string.IsNullOrWhiteSpace(alerta))
                {
                    @if (alertaEstilo == MessageBoxRenderStyle.Danger)
                    {
                        <DxAlert AlertType="AlertType.Danger" CssClass="mb-3">@alerta</DxAlert>
                    }
                    else if (alertaEstilo == MessageBoxRenderStyle.Warning)
                    {
                        <DxAlert AlertType="AlertType.Warning" CssClass="mb-3">@alerta</DxAlert>
                    }
                    else if (alertaEstilo == MessageBoxRenderStyle.Success)
                    {
                        <DxAlert AlertType="AlertType.Success" CssClass="mb-3">@alerta</DxAlert>
                    }
                    else
                    {
                        <DxAlert AlertType="AlertType.Info" CssClass="mb-3">@alerta</DxAlert>
                    }
                }
                @if (MostrarAvisoSinConfiguracion)
                {
                    <DxAlert AlertType="AlertType.Info" CssClass="mb-3">
                        Esta empresa aún no tiene configuración del sistema contable. Complete el formulario a continuación para configurarla.
                    </DxAlert>
                }
                @if (MostrarAvisoSinPlanCuentas)
                {
                    <DxAlert AlertType="AlertType.Warning" CssClass="mb-3">
                        No existe un plan de cuentas cargado para esta empresa. Por ahora solo se validará y guardará la pestaña de configuración principal.
                    </DxAlert>
                }

                <div class="mb-4">
                    <DxToolbar ItemSpacing="12px" CssClass="toolbar-empresa">
                        <DxToolbarItem>
                            <Template>
                                <DxComboBox Data="@empresas"
                                            TData="TenantCompanyDto"
                                            TValue="long"
                                            Value="@empresaSeleccionadaId"
                                            ValueChanged="@OnEmpresaChangedAsync"
                                            ValueExpression="@(() => empresaSeleccionadaId)"
                                            ValueFieldName="@nameof(TenantCompanyDto.CompanyId)"
                                            TextFieldName="@nameof(TenantCompanyDto.Name)"
                                            NullText="Seleccione empresa"
                                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                            SearchMode="ListSearchMode.AutoSearch"
                                            SearchFilterCondition="ListSearchFilterCondition.Contains"
                                            Enabled="@(!cargando && empresas.Count > 0)"
                                            Width="260px">
                                    <ItemTemplate Context="e">
                                        <div class="d-flex flex-column">
                                            <span class="fw-semibold">@e.Code - @e.Name</span>
                                            <small class="text-muted">ID: @e.CompanyId</small>
                                        </div>
                                    </ItemTemplate>
                                </DxComboBox>
                            </Template>
                        </DxToolbarItem>
                        <DxToolbarItem IconCssClass="bi bi-arrow-clockwise"
                                       Text="Recargar"
                                       RenderStyle="ButtonRenderStyle.Secondary"
                                       Enabled="@(!cargando)"
                                       Click="@RecargarAsync" />
                    </DxToolbar>
                </div>

                @if (editContext != null)
                {
                    <EditForm EditContext="@editContext" Context="editCtx">
                        <DataAnnotationsValidator />
                        <DxTabs CssClass="modern-tabs"
                                @bind-ActiveTabIndex="activeTabIndex"
                                RenderMode="TabsRenderMode.OnDemand">
                            <DxTabPage Text="Configuración principal" CssClass="p-3">
                                <DxFormLayout ColumnCountMd="12"
                                              ColumnCountSm="1"
                                              CaptionPosition="CaptionPosition.Vertical"
                                              RequiredMarkDisplayMode="DataAnnotations"
                                              ReadOnly="@cargando">
                                    <DxFormLayoutGroup Caption="Fechas de ejercicio" ColSpanMd="12" CssClass="mb-3">
                                        <DxFormLayoutItem Caption="Inicio del ejercicio *" ColSpanMd="6" ColSpanSm="12">
                                            <DxDateEdit T="DateTime?" @bind-Date="modelo.Principal.FechaInicioEjercicio" />
                                            <ValidationMessage For="@(() => modelo.Principal.FechaInicioEjercicio)" />
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Fin del ejercicio *" ColSpanMd="6" ColSpanSm="12">
                                            <DxDateEdit T="DateTime?" @bind-Date="modelo.Principal.FechaFinEjercicio" />
                                            <ValidationMessage For="@(() => modelo.Principal.FechaFinEjercicio)" />
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Meses del ejercicio" ColSpanMd="6" ColSpanSm="12">
                                            <DxSpinEdit TValue="int" @bind-Value="modelo.Principal.MesesCalculados" ReadOnly="true" Min="0" Max="36" />
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Última depreciación" ColSpanMd="6" ColSpanSm="12">
                                            <DxDateEdit T="DateTime?" @bind-Date="modelo.Principal.UltimaDepreciacion" DisplayFormatString="g" />
                                        </DxFormLayoutItem>
                                    </DxFormLayoutGroup>
                                    <DxFormLayoutGroup Caption="Formatos y separadores" ColSpanMd="12" CssClass="mb-3">
                                        <DxFormLayoutItem Caption="Separador del código" ColSpanMd="6" ColSpanSm="12">
                                            <DxComboBox Data="@separadores" TData="string" TValue="string"
                                                        NullText="Selecciona" @bind-Value="modelo.Principal.SeparadorCodigo" />
                                            <ValidationMessage For="@(() => modelo.Principal.SeparadorCodigo)" />
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Formato del código" ColSpanMd="6" ColSpanSm="12">
                                            <DxTextBox @bind-Text="modelo.Principal.FormatoCuentas" NullText="###-###-##" />
                                            <ValidationMessage For="@(() => modelo.Principal.FormatoCuentas)" />
                                            @if (MostrarSugerenciaFormato)
                                            {
                                                <div class="small text-muted mt-1">
                                                    Sugerido: @formatoCuentasSugerido
                                                    <button type="button" class="btn btn-link btn-sm p-0 ms-2" @onclick="AplicarFormatoSugerido">Usar sugerido</button>
                                                </div>
                                            }
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Formato de centros" ColSpanMd="6" ColSpanSm="12">
                                            <DxTextBox @bind-Text="modelo.Principal.FormatoCentros" NullText="###-##" />
                                            <ValidationMessage For="@(() => modelo.Principal.FormatoCentros)" />
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Símbolo saldo acreedor" ColSpanMd="6" ColSpanSm="12">
                                            <DxComboBox Data="@simbolosUi" TData="string" TValue="string"
                                                        NullText="Selecciona"
                                                        Value="@ObtenerSimboloSaldoAcreedorUi(modelo.Principal.SymbolSaldoAcreedor)"
                                                        ValueChanged="@OnSimboloSaldoAcreedorChanged"
                                                        ValueExpression="@(() => modelo.Principal.SymbolSaldoAcreedor)" />
                                            <ValidationMessage For="@(() => modelo.Principal.SymbolSaldoAcreedor)" />
                                        </DxFormLayoutItem>
                                    </DxFormLayoutGroup>
                                    <DxFormLayoutGroup Caption="Montos y depreciación" ColSpanMd="12">
                                        <DxFormLayoutItem Caption="Monto máximo débito/crédito" ColSpanMd="6" ColSpanSm="12">
                                            <DxSpinEdit TValue="decimal?" @bind-Value="modelo.Principal.MontoMaximo"
                                                        Min="0" Max="99999999999m" Increment="1000m" DisplayFormatString="N2" />
                                            <ValidationMessage For="@(() => modelo.Principal.MontoMaximo)" />
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Frecuencia de depreciación" ColSpanMd="6" ColSpanSm="12">
                                            <DxComboBox Data="@frecuencias" TData="string" TValue="string"
                                                        NullText="Selecciona" @bind-Value="modelo.Principal.FrecuenciaDepreciacion" />
                                            <ValidationMessage For="@(() => modelo.Principal.FrecuenciaDepreciacion)" />
                                        </DxFormLayoutItem>
                                    </DxFormLayoutGroup>
                                </DxFormLayout>
                            </DxTabPage>
                            <DxTabPage Text="Cuentas de utilidad" CssClass="p-3">
                                <DxFormLayout ColumnCountMd="12" ColumnCountSm="1" CaptionPosition="CaptionPosition.Vertical" ReadOnly="@cargando">
                                    <DxFormLayoutGroup Caption="Históricas" ColSpanMd="12" CssClass="mb-3">
                                        <DxFormLayoutItem Caption="Utilidad acumulada" ColSpanMd="6" ColSpanSm="12">
                                            <DxComboBox Data="@cuentasDisponibles" TData="CuentaContableLookupDto" TValue="string"
                                                        ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                                                        TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                                                        @bind-Value="modelo.CuentasUtilidad.CodigoCuentaUtilAcumuladaHistorica"
                                                        NullText="Seleccione cuenta"
                                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                        DropDownWidth="420px"
                                                        SearchMode="ListSearchMode.AutoSearch"
                                                        SearchFilterCondition="ListSearchFilterCondition.Contains" />
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Pérdida acumulada" ColSpanMd="6" ColSpanSm="12">
                                            <DxComboBox Data="@cuentasDisponibles" TData="CuentaContableLookupDto" TValue="string"
                                                        ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                                                        TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                                                        @bind-Value="modelo.CuentasUtilidad.CodigoCuentaPerdidaAcumuladaHistorica"
                                                        NullText="Seleccione cuenta"
                                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                        DropDownWidth="420px"
                                                        SearchMode="ListSearchMode.AutoSearch"
                                                        SearchFilterCondition="ListSearchFilterCondition.Contains" />
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Utilidad del ejercicio" ColSpanMd="6" ColSpanSm="12">
                                            <DxComboBox Data="@cuentasDisponibles" TData="CuentaContableLookupDto" TValue="string"
                                                        ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                                                        TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                                                        @bind-Value="modelo.CuentasUtilidad.CodigoCuentaUtilEjercicioHistorica"
                                                        NullText="Seleccione cuenta"
                                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                        DropDownWidth="420px"
                                                        SearchMode="ListSearchMode.AutoSearch"
                                                        SearchFilterCondition="ListSearchFilterCondition.Contains" />
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Pérdidas del ejercicio" ColSpanMd="6" ColSpanSm="12">
                                            <DxComboBox Data="@cuentasDisponibles" TData="CuentaContableLookupDto" TValue="string"
                                                        ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                                                        TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                                                        @bind-Value="modelo.CuentasUtilidad.CodigoCuentaPerdidaEjercicioHistorica"
                                                        NullText="Seleccione cuenta"
                                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                        DropDownWidth="420px"
                                                        SearchMode="ListSearchMode.AutoSearch"
                                                        SearchFilterCondition="ListSearchFilterCondition.Contains" />
                                        </DxFormLayoutItem>
                                    </DxFormLayoutGroup>
                                    <DxFormLayoutGroup Caption="De ajustes por inflación" ColSpanMd="12">
                                        <DxFormLayoutItem Caption="Utilidad acumulada" ColSpanMd="6" ColSpanSm="12">
                                            <DxComboBox Data="@cuentasDisponibles" TData="CuentaContableLookupDto" TValue="string"
                                                        ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                                                        TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                                                        @bind-Value="modelo.CuentasUtilidad.CodigoCuentaUtilAcumuladaInflacion"
                                                        NullText="Seleccione cuenta"
                                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                        DropDownWidth="420px"
                                                        SearchMode="ListSearchMode.AutoSearch"
                                                        SearchFilterCondition="ListSearchFilterCondition.Contains" />
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Pérdida acumulada" ColSpanMd="6" ColSpanSm="12">
                                            <DxComboBox Data="@cuentasDisponibles" TData="CuentaContableLookupDto" TValue="string"
                                                        ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                                                        TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                                                        @bind-Value="modelo.CuentasUtilidad.CodigoCuentaPerdidaAcumuladaInflacion"
                                                        NullText="Seleccione cuenta"
                                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                        DropDownWidth="420px"
                                                        SearchMode="ListSearchMode.AutoSearch"
                                                        SearchFilterCondition="ListSearchFilterCondition.Contains" />
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Utilidad del ejercicio" ColSpanMd="6" ColSpanSm="12">
                                            <DxComboBox Data="@cuentasDisponibles" TData="CuentaContableLookupDto" TValue="string"
                                                        ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                                                        TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                                                        @bind-Value="modelo.CuentasUtilidad.CodigoCuentaUtilEjercicioInflacion"
                                                        NullText="Seleccione cuenta"
                                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                        DropDownWidth="420px"
                                                        SearchMode="ListSearchMode.AutoSearch"
                                                        SearchFilterCondition="ListSearchFilterCondition.Contains" />
                                        </DxFormLayoutItem>
                                        <DxFormLayoutItem Caption="Pérdidas del ejercicio" ColSpanMd="6" ColSpanSm="12">
                                            <DxComboBox Data="@cuentasDisponibles" TData="CuentaContableLookupDto" TValue="string"
                                                        ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                                                        TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                                                        @bind-Value="modelo.CuentasUtilidad.CodigoCuentaPerdidaEjercicioInflacion"
                                                        NullText="Seleccione cuenta"
                                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                        DropDownWidth="420px"
                                                        SearchMode="ListSearchMode.AutoSearch"
                                                        SearchFilterCondition="ListSearchFilterCondition.Contains" />
                                        </DxFormLayoutItem>
                                    </DxFormLayoutGroup>
                                </DxFormLayout>
                            </DxTabPage>
                            <DxTabPage Text="Estado situación financiera" CssClass="p-3">
                                <div class="grid-container">
                                    <DxGrid Data="@balancePreviewData"
                                            ShowGroupPanel="false"
                                            TextWrapEnabled="false"
                                            HighlightRowOnHover="true"
                                            ShowAllRows="true"
                                            PagerVisible="false"
                                            CssClass="estado-sf-grid">
                                        <Columns>
                                            <DxGridDataColumn FieldName="@nameof(BalancePreviewRow.Categoria)"
                                                              Caption="Categoría / Cuentas"
                                                              Width="240px">
                                                <CellDisplayTemplate Context="grid">
                                                    @{
                                                        var row = (BalancePreviewRow)grid.DataItem;
                                                    }
                                                    @if (row.EsTitulo)
                                                    {
                                                        <strong>@row.Cuenta</strong>
                                                    }
                                                    else if (row.Categoria.Equals("Orden", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <span class="form-control-plaintext px-2 py-1 fw-semibold">@row.Cuenta</span>
                                                    }
                                                    else
                                                    {
                                                        <span></span>
                                                    }
                                                </CellDisplayTemplate>
                                            </DxGridDataColumn>
                                            <DxGridDataColumn FieldName="@nameof(BalancePreviewRow.Codigo)" Caption="Código" MinWidth="140" Width="160px">
                                                <CellDisplayTemplate Context="grid">
                                                    @{
                                                        var row = (BalancePreviewRow)grid.DataItem;
                                                    }
                                                    @if (row.EsTitulo)
                                                    {
                                                        <span class="form-control-plaintext px-2 py-1">&nbsp;</span>
                                                    }
                                                    else
                                                    {
                                                            <DxComboBox Data="@cuentasDisponibles"
                                                                        TData="CuentaContableLookupDto"
                                                                        TValue="string"
                                                                        ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                                                                        TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                                                                        Value="@row.Codigo"
                                                                        ValueChanged="@(code => OnCuentaSeleccionada(row, code))"
                                                                        ValueExpression="@(() => row.Codigo)"
                                                                        NullText="Seleccione cuenta"
                                                                        EnableValidation="false"
                                                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                        DropDownWidth="420px"
                                                                        SearchMode="ListSearchMode.AutoSearch"
                                                                        SearchFilterCondition="ListSearchFilterCondition.Contains" />
                                                    }
                                                </CellDisplayTemplate>
                                            </DxGridDataColumn>
                                            <DxGridDataColumn FieldName="@nameof(BalancePreviewRow.Descripcion)" Caption="Descripción" MinWidth="260" Width="420px">
                                                <CellDisplayTemplate Context="grid">
                                                    @{
                                                        var row = (BalancePreviewRow)grid.DataItem;
                                                    }
                                                    @if (row.EsTitulo)
                                                    {
                                                        <DxTextBox @bind-Text="row.Descripcion" NullText="Descripción manual" />
                                                    }
                                                    else if (row.Categoria.Equals("Orden", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <DxTextBox @bind-Text="row.Descripcion" NullText="Descripción de la cuenta" ReadOnly="true" />
                                                    }
                                                    else
                                                    {
                                                        <DxTextBox @bind-Text="row.Descripcion" NullText="Descripción de la cuenta" />
                                                    }
                                                </CellDisplayTemplate>
                                            </DxGridDataColumn>
                                        </Columns>
                                    </DxGrid>
                                </div>
                            </DxTabPage>
                            <DxTabPage Text="Estado resultados" CssClass="p-3">
                                <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <DxButton Text="Agregar línea"
                                                  IconCssClass="bi bi-plus-lg"
                                                  RenderStyle="ButtonRenderStyle.Secondary"
                                                  Click="@AgregarLineaResultado"
                                                  Enabled="@(!cargando)" />
                                        <small class="text-muted">Tipos permitidos: Ingreso, Costo, Gasto.</small>
                                    </div>
                                </div>
                                @if (modelo.LineasResultado.Count == 0)
                                {
                                    <div class="configuracion-status configuracion-status-info" role="status">
                                        <div class="configuracion-status-content">
                                            <i class="bi bi-info-circle-fill" aria-hidden="true"></i>
                                            <span>Agrega al menos una línea para el estado de resultados.</span>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <DxGrid Data="@modelo.LineasResultado"
                                            KeyFieldName="@nameof(LineaResultadoDto.RowId)"
                                            ShowAllRows="true"
                                            TextWrapEnabled="false">
                                        <Columns>
                                            <DxGridDataColumn FieldName="@nameof(LineaResultadoDto.Tipo)" Caption="Tipo" Width="120px">
                                                <CellDisplayTemplate Context="cell">
                                                    @{
                                                        var linea = (LineaResultadoDto)cell.DataItem;
                                                    }
                                                    <DxComboBox Data="@tiposResultado"
                                                                TData="string"
                                                                TValue="string"
                                                                @bind-Value="linea.Tipo"
                                                                NullText="Selecciona"
                                                                DropDownStyle="DropDownStyle.DropDownList" />
                                                </CellDisplayTemplate>
                                            </DxGridDataColumn>
                                            <DxGridDataColumn FieldName="@nameof(LineaResultadoDto.CodigoCuenta)" Caption="Código" Width="160px">
                                                <CellDisplayTemplate Context="cell">
                                                    @{
                                                        var linea = (LineaResultadoDto)cell.DataItem;
                                                    }
                                                    <DxComboBox Data="@cuentasDisponibles"
                                                                TData="CuentaContableLookupDto"
                                                                TValue="string"
                                                                ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                                                                TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                                                                Value="@linea.CodigoCuenta"
                                                                ValueChanged="@(code => OnCodigoResultadoChanged(linea, code))"
                                                                ValueExpression="@(() => linea.CodigoCuenta)"
                                                                NullText="Seleccione cuenta"
                                                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                DropDownWidth="420px"
                                                                SearchMode="ListSearchMode.AutoSearch"
                                                                SearchFilterCondition="ListSearchFilterCondition.Contains" />
                                                </CellDisplayTemplate>
                                            </DxGridDataColumn>
                                            <DxGridDataColumn FieldName="@nameof(LineaResultadoDto.Descripcion)" Caption="Descripción">
                                                <CellDisplayTemplate Context="cell">
                                                    @{
                                                        var linea = (LineaResultadoDto)cell.DataItem;
                                                    }
                                                    <DxTextBox @bind-Text="linea.Descripcion" NullText="Descripción" />
                                                </CellDisplayTemplate>
                                            </DxGridDataColumn>
                                            <DxGridDataColumn Caption="" Width="110px">
                                                <CellDisplayTemplate Context="cell">
                                                    @{
                                                        var linea = (LineaResultadoDto)cell.DataItem;
                                                    }
                                                    <DxButton Text="Eliminar"
                                                              RenderStyle="ButtonRenderStyle.Danger"
                                                              Click="@(() => EliminarLineaResultado(linea.RowId))"
                                                              Enabled="@(!cargando)" />
                                                </CellDisplayTemplate>
                                            </DxGridDataColumn>
                                        </Columns>
                                    </DxGrid>
                                }
                            </DxTabPage>
                            <DxTabPage Text="Correlativos" Visible="@MostrarCorrelativos" />
                        </DxTabs>
                        <div class="d-flex flex-wrap gap-2 mt-4">
                            <DxButton RenderStyle="ButtonRenderStyle.Primary" IconCssClass="bi bi-save"
                                      Text="Guardar configuración" Enabled="@(!cargando && empresaSeleccionadaId > 0)"
                                      Click="@GuardarAsync" />
                            <DxButton RenderStyle="ButtonRenderStyle.Secondary" IconCssClass="bi bi-arrow-counterclockwise"
                                      Text="Restablecer" Enabled="@(!cargando)" Click="@RecargarAsync" />
                        </div>
                    </EditForm>
                }
            </div>
        </ChildContent>
    </DxCard>
    <DxLoadingPanel Visible="@cargando"
                    PositionTarget="@LoadingTargetSelector"
                    ApplyBackgroundShading="false"
                    IsContentBlocked="true"
                    Text="Cargando configuración..." />

    <DxPopup @bind-Visible="popupGuardadoVisible"
             Attributes="popupGuardadoAttributes"
             Width="420px"
             CloseOnEscape="true"
             CloseOnOutsideClick="true"
             ShowFooter="true">
        <HeaderContentTemplate>
            <div id="configuracion-popup-guardado-titulo" class="configuracion-success-header d-flex align-items-center gap-2">
                <i class="bi bi-check-circle-fill fs-3"></i>
                <strong>Configuración guardada</strong>
            </div>
        </HeaderContentTemplate>
        <BodyContentTemplate>
            <div class="p-3">
                <p class="mb-0">@popupGuardadoMensaje</p>
            </div>
        </BodyContentTemplate>
        <FooterContentTemplate Context="popupFooter">
            <div class="p-2 text-end">
                <DxButton RenderStyle="ButtonRenderStyle.Primary" Text="Aceptar" Click="@popupFooter.CloseCallback" />
            </div>
        </FooterContentTemplate>
    </DxPopup>
</div>

@code {
    // Modelo y contexto de edición
    private ConfiguracionSistemaDto modelo = new();
    private EditContext? editContext;
    private List<TenantCompanyDto> empresas = new();
    private IReadOnlyList<CuentaContableLookupDto> cuentasDisponibles = Array.Empty<CuentaContableLookupDto>();
    private long empresaSeleccionadaId;
    private int activeTabIndex;
    private bool cargando;
    private bool configuracionExiste = false;
    private string? alerta;
    private MessageBoxRenderStyle alertaEstilo = MessageBoxRenderStyle.Info;
    private bool popupGuardadoVisible;
    private string? formatoCuentasSugerido;
    private List<BalancePreviewRow> balancePreviewData = CrearBalancePreview();
