@page "/contabilidad/empresas/nueva"

@attribute [Authorize(Roles = RoleNames.AdminContabilidad + "," + RoleNames.SuperAdministrador)]
@using DevExpress.Blazor
@using apc.Client.Services.Contabilidad
@using apc.Client.Services.Tenant
@using SIAD.Core.Constants
@using SIAD.Core.DTOs.Contabilidad
@using SIAD.Core.DTOs.Tenant
@inject EmpresasContabilidadClient EmpresasClient
@inject TenantCompaniesClient TenantCompaniesClient

<div class="contabilidad-page contabilidad-content nueva-empresa-page">
    <DxCard CssClass="shadow-sm border-0 rounded">
        <DxCardHeader>
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <div class="fs-5 fw-semibold mb-1">Crear nueva empresa</div>
                    <p class="text-muted mb-0 small">
                        Captura la información obligatoria para registrar una empresa contable en el tenant activo.
                    </p>
                </div>
                @if (model?.CompanyId > 0)
                {
                    <DxBadge CssClass="bg-success-subtle text-success fw-semibold"
                             Text="@($"ID {model!.CompanyId}")" />
                }
            </div>
        </DxCardHeader>

        <DxCardBody CssClass="p-4">
            @if (mostrarMensajeCreacion && !string.IsNullOrWhiteSpace(mensajeCreacion))
            {
                <DxMessageBox Type="MessageBoxType.Alert"
                              RenderStyle="MessageBoxRenderStyle.Success"
                              CssClass="mb-3"
                              ShowIcon="true"
                              ShowCloseButton="true"
                              Text="@mensajeCreacion"
                              Closed="@OnMensajeCreacionClosed" />
            }

            @if (!string.IsNullOrWhiteSpace(alertaMensaje))
            {
                <DxMessageBox Type="MessageBoxType.Alert"
                              RenderStyle="@alertaTipo"
                              CssClass="mb-4"
                              ShowIcon="true"
                              ShowCloseButton="true"
                              Text="@alertaMensaje"
                              Closed="@OnAlertaClosedAsync" />
            }

            <div class="row g-4 align-items-start">
                <div class="col-12 col-lg-7">
                    <EditForm EditContext="@editContext"
                              Context="formContext">
                        <DataAnnotationsValidator />
                        <DxValidationSummary CssClass="mb-3" />
                        <DxWaitIndicator Visible="@guardando" CssClass="mb-3" />

                        <div class="d-flex flex-wrap gap-2 mb-4">
                            <DxButton RenderStyle="ButtonRenderStyle.Primary"
                                      IconCssClass="bi bi-save"
                                      Text="Guardar empresa"
                                      ButtonType="ButtonType.Normal"
                                      Enabled="@(!guardando)"
                                      Click="@AbrirConfirmacionAsync" />
                            <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                                      IconCssClass="bi bi-arrow-counterclockwise"
                                      Text="Limpiar"
                                      Enabled="@(!guardando)"
                                      Click="@RestablecerAsync" />
                        </div>

                        <DxFormLayout CssClass="mb-3"
                                      ReadOnly="@guardando"
                                      ColumnCountMd="12"
                                      RequiredMarkDisplayMode="DataAnnotations">
                            <!-- Grupo Información general -->
                            <DxFormLayoutGroup Caption="Información general" Decoration="FormLayoutGroupDecoration.Card" ColSpanMd="12">
                                <DxFormLayoutItem Caption="Código *" ColSpanMd="4">
                                    <DxTextBox @bind-Text="model.Codigo"
                                               NullText="Código de la empresa"
                                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                                    <ValidationMessage For="@(() => model.Codigo)" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Descripción *" ColSpanMd="8">
                                    <DxTextBox @bind-Text="model.Descripcion"
                                               NullText="Nombre de la empresa"
                                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                                    <ValidationMessage For="@(() => model.Descripcion)" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Tipo de empresa *" ColSpanMd="6">
                                    <DxTextBox @bind-Text="model.TipoEmpresa"
                                               NullText="p. ej. '02'"
                                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                                    <ValidationMessage For="@(() => model.TipoEmpresa)" />
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>

                            <!-- Grupo Datos fiscales -->
                            <DxFormLayoutGroup Caption="Datos fiscales" ColSpanMd="12" Decoration="FormLayoutGroupDecoration.Card">
                                <DxFormLayoutItem Caption="ID fiscal (siglas) *" ColSpanMd="4">
                                    <DxTextBox @bind-Text="model.IdFiscalSiglas"
                                               NullText="RTN"
                                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                                    <ValidationMessage For="@(() => model.IdFiscalSiglas)" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="ID fiscal (valor) *" ColSpanMd="8">
                                    <DxTextBox @bind-Text="model.IdFiscalValor"
                                               NullText="04019001034761"
                                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                                    <ValidationMessage For="@(() => model.IdFiscalValor)" />
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>

                            <!-- Grupo Características -->
                            <DxFormLayoutGroup Caption="Características" ColSpanMd="12" Decoration="FormLayoutGroupDecoration.Card">
                                <DxFormLayoutItem Caption="Tamaño *" ColSpanMd="4">
                                    <DxComboBox TData="EnumOption<CompanySizeType>"
                                                TValue="CompanySizeType?"
                                                Data="sizeOptions"
                                                ValueFieldName="@nameof(EnumOption<CompanySizeType>.Value)"
                                                TextFieldName="@nameof(EnumOption<CompanySizeType>.Text)"
                                                AllowUserInput="false"
                                                NullText="Selecciona un tamano"
                                                @bind-Value="model.Tamano" />
                                    <ValidationMessage For="@(() => model.Tamano)" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Capital *" ColSpanMd="4" >
                                    <DxComboBox TData="EnumOption<CompanyCapitalType>"
                                                TValue="CompanyCapitalType?"
                                                Data="capitalOptions"
                                                ValueFieldName="@nameof(EnumOption<CompanyCapitalType>.Value)"
                                                TextFieldName="@nameof(EnumOption<CompanyCapitalType>.Text)"
                                                AllowUserInput="false"
                                                NullText="Selecciona el capital"
                                                @bind-Value="model.Capital" />
                                    <ValidationMessage For="@(() => model.Capital)" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Fecha constitución *" ColSpanMd="4">
                                    <DxDateEdit T="DateTime?"
                                                @bind-Date="model.FechaConstitucion"
                                                DisplayFormatString="d"
                                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                InputCssClass="w-100" />
                                    <ValidationMessage For="@(() => model.FechaConstitucion)" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Activa" ColSpanMd="4">
                                    <DxCheckBox @bind-Checked="model.Activa"
                                                Caption="Empresa disponible para selección" />
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>

                            <!-- Grupo Contacto y ubicación -->
                            <DxFormLayoutGroup Caption="Contacto y ubicación" ColSpanMd="12" Decoration="FormLayoutGroupDecoration.Card">
                                <DxFormLayoutItem Caption="Persona contacto" ColSpanMd="4">
                                    <DxTextBox @bind-Text="model.Contacto"
                                               NullText="Nombre del contacto"
                                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                                    <ValidationMessage For="@(() => model.Contacto)" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Dirección *" ColSpanMd="8">
                                    <DxMemo @bind-Text="model.Direccion" Rows="3"
                                            NullText="Dirección completa" />
                                    <ValidationMessage For="@(() => model.Direccion)" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Teléfonos" ColSpanMd="4">
                                    <DxTextBox @bind-Text="model.Telefonos"
                                               NullText="Teléfono(s)"
                                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                                    <ValidationMessage For="@(() => model.Telefonos)" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="País *" ColSpanMd="4">
                                    <DxTextBox @bind-Text="model.Pais"
                                               NullText="País"
                                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                                    <ValidationMessage For="@(() => model.Pais)" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Correo electrónico" ColSpanMd="4">
                                    <DxTextBox @bind-Text="model.Email"
                                               NullText="correo@dominio.com"
                                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                                    <ValidationMessage For="@(() => model.Email)" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Página web" ColSpanMd="4">
                                    <DxTextBox @bind-Text="model.PaginaWeb"
                                               NullText="https://"
                                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                                    <ValidationMessage For="@(() => model.PaginaWeb)" />
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>
                        </DxFormLayout>
                    </EditForm>
                </div>

                <div class="col-12 col-lg-5">
                    <DxCard CssClass="h-100 shadow-sm">
                        <DxCardHeader>
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="fw-semibold">Empresas Existentes</div>
                                    <small class="text-muted">
                                        Empresa del Tenat Actual
                                    </small>
                                </div>
                                <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                                          IconCssClass="bi bi-arrow-clockwise"
                                          Text="Recargar"
                                          Enabled="@(!cargandoEmpresas)"
                                          Click="@CargarEmpresasAsync"/>
                            </div>
                        </DxCardHeader>
                        <DxCardBody>
                            @if (cargandoEmpresas)
                            {
                                <DxSkeleton  height="80px"
                                             width="100%"
                                             Active="true"
                                             CssClass="rounded-3"/>

                            }else if (empresas.Count== 0)
                            {
                                <div class="text-muted small">No hay empresas registradas.</div>

                            }
                            else
                            {
                                <DxGrid Data="@empresas"
                                        ShowGroupPanel="false"
                                        ShowFilterRow="false"
                                        CssClass="empresa-grid-compacta">
                                    <Columns>
                                        <DxGridDataColumn FieldName="Code" Caption="Código" />
                                        <DxGridDataColumn FieldName="Name" Caption="Descripción" />

                                    </Columns>
                                </DxGrid>
                            }
                        </DxCardBody>

                    </DxCard>
                    
                </div>
            </div>
        </DxCardBody>
    </DxCard>
    
    <DxPopup @bind-Visible="mostrarConfirmacion"
             ShowCloseButton="true"
             CloseOnEscape="true"
             HeaderText="Confirmar creación"
             Width="450px">

        <div class="mb-3 text-secondary">
            ¿Deseas crear la empresa con los datos proporcionados?
        </div>

        <div class="popup-summary-grid">
            <div class="label">Código</div>
            <div class="value">@model.Codigo</div>

            <div class="label">Nombre</div>
            <div class="value">@model.Descripcion</div>

            <div class="label">Tipo</div>
            <div class="value">@model.TipoEmpresa</div>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-3">
            <DxButton Text="Cancelar"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      Click="@(() => mostrarConfirmacion = false)" />

            <DxButton Text="Crear empresa"
                      RenderStyle="ButtonRenderStyle.Primary"
                      IconCssClass="bi bi-check2-square"
                      Enabled="@(!guardando)"
                      Click="@OnGuardarConfirmadoAsync" />
        </div>

    </DxPopup>

    @* <DxPopup @bind-Visible="mostrarConfirmacion"
             CssClass="popup-confirmacion-empresa"
             Width="520px"
             ShowCloseButton="true"
             CloseOnOutsideClick="true"
             ShowFooter="true">

        <HeaderTemplate>
            <div class="d-flex align-items-center gap-2">
                <DxIcon IconName="IconName.Warning" CssClass="text-warning fs-4" />
                <span class="fw-semibold fs-6">Confirmar creación</span>
            </div>
        </HeaderTemplate>

        <BodyTemplate Context="ctx">

            <p class="text-secondary mb-3">
                ¿Deseas crear la empresa con los datos proporcionados?
            </p>

            <div class="popup-summary-grid">

