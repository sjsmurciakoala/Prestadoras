                <DxButton Text="Crear empresa"
                          IconCssClass="bi bi-check2"
                          RenderStyle="ButtonRenderStyle.Primary"
                          Enabled="@(!guardando)"
                          Click="@OnGuardarConfirmadoAsync" />
            </div>
        </FooterTemplate>

    </DxPopup> *@


</div>



@code {
    private CompanyCreationDto model = null!;
    private EditContext? editContext;
    private bool guardando;
    private string? alertaMensaje;
    private MessageBoxRenderStyle alertaTipo = MessageBoxRenderStyle.Info;
    private string? errorConfirmacion;
    private MessageBoxRenderStyle errorConfirmacionEstilo = MessageBoxRenderStyle.Warning;
    private IReadOnlyList<EnumOption<CompanySizeType>> sizeOptions = Array.Empty<EnumOption<CompanySizeType>>();
    private IReadOnlyList<EnumOption<CompanyCapitalType>> capitalOptions = Array.Empty<EnumOption<CompanyCapitalType>>();
    private List<TenantCompanyDto> empresas = new();
    private bool cargandoEmpresas = true;
    private bool mostrarConfirmacion;
    private bool mostrarMensajeCreacion;
    private string? mensajeCreacion;

    protected override async Task OnInitializedAsync()
    {
        sizeOptions = Enum.GetValues<CompanySizeType>()
            .Select(value => new EnumOption<CompanySizeType>(value, ObtenerTextoTamano(value)))
            .ToArray();
        capitalOptions = Enum.GetValues<CompanyCapitalType>()
            .Select(value => new EnumOption<CompanyCapitalType>(value, ObtenerTextoCapital(value)))
            .ToArray();

        model = CrearModeloInicial();
        ConfigurarEditContext();
        await CargarEmpresasAsync();
    }

    private async Task AbrirConfirmacionAsync()
    {
        if (guardando || editContext is null)
        {
            return;
        }

        errorConfirmacion = null;
        alertaMensaje = null;
        mostrarMensajeCreacion = false;

        if (!editContext.Validate())
        {
            await MostrarErroresAsync(editContext);
            return;
        }

        mostrarConfirmacion = true;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnGuardarConfirmadoAsync()
    {
        if (!mostrarConfirmacion)
        {
            return;
        }

        if (ExisteEmpresaConCodigo(model.Codigo))
        {
            errorConfirmacion = $"Ya existe la empresa con código {model.Codigo}. Por favor verifique o ingrese un código diferente.";
            errorConfirmacionEstilo = MessageBoxRenderStyle.Warning;
            await InvokeAsync(StateHasChanged);
            return;
        }

        mostrarConfirmacion = false;
        await CrearEmpresaAsync();
    }

    private void CerrarConfirmacion()
    {
        mostrarConfirmacion = false;
    }

    private void OnConfirmacionCerrada(bool visible)
    {
        mostrarConfirmacion = visible;
    }

    private async Task CrearEmpresaAsync()
    {
        if (editContext is null || guardando)
        {
            return;
        }

        alertaMensaje = null;
        mostrarMensajeCreacion = false;
        guardando = true;

        try
        {
            var creada = await EmpresasClient.CrearAsync(model);
            mensajeCreacion = $"La empresa \"{creada.Descripcion}\" se creó correctamente (ID {creada.CompanyId}).";
            mostrarMensajeCreacion = true;
            model = CrearModeloInicial();
            ConfigurarEditContext();
            await InvokeAsync(StateHasChanged);
            await CargarEmpresasAsync();
        }
        catch (HttpRequestException ex)
        {
            alertaTipo = MessageBoxRenderStyle.Danger;
            alertaMensaje = ex.Message;
        }
        catch (InvalidOperationException ex)
        {
            alertaTipo = MessageBoxRenderStyle.Danger;
            alertaMensaje = ex.Message;
        }
        catch (Exception ex)
        {
            alertaTipo = MessageBoxRenderStyle.Danger;
            alertaMensaje = $"Error inesperado: {ex.Message}";
        }
        finally
        {
            guardando = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private Task MostrarErroresAsync(EditContext context)
    {
        var errores = context.GetValidationMessages().ToList();
        if (errores.Count == 0)
        {
            alertaMensaje = "Hay campos con datos incompletos o inválidos.";
        }
        else
        {
            alertaMensaje = string.Join(Environment.NewLine, errores.Select(m => $"• {m}"));
        }

        alertaTipo = MessageBoxRenderStyle.Warning;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private Task OnAlertaClosedAsync(bool _)
    {
        alertaMensaje = null;
        StateHasChanged();
        return Task.CompletedTask;
    }

    private async Task RestablecerAsync()
    {
        if (guardando)
        {
            return;
        }

        model = CrearModeloInicial();
        alertaMensaje = null;
        mostrarMensajeCreacion = false;
        mensajeCreacion = null;
        ConfigurarEditContext();
        await InvokeAsync(StateHasChanged);
    }

    private void ConfigurarEditContext()
    {
        editContext = new EditContext(model);
        editContext.OnFieldChanged += (_, _) =>
        {
            if (!string.IsNullOrWhiteSpace(alertaMensaje) && alertaTipo != MessageBoxRenderStyle.Success)
            {
                alertaMensaje = null;
                InvokeAsync(StateHasChanged);
            }
        };
    }

    private static CompanyCreationDto CrearModeloInicial()
    {
        return new CompanyCreationDto
        {
            Activa = true,
            FechaConstitucion = DateTime.Today
        };
    }

    private static string ObtenerTextoTamano(CompanySizeType value)
    {
        return value switch
        {
            CompanySizeType.Pequena => "Pequeña",
            CompanySizeType.Mediana => "Mediana",
            CompanySizeType.GranContribuyente => "Gran contribuyente",
            _ => value.ToString()
        };
    }

    private static string ObtenerTextoCapital(CompanyCapitalType value)
    {
        return value switch
        {
            CompanyCapitalType.Privado => "Privado",
            CompanyCapitalType.Oficial => "Oficial",
            CompanyCapitalType.Mixto => "Mixto",
            _ => value.ToString()
        };
    }

    private async Task CargarEmpresasAsync()
    {
        cargandoEmpresas = true;
        try
        {
            var resultado = await TenantCompaniesClient.ObtenerAsync();
            empresas = resultado?.OrderBy(e => e.Code).ToList() ?? new List<TenantCompanyDto>();
        }
        catch (HttpRequestException ex)
        {
            alertaTipo = MessageBoxRenderStyle.Danger;
            alertaMensaje = $"No fue posible cargar las empresas: {ex.Message}";
        }
        finally
        {
            cargandoEmpresas = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private sealed record EnumOption<TValue>(TValue Value, string Text);

    private void LimpiarErrorConfirmacion()
    {
        errorConfirmacion = null;
        StateHasChanged();
    }

    private bool ExisteEmpresaConCodigo(string? codigo)
    {
        if (string.IsNullOrWhiteSpace(codigo))
        {
            return false;
        }

        return empresas.Any(e => string.Equals(e.Code, codigo.Trim(), StringComparison.OrdinalIgnoreCase));
    }

    private Task OnMensajeCreacionClosed(bool visible)
    {
        mostrarMensajeCreacion = visible;
        if (!visible)
        {
            mensajeCreacion = null;
        }

        StateHasChanged();
        return Task.CompletedTask;
    }
}


