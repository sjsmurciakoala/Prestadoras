                <div class="label">Tipo</div>
                <div class="value">@model.TipoEmpresa</div>

            </div>

        </BodyTemplate>

        <FooterTemplate>
            <div class="d-flex justify-content-end gap-2">
                <DxButton Text="Cancelar"
