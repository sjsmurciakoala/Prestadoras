@page "/contabilidad/periodos"
@attribute [Authorize]
@using SIAD.Core.Constants
@using SIAD.Core.DTOs.PeriodosComerciales
@using apc.Client.Services
@using apc.Client.Services.Contabilidad
@using apc.Client.Services.Tenant
@inject HttpClient Http
@inject IToastNotificationService ToastService
@inject PeriodosContablesClient PeriodosClient
@inject TenantState TenantState

<PageTitle>SIAD - Periodos contables</PageTitle>

<DxLayoutBreakpoint DeviceSize="DeviceSize.XSmall" @bind-IsActive="isXSmallScreen" />

<DxMessageBox @bind-Visible="statusMessageVisible"
              Type="MessageBoxType.Alert"
              Title="@statusMessageTitle"
              Text="@statusMessageText"
              RenderStyle="@statusMessageRenderStyle"
              OkButtonText="Entendido"
              ShowCloseButton="false"
              CloseOnOutsideClick="false" />

@* F7: el cierre pasa por el popup de checklist (precierre → cierre) *@

<div class="periodos-page" id="periodos-grid-shell">

    @* ── Encabezado (patron DxStackLayout igual que CentrosCosto) ── *@
    <div class="d-flex align-items-start flex-wrap gap-3 mb-3">
        <div class="flex-grow-1">
            <h4 class="mb-1 fw-bold text-secondary">
                <i class="bi bi-calendar-range me-2 text-primary"></i>Periodos contables
            </h4>
            <div class="d-flex flex-wrap align-items-center gap-2">
                @if (CurrentOpenPeriodo is not null)
                {
                    <span class="badge bg-success">
                        <i class="bi bi-circle-fill me-1" style="font-size:0.45rem;vertical-align:middle"></i>
                        Activo: @CurrentOpenPeriodo.Code
                    </span>
                    <small class="text-muted">@CurrentOpenPeriodo.Name &middot; @CurrentOpenPeriodo.StartDate.ToString("dd/MM/yyyy") – @CurrentOpenPeriodo.EndDate.ToString("dd/MM/yyyy")</small>
                }
                else if (HasMultipleOpenPeriodos)
                {
                    <span class="badge bg-warning text-dark">Multiples periodos abiertos</span>
                    <small class="text-muted">Deja un unico periodo abierto para operar.</small>
                }
                else
                {
                    <span class="badge bg-secondary">Sin periodo abierto</span>
                    <small class="text-muted">Abre un periodo para habilitar operaciones.</small>
                }
            </div>
        </div>
        <div class="d-flex flex-wrap gap-2 flex-shrink-0">
            <DxButton Text="@(isVerifyingSaldos ? "Verificando..." : "Verificar saldos")"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      IconCssClass="bi bi-shield-check"
                      title="Reconciliar el caché oficial de saldos (con_saldo_cuenta) contra el libro"
                      Click="VerificarSaldosAsync"
                      Enabled="@(!IsBusy)" />
            <DxButton Text="Actualizar"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      IconCssClass="bi bi-arrow-clockwise"
                      Click="LoadPeriodosAsync"
                      Enabled="@(!IsBusy)" />
            <DxButton Text="Nuevo periodo"
                      RenderStyle="ButtonRenderStyle.Primary"
                      IconCssClass="bi bi-plus-lg"
                      Click="@(() => OpenForm(null))"
                      Enabled="@(!IsBusy)" />
        </div>
    </div>

    @* ── Aviso de reconciliación de saldos (F6) ── *@
    @if (saldoVerificacion is not null)
    {
        @if (saldoVerificacion.Consistente)
        {
            <div class="alert alert-success d-flex align-items-center gap-2 py-2 mb-3" role="alert">
                <i class="bi bi-shield-check fs-5"></i>
                <div>
                    Saldos consistentes: el caché oficial (con_saldo_cuenta) coincide con el libro.
                    <small class="text-muted d-block">Verificado: @saldoVerificacion.VerificadoEn.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</small>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-danger d-flex align-items-center gap-2 py-2 mb-3" role="alert">
                <i class="bi bi-shield-exclamation fs-5"></i>
                <div class="flex-grow-1">
                    <strong>@saldoVerificacion.TotalDivergencias divergencia(s)</strong> entre el caché de saldos y el libro
                    (montos: @saldoVerificacion.Montos, conteos: @saldoVerificacion.Conteos,
                    solo caché: @saldoVerificacion.SoloCache, solo libro: @saldoVerificacion.SoloLibro@(saldoVerificacion.FechasFueraPeriodo > 0 ? $", fechas fuera de período: {saldoVerificacion.FechasFueraPeriodo}" : string.Empty)).
                    Reportes de períodos cerrados pueden estar incorrectos — coordinar la reconstrucción
                    (sp_con_reconstruir_saldo_cuenta) en ventana de mantenimiento.
                </div>
                <DxButton Text="Ver detalle"
                          RenderStyle="ButtonRenderStyle.Danger"
                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                          SizeMode="SizeMode.Small"
                          Click="@(() => isDivergenciasPopupVisible = true)" />
            </div>
        }
    }

    @* ── Indicadores rapidos ── *@
    <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="periodos-stat-badge">
            <i class="bi bi-calendar-range"></i> Total: <strong>@periodos.Length.ToString("N0")</strong>
        </span>
        <span class="periodos-stat-badge periodos-stat-badge--success">
            <i class="bi bi-unlock"></i> Abiertos: <strong>@OpenCount</strong>
        </span>
        <span class="periodos-stat-badge periodos-stat-badge--warning">
            <i class="bi bi-clock-history"></i> Precierre: <strong>@PreCloseCount</strong>
        </span>
        <span class="periodos-stat-badge periodos-stat-badge--secondary">
            <i class="bi bi-lock"></i> Cerrados: <strong>@ClosedCount</strong>
        </span>
    </div>

    @* ── Grid principal ── *@
    <div class="periodos-grid-wrapper shadow-sm">
        <DxGrid @ref="periodosGrid"
                Data="@periodos"
                KeyFieldName="@nameof(PeriodoContableDto.PeriodId)"
                ShowFilterRow="true"
                ShowPager="true"
                PageSize="12"
                PageSizeSelectorVisible="true"
                PageSizeSelectorItems="new int[] { 10, 20, 50 }"
                SizeMode="SizeMode.Medium"
                ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
                DetailRowDisplayMode="@GetGridDetailRowDisplayMode()"
                CssClass="border-0">
            <ToolbarTemplate>
                <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Contained">
                    <Items>
                        <DxToolbarItem Text="Columnas"
                                       Alignment="ToolbarItemAlignment.Right"
                                       IconCssClass="bi bi-layout-three-columns"
                                       RenderStyle="ButtonRenderStyle.Secondary"
                                       CssClass="periodos-column-chooser-button"
                                       Click="MostrarColumnChooser" />
                    </Items>
                </DxToolbar>
            </ToolbarTemplate>
            <Columns>
                <DxGridCommandColumn Caption="Acciones" Width="120px"
                                     NewButtonVisible="false" EditButtonVisible="false" DeleteButtonVisible="false"
                                     VisibleIndex="99">
                    <CellDisplayTemplate Context="cellContext">
                        @if (cellContext.DataItem is PeriodoContableDto item)
                        {
                            <div class="d-flex gap-1 justify-content-center">
                                <DxButton RenderStyle="ButtonRenderStyle.Info"
                                          RenderStyleMode="ButtonRenderStyleMode.Text"
                                          SizeMode="SizeMode.Small"
                                          IconCssClass="bi bi-pencil-square fs-5"
                                          title="Editar"
                                          Enabled="@(!IsBusy)"
                                          Click="@(() => OpenForm(item))" />
                                <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                                          RenderStyleMode="ButtonRenderStyleMode.Text"
                                          SizeMode="SizeMode.Small"
                                          IconCssClass="bi bi-lock fs-5"
                                          title="Cierre del período (checklist)"
                                          Enabled="@(!IsPeriodoClosed(item) && !IsBusy)"
                                          Click="@(() => AbrirCierrePeriodoAsync(item))" />
                            </div>
                        }
                    </CellDisplayTemplate>
                </DxGridCommandColumn>

                <DxGridDataColumn FieldName="@nameof(PeriodoContableDto.Code)" Caption="Codigo" Width="120px">
                    <CellDisplayTemplate Context="cell">
                        <span class="fw-bold text-primary">@((cell.DataItem as PeriodoContableDto)?.Code)</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(PeriodoContableDto.Name)" Caption="Nombre" MinWidth="200" />

                <DxGridDataColumn FieldName="@nameof(PeriodoContableDto.StartDate)" Caption="Inicio"
                                  DisplayFormat="{0:dd/MM/yyyy}" Width="120px" />

                <DxGridDataColumn FieldName="@nameof(PeriodoContableDto.EndDate)" Caption="Fin"
                                  DisplayFormat="{0:dd/MM/yyyy}" Width="120px" />

                <DxGridDataColumn FieldName="@nameof(PeriodoContableDto.StatusId)" Caption="Estado" Width="120px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is PeriodoContableDto item)
                        {
                            <span class="@GetPeriodoBadgeCss(item)">@GetPeriodoStatusLabel(item)</span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(PeriodoContableDto.ClosedAt)" Caption="Fecha cierre" Width="160px" Visible="@GetAuditColumnsVisible()">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is PeriodoContableDto item)
                        {
                            @(item.ClosedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(PeriodoContableDto.ClosedBy)" Caption="Cerrado por"
                                  Width="160px" Visible="@GetAuditColumnsVisible()" />
            </Columns>
            <DetailRowTemplate Context="detail">
                @if (detail.DataItem is PeriodoContableDto item)
                {
                    <div class="p-3">
                        <div class="row g-3">
                            <div class="col-sm-4">
                                <small class="text-muted d-block">Estado</small>
                                <strong>@GetPeriodoStatusLabel(item)</strong>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted d-block">Fecha de cierre</small>
                                <strong>@(item.ClosedAt?.ToString("dd/MM/yyyy HH:mm") ?? "Pendiente")</strong>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted d-block">Cerrado por</small>
                                <strong>@(string.IsNullOrWhiteSpace(item.ClosedBy) ? "—" : item.ClosedBy)</strong>
                            </div>
                        </div>
                    </div>
                }
            </DetailRowTemplate>
            <EmptyDataAreaTemplate>
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                    <h5 class="fw-bold text-dark">No hay periodos registrados</h5>
                    <p class="mb-0">Crea el primer periodo contable para empezar a operar.</p>
                </div>
            </EmptyDataAreaTemplate>
        </DxGrid>
    </div>

    <DxLoadingPanel Visible="@(isLoading || isClosingPeriod)"
                    PositionTarget="#periodos-grid-shell"
                    CssClass="w-100"
                    ApplyBackgroundShading="true"
                    IsContentBlocked="true"
                    Text="@GetLoadingText()" />
</div>

@* ── Popup de formulario ── *@
<DxPopup @bind-Visible="isFormVisible"
         Width="720px"
         MaxWidth="95vw"
         MinWidth="320px"
         MaxHeight="90vh"
         Scrollable="true"
         ShowFooter="true"
         ShowCloseButton="true"
         CloseOnOutsideClick="false"
         HeaderText="@popupTitle"
         CssClass="periodos-popup">
    <BodyContentTemplate Context="popupBody">
        <DxFormLayout SizeMode="SizeMode.Medium" CaptionPosition="CaptionPosition.Vertical" CssClass="w-100">
            <DxFormLayoutGroup Caption="Datos del periodo" HeaderIconCssClass="bi bi-calendar-range">
                <DxFormLayoutItem ColSpanMd="4" ColSpanSm="6" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Codigo</span></CaptionTemplate>
                    <Template>
                        <DxTextBox @bind-Text="formModel.Code" NullText="Ej. 202602" InputId="periodo-code" />
                    </Template>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanMd="8" ColSpanSm="6" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Nombre</span></CaptionTemplate>
                    <Template>
                        <DxTextBox @bind-Text="formModel.Name" NullText="Nombre del periodo" InputId="periodo-name" />
                    </Template>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanMd="4" ColSpanSm="6" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Inicio</span></CaptionTemplate>
                    <Template>
                        <DxDateEdit @bind-Date="formModel.StartDate"
                                    Format="@PeriodoDateFormat"
                                    DisplayFormat="@PeriodoDateFormat"
                                    Mask="@PeriodoDateFormat"
                                    InputId="periodo-start" />
                    </Template>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanMd="4" ColSpanSm="6" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Fin</span></CaptionTemplate>
                    <Template>
                        <DxDateEdit @bind-Date="formModel.EndDate"
                                    Format="@PeriodoDateFormat"
                                    DisplayFormat="@PeriodoDateFormat"
                                    Mask="@PeriodoDateFormat"
                                    InputId="periodo-end" />
                    </Template>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanMd="4" ColSpanSm="12" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Estado</span></CaptionTemplate>
                    <Template>
                        <DxComboBox Data="@statusOptions"
                                    TData="PeriodoStatusOption"
                                    TValue="short"
                                    @bind-Value="formModel.StatusId"
                                    TextFieldName="@nameof(PeriodoStatusOption.Text)"
                                    ValueFieldName="@nameof(PeriodoStatusOption.Value)"
                                    NullText="Selecciona estado"
                                    Enabled="@(!formModel.PeriodId.HasValue)"
                                    InputId="periodo-status" />
                        @if (formModel.PeriodId.HasValue)
                        {
                            <small class="text-muted">
                                El estado se cambia con el flujo de cierre (botón <i class="bi bi-lock"></i> del período).
                            </small>
                        }
                    </Template>
                </DxFormLayoutItem>
            </DxFormLayoutGroup>

            <DxFormLayoutGroup Caption="Vista previa" HeaderIconCssClass="bi bi-eye" CssClass="mt-3">
                <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Resumen</span></CaptionTemplate>
                    <Template>
                        <div class="periodos-preview-card">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Codigo</span>
                                <strong>@GetPreviewCode()</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Rango</span>
                                <strong>@GetPreviewRange()</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Duracion</span>
                                <strong>@GetPreviewDuration()</strong>
                            </div>
                        </div>
                    </Template>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Estado operativo</span></CaptionTemplate>
                    <Template>
                        <div class="@GetStatusPanelCss(formModel.StatusId)">
                            <div>
                                <div class="fw-bold">@GetStatusHelpTitle(formModel.StatusId)</div>
                                <small class="text-muted">@GetStatusHelpDescription(formModel.StatusId)</small>
                            </div>
                            <span class="@GetPeriodoBadgeCss(formModel.StatusId)">
                                @GetPeriodoStatusLabel(formModel.StatusId)
                            </span>
                        </div>
                    </Template>
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
        </DxFormLayout>
    </BodyContentTemplate>
    <FooterContentTemplate Context="popupFooter">
        <div class="d-flex justify-content-end gap-2 w-100">
            <DxButton Text="Cancelar"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      Click="CloseForm"
                      Enabled="@(!isSaving)" />
            <DxButton Text="@(isSaving ? "Guardando..." : "Guardar periodo")"
                      RenderStyle="ButtonRenderStyle.Primary"
                      IconCssClass="bi bi-check-lg"
                      Click="SavePeriodoAsync"
                      Enabled="@(!isSaving)" />
        </div>
    </FooterContentTemplate>
</DxPopup>

@* ── Popup de divergencias caché vs libro (F6) ── *@
<DxPopup @bind-Visible="isDivergenciasPopupVisible"
         Width="980px"
         MaxWidth="95vw"
         MinWidth="320px"
         MaxHeight="90vh"
         Scrollable="true"
         ShowCloseButton="true"
         CloseOnOutsideClick="true"
         HeaderText="Divergencias caché de saldos vs libro">
    <BodyContentTemplate Context="divergenciasBody">
        <p class="text-muted small mb-2">
            Cada fila es un (período, cuenta) donde con_saldo_cuenta no coincide con la suma de
            con_partida_dtl posteada. La corrección es la reconstrucción por SQL
            (sp_con_reconstruir_saldo_cuenta) en ventana de mantenimiento — ningún dato del libro se toca.
            Las filas FECHA_FUERA_PERIODO son pólizas con fecha fuera del rango de su período:
            se corrige la póliza, no el caché.
        </p>
        @if (saldoVerificacion?.DetalleTruncado == true)
        {
            <div class="alert alert-warning py-1 px-2 small mb-2">
                El detalle se truncó a @saldoVerificacion.Divergencias.Count filas; los contadores del aviso sí son totales.
            </div>
        }
        <DxGrid Data="@(saldoVerificacion?.Divergencias)"
                ShowPager="true"
                PageSize="10"
                SizeMode="SizeMode.Small"
                ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
                CssClass="border-0">
            <Columns>
                <DxGridDataColumn FieldName="@nameof(SaldoDivergenciaDto.PeriodoCode)" Caption="Periodo" Width="90px" />
                <DxGridDataColumn FieldName="@nameof(SaldoDivergenciaDto.CodigoCuenta)" Caption="Cuenta" Width="140px" />
                <DxGridDataColumn FieldName="@nameof(SaldoDivergenciaDto.TipoDivergencia)" Caption="Tipo" Width="110px" />
                <DxGridDataColumn FieldName="@nameof(SaldoDivergenciaDto.DebitosCache)" Caption="Débitos caché" DisplayFormat="{0:N2}" TextAlignment="GridTextAlignment.Right" />
                <DxGridDataColumn FieldName="@nameof(SaldoDivergenciaDto.DebitosLibro)" Caption="Débitos libro" DisplayFormat="{0:N2}" TextAlignment="GridTextAlignment.Right" />
                <DxGridDataColumn FieldName="@nameof(SaldoDivergenciaDto.CreditosCache)" Caption="Créditos caché" DisplayFormat="{0:N2}" TextAlignment="GridTextAlignment.Right" />
                <DxGridDataColumn FieldName="@nameof(SaldoDivergenciaDto.CreditosLibro)" Caption="Créditos libro" DisplayFormat="{0:N2}" TextAlignment="GridTextAlignment.Right" />
            </Columns>
        </DxGrid>
    </BodyContentTemplate>
</DxPopup>

@* ── Popup de cierre del período con checklist (F7) ── *@
<DxPopup @bind-Visible="isCierrePopupVisible"
         Width="640px"
         MaxWidth="95vw"
         Scrollable="true"
         CloseOnEscape="true"
         CloseOnOutsideClick="false"
         ShowFooter="true">
    <HeaderContentTemplate>
        <div class="d-flex align-items-center gap-2 p-1">
            <i class="bi bi-lock fs-4 text-danger"></i>
            <strong>Cierre del período @cierrePeriodo?.Code (@GetPeriodoStatusLabel(cierrePeriodo?.StatusId ?? -1))</strong>
        </div>
    </HeaderContentTemplate>
    <BodyContentTemplate Context="cierreBody">
        <div class="p-3">
            <ul class="list-group mb-3">
                @foreach (var item in checklistCierre)
                {
                    <li class="list-group-item d-flex align-items-start gap-2">
                        <i class="bi @(item.Ok ? "bi-check-circle-fill text-success" : "bi-x-circle-fill text-danger") mt-1"></i>
                        <div>
                            <div class="fw-semibold">@EtiquetaChecklistContable(item.Item)</div>
                            <small class="text-muted">@item.Detalle</small>
                        </div>
                    </li>
                }
            </ul>
            @if (cierrePeriodo?.StatusId == EstadoPeriodoHelper.AbiertoId)
            {
                <div class="alert @(ChecklistCierreOk ? "alert-success" : "alert-danger") mb-0">
                    @(ChecklistCierreOk
                        ? "Checklist en verde: el período puede pasar a precierre."
                        : "Resuelva los puntos marcados antes de pasar a precierre.")
                </div>
            }
            else if (cierrePeriodo?.StatusId == EstadoPeriodoHelper.PrecierreId)
            {
                <div class="alert @(ChecklistCierreOk ? "alert-warning" : "alert-danger") mb-0">
                    @(ChecklistCierreOk
                        ? "El cierre definitivo oficializa el período (los reportes pasan a leer el caché de saldos) y crea el período siguiente. No se reabre desde la aplicación."
                        : "El checklist dejó de estar en verde: resuelva los puntos o reabra el período.")
                </div>
            }
        </div>
    </BodyContentTemplate>
    <FooterContentTemplate Context="cierreFooter">
        <div class="p-2 d-flex justify-content-end gap-2">
            <DxButton RenderStyle="ButtonRenderStyle.Secondary" Text="Cancelar"
                      Click="@cierreFooter.CloseCallback" />
            @if (cierrePeriodo?.StatusId == EstadoPeriodoHelper.AbiertoId)
            {
                <DxButton RenderStyle="ButtonRenderStyle.Warning" Text="Pasar a precierre"
                          Enabled="@(ChecklistCierreOk && !IsBusy)"
                          Click="@PrecerrarPeriodoAsync" />
            }
            else if (cierrePeriodo?.StatusId == EstadoPeriodoHelper.PrecierreId)
            {
                <DxButton RenderStyle="ButtonRenderStyle.Secondary" Text="Reabrir"
                          Enabled="@(!IsBusy)"
                          Click="@ReabrirPeriodoAsync" />
                <DxButton RenderStyle="ButtonRenderStyle.Danger" Text="Cerrar definitivo"
                          Enabled="@(ChecklistCierreOk && !IsBusy)"
                          Click="@CerrarPeriodoDefinitivoAsync" />
            }
        </div>
    </FooterContentTemplate>
</DxPopup>

@code {
    private readonly PeriodoStatusOption[] statusOptions =
    [
        new(0, "Abierto"),
        new(1, "Precierre"),
        new(2, "Cerrado")
    ];

    private PeriodoContableDto[] periodos = Array.Empty<PeriodoContableDto>();
    private IGrid? periodosGrid;
    private PeriodoFormModel formModel = new();
    private bool isFormVisible;
    private bool isSaving;
    private bool isLoading;
    private bool isClosingPeriod;
    private bool isXSmallScreen;
    private string popupTitle = "Nuevo periodo";
    private bool statusMessageVisible;
    private string statusMessageTitle = string.Empty;
    private string statusMessageText = string.Empty;
    private MessageBoxRenderStyle statusMessageRenderStyle = MessageBoxRenderStyle.Info;
    private bool isCierrePopupVisible;
    private PeriodoContableDto? cierrePeriodo;
    private List<ChecklistCierreItemDto> checklistCierre = [];
    private bool isVerifyingSaldos;
    private bool isDivergenciasPopupVisible;
    private SaldoVerificacionResultDto? saldoVerificacion;

    private bool IsBusy => isLoading || isSaving || isClosingPeriod || isVerifyingSaldos;
    private bool ChecklistCierreOk => checklistCierre.Count > 0 && checklistCierre.All(i => i.Ok);
    private int OpenCount => periodos.Count(item => item.StatusId == EstadoPeriodoHelper.AbiertoId);
    private int PreCloseCount => periodos.Count(item => item.StatusId == EstadoPeriodoHelper.PrecierreId);
    private int ClosedCount => periodos.Count(item => item.StatusId == EstadoPeriodoHelper.CerradoId);
    private bool HasMultipleOpenPeriodos => OpenCount > 1;
    private PeriodoContableDto? CurrentOpenPeriodo => OpenCount == 1
        ? periodos.FirstOrDefault(item => item.StatusId == EstadoPeriodoHelper.AbiertoId)
        : null;

    protected override async Task OnInitializedAsync()
    {
        await LoadPeriodosAsync();
    }

    private async Task LoadPeriodosAsync()
    {
        try
        {
            isLoading = true;
            periodos = await Http.GetFromJsonAsync<PeriodoContableDto[]>("api/contabilidad/catalogos/periodos")
                ?? Array.Empty<PeriodoContableDto>();
        }
        catch (Exception ex)
        {
            periodos = Array.Empty<PeriodoContableDto>();
            ShowStatusMessage("Error", $"No se pudieron cargar los periodos: {ex.Message}", MessageBoxRenderStyle.Danger);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task VerificarSaldosAsync()
    {
        try
        {
            isVerifyingSaldos = true;
            var companyId = await TenantState.EnsureCompanyAsync();
            if (companyId <= 0)
            {
                ToastService.ShowToast(new ToastOptions { Title = "Saldos", Text = "No se pudo resolver la empresa actual.", RenderStyle = ToastRenderStyle.Danger });
                return;
            }

            saldoVerificacion = await PeriodosClient.VerificarSaldosAsync(companyId);
        }
        catch (UnauthorizedAccessException)
        {
            saldoVerificacion = null;
            ShowStatusMessage("Sesión expirada", "La sesión expiró. Vuelve a iniciar sesión.", MessageBoxRenderStyle.Danger);
        }
        catch (Exception ex)
        {
            saldoVerificacion = null;
            ToastService.ShowToast(new ToastOptions { Title = "Saldos", Text = $"No se pudo verificar: {ex.Message}", RenderStyle = ToastRenderStyle.Danger });
        }
        finally
        {
            isVerifyingSaldos = false;
        }
    }

    private void OpenForm(PeriodoContableDto? periodo)
    {
        if (periodo is null)
        {
            formModel = new PeriodoFormModel
            {
                StatusId = EstadoPeriodoHelper.AbiertoId,
                StartDate = DateTime.Today,
                EndDate = DateTime.Today
            };
            popupTitle = "Nuevo periodo";
        }
        else
        {
            formModel = new PeriodoFormModel
            {
                PeriodId = periodo.PeriodId,
                Code = periodo.Code,
                Name = periodo.Name,
                StartDate = periodo.StartDate,
                EndDate = periodo.EndDate,
                StatusId = periodo.StatusId
            };
            popupTitle = $"Editar {periodo.Code}";
        }

        isFormVisible = true;
    }

    private void CloseForm()
    {
        isFormVisible = false;
    }

    private async Task SavePeriodoAsync()
    {
        if (string.IsNullOrWhiteSpace(formModel.Code) || string.IsNullOrWhiteSpace(formModel.Name))
        {
            ToastService.ShowToast(new ToastOptions { Title = "Periodos", Text = "Codigo y nombre son obligatorios.", RenderStyle = ToastRenderStyle.Danger });
            return;
        }

        if (formModel.EndDate < formModel.StartDate)
        {
            ToastService.ShowToast(new ToastOptions { Title = "Periodos", Text = "La fecha final debe ser posterior o igual al inicio.", RenderStyle = ToastRenderStyle.Danger });
            return;
        }

        var payload = new PeriodoContableUpsertDto(
            formModel.Code.Trim(),
            formModel.Name.Trim(),
            formModel.StartDate,
            formModel.EndDate,
            string.Empty,
            string.Empty,
            formModel.PeriodId,
            formModel.StatusId);

        try
        {
            isSaving = true;

            var response = await Http.PostAsJsonAsync("api/contabilidad/catalogos/periodos", payload);
            var detail = await response.Content.ReadAsStringAsync();

            if (!response.IsSuccessStatusCode)
            {
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Periodos",
                    Text = string.IsNullOrWhiteSpace(detail) ? "No se pudo guardar el periodo." : detail,
                    RenderStyle = ToastRenderStyle.Danger
                });
                return;
            }

            isFormVisible = false;
            await LoadPeriodosAsync();
            ShowStatusMessage("Exito", "Periodo guardado correctamente.", MessageBoxRenderStyle.Success);
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions { Title = "Periodos", Text = ex.Message, RenderStyle = ToastRenderStyle.Danger });
        }
        finally
        {
            isSaving = false;
        }
    }

    // ── Cierre con checklist (F7): abierto → precierre → cerrado ──

    private async Task AbrirCierrePeriodoAsync(PeriodoContableDto periodo)
    {
        if (IsPeriodoClosed(periodo) || IsBusy)
        {
            return;
        }

        try
        {
            isClosingPeriod = true;
            cierrePeriodo = periodo;
            checklistCierre = await Http.GetFromJsonAsyncWithAuthCheck<List<ChecklistCierreItemDto>>(
                $"api/contabilidad/catalogos/periodos/{periodo.PeriodId}/checklist-cierre") ?? [];
            isCierrePopupVisible = true;
        }
        catch (Exception ex)
        {
            ShowStatusMessage("Error", $"No se pudo evaluar el checklist de cierre: {ex.Message}", MessageBoxRenderStyle.Danger);
        }
        finally
        {
            isClosingPeriod = false;
        }
    }

    private Task PrecerrarPeriodoAsync() =>
        EjecutarTransicionCierreAsync("precerrar", $"Período {cierrePeriodo?.Code} en precierre.");

    private Task ReabrirPeriodoAsync() =>
        EjecutarTransicionCierreAsync("reabrir", $"Período {cierrePeriodo?.Code} reabierto.");

    private Task CerrarPeriodoDefinitivoAsync() =>
        EjecutarTransicionCierreAsync("cerrar", $"Período {cierrePeriodo?.Code} cerrado. Se habilitó el período siguiente.");

    private async Task EjecutarTransicionCierreAsync(string accion, string mensajeExito)
    {
        if (cierrePeriodo is null)
        {
            return;
        }

        try
        {
            isClosingPeriod = true;

            var response = await Http.PostAsync(
                $"api/contabilidad/catalogos/periodos/{cierrePeriodo.PeriodId}/{accion}", null);

            if (!response.IsSuccessStatusCode)
            {
                var detail = await HttpClientExtensions.ObtenerMensajeErrorAsync(response);
                ShowStatusMessage("Cierre bloqueado",
                    string.IsNullOrWhiteSpace(detail) ? "No se pudo completar la transición." : detail,
                    MessageBoxRenderStyle.Danger);
                return;
            }

            isCierrePopupVisible = false;
            cierrePeriodo = null;
            await LoadPeriodosAsync();
            ShowStatusMessage("Exito", mensajeExito, MessageBoxRenderStyle.Success);
        }
        catch (Exception ex)
        {
            ShowStatusMessage("Error", $"No se pudo completar la transición: {ex.Message}", MessageBoxRenderStyle.Danger);
        }
        finally
        {
            isClosingPeriod = false;
        }
    }

