    private int TiposConCentroCosto => tipos?.Count(t => t.AllowsCostCenter) ?? 0;


    private TipoTransaccionDto? SelectedTipo
    {
        get => selectedTipo;
        set => selectedTipo = value;
    }

    protected override async Task OnInitializedAsync()
    {
        await TenantState.EnsureCompanyAsync();
        await LoadLookupsAsync();
        await LoadTiposAsync();
    }

    private Task OnRefreshClick(MouseEventArgs e) => LoadTiposAsync();

    private async Task OnSelectedTipoChanged(TipoTransaccionDto newValue)
    {
        if (ReferenceEquals(selectedTipo, newValue))
            return;

        selectedTipo = newValue;
        await OnSelectedTipoChangedAsync();
    }

    private async Task LoadTiposAsync()
    {
        try
        {
            isLoading = true;
            pageError = null;
            
            tipos = await Http.GetFromJsonAsync<List<TipoTransaccionDto>>("api/contabilidad/catalogos/tipos-transaccion")
                    ?? new List<TipoTransaccionDto>();

            var currentId = selectedTipo?.TypeId;
            selectedTipo = currentId.HasValue
                ? tipos.FirstOrDefault(t => t.TypeId == currentId.Value)
                : tipos.FirstOrDefault();

            await OnSelectedTipoChangedAsync();
        }
        catch (Exception ex)
        {
            pageError = $"Error al cargar tipos: {ex.Message}";
            tipos = new List<TipoTransaccionDto>();
            rules = new List<TipoTransaccionRuleDto>();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task LoadLookupsAsync()
    {
        try
        {
            var cuentas = await Http.GetFromJsonAsync<List<PlanCuentaDto>>("api/contabilidad/catalogos/plan-cuentas")
                          ?? new();
            accountOptions = cuentas
                .Where(c => !string.IsNullOrWhiteSpace(c.Code))
                .Select(c => new SimpleLookup
                {
                    Code = c.Code!,
                    Display = string.IsNullOrWhiteSpace(c.Description)
                        ? AccountCodeFormatter.Format(c.Code!)
                        : AccountCodeFormatter.FormatDisplay(c.Code, c.Description)
                })
                .OrderBy(x => x.Code, StringComparer.OrdinalIgnoreCase)
                .ToList();

            var centros = await Http.GetFromJsonAsync<List<CentroCostoDto>>("api/contabilidad/catalogos/centros-costo")
                          ?? new();
            costCenterOptions = centros
                .Where(c => !string.IsNullOrWhiteSpace(c.Code))
                .Select(c => new SimpleLookup
                {
                    Code = c.Code!,
                    Display = string.IsNullOrWhiteSpace(c.Name)
                        ? c.Code!
                        : $"{c.Code} - {c.Name}"
                })
                .OrderBy(x => x.Code, StringComparer.OrdinalIgnoreCase)
                .ToList();
        }
        catch (Exception ex)
        {
            pageError = $"Error al cargar catálogos: {ex.Message}";
        }
    }

    private async Task OnSelectedTipoChangedAsync()
    {
        if (selectedTipo is null)
        {
            rules = new List<TipoTransaccionRuleDto>();
            return;
        }

        await LoadRulesAsync(selectedTipo.TypeId);
    }

    private async Task LoadRulesAsync(long typeId)
    {
        try
        {
            rulesLoading = true;
            rules = await Http.GetFromJsonAsync<List<TipoTransaccionRuleDto>>(
                        $"api/contabilidad/catalogos/tipos-transaccion/{typeId}/rules")
                    ?? new List<TipoTransaccionRuleDto>();
        }
        catch (Exception ex)
        {
            pageError = $"Error al cargar reglas: {ex.Message}";
            rules = new List<TipoTransaccionRuleDto>();
        }
        finally
        {
            rulesLoading = false;
        }
    }

    private void OpenTipoForm(TipoTransaccionDto? item)
    {
        tipoFormError = null;

        if (item is null)
        {
            tipoEdit = new TipoTransaccionEditModel
            {
                IsNew = true,
                Category = "GENERAL",
                MaxEntries = 0,
                TypeTrans = 0,
                TypeOper = 0,
                Frequency = 0,
                DocumentSequenceStart = 1,
                LastDocumentNumber = 0,
                NextDocumentNumber = 1,
                HasPolizas = false
            };
        }
        else
        {
            tipoEdit = new TipoTransaccionEditModel
            {
                IsNew = false,
                TypeId = item.TypeId,
                Code = item.Code ?? string.Empty,
                Name = item.Name ?? string.Empty,
                Description = item.Desciption ?? string.Empty,
                Category = item.Category ?? string.Empty,
                TypeTrans = item.TypeTrans,
                TypeOper = item.TypeOper,
                Frequency = item.Frequency,
                MaxEntries = item.MaxEntries,
                AllowsCostCenter = item.AllowsCostCenter,
                AllowsThirdParty = item.AllowsThirdParty,
                AllowsCashFlow = item.AllowsCashFlow,
                AllowsAccountLimit = item.AllowsAccountLimit,
                IsDefault = item.IsDefault,
                IsAutomatic = item.IsAutomatic,
                DocumentSequenceStart = item.DocumentSequenceStart,
                LastDocumentNumber = item.LastDocumentNumber,
                NextDocumentNumber = item.NextDocumentNumber,
                HasPolizas = item.HasPolizas
            };
        }

        tipoFormVisible = true;
    }

    private void CloseTipoForm()
    {
        tipoFormVisible = false;
        tipoFormError = null;
    }

    private async Task SaveTipoAsync()
    {
        var validation = ValidateTipo(tipoEdit);
        if (!string.IsNullOrWhiteSpace(validation))
        {
            tipoFormError = validation;
            return;
        }

        var payload = new TipoTransaccionUpsertDto(
            Code: tipoEdit.Code.Trim(),
            Name: tipoEdit.Name.Trim(),
            Description: string.IsNullOrWhiteSpace(tipoEdit.Description) ? null : tipoEdit.Description.Trim(),
            Category: tipoEdit.Category.Trim(),
            TypeTrans: tipoEdit.TypeTrans,
            TypeOper: tipoEdit.TypeOper,
            Frequency: tipoEdit.Frequency,
            MaxEntries: tipoEdit.MaxEntries,
            AllowsCostCenter: tipoEdit.AllowsCostCenter,
            AllowsThirdParty: tipoEdit.AllowsThirdParty,
            AllowsCashFlow: tipoEdit.AllowsCashFlow,
            AllowsAccountLimit: tipoEdit.AllowsAccountLimit,
            IsDefault: tipoEdit.IsDefault,
            IsAutomatic: tipoEdit.IsAutomatic,
            User: "system",
            TypeId: tipoEdit.TypeId,
            DocumentSequenceStart: tipoEdit.DocumentSequenceStart);

        try
        {
            tipoFormError = null;
            var response = await Http.PostAsJsonAsync("api/contabilidad/catalogos/tipos-transaccion", payload);
            
            if (!response.IsSuccessStatusCode)
            {
                var msg = await response.Content.ReadAsStringAsync();
                tipoFormError = string.IsNullOrWhiteSpace(msg) ? "Error al guardar (Server)." : msg;
                return;
            }

            tipoFormVisible = false;
            await LoadTiposAsync();
        }
        catch (Exception ex)
        {
            tipoFormError = ex.Message;
        }
    }

    private static string? ValidateTipo(TipoTransaccionEditModel model)
    {
        if (string.IsNullOrWhiteSpace(model.Code)) return "El código es obligatorio.";
        if (string.IsNullOrWhiteSpace(model.Name)) return "El nombre es obligatorio.";
        if (string.IsNullOrWhiteSpace(model.Category)) return "La categoría es obligatoria.";
        if (model.TypeTrans < 0 || model.TypeTrans > 5) return "Tipo transacción inválido (0-5).";
        if (model.TypeOper < 0 || model.TypeOper > 10) return "Tipo operación inválido (0-10).";
        if (model.Frequency < 0 || model.Frequency > 2) return "Frecuencia inválida (0-2).";
        if (model.MaxEntries < 0) return "Límite debe ser >= 0.";
        if (model.DocumentSequenceStart < 1) return "El número inicial debe ser mayor o igual a 1.";
        return null;
    }

    private static string FormatSequence(long value) => value.ToString("N0");

    private static long GetNextDocumentPreview(TipoTransaccionEditModel model)
        => Math.Max(model.DocumentSequenceStart, model.LastDocumentNumber + 1);

    private static string GetLastDocumentLabel(long value) => value > 0 ? FormatSequence(value) : "Sin uso";

    private static string GetSequenceStatusText(bool hasPolizas) => hasPolizas ? "En uso" : "Editable";

    private static string GetSequenceStatusCss(bool hasPolizas)
        => hasPolizas ? "tipo-sequence-cell__status is-locked" : "tipo-sequence-cell__status is-open";

