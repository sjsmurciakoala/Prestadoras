            NullIfWhite(ruleEdit.CostCenterCodeFrom),
            NullIfWhite(ruleEdit.CostCenterCodeTo),
            NullIfWhite(ruleEdit.ThirdPartyCodeFrom),
            NullIfWhite(ruleEdit.ThirdPartyCodeTo),
            ruleEdit.IsActive,
            "system",
            ruleEdit.RuleId);

        try
        {
            ruleFormError = null;
            var response = await Http.PostAsJsonAsync(
                $"api/contabilidad/catalogos/tipos-transaccion/{SelectedTipo.TypeId}/rules", payload);

            if (!response.IsSuccessStatusCode)
            {
                var msg = await response.Content.ReadAsStringAsync();
                ruleFormError = string.IsNullOrWhiteSpace(msg) ? "Error al guardar regla (Server)." : msg;
