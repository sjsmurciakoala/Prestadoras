@page "/contabilidad/tipos-transaccion"
@attribute [Authorize]

@using DevExpress.Blazor
@using System.Net.Http.Json
@using System.Linq
@using Microsoft.AspNetCore.Components.Web
@using apc.Client.Services.Tenant
@using SIAD.Core.DTOs.Contabilidad

@inject HttpClient Http
@inject TenantState TenantState

<PageTitle>SIAD - Tipos de transacción</PageTitle>

@* ═══════════════════════════════════════════════════════════════════════════
   LOADING PANEL GLOBAL
   ═══════════════════════════════════════════════════════════════════════════ *@
<DxLoadingPanel @bind-Visible="@isLoading"
                PositionTarget="body"
                ApplyBackgroundShading="true"
                IsContentBlocked="true"
                Text="Cargando..." />

<div class="tipos-transaccion-page" id="tipos-transaccion-view">
    @* ═══════════════════════════════════════════════════════════════════════════
       HEADER CON TOOLBAR PRINCIPAL
       ═══════════════════════════════════════════════════════════════════════════ *@
    <section class="tipos-hero mb-3">
        <div class="tipos-hero__copy">
            <span class="tipos-hero__eyebrow">Contabilidad</span>
            <h1 class="tipos-hero__title">Tipos de transacción</h1>
            <p class="tipos-hero__subtitle">Configuración de tipos de comprobantes contables y sus reglas de validación.</p>
        </div>
        <div class="tipos-hero__actions">
            <DxButton Text="Nuevo tipo"
                      IconCssClass="bi bi-plus-lg"
                      RenderStyle="ButtonRenderStyle.Primary"
                      Click="@(() => OpenTipoForm(null))" />
            <DxButton Text="Editar"
                      IconCssClass="bi bi-pencil-square"
                      RenderStyle="ButtonRenderStyle.Info"
                      Enabled="@(SelectedTipo is not null && !tipoFormVisible)"
                      Click="@(() => OpenTipoForm(SelectedTipo))" />
            <DxButton Text="Eliminar"
                      IconCssClass="bi bi-trash"
                      RenderStyle="ButtonRenderStyle.Danger"
                      Enabled="@(SelectedTipo is not null)"
                      Click="@(() => OpenDeleteTipoConfirm(SelectedTipo))" />
            <DxButton IconCssClass="bi bi-arrow-clockwise"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      Click="@(async _ => await LoadTiposAsync())" />
        </div>
    </section>

    @* Alerta de error global *@
    @if (!string.IsNullOrWhiteSpace(pageError))
    {
        <div class="alert alert-danger d-flex align-items-center mb-3" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            <div>@pageError</div>
            <button type="button" class="btn-close ms-auto" @onclick="() => pageError = null"></button>
        </div>
    }

    @* ═══════════════════════════════════════════════════════════════════════════
       CONTENIDO PRINCIPAL - Dos paneles (Catálogo y Reglas)
       ═══════════════════════════════════════════════════════════════════════════ *@
    <div class="row g-3">
        @* ─────────────────────────────────────────────────────────────────────────
           PANEL IZQUIERDO: Catálogo de Tipos
           ───────────────────────────────────────────────────────────────────────── *@
        <div class="col-12 col-xl-7">
            <div class="tipos-shell" id="catalog-panel">
                <div class="tipos-shell__header">
                    <div>
                        <i class="bi bi-list-check me-2 text-primary"></i>
                        <span class="fw-bold">Catálogo</span>
                        <small class="text-muted ms-2">Tipos disponibles</small>
                    </div>
                    <span class="tipos-pill">
                        <i class="bi bi-list-check me-1"></i> @(tipos?.Count ?? 0)
                    </span>
                </div>
                <div class="tipos-shell__body p-0">
                    <DxGrid Data="@tipos"
                            KeyFieldName="@nameof(TipoTransaccionDto.TypeId)"
                            SelectionMode="GridSelectionMode.Single"
                            AllowSelectRowByClick="true"
                            SelectedDataItem="@SelectedTipo"
                            SelectedDataItemChanged="@((object item) => OnSelectedTipoChanged((TipoTransaccionDto)item))"
                            FocusedRowEnabled="true"
                            HighlightRowOnHover="true"
                            TextWrapEnabled="false"
                            ShowFilterRow="true"
                            ShowSearchBox="true"
                            SearchBoxNullText="Buscar tipos..."
                            ColumnResizeMode="GridColumnResizeMode.NextColumn"
                            PageSize="10"
                            PageSizeSelectorVisible="true"
                            PageSizeSelectorItems="@(new[] { 5, 10, 20 })"
                            SizeMode="SizeMode.Medium"
                            PagerPosition="GridPagerPosition.Bottom">
                        <Columns>
                            <DxGridDataColumn FieldName="@nameof(TipoTransaccionDto.Code)"
                                              Caption="Código"
                                              Width="100px"
                                              FilterRowOperatorType="GridFilterRowOperatorType.Contains" />
                            <DxGridDataColumn FieldName="@nameof(TipoTransaccionDto.Name)"
                                              Caption="Nombre"
                                              MinWidth="180"
                                              FilterRowOperatorType="GridFilterRowOperatorType.Contains" />
                            <DxGridDataColumn Caption="Correlativo"
                                              MinWidth="200"
                                              AllowSort="false">
                                <CellDisplayTemplate Context="cell">
                                    @if (cell.DataItem is TipoTransaccionDto item)
                                    {
                                        <div class="tipo-sequence-cell">
                                            <div class="tipo-sequence-cell__top">
                                                <strong class="tipo-sequence-cell__value">@FormatSequence(item.NextDocumentNumber)</strong>
                                                <span class="@GetSequenceStatusCss(item.HasPolizas)">@GetSequenceStatusText(item.HasPolizas)</span>
                                            </div>
                                            <span class="tipo-sequence-cell__meta">Inicio @FormatSequence(item.DocumentSequenceStart) · Último @GetLastDocumentLabel(item.LastDocumentNumber)</span>
                                        </div>
                                    }
                                </CellDisplayTemplate>
                            </DxGridDataColumn>
                            <DxGridDataColumn Caption="Configuración"
                                              MinWidth="140"
                                              TextAlignment="GridTextAlignment.Center"
                                              AllowSort="false"
                                              AllowFilter="false">
                                <CellDisplayTemplate Context="cell">
                                    @if (cell.DataItem is TipoTransaccionDto item)
                                    {
                                        <div class="d-flex gap-1 justify-content-center flex-wrap">
                                            @if (item.AllowsCostCenter) { <span class="badge bg-warning text-dark" title="Centros Costo">CC</span> }
                                            @if (item.AllowsThirdParty) { <span class="badge bg-info text-dark" title="Terceros">TE</span> }
                                            @if (item.AllowsCashFlow) { <span class="badge bg-secondary" title="Flujo Efectivo">FE</span> }
                                            @if (item.IsDefault) { <span class="badge bg-success" title="Tipo por defecto">DF</span> }
                                            @if (item.IsAutomatic) { <span class="badge bg-primary" title="Tipo automático">AU</span> }
                                        </div>
                                    }
                                </CellDisplayTemplate>
                            </DxGridDataColumn>
                        </Columns>
                    </DxGrid>
                </div>
            </div>
        </div>

        @* ─────────────────────────────────────────────────────────────────────────
           PANEL DERECHO: Reglas del Tipo Seleccionado
           ───────────────────────────────────────────────────────────────────────── *@
        <div class="col-12 col-xl-5">
            <div class="tipos-shell" id="rules-panel">
                <div class="tipos-shell__header">
                    <div>
                        <i class="bi bi-diagram-3 me-2 text-primary"></i>
                        <span class="fw-bold">Reglas</span>
                        <small class="text-muted ms-2">
                            @if (SelectedTipo is null)
                            {
                                <span>Seleccione un tipo para gestionar reglas</span>
                            }
                            else
                            {
                                <span>Aplican a: <strong>@SelectedTipo.Code</strong> - @SelectedTipo.Name</span>
                            }
                        </small>
                    </div>
                    <DxButton Text="Nueva Regla"
                              RenderStyle="ButtonRenderStyle.Primary"
                              RenderStyleMode="ButtonRenderStyleMode.Outline"
                              IconCssClass="bi bi-plus-lg"
                              Enabled="@(SelectedTipo is not null)"
                              Click="@(() => OpenRuleForm(null))"
                              SizeMode="SizeMode.Small" />
                </div>
                <div class="tipos-shell__body p-0 position-relative" id="rules-panel-body" style="min-height:200px;">
                    @if (SelectedTipo is null)
                    {
                        <div class="d-flex flex-column align-items-center justify-content-center h-100 p-5 text-muted opacity-50">
                            <i class="bi bi-arrow-left-square fs-1 mb-2 d-none d-xl-block"></i>
                            <i class="bi bi-arrow-up-square fs-1 mb-2 d-xl-none"></i>
                            <div class="text-center">Seleccione un tipo para ver sus reglas</div>
                        </div>
                    }
                    else
                    {
                        <DxGrid Data="@rules"
                                KeyFieldName="@nameof(TipoTransaccionRuleDto.RuleId)"
                                FocusedRowEnabled="true"
                                HighlightRowOnHover="true"
                                TextWrapEnabled="false"
                                PageSize="10"
                                ShowSearchBox="true"
                                SearchBoxNullText="Buscar reglas..."
                                SizeMode="SizeMode.Small"
                                PagerPosition="GridPagerPosition.Bottom">
                            <Columns>
                                <DxGridDataColumn Caption=" " Width="90px" AllowSort="false" TextAlignment="GridTextAlignment.Center">
                                    <CellDisplayTemplate Context="cell">
                                        <div class="d-flex gap-1 justify-content-center">
                                            <DxButton RenderStyle="ButtonRenderStyle.Info"
                                                      RenderStyleMode="ButtonRenderStyleMode.Text"
                                                      IconCssClass="bi bi-pencil-square"
                                                      SizeMode="SizeMode.Small"
                                                      Click="@(() => OpenRuleForm((TipoTransaccionRuleDto)cell.DataItem))" />
                                            <DxButton RenderStyle="ButtonRenderStyle.Danger"
                                                      RenderStyleMode="ButtonRenderStyleMode.Text"
                                                      IconCssClass="bi bi-trash"
                                                      SizeMode="SizeMode.Small"
                                                      Click="@(() => OpenDeleteRuleConfirm((TipoTransaccionRuleDto)cell.DataItem))" />
                                        </div>
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                                <DxGridDataColumn FieldName="@nameof(TipoTransaccionRuleDto.LineNumber)"
                                                  Caption="#"
                                                  Width="50px"
                                                  TextAlignment="GridTextAlignment.Center"
                                                  SortIndex="0"
                                                  SortOrder="GridColumnSortOrder.Ascending" />
                                <DxGridDataColumn FieldName="@nameof(TipoTransaccionRuleDto.AccountCodeFrom)" Caption="Cta. Desde">
                                    <CellDisplayTemplate Context="cell">
                                        @AccountCodeFormatter.Format(((TipoTransaccionRuleDto)cell.DataItem).AccountCodeFrom)
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                                <DxGridDataColumn FieldName="@nameof(TipoTransaccionRuleDto.AccountCodeTo)" Caption="Cta. Hasta">
                                    <CellDisplayTemplate Context="cell">
                                        @AccountCodeFormatter.Format(((TipoTransaccionRuleDto)cell.DataItem).AccountCodeTo)
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                                <DxGridDataColumn Caption="Act" Width="55px" TextAlignment="GridTextAlignment.Center" AllowSort="false">
                                    <CellDisplayTemplate Context="cell">
                                        @if (((TipoTransaccionRuleDto)cell.DataItem).IsActive)
                                        {
                                            <i class="bi bi-check-circle-fill text-success" title="Regla activa"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-circle text-muted" title="Regla inactiva"></i>
                                        }
                                    </CellDisplayTemplate>
                                </DxGridDataColumn>
                            </Columns>
                        </DxGrid>
                    }
                    <DxLoadingPanel @bind-Visible="@rulesLoading"
                                    PositionTarget="#rules-panel-body"
                                    ApplyBackgroundShading="true"
                                    IsContentBlocked="true"
                                    Text="Cargando reglas..." />
                </div>
            </div>
        </div>
    </div>
</div>

@* ═══════════════════════════════════════════════════════════════════════════
   POPUP: Formulario de Tipo de Transacción
   ═══════════════════════════════════════════════════════════════════════════ *@
<DxPopup @bind-Visible="tipoFormVisible"
         HeaderText="@(tipoEdit.IsNew ? "Nuevo tipo de transacción" : "Editar tipo de transacción")"
         ShowFooter="true"
         Width="min(920px, 96vw)"
         ShowCloseButton="true"
         CloseOnOutsideClick="false"
         CloseOnEscape="true">
    <BodyContentTemplate Context="popupContext">
        @if (!string.IsNullOrWhiteSpace(tipoFormError))
        {
            <div class="alert alert-danger d-flex align-items-center mb-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <div>@tipoFormError</div>
            </div>
        }

        <DxFormLayout CssClass="w-100" CaptionPosition="CaptionPosition.Vertical">
            <DxFormLayoutGroup Caption="Información General" ColSpanMd="12">
                <DxFormLayoutItem ColSpanMd="4" ColSpanXs="12" Caption="Código *">
                    <DxTextBox @bind-Text="tipoEdit.Code"
                               ReadOnly="@(!tipoEdit.IsNew)"
                               NullText="Ingrese código..." />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="8" ColSpanXs="12" Caption="Nombre *">
                    <DxTextBox @bind-Text="tipoEdit.Name"
                               NullText="Ingrese nombre del tipo..." />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="12" Caption="Descripción">
                    <DxMemo @bind-Text="tipoEdit.Description"
                            Rows="2"
                            NullText="Descripción opcional..." />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12" Caption="Categoría *">
                    <DxTextBox @bind-Text="tipoEdit.Category"
                               NullText="Ej: GENERAL" />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12" Caption="Límite docs">
                    <DxSpinEdit T="int"
                                @bind-Value="tipoEdit.MaxEntries"
                                MinValue="0" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>

            <DxFormLayoutGroup Caption="Correlativo" ColSpanMd="12" CssClass="mt-3">
                <DxFormLayoutItem ColSpanMd="5" ColSpanXs="12" Caption="Número inicial">
                    <DxSpinEdit T="long"
                                @bind-Value="tipoEdit.DocumentSequenceStart"
                                MinValue="1"
                                ReadOnly="@tipoEdit.HasPolizas" />
                    @if (tipoEdit.HasPolizas)
                    {
                        <small class="text-muted d-block mt-2">
                            <i class="bi bi-lock me-1"></i>Bloqueado: este tipo ya tiene pólizas registradas.
                        </small>
                    }
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="7" ColSpanXs="12" Caption="Vista previa">
                    <div class="tipo-sequence-card">
                        <div class="tipo-sequence-card__row">
                            <span class="tipo-sequence-card__label">Siguiente No. documento</span>
                            <strong class="tipo-sequence-card__value">@FormatSequence(GetNextDocumentPreview(tipoEdit))</strong>
                        </div>
                        <div class="tipo-sequence-card__row">
                            <span class="tipo-sequence-card__label">Último usado</span>
                            <strong class="tipo-sequence-card__value">@GetLastDocumentLabel(tipoEdit.LastDocumentNumber)</strong>
                        </div>
                        <div class="tipo-sequence-card__row">
                            <span class="tipo-sequence-card__label">Estado</span>
                            <strong class="tipo-sequence-card__value">@(tipoEdit.HasPolizas ? "En uso" : "Editable")</strong>
                        </div>
                    </div>
                </DxFormLayoutItem>
            </DxFormLayoutGroup>

            <DxFormLayoutGroup Caption="Configuración Técnica" ColSpanMd="12" CssClass="mt-3">
                <DxFormLayoutItem ColSpanMd="4" ColSpanXs="6" Caption="Contabilización">
                    <DxComboBox Data="@typeTransOptions"
                                TextFieldName="Text"
                                ValueFieldName="Value"
                                @bind-Value="tipoEdit.TypeTrans" />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="4" ColSpanXs="6" Caption="Aplicable a">
                    <DxComboBox Data="@typeOperOptions"
                                TextFieldName="Text"
                                ValueFieldName="Value"
                                @bind-Value="tipoEdit.TypeOper" />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="4" ColSpanXs="6" Caption="Frecuencia">
                    <DxComboBox Data="@frequencyOptions"
                                TextFieldName="Text"
                                ValueFieldName="Value"
                                @bind-Value="tipoEdit.Frequency" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>

            <DxFormLayoutGroup Caption="Opciones" ColSpanMd="12" CssClass="mt-3">
                <DxFormLayoutItem ColSpanMd="4" ColSpanXs="6">
                    <DxCheckBox @bind-Checked="tipoEdit.AllowsCostCenter" CheckType="CheckType.Switch">Centros Costo</DxCheckBox>
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="4" ColSpanXs="6">
                    <DxCheckBox @bind-Checked="tipoEdit.AllowsThirdParty" CheckType="CheckType.Switch">Terceros</DxCheckBox>
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="4" ColSpanXs="6">
                    <DxCheckBox @bind-Checked="tipoEdit.AllowsCashFlow" CheckType="CheckType.Switch">Flujo Efectivo</DxCheckBox>
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="4" ColSpanXs="6">
                    <DxCheckBox @bind-Checked="tipoEdit.IsDefault" CheckType="CheckType.Switch">Por defecto</DxCheckBox>
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="4" ColSpanXs="6">
                    <DxCheckBox @bind-Checked="tipoEdit.IsAutomatic" CheckType="CheckType.Switch">Automático</DxCheckBox>
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
        </DxFormLayout>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton Text="Cancelar"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  Click="@CloseTipoForm" />
        <DxButton Text="Guardar"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Click="@SaveTipoAsync"
                  IconCssClass="bi bi-check-lg" />
    </FooterContentTemplate>
</DxPopup>

@* ═══════════════════════════════════════════════════════════════════════════
   POPUP: Formulario de Regla
   ═══════════════════════════════════════════════════════════════════════════ *@
<DxPopup @bind-Visible="ruleFormVisible"
         HeaderText="@ruleFormHeader"
         ShowFooter="true"
         Width="min(700px, 95vw)"
         ShowCloseButton="true"
         CloseOnOutsideClick="false"
         CloseOnEscape="true">
    <BodyContentTemplate Context="popupContext">
        @if (!string.IsNullOrWhiteSpace(ruleFormError))
        {
            <div class="alert alert-danger d-flex align-items-center mb-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <div>@ruleFormError</div>
            </div>
        }
        <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
            <DxFormLayoutItem ColSpanMd="6" ColSpanXs="6" Caption="Línea">
                <DxSpinEdit T="int"
                            @bind-Value="ruleEdit.LineNumber"
                            MinValue="1"
                            ReadOnly="true" />
            </DxFormLayoutItem>
            <DxFormLayoutItem ColSpanMd="6" ColSpanXs="6">
                <DxCheckBox @bind-Checked="ruleEdit.IsActive" CheckType="CheckType.Switch">Regla Activa</DxCheckBox>
            </DxFormLayoutItem>

            <DxFormLayoutGroup Caption="Rangos de Cuentas" ColSpanMd="12" CssClass="mt-2">
                <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12" Caption="Desde">
                    <DxComboBox Data="@accountOptions"
                                TextFieldName="Display"
                                ValueFieldName="Code"
                                @bind-Value="ruleEdit.AccountCodeFrom"
                                SearchMode="ListSearchMode.AutoSearch"
                                SearchFilterCondition="ListSearchFilterCondition.Contains"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                NullText="Buscar cuenta..."
                                ListRenderMode="ListRenderMode.Virtual" />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12" Caption="Hasta">
                    <DxComboBox Data="@accountOptions"
                                TextFieldName="Display"
                                ValueFieldName="Code"
                                @bind-Value="ruleEdit.AccountCodeTo"
                                SearchMode="ListSearchMode.AutoSearch"
                                SearchFilterCondition="ListSearchFilterCondition.Contains"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                NullText="Buscar cuenta..."
                                ListRenderMode="ListRenderMode.Virtual" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>

            <DxFormLayoutGroup Caption="Rangos de Centros" ColSpanMd="12" CssClass="mt-2">
                <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12" Caption="Desde">
                    <DxComboBox Data="@costCenterOptions"
                                TextFieldName="Display"
                                ValueFieldName="Code"
                                @bind-Value="ruleEdit.CostCenterCodeFrom"
                                SearchMode="ListSearchMode.AutoSearch"
                                SearchFilterCondition="ListSearchFilterCondition.Contains"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                NullText="Buscar centro..."
                                ListRenderMode="ListRenderMode.Virtual" />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12" Caption="Hasta">
                    <DxComboBox Data="@costCenterOptions"
                                TextFieldName="Display"
                                ValueFieldName="Code"
                                @bind-Value="ruleEdit.CostCenterCodeTo"
                                SearchMode="ListSearchMode.AutoSearch"
                                SearchFilterCondition="ListSearchFilterCondition.Contains"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                NullText="Buscar centro..."
                                ListRenderMode="ListRenderMode.Virtual" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>

            <DxFormLayoutGroup Caption="Rangos de Terceros" ColSpanMd="12" CssClass="mt-2">
                <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12" Caption="Desde">
                    <DxTextBox @bind-Text="ruleEdit.ThirdPartyCodeFrom"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                               NullText="Código tercero desde..." />
                </DxFormLayoutItem>
                <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12" Caption="Hasta">
                    <DxTextBox @bind-Text="ruleEdit.ThirdPartyCodeTo"
                               ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                               NullText="Código tercero hasta..." />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
        </DxFormLayout>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton Text="Cancelar"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  Click="@CloseRuleForm" />
        <DxButton Text="Guardar"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Click="@SaveRuleAsync"
                  IconCssClass="bi bi-check-lg" />
    </FooterContentTemplate>
</DxPopup>

@* ═══════════════════════════════════════════════════════════════════════════
   POPUP: Confirmar eliminación de Tipo
   ═══════════════════════════════════════════════════════════════════════════ *@
<DxPopup @bind-Visible="deleteTipoVisible"
         HeaderText="Confirmar eliminación"
         Width="420px"
         ShowFooter="true"
         CloseOnOutsideClick="true"
         CloseOnEscape="true">
    <BodyContentTemplate>
        <div class="d-flex align-items-center gap-3">
            <i class="bi bi-exclamation-triangle-fill text-warning fs-1"></i>
            <div>
                <p class="mb-1 fw-bold">¿Eliminar este tipo?</p>
                <small class="text-muted d-block">Código: <strong>@deleteTipo?.Code</strong></small>
                <small class="text-muted">Nombre: @deleteTipo?.Name</small>
                <div class="mt-2 text-danger small">
                    <i class="bi bi-exclamation-circle me-1"></i>Esta acción no se puede deshacer.
                </div>
            </div>
        </div>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton Text="Cancelar"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  Click="@CloseDeleteTipoConfirm" />
        <DxButton Text="Eliminar"
                  RenderStyle="ButtonRenderStyle.Danger"
                  Click="@ConfirmDeleteTipoAsync"
                  IconCssClass="bi bi-trash" />
    </FooterContentTemplate>
</DxPopup>

@* ═══════════════════════════════════════════════════════════════════════════
   POPUP: Confirmar eliminación de Regla
   ═══════════════════════════════════════════════════════════════════════════ *@
<DxPopup @bind-Visible="deleteRuleVisible"
         HeaderText="Confirmar eliminación"
         Width="420px"
         ShowFooter="true"
         CloseOnOutsideClick="true"
         CloseOnEscape="true">
    <BodyContentTemplate>
        <div class="d-flex align-items-center gap-3">
            <i class="bi bi-exclamation-triangle-fill text-warning fs-1"></i>
            <div>
                <p class="mb-1 fw-bold">¿Eliminar Regla?</p>
                <small class="text-muted">Línea @deleteRule?.LineNumber</small>
                <div class="mt-2 text-danger small">
                    <i class="bi bi-exclamation-circle me-1"></i>Esta acción no se puede deshacer.
                </div>
            </div>
        </div>
    </BodyContentTemplate>
    <FooterContentTemplate>
        <DxButton Text="Cancelar"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  Click="@CloseDeleteRuleConfirm" />
        <DxButton Text="Eliminar"
