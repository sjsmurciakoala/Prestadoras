    private string? ValidateCentroCosto(CentroCostoEditModel model)
    {
        var normalized = NormalizeCode(model.Code);
        if (string.IsNullOrWhiteSpace(normalized)) return "El código es obligatorio.";
        if (string.IsNullOrWhiteSpace(model.Name)) return "El nombre es obligatorio.";
        if (string.IsNullOrWhiteSpace(model.Description)) return "La descripción es obligatoria.";

        var totalDigits = nivelesCentros.Sum();
        if (totalDigits > 0 && normalized.Length != totalDigits)
            return $"El código debe tener {totalDigits} dígitos según el formato {formatoCentros}.";

        var modelId = model.CostCenterId;
        var codigoDuplicado = centros.Any(c =>
        string.Equals(NormalizeCode(c.Code), normalized, StringComparison.OrdinalIgnoreCase) &&
        (!modelId.HasValue || ToNullableLong(c.CostCenterId) != modelId));

        if (codigoDuplicado)
            return "El codigo ya existe.";

        if (model.IsPeriodic)
        {
            if (!model.StartDate.HasValue || !model.EndDate.HasValue)
                return "Las fechas de inicio y fin son obligatorias cuando el centro es periódico.";
            if (model.StartDate.Value > model.EndDate.Value)
                return "La fecha inicial no puede ser mayor a la fecha final.";
        }
        return null;
    }

    private void RecalcularFormatos()
    {
        nivelesCentros = ParseFormatoNiveles(formatoCentros);
        nivelesCuentas = ParseFormatoNiveles(formatoCuentas);
        maskedFormatoCentros = string.Join("", formatoCentros.Select(ch => ch == '#' ? '0' : ch));
        maskedFormatoCuentas = string.Join("", formatoCuentas.Select(ch => ch == '#' ? '0' : ch));
    }

    // NUEVO MÉTODO AGREGADO AQUÍ PARA FORMATEAR CENTROS
    private string FormatCentroCode(string? raw) => FormatFromMask(NormalizeCode(raw), nivelesCentros);

    private string FormatCuentaCode(string? raw) => FormatFromMask(NormalizeCode(raw), nivelesCuentas);

    private string FormatFromMask(string normalized, IReadOnlyList<int> niveles)
    {
        if (string.IsNullOrWhiteSpace(normalized)) return string.Empty;
        if (niveles.Count == 0) return normalized;

        var sep = string.IsNullOrWhiteSpace(separadorCodigo) ? "-" : separadorCodigo;
        var parts = new List<string>();
        var index = 0;

        foreach (var len in niveles)
        {
            if (index >= normalized.Length) break;
            var take = Math.Min(len, normalized.Length - index);
            parts.Add(normalized.Substring(index, take));
            index += take;
        }
        if (index < normalized.Length) parts.Add(normalized.Substring(index));
        return string.Join(sep, parts);
    }

    private static string NormalizeCode(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return string.Empty;
        return new string(value.Where(char.IsLetterOrDigit).ToArray());
    }

    private static IReadOnlyList<int> ParseFormatoNiveles(string? formato)
    {
        if (string.IsNullOrWhiteSpace(formato)) return Array.Empty<int>();
        var grupos = new List<int>();
        var current = 0;

        foreach (var ch in formato)
        {
            if (ch == '#' || ch == 'X' || ch == 'x') { current++; continue; }
            if (current > 0) { grupos.Add(current); current = 0; }
        }
        if (current > 0) grupos.Add(current);
        return grupos;
    }

    private static long? ToNullableLong(object? value)
    {
        if (value is null) return null;
        try
        {
            var v = System.Convert.ToInt64(value);
            return v <= 0 ? null : v;
        }
        catch
        {
            return null;
        }
    }

