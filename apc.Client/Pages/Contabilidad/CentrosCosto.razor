@page "/contabilidad/centros-costo"
@attribute [Authorize]

@using apc.Client.Services.Contabilidad
@using apc.Client.Services.Tenant
@using System.Linq
@using System.ComponentModel.DataAnnotations

@inject HttpClient Http
@inject ConfiguracionSistemaClient ConfiguracionClient
@inject TenantState TenantState
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Centros de Costo</PageTitle>
<DxLayoutBreakpoint DeviceSize="DeviceSize.XSmall" @bind-IsActive="isXSmallScreen" />
<DxMessageBox @bind-Visible="statusMessageVisible"
              Type="MessageBoxType.Alert"
              Title="@statusMessageTitle"
              Text="@statusMessageText"
              RenderStyle="@statusMessageRenderStyle"
              OkButtonText="Entendido"
              ShowCloseButton="false"
              CloseOnOutsideClick="false" />
<DxMessageBox @bind-Visible="discardChangesVisible"
              Type="MessageBoxType.Confirmation"
              Title="Cambios sin guardar"
              Text="Hay cambios sin guardar en el formulario actual. Si continúas, se descartarán. ¿Deseas continuar?"
              RenderStyle="MessageBoxRenderStyle.Warning"
              OkButtonText="Descartar"
              CancelButtonText="Seguir editando"
              ShowCloseButton="false"
              CloseOnOutsideClick="false"
              Closed="OnDiscardChangesMessageClosed" />
<DxMessageBox @bind-Visible="deleteConfirmVisible"
              Type="MessageBoxType.Confirmation"
              Title="Eliminar centro de costo"
              Text="@deleteConfirmText"
              RenderStyle="MessageBoxRenderStyle.Danger"
              OkButtonText="Sí, eliminar"
              CancelButtonText="Cancelar"
              ShowCloseButton="false"
              CloseOnOutsideClick="false"
              Closed="OnDeleteConfirmClosed" />
<div class="cc-page" id="centros-costo-view">

    @* ── Encabezado ── *@
    <div class="d-flex align-items-start flex-wrap gap-3 mb-3">
        <div class="flex-grow-1">
            <h4 class="mb-1 fw-bold text-secondary">
                <i class="bi bi-diagram-3 me-2 text-primary"></i>Centros de Costo
            </h4>
        </div>
        <div class="d-flex flex-wrap gap-2 flex-shrink-0">
            <DxButton Text="Actualizar"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      IconCssClass="bi bi-arrow-clockwise"
                      Click="@OnActualizarClick"
                      Enabled="@(!IsBusy)" />
            <DxButton Text="Nuevo"
                      RenderStyle="ButtonRenderStyle.Primary"
                      IconCssClass="bi bi-plus-lg"
                      Click="@OnNuevoToolbarClick"
                      Enabled="@(!IsBusy)" />
        </div>
    </div>

    @* ── Indicadores rápidos ── *@
    <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="cc-stat-badge">
            <i class="bi bi-diagram-3"></i> Total: <strong>@centros.Count.ToString("N0")</strong>
        </span>
        <span class="cc-stat-badge cc-stat-badge--success">
            <i class="bi bi-check2-circle"></i> Activos: <strong>@ActiveCount</strong>
        </span>
        <span class="cc-stat-badge cc-stat-badge--info">
            <i class="bi bi-check-circle"></i> Con movimiento: <strong>@AllowsMovementCount</strong>
        </span>
        <span class="cc-stat-badge cc-stat-badge--warning">
            <i class="bi bi-clock-history"></i> Periódicos: <strong>@PeriodicCount</strong>
        </span>
    </div>

    @* ── Grid principal ── *@
    <div class="cc-grid-wrapper shadow-sm">
        <DxGrid @ref="gridCentros"
                Data="@centros"
                KeyFieldName="@nameof(CentroCostoDto.CostCenterId)"
                ShowFilterRow="true"
                ShowPager="true"
                PageSize="10"
                PageSizeSelectorVisible="true"
                PageSizeSelectorItems="new int[] { 10, 20, 50 }"
                SizeMode="SizeMode.Medium"
                ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
                DetailRowDisplayMode="@GetGridDetailRowDisplayMode()"
                EditMode="GridEditMode.PopupEditForm"
                PopupEditFormHeaderText="@popupHeaderText"
                PopupEditFormCssClass="cc-popup-edit"
                EditFormButtonsVisible="false"
                CustomizeEditModel="OnCustomizeEditModel"
                EditModelSaving="OnEditModelSaving"
                CssClass="border-0">
            <ToolbarTemplate>
                <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Contained">
                    <Items>
                        <DxToolbarItem Text="Columnas"
                                       Alignment="ToolbarItemAlignment.Right"
                                       IconCssClass="bi bi-layout-three-columns"
                                       RenderStyle="ButtonRenderStyle.Secondary"
                                       CssClass="cc-column-chooser-button"
                                       Click="MostrarColumnChooser" />
                    </Items>
                </DxToolbar>
            </ToolbarTemplate>
            <Columns>
                <DxGridCommandColumn Caption="Acciones" Width="100px" VisibleIndex="99"
                                     NewButtonVisible="false" EditButtonVisible="false" DeleteButtonVisible="false">
                    <CellDisplayTemplate Context="cellContext">
                        <div class="d-flex gap-1 justify-content-center">
                             <DxButton RenderStyle="ButtonRenderStyle.Info" RenderStyleMode="ButtonRenderStyleMode.Text" SizeMode="SizeMode.Small"
                                  IconCssClass="bi bi-pencil-square fs-5"
                                  Click="@((MouseEventArgs e) => OnEditarClick(cellContext.VisibleIndex))" 
                                  title="Editar"/>

                            <DxButton RenderStyle="ButtonRenderStyle.Danger" RenderStyleMode="ButtonRenderStyleMode.Text" SizeMode="SizeMode.Small"
                                  IconCssClass="bi bi-trash fs-5"
                                  Click="@((MouseEventArgs e) => OpenDeleteConfirm((CentroCostoDto)cellContext.DataItem))" 
                                  title="Eliminar"/>
                        </div>
                    </CellDisplayTemplate>
                </DxGridCommandColumn>

                <DxGridDataColumn FieldName="@nameof(CentroCostoDto.Code)" Caption="Código" Width="120px">
                    <CellDisplayTemplate Context="cell">
                        <span class="fw-bold text-primary">@FormatCentroCode((string?)cell.Value)</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(CentroCostoDto.Name)" Caption="Nombre" MinWidth="200" />
                <DxGridDataColumn FieldName="@nameof(CentroCostoDto.Description)" Caption="Descripción" Visible="false" />

                <DxGridDataColumn FieldName="@nameof(CentroCostoDto.AllowsMovement)" Caption="Movimientos" Width="110px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate Context="cell">
                        @if ((bool)cell.Value) { <i class="bi bi-check-circle-fill text-success"></i> } else { <span class="text-muted">-</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(CentroCostoDto.IsPeriodic)" Caption="Periódico" Width="100px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate Context="cell">
                        @if ((bool)cell.Value) { <i class="bi bi-clock-history text-info"></i> } else { <span class="text-muted">-</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(CentroCostoDto.StartDate)" Caption="Inicio" DisplayFormat="{0:d}" Width="100px" />
                <DxGridDataColumn FieldName="@nameof(CentroCostoDto.EndDate)" Caption="Fin" DisplayFormat="{0:d}" Width="100px" />

                <DxGridDataColumn FieldName="@nameof(CentroCostoDto.LegacyStatus)" Caption="Estado" Width="100px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is CentroCostoDto item && IsCentroActivo(item))
                        { <span class="cc-badge cc-badge--success">Activo</span> }
                        else
                        { <span class="cc-badge cc-badge--neutral">Inactivo</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
            <DetailRowTemplate Context="detail">
                @if (detail.DataItem is CentroCostoDto item)
                {
                    <div class="p-3">
                        <div class="row g-3">
                            <div class="col-sm-4">
                                <small class="text-muted d-block">Descripción</small>
                                <strong>@(string.IsNullOrWhiteSpace(item.Description) ? "—" : item.Description)</strong>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted d-block">Inicio vigencia</small>
                                <strong>@(item.StartDate.HasValue ? item.StartDate.Value.ToString("d") : "—")</strong>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted d-block">Fin vigencia</small>
                                <strong>@(item.EndDate.HasValue ? item.EndDate.Value.ToString("d") : "—")</strong>
                            </div>
                        </div>
                    </div>
                }
            </DetailRowTemplate>
            <EmptyDataAreaTemplate>
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-diagram-3 fs-1 d-block mb-2"></i>
                    <h5 class="fw-bold text-dark">No hay centros de costo</h5>
                    <p class="mb-0">Crea el primer centro de costo usando el botón "Nuevo".</p>
                </div>
            </EmptyDataAreaTemplate>

            <EditFormTemplate Context="ctx">
                @{ var model = (CentroCostoEditModel)ctx.EditModel; }
                <div class="d-flex flex-column h-100">

                    <div class="flex-grow-1 p-3 overflow-auto custom-scrollbar">
                        <DxFormLayout SizeMode="SizeMode.Medium" CaptionPosition="CaptionPosition.Vertical">
                            
                            <DxFormLayoutGroup Caption="Información General" HeaderIconCssClass="bi bi-card-heading">
                                <DxFormLayoutItem ColSpanMd="6" ColSpanSm="12">
                                    <CaptionTemplate><span class="fw-semibold">Código</span></CaptionTemplate>
                                    <Template>
                                        <DxMaskedInput @bind-Value="model.CodeDisplay" Mask="@maskedFormatoCentros" MaskChar="_" NullText="@formatoCentros" TextChanged="@(value => OnCentroCodeChanged(model, value))" />
                                        <ValidationMessage For="@(() => model.Code)" />
                                    </Template>
                                </DxFormLayoutItem>

                                <DxFormLayoutItem ColSpanMd="6" ColSpanSm="12">
                                    <CaptionTemplate><span class="fw-semibold">Nombre</span></CaptionTemplate>
                                    <Template>
                                        <DxTextBox @bind-Text="model.Name" NullText="Ej. Administrativo" />
                                        <ValidationMessage For="@(() => model.Name)" />
                                    </Template>
                                </DxFormLayoutItem>

                                <DxFormLayoutItem ColSpanMd="12">
                                    <CaptionTemplate><span class="fw-semibold">Descripción</span></CaptionTemplate>
                                    <Template>
                                        <DxMemo @bind-Text="model.Description" Rows="2" />
                                        <ValidationMessage For="@(() => model.Description)" />
                                    </Template>
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>

                            <DxFormLayoutGroup Caption="Configuración" HeaderIconCssClass="bi bi-gear" CssClass="mt-3">
                                <DxFormLayoutItem ColSpanMd="3" ColSpanSm="6">
                                    <Template>
                                        <DxCheckBox @bind-Checked="model.AllowsMovement" CheckType="CheckType.Switch">Permite Movimientos</DxCheckBox>
                                    </Template>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem ColSpanMd="3" ColSpanSm="6">
                                    <Template>
                                        <DxCheckBox @bind-Checked="model.IsPeriodic" CheckType="CheckType.Switch">Es Periódico</DxCheckBox>
                                    </Template>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem ColSpanMd="3" ColSpanSm="6">
                                    <Template>
                                        <DxCheckBox @bind-Checked="model.IsActive" CheckType="CheckType.Switch">Activo</DxCheckBox>
                                    </Template>
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>

                            @if(model.IsPeriodic)
                            {
                                <DxFormLayoutGroup Caption="Vigencia" HeaderIconCssClass="bi bi-calendar-range" CssClass="mt-3">
                                    <DxFormLayoutItem ColSpanMd="6" ColSpanSm="12">
                                        <CaptionTemplate>Desde</CaptionTemplate>
                                        <Template>
                                            <DxDateEdit T="DateTime?" @bind-Date="model.StartDate" DisplayFormat="d" />
                                        </Template>
                                    </DxFormLayoutItem>
                                    <DxFormLayoutItem ColSpanMd="6" ColSpanSm="12">
                                        <CaptionTemplate>Hasta</CaptionTemplate>
                                        <Template>
                                            <DxDateEdit T="DateTime?" @bind-Date="model.EndDate" DisplayFormat="d" />
                                        </Template>
                                    </DxFormLayoutItem>
                                </DxFormLayoutGroup>
                            }
                        </DxFormLayout>
                    </div>

                    <div class="d-flex justify-content-between align-items-center p-3 border-top bg-light">
                        <div>
                            @if (model.CostCenterId.HasValue)
                            {
                                <DxButton Text="Eliminar" RenderStyle="ButtonRenderStyle.Danger" RenderStyleMode="ButtonRenderStyleMode.Outline" IconCssClass="bi bi-trash" Click="@((MouseEventArgs e) => OpenDeleteConfirmFromEdit(model))" />
                            }
                        </div>
                        <div class="d-flex gap-2">
                            <DxButton Text="Cancelar" RenderStyle="ButtonRenderStyle.Secondary" Click="@OnCancelarClick" />
                            <DxButton Text="Guardar" RenderStyle="ButtonRenderStyle.Primary" IconCssClass="bi bi-check-lg" SubmitFormOnClick="true" />
                        </div>
                    </div>
                </div>
            </EditFormTemplate>
        </DxGrid>
    </div>

    <DxCard CssClass="mt-4 shadow-sm border-0">
        <HeaderContent>
            <h5 class="mb-0 text-secondary fw-bold"><i class="bi bi-list-nested me-2"></i>Cuentas Relacionadas</h5>
        </HeaderContent>
        <ChildContent>
            <DxGrid Data="@cuentasCentro" ShowFilterRow="true" ShowPager="true" PageSize="5" SizeMode="SizeMode.Medium"
                    CssClass="border-0">
                <Columns>
                    <DxGridDataColumn FieldName="@nameof(PlanCuentaDto.Code)" Caption="Cuenta" Width="150px">
                        <CellDisplayTemplate Context="cell">
                            <span class="font-monospace fw-bold text-primary">@FormatCuentaCode(((PlanCuentaDto)cell.DataItem).Code)</span>
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="@nameof(PlanCuentaDto.Name)" Caption="Descripción" />
                    <DxGridDataColumn FieldName="@nameof(PlanCuentaDto.AccountType)" Caption="Tipo" Width="120px" />
                </Columns>
            </DxGrid>
        </ChildContent>
    </DxCard>

    <DxLoadingPanel Visible="@IsBusy"
                    PositionTarget="#centros-costo-view"
                    CssClass="w-100"
                    ApplyBackgroundShading="true"
                    IsContentBlocked="true"
                    Text="Cargando centros de costo..." />

</div>

@code {
    private IList<CentroCostoDto> centros = new List<CentroCostoDto>();
    private IList<PlanCuentaDto> cuentasCentro = new List<PlanCuentaDto>();
    private bool cargando;
    private bool isXSmallScreen;

    private string formatoCentros = "###-##";
    private string formatoCuentas = "###-###-##";
    private string separadorCodigo = "-";
    private string maskedFormatoCentros = "000-00";
    private string maskedFormatoCuentas = "000-000-00";
    private IReadOnlyList<int> nivelesCentros = Array.Empty<int>();
    private IReadOnlyList<int> nivelesCuentas = Array.Empty<int>();

    private DxGrid? gridCentros;

    private bool deleteConfirmVisible;
    private DeleteCentroCostoInfo? deleteItem;

    private string popupHeaderText = "Centro de costo";
    private bool statusMessageVisible;
    private string statusMessageTitle = string.Empty;
    private string statusMessageText = string.Empty;
    private MessageBoxRenderStyle statusMessageRenderStyle = MessageBoxRenderStyle.Info;
    private bool discardChangesVisible;
    private string deleteConfirmText = string.Empty;
    private PendingGridAction pendingGridAction = PendingGridAction.None;
    private int pendingVisibleIndex = -1;

    private bool IsBusy => cargando;
    private int ActiveCount => centros.Count(IsCentroActivo);
    private int AllowsMovementCount => centros.Count(c => c.AllowsMovement);
    private int PeriodicCount => centros.Count(c => c.IsPeriodic);

    protected override async Task OnInitializedAsync()
    {
        await LoadConfiguracionAsync();
        await LoadCentrosAsync();
        await LoadCuentasCentroAsync();
    }

    private Task OnActualizarClick(MouseEventArgs e) => QueueGridActionAsync(PendingGridAction.Refresh);

    private Task OnNuevoToolbarClick(MouseEventArgs e)
        => QueueGridActionAsync(PendingGridAction.NewRow);

    private Task OnCancelarClick(MouseEventArgs e)
    => gridCentros is null ? Task.CompletedTask : gridCentros.CancelEditAsync();

    private Task OnEditarClick(int visibleIndex)
        => QueueGridActionAsync(PendingGridAction.EditRow, visibleIndex);

    private void OpenDeleteConfirm(CentroCostoDto item)
    {
        deleteItem = new DeleteCentroCostoInfo
        {
            Id = System.Convert.ToInt64(item.CostCenterId),
            Code = item.Code ?? "",
            Name = item.Name ?? ""
        };
        deleteConfirmText = $"Se eliminará '{item.Code} - {item.Name}' permanentemente. Esta acción no se puede deshacer.";
        deleteConfirmVisible = true;
    }

    private void OpenDeleteConfirmFromEdit(CentroCostoEditModel model)
    {
        deleteItem = new DeleteCentroCostoInfo
        {
            Id = model.CostCenterId ?? 0,
            Code = model.Code ?? "",
            Name = model.Name ?? ""
        };
        deleteConfirmText = $"Se eliminará '{model.Code} - {model.Name}' permanentemente. Esta acción no se puede deshacer.";
        deleteConfirmVisible = true;
    }

    private async Task OnDeleteConfirmClosed(bool confirmed)
    {
        if (!confirmed || deleteItem is null)
        {
            deleteItem = null;
            deleteConfirmText = string.Empty;
            return;
        }

        var id = deleteItem.Id;
        deleteItem = null;
        deleteConfirmText = string.Empty;

        var deleted = await DeleteCentroCostoAsync(id);
        if (deleted && gridCentros is not null && gridCentros.IsEditing())
            await gridCentros.CancelEditAsync();
    }

    private async Task LoadConfiguracionAsync()
    {
        try
        {
            var companyId = await TenantState.EnsureCompanyAsync();
            if (companyId <= 0) return;

            var config = await ConfiguracionClient.ObtenerAsync(companyId);
            if (config?.Principal != null)
            {
                if (!string.IsNullOrWhiteSpace(config.Principal.FormatoCentros))
                    formatoCentros = config.Principal.FormatoCentros;

                if (!string.IsNullOrWhiteSpace(config.Principal.FormatoCuentas))
                    formatoCuentas = config.Principal.FormatoCuentas;

                if (!string.IsNullOrWhiteSpace(config.Principal.SeparadorCodigo))
                    separadorCodigo = config.Principal.SeparadorCodigo;
            }

            RecalcularFormatos();
        }
        catch (Exception ex)
        {
            ShowStatusMessage("Error", $"Error al cargar configuración: {ex.Message}. Se utilizará la configuración predeterminada.",
                MessageBoxRenderStyle.Danger);
        }
    }

    private async Task LoadCentrosAsync()
    {
        try
        {
            cargando = true;
            var result = await Http.GetFromJsonAsync<List<CentroCostoDto>>("api/contabilidad/catalogos/centros-costo");
            centros = result ?? new List<CentroCostoDto>();
        }
        catch (Exception ex)
        {
            centros = new List<CentroCostoDto>();
            ShowStatusMessage("Error", $"No se pudieron cargar los centros de costo: {ex.Message}",
                MessageBoxRenderStyle.Danger);
        }
        finally
        {
            cargando = false;
        }
    }

    private async Task LoadCuentasCentroAsync()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<List<PlanCuentaDto>>("api/contabilidad/catalogos/plan-cuentas");
            cuentasCentro = result?
            .Where(c => c.AllowsCostCenter)
            .OrderBy(c => c.Code)
            .ToList() ?? new List<PlanCuentaDto>();
        }
        catch (Exception ex)
        {
            cuentasCentro = new List<PlanCuentaDto>();
            ShowStatusMessage("Error", $"No se pudieron cargar las cuentas con centro de costo: {ex.Message}",
                MessageBoxRenderStyle.Danger);
        }
    }

    private void OnCustomizeEditModel(GridCustomizeEditModelEventArgs e)
    {
        if (e.IsNew || e.DataItem is not CentroCostoDto item)
        {
            popupHeaderText = "Nuevo centro de costo";
            e.EditModel = new CentroCostoEditModel
            {
                IsActive = true,
                StartDate = DateTime.UtcNow.Date,
                EndDate = DateTime.UtcNow.Date
            };
        }
        else
        {
            popupHeaderText = "Editar centro de costo";
            var normalizedCode = NormalizeCode(item.Code);
            e.EditModel = new CentroCostoEditModel
            {
                CostCenterId = ToNullableLong(item.CostCenterId),
                Code = normalizedCode,
                CodeDisplay = FormatFromMask(normalizedCode, nivelesCentros),
                Name = item.Name,
                Description = item.Description ?? string.Empty,
                AllowsMovement = item.AllowsMovement,
                IsPeriodic = item.IsPeriodic,
                StartDate = item.StartDate,
                EndDate = item.EndDate,
                IsActive = item.LegacyStatus || string.Equals(item.Status, "ACTIVE", StringComparison.OrdinalIgnoreCase)
            };
        }
    }

    private void OnCentroCodeChanged(CentroCostoEditModel model, string? value)
    {
        var normalized = NormalizeCode(value);
        model.Code = normalized;
        model.CodeDisplay = FormatFromMask(normalized, nivelesCentros);
    }

    private async Task OnEditModelSaving(GridEditModelSavingEventArgs e)
    {
        if (e.EditModel is CentroCostoEditModel model)
        {
            var validationMessage = ValidateCentroCosto(model);
            if (!string.IsNullOrWhiteSpace(validationMessage))
            {
                ToastService.ShowToast(new ToastOptions { Title = "Centros de costo", Text = validationMessage, RenderStyle = ToastRenderStyle.Danger });
                e.Cancel = true;
                return;
            }

            var startDate = model.IsPeriodic ? model.StartDate : null;
            var endDate = model.IsPeriodic ? model.EndDate : null;

            var payload = new CentroCostoUpsertDto(
            model.Code.Trim(),
            model.Name.Trim(),
            model.IsActive ? "ACTIVE" : "INACTIVE",
            string.Empty,
            model.CostCenterId, // long?
            model.Description.Trim(),
            model.AllowsMovement,
            model.IsPeriodic,
            startDate,
            endDate,
            model.IsActive
            );

            try
            {
                var response = await Http.PostAsJsonAsync("api/contabilidad/catalogos/centros-costo", payload);
                if (!response.IsSuccessStatusCode)
                {
                    var detail = await response.Content.ReadAsStringAsync();
                    ToastService.ShowToast(new ToastOptions
                    {
                        Title = "Centros de costo",
                        Text = string.IsNullOrWhiteSpace(detail) ? "No se pudo guardar el centro de costo." : detail,
                        RenderStyle = ToastRenderStyle.Danger
                    });
                    e.Cancel = true;
                    return;
                }
                await LoadCentrosAsync();
            }
            catch (Exception ex)
            {
                ToastService.ShowToast(new ToastOptions { Title = "Centros de costo", Text = ex.Message, RenderStyle = ToastRenderStyle.Danger });
                e.Cancel = true;
            }
        }
    }

    private async Task<bool> DeleteCentroCostoAsync(long costCenterId)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/contabilidad/catalogos/centros-costo/{costCenterId}");
            if (!response.IsSuccessStatusCode)
            {
                var message = await response.Content.ReadAsStringAsync();
                ShowStatusMessage("Error",
                    string.IsNullOrWhiteSpace(message)
                        ? "No se pudo eliminar el centro de costo."
                        : message,
                    MessageBoxRenderStyle.Danger);
                return false;
            }
            await LoadCentrosAsync();
            return true;
        }
        catch (Exception ex)
        {
            ShowStatusMessage("Error", ex.Message, MessageBoxRenderStyle.Danger);
            return false;
        }
    }

    private async Task QueueGridActionAsync(PendingGridAction action, int visibleIndex = -1)
    {
        if (action == PendingGridAction.EditRow && gridCentros is not null && gridCentros.IsEditingRow(visibleIndex))
        {
            return;
        }

        if (HasUnsavedGridChanges())
        {
            pendingGridAction = action;
            pendingVisibleIndex = visibleIndex;
            discardChangesVisible = true;
            return;
        }

        await ExecuteGridActionAsync(action, visibleIndex);
    }

    private async Task ExecuteGridActionAsync(PendingGridAction action, int visibleIndex = -1)
    {
        switch (action)
        {
            case PendingGridAction.Refresh:
                await LoadCentrosAsync();
                break;
            case PendingGridAction.NewRow:
                if (gridCentros is not null)
                {
                    await gridCentros.StartEditNewRowAsync();
                }
                break;
            case PendingGridAction.EditRow:
                if (gridCentros is not null && visibleIndex >= 0)
                {
                    await gridCentros.StartEditRowAsync(visibleIndex);
                }
                break;
        }
    }

    private bool HasUnsavedGridChanges()
    {
        if (gridCentros is null || !gridCentros.IsEditing())
        {
            return false;
        }

        var editContext = gridCentros.GetEditContext();
        return editContext?.IsModified() == true;
    }

    private async Task OnDiscardChangesMessageClosed(bool confirmed)
    {
        var action = pendingGridAction;
        var visibleIndex = pendingVisibleIndex;
        ClearPendingGridAction();

        if (!confirmed)
        {
            return;
        }

        if (gridCentros is not null && gridCentros.IsEditing())
        {
            await gridCentros.CancelEditAsync();
        }

        await ExecuteGridActionAsync(action, visibleIndex);
    }

