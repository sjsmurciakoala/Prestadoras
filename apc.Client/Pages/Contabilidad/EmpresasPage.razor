@page "/contabilidad/empresas"
@attribute [Authorize]

@using SIAD.Core.DTOs.Tenant
@using DevExpress.Blazor
@inject TenantCompaniesClient TenantCompaniesClient
@inject TenantCompanyContextClient TenantCompanyContextClient
@inject TenantState TenantState
@inject NavigationManager NavigationManager
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Empresas</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
	<div>
		<h3 class="mb-1">Empresas</h3>
		<p class="text-muted mb-0">Listado de empresas</p>
	</div>
	<DxButton Text="Crear nueva" CssClass="mb-0" NavigateUrl="/contabilidad/empresas/nueva" />
</div>

@if (loading)
{
	<p>Cargando...</p>
}
else if (!string.IsNullOrWhiteSpace(error))
{
	<p class="text-danger">@error</p>
}
else
{
	    <DxGrid Data="@companies"
		    PageSize="10">
		<Columns>
			<DxGridDataColumn FieldName="@nameof(TenantCompanyDto.Code)" Caption="Código" Width="140px" />
			<DxGridDataColumn FieldName="@nameof(TenantCompanyDto.Name)" Caption="Nombre" />
			<DxGridDataColumn Caption="Acciones" Width="140px">
				<CellDisplayTemplate Context="cellContext">
					@if (cellContext.DataItem is TenantCompanyDto company)
					{
						<div class="d-flex gap-2 align-items-center">
							@if (company.CompanyId == activeCompanyId)
							{
								<span class="badge text-bg-success">Activa</span>
							}
							else
							{
								<DxButton Text="Usar"
										  Size="ButtonSize.Small"
										  RenderStyle="ButtonRenderStyle.Primary"
										  Enabled="@(activatingCompanyId == 0)"
										  Click="@(async () => await ActivarEmpresaAsync(company.CompanyId))" />
							}
							<DxButton Text="Editar"
									  Size="ButtonSize.Small"
									  RenderStyle="ButtonRenderStyle.Secondary"
									  Click="@(async () => await NavegarEditarAsync(company.CompanyId))" />
						</div>
					}
				</CellDisplayTemplate>
			</DxGridDataColumn>
		</Columns>
	</DxGrid>
}

@code {
	private List<TenantCompanyDto> companies = new();
	private bool loading = true;
	private string? error;
	private long activeCompanyId;
	private long activatingCompanyId;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			var companiesTask = TenantCompaniesClient.ObtenerAsync();
			var contextTask = TenantCompanyContextClient.ObtenerAsync();

			await Task.WhenAll(companiesTask, contextTask);
			companies = companiesTask.Result.ToList();
			activeCompanyId = contextTask.Result.CurrentCompanyId;
		}
		catch (UnauthorizedAccessException)
		{
			// Sesión expirada - redirigir a login
			NavigationManager.NavigateTo("/Account/Login");
		}
		catch (Exception ex)
		{
			error = ex.Message;
		}
		finally
		{
			loading = false;
		}
	}

	private Task NavegarEditarAsync(long companyId)
	{
		NavigationManager.NavigateTo($"/contabilidad/empresas/editar/{companyId}", forceLoad: true);
		return Task.CompletedTask;
	}

	private async Task ActivarEmpresaAsync(long companyId)
	{
		if (companyId <= 0 || activatingCompanyId != 0)
		{
			return;
		}

		activatingCompanyId = companyId;
		error = null;

		try
		{
			var actualizado = await TenantState.TrySetCompanyIdAsync(companyId);
			if (!actualizado)
			{
				error = "No fue posible activar la empresa seleccionada.";
				return;
			}

			activeCompanyId = companyId;
			ToastService.ShowToast(new ToastOptions { Title = "Empresas", Text = "Empresa activada correctamente.", RenderStyle = ToastRenderStyle.Success });
			NavigationManager.NavigateTo("/", forceLoad: true);
		}
		catch (HttpRequestException ex)
		{
			error = ex.Message;
		}
		finally
		{
			activatingCompanyId = 0;
		}
	}
}
