@page "/contabilidad/diarios"
@attribute [Authorize]
@inject HttpClient Http
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Diarios contables</PageTitle>

<DxLayoutBreakpoint DeviceSize="DeviceSize.XSmall" @bind-IsActive="isXSmallScreen" />

<DxMessageBox @bind-Visible="statusMessageVisible"
              Type="MessageBoxType.Alert"
              Title="@statusMessageTitle"
              Text="@statusMessageText"
              RenderStyle="@statusMessageRenderStyle"
              OkButtonText="Entendido"
              ShowCloseButton="false"
              CloseOnOutsideClick="false" />

<ErrorNotice @ref="errorNotice" />

<div class="diarios-page" id="diarios-grid-shell">

    @* ── Encabezado ── *@
    <div class="d-flex align-items-start flex-wrap gap-3 mb-3">
        <div class="flex-grow-1">
            <h4 class="mb-1 fw-bold text-secondary">
                <i class="bi bi-book me-2 text-primary"></i>Diarios contables
            </h4>
        </div>
        <div class="d-flex flex-wrap gap-2 flex-shrink-0">
            <DxButton Text="Actualizar"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      IconCssClass="bi bi-arrow-clockwise"
                      Click="LoadDiariosAsync"
                      Enabled="@(!IsBusy)" />
            <DxButton Text="Nuevo diario"
                      RenderStyle="ButtonRenderStyle.Primary"
                      IconCssClass="bi bi-plus-lg"
                      Click="@(() => OpenForm(null))"
                      Enabled="@(!IsBusy)" />
        </div>
    </div>

    @* ── Indicadores rapidos ── *@
    <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="diarios-stat-badge">
            <i class="bi bi-book"></i> Total: <strong>@diarios.Length.ToString("N0")</strong>
        </span>
        <span class="diarios-stat-badge diarios-stat-badge--success">
            <i class="bi bi-check2-circle"></i> Activos: <strong>@ActiveCount</strong>
        </span>
        <span class="diarios-stat-badge diarios-stat-badge--info">
            <i class="bi bi-keyboard"></i> Captura manual: <strong>@ManualCount</strong>
        </span>
    </div>

    @* ── Grid principal ── *@
    <div class="diarios-grid-wrapper shadow-sm">
        <DxGrid @ref="diariosGrid"
                Data="@diarios"
                KeyFieldName="@nameof(DiarioDto.JournalId)"
                ShowFilterRow="true"
                ShowPager="true"
                PageSize="12"
                PageSizeSelectorVisible="true"
                PageSizeSelectorItems="new int[] { 10, 20, 50 }"
                SizeMode="SizeMode.Medium"
                ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
                DetailRowDisplayMode="@GetGridDetailRowDisplayMode()"
                CssClass="border-0">
            <ToolbarTemplate>
                <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Contained">
                    <Items>
                        <DxToolbarItem Text="Columnas"
                                       Alignment="ToolbarItemAlignment.Right"
                                       IconCssClass="bi bi-layout-three-columns"
                                       RenderStyle="ButtonRenderStyle.Secondary"
                                       CssClass="diarios-column-chooser-button"
                                       Click="MostrarColumnChooser" />
                    </Items>
                </DxToolbar>
            </ToolbarTemplate>
            <Columns>
                <DxGridCommandColumn Caption="Acciones" Width="80px"
                                     NewButtonVisible="false" EditButtonVisible="false" DeleteButtonVisible="false"
                                     ShowInColumnChooser="false">
                    <CellDisplayTemplate Context="cellContext">
                        @if (cellContext.DataItem is DiarioDto item)
                        {
                            <div class="d-flex gap-1 justify-content-center">
                                <DxButton RenderStyle="ButtonRenderStyle.Info"
                                          RenderStyleMode="ButtonRenderStyleMode.Text"
                                          SizeMode="SizeMode.Small"
                                          IconCssClass="bi bi-pencil-square fs-5"
                                          title="Editar"
                                          Enabled="@(!IsBusy)"
                                          Click="@(() => OpenForm(item))" />
                            </div>
                        }
                    </CellDisplayTemplate>
                </DxGridCommandColumn>

                <DxGridDataColumn FieldName="@nameof(DiarioDto.Code)" Caption="Codigo" Width="110px">
                    <CellDisplayTemplate Context="cell">
                        <span class="fw-bold text-primary">@((cell.DataItem as DiarioDto)?.Code)</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(DiarioDto.Name)" Caption="Nombre" Width="18%" />
                <DxGridDataColumn FieldName="@nameof(DiarioDto.Description)" Caption="Descripcion" Width="28%" />
                <DxGridDataColumn FieldName="@nameof(DiarioDto.SequencePrefix)" Caption="Prefijo" Width="100px" />
                <DxGridDataColumn FieldName="@nameof(DiarioDto.LastSequence)" Caption="Ultima secuencia" Width="130px" />

                <DxGridDataColumn FieldName="@nameof(DiarioDto.IsActive)" Caption="Estado" Width="120px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is DiarioDto diario)
                        {
                            <span class="@GetActiveBadgeCss(diario.IsActive)">
                                @(diario.IsActive ? "Activo" : "Inactivo")
                            </span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(DiarioDto.AllowsManual)" Caption="Manual" Width="132px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is DiarioDto diario)
                        {
                            <span class="@GetManualBadgeCss(diario.AllowsManual)">
                                @(diario.AllowsManual ? "Permitido" : "Solo sistema")
                            </span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(DiarioDto.IsDefaultManual)" Caption="Predeterminado" Width="150px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate Context="cell">
                        @if (cell.DataItem is DiarioDto diario)
                        {
                            <span class="@GetDefaultBadgeCss(diario.IsDefaultManual)">
                                @(diario.IsDefaultManual ? "Si" : "No")
                            </span>
                        }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>
            <DetailRowTemplate Context="detail">
                @if (detail.DataItem is DiarioDto item)
                {
                    <div class="p-3">
                        <div class="row g-3">
                            <div class="col-sm-4">
                                <small class="text-muted d-block">Estado</small>
                                <strong>@(item.IsActive ? "Activo" : "Inactivo")</strong>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted d-block">Captura manual</small>
                                <strong>@(item.AllowsManual ? "Permitido" : "Solo sistema")</strong>
                            </div>
                            <div class="col-sm-4">
                                <small class="text-muted d-block">Predeterminado manual</small>
                                <strong>@(item.IsDefaultManual ? "Si" : "No")</strong>
                            </div>
                        </div>
                    </div>
                }
            </DetailRowTemplate>
            <EmptyDataAreaTemplate>
                <div class="text-center p-5 text-muted">
                    <i class="bi bi-journal-x fs-1 d-block mb-2"></i>
                    <h5 class="fw-bold text-dark">No hay diarios registrados</h5>
                    <p class="mb-0">Crea el primer diario para empezar a organizar tus movimientos contables.</p>
                </div>
            </EmptyDataAreaTemplate>
        </DxGrid>
    </div>

    <DxLoadingPanel Visible="@isLoading"
                    PositionTarget="#diarios-grid-shell"
                    CssClass="w-100"
                    ApplyBackgroundShading="true"
                    IsContentBlocked="true"
                    Text="Cargando diarios..." />
</div>

@* ── Popup de formulario ── *@
<DxPopup @bind-Visible="isFormVisible"
         Width="720px"
         MaxWidth="95vw"
         MinWidth="320px"
         MaxHeight="90vh"
         Scrollable="true"
         ShowFooter="true"
         ShowCloseButton="true"
         CloseOnOutsideClick="false"
         HeaderText="@popupTitle"
         CssClass="diarios-popup">
    <BodyContentTemplate Context="popupBody">
        <DxFormLayout SizeMode="SizeMode.Medium" CaptionPosition="CaptionPosition.Vertical" CssClass="w-100">
            <DxFormLayoutGroup Caption="Datos del diario" HeaderIconCssClass="bi bi-book">
                <DxFormLayoutItem ColSpanMd="4" ColSpanSm="6" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Codigo</span></CaptionTemplate>
                    <Template>
                        <DxTextBox @bind-Text="formModel.Code" NullText="Ej. VEN" InputId="diario-code" />
                    </Template>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanMd="8" ColSpanSm="6" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Nombre</span></CaptionTemplate>
                    <Template>
                        <DxTextBox @bind-Text="formModel.Name" NullText="Nombre del diario" InputId="diario-name" />
                    </Template>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanMd="12" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Descripcion</span></CaptionTemplate>
                    <Template>
                        <DxMemo @bind-Text="formModel.Description"
                                Rows="3"
                                NullText="Describe el uso operativo del diario" />
                    </Template>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanMd="6" ColSpanSm="6" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Prefijo de secuencia</span></CaptionTemplate>
                    <Template>
                        <DxTextBox @bind-Text="formModel.SequencePrefix" NullText="Ej. DIA-" />
                    </Template>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanMd="6" ColSpanSm="6" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Resumen</span></CaptionTemplate>
                    <Template>
                        <div class="diarios-preview-card">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Codigo</span>
                                <strong>@GetPreviewCode()</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Prefijo</span>
                                <strong>@GetPreviewPrefix()</strong>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Por defecto</span>
                                <strong>@(formModel.IsDefaultManual ? "Si" : "No")</strong>
                            </div>
                        </div>
                    </Template>
                </DxFormLayoutItem>
            </DxFormLayoutGroup>

            <DxFormLayoutGroup Caption="Configuracion de uso" HeaderIconCssClass="bi bi-toggles" CssClass="mt-3">
                <DxFormLayoutItem ColSpanMd="4" ColSpanSm="6" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Activo</span></CaptionTemplate>
                    <Template>
                        <div class="diarios-toggle-card @(formModel.IsActive ? "is-on" : string.Empty)">
                            <div>
                                <div class="diarios-toggle-card__title">Estado del diario</div>
                                <div class="diarios-toggle-card__description">Permite usar este diario en operaciones nuevas.</div>
                            </div>
                            <DxCheckBox @bind-Checked="formModel.IsActive" />
                        </div>
                    </Template>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanMd="4" ColSpanSm="6" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Captura manual</span></CaptionTemplate>
                    <Template>
                        <div class="diarios-toggle-card @(formModel.AllowsManual ? "is-on is-blue" : string.Empty)">
                            <div>
                                <div class="diarios-toggle-card__title">Permite manual</div>
                                <div class="diarios-toggle-card__description">Habilita registros manuales ademas del sistema.</div>
                            </div>
                            <DxCheckBox @bind-Checked="formModel.AllowsManual" />
                        </div>
                    </Template>
                </DxFormLayoutItem>

                <DxFormLayoutItem ColSpanMd="4" ColSpanSm="12" ColSpanXs="12">
                    <CaptionTemplate><span class="fw-semibold">Manual por defecto</span></CaptionTemplate>
                    <Template>
                        <div class="diarios-toggle-card @(formModel.IsDefaultManual ? "is-on is-amber" : string.Empty)">
                            <div>
                                <div class="diarios-toggle-card__title">Diario predeterminado</div>
                                <div class="diarios-toggle-card__description">Se usara al registrar partidas manuales.</div>
                            </div>
                            <DxCheckBox @bind-Checked="formModel.IsDefaultManual"
                                        Enabled="@(formModel.IsActive && formModel.AllowsManual)" />
                        </div>
                    </Template>
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
        </DxFormLayout>
    </BodyContentTemplate>
    <FooterContentTemplate Context="popupFooter">
        <div class="d-flex justify-content-end gap-2 w-100">
            <DxButton Text="Cancelar"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      Click="CloseForm"
                      Enabled="@(!isSaving)" />
            <DxButton Text="@(isSaving ? "Guardando..." : "Guardar diario")"
                      RenderStyle="ButtonRenderStyle.Primary"
                      IconCssClass="bi bi-check-lg"
                      Click="SaveDiarioAsync"
                      Enabled="@(!isSaving)" />
        </div>
    </FooterContentTemplate>
</DxPopup>

@code {
    private DiarioDto[] diarios = Array.Empty<DiarioDto>();
    private IGrid? diariosGrid;
    private DiarioFormModel formModel = new();
    private bool isFormVisible;
    private bool isSaving;
    private bool isLoading;
    private bool isXSmallScreen;
    private string popupTitle = "Nuevo diario";
    private ErrorNotice errorNotice = default!;
    private bool statusMessageVisible;
    private string statusMessageTitle = string.Empty;
    private string statusMessageText = string.Empty;
    private MessageBoxRenderStyle statusMessageRenderStyle = MessageBoxRenderStyle.Info;

    private bool IsBusy => isLoading || isSaving;
    private int ActiveCount => diarios.Count(item => item.IsActive);
    private int ManualCount => diarios.Count(item => item.AllowsManual);

    protected override async Task OnInitializedAsync()
    {
        await LoadDiariosAsync();
    }

    private async Task LoadDiariosAsync()
    {
        try
        {
            isLoading = true;
            diarios = await Http.GetFromJsonAsync<DiarioDto[]>("api/contabilidad/catalogos/diarios")
                ?? Array.Empty<DiarioDto>();
        }
        catch (Exception ex)
        {
            diarios = Array.Empty<DiarioDto>();
            ShowStatusMessage("Error", "No se pudieron cargar los diarios.", MessageBoxRenderStyle.Danger);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenForm(DiarioDto? diario)
    {
        if (diario is null)
        {
            formModel = new DiarioFormModel
            {
                IsActive = true,
                AllowsManual = true,
                IsDefaultManual = false
            };
            popupTitle = "Nuevo diario";
        }
        else
        {
            formModel = new DiarioFormModel
            {
                JournalId = diario.JournalId,
                Code = diario.Code,
                Name = diario.Name,
                Description = diario.Description,
                SequencePrefix = diario.SequencePrefix,
                IsActive = diario.IsActive,
                AllowsManual = diario.AllowsManual,
                IsDefaultManual = diario.IsDefaultManual
            };
            popupTitle = $"Editar {diario.Code}";
        }

        isFormVisible = true;
    }

    private void CloseForm()
    {
        isFormVisible = false;
    }

    private async Task SaveDiarioAsync()
    {
        if (string.IsNullOrWhiteSpace(formModel.Code) || string.IsNullOrWhiteSpace(formModel.Name))
        {
            ToastService.ShowToast(new ToastOptions { Title = "Diarios", Text = "Codigo y nombre son obligatorios.", RenderStyle = ToastRenderStyle.Danger });
            return;
        }

        if (!formModel.IsActive || !formModel.AllowsManual)
        {
            formModel.IsDefaultManual = false;
        }

        var payload = new DiarioUpsertDto(
            Code: formModel.Code.Trim(),
            Name: formModel.Name.Trim(),
            IsActive: formModel.IsActive,
            AllowsManual: formModel.AllowsManual,
            User: string.Empty,
            JournalId: formModel.JournalId,
            Description: string.IsNullOrWhiteSpace(formModel.Description) ? null : formModel.Description.Trim(),
            SequencePrefix: string.IsNullOrWhiteSpace(formModel.SequencePrefix) ? null : formModel.SequencePrefix.Trim(),
            IsDefaultManual: formModel.IsDefaultManual);

        try
        {
            isSaving = true;

            var response = await Http.PostAsJsonAsync("api/contabilidad/catalogos/diarios", payload);
            var detail = await response.Content.ReadAsStringAsync();

            if (!response.IsSuccessStatusCode)
            {
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Diarios",
                    Text = string.IsNullOrWhiteSpace(detail) ? "No se pudo guardar el diario." : detail,
                    RenderStyle = ToastRenderStyle.Danger
                });
                return;
            }

            isFormVisible = false;
            await LoadDiariosAsync();
            ShowStatusMessage("Exito", "Diario guardado correctamente.", MessageBoxRenderStyle.Success);
        }
        catch (Exception ex)
        {
            errorNotice.ShowError("No se pudo guardar el diario.", ex);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ShowStatusMessage(string title, string message, MessageBoxRenderStyle renderStyle = MessageBoxRenderStyle.Info)
    {
        statusMessageTitle = title;
        statusMessageText = message;
        statusMessageRenderStyle = renderStyle;
        statusMessageVisible = true;
    }

    private string GetPopupHeading()
    {
        return formModel.JournalId.HasValue ? "Actualizar diario contable" : "Crear nuevo diario contable";
    }

    private string GetPopupModeLabel()
    {
        return formModel.JournalId.HasValue ? "Edicion" : "Nuevo";
    }

    private string GetPreviewCode()
    {
        return string.IsNullOrWhiteSpace(formModel.Code) ? "Sin definir" : formModel.Code.Trim().ToUpperInvariant();
    }

    private string GetPreviewPrefix()
    {
        return string.IsNullOrWhiteSpace(formModel.SequencePrefix) ? "Sin prefijo" : formModel.SequencePrefix.Trim().ToUpperInvariant();
    }

    private static string GetActiveBadgeCss(bool isActive)
    {
        return isActive ? "diarios-badge diarios-badge--success" : "diarios-badge diarios-badge--neutral";
    }

    private static string GetManualBadgeCss(bool allowsManual)
    {
        return allowsManual ? "diarios-badge diarios-badge--info" : "diarios-badge diarios-badge--neutral";
    }

    private static string GetDefaultBadgeCss(bool isDefaultManual)
    {
        return isDefaultManual ? "diarios-badge diarios-badge--accent" : "diarios-badge diarios-badge--neutral";
    }

    private void MostrarColumnChooser()
    {
        diariosGrid?.ShowColumnChooser(".diarios-column-chooser-button");
    }

    private GridDetailRowDisplayMode GetGridDetailRowDisplayMode()
    {
        return isXSmallScreen ? GridDetailRowDisplayMode.Always : GridDetailRowDisplayMode.Never;
    }

    private sealed class DiarioFormModel
    {
        public long? JournalId { get; set; }
        public string? Code { get; set; }
        public string? Name { get; set; }
        public string? Description { get; set; }
        public string? SequencePrefix { get; set; }
        public bool IsActive { get; set; } = true;
        public bool AllowsManual { get; set; } = true;
        public bool IsDefaultManual { get; set; }
    }
}
