@page "/contabilidad/reglas-integracion"
@attribute [Authorize]

@using DevExpress.Blazor
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Web
@using SIAD.Core.DTOs.Contabilidad
@using apc.Client.Services.Tenant

@inject HttpClient Http
@inject TenantState TenantState

<div class="container-fluid p-3 p-md-4">
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                <div>
                    <h3 class="fw-bold text-dark mb-0">Reglas de Integración <span class="badge bg-warning text-dark fs-6">Legacy</span></h3>
                    <div class="text-muted small">Configuración legacy — solo aplica al flujo de lectura móvil (sp_lectura_v2)</div>
                </div>

                <div class="d-flex flex-wrap gap-2 justify-content-start justify-content-md-end">
                    <DxButton Text="Actualizar"
                              RenderStyle="ButtonRenderStyle.Secondary"
                              RenderStyleMode="ButtonRenderStyleMode.Text"
                              IconCssClass="bi bi-arrow-clockwise"
                              Click="@OnRefreshClick" />

                    <DxButton Text="Nueva regla"
                              RenderStyle="ButtonRenderStyle.Primary"
                              RenderStyleMode="ButtonRenderStyleMode.Contained"
                              IconCssClass="bi bi-plus-lg"
                              Click="@(() => OpenForm(null))" />
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-warning shadow-sm d-flex align-items-start mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2 fs-5 mt-1"></i>
        <div>
            <strong>Alcance restringido.</strong> Esta configuración solo aplica al flujo de <strong>lectura móvil</strong> (sp_lectura_v2).
            Los flujos de captación (lectora, manual, misceláneos) usan plantillas contables (<code>con_plantilla_partida_hdr/dtl</code>) como fuente de verdad runtime.
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(pageError))
    {
        <div class="alert alert-danger shadow-sm d-flex align-items-center mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2 fs-4"></i>
            <div class="flex-grow-1">@pageError</div>
            <button type="button" class="btn-close" @onclick="@(() => pageError = null)"></button>
        </div>
    }

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-3">
            <div class="row g-3 align-items-end">
                <div class="col-12 col-md-3">
                    <label class="form-label">Módulo</label>
                    <DxComboBox Data="@moduleOptions"
                                @bind-Value="filterModule"
                                NullText="Todos"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                DropDownButtonDisplayMode="DropDownButtonDisplayMode.Auto" />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Documento</label>
                    <DxComboBox Data="@documentTypeOptions"
                                TextFieldName="Display"
                                ValueFieldName="DocumentTypeId"
                                @bind-Value="filterDocumentTypeId"
                                NullText="Todos"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                DropDownButtonDisplayMode="DropDownButtonDisplayMode.Auto" />
                </div>
                <div class="col-12 col-md-4">
                    <label class="form-label">Búsqueda</label>
                    <DxTextBox @bind-Text="filterSearch" Placeholder="Escenario o descripción" />
                </div>
                <div class="col-12 col-md-1 d-flex">
                    <DxButton Text="Filtrar"
                              RenderStyle="ButtonRenderStyle.Primary"
                              RenderStyleMode="ButtonRenderStyleMode.Outline"
                              IconCssClass="bi bi-funnel"
                              Click="@OnFilterClick"
                              CssClass="w-100" />
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-transparent border-0 d-flex justify-content-between align-items-center py-3">
            <div>
                <div class="fw-bold text-dark">Reglas configuradas</div>
                <small class="text-muted">Total: @reglas.Count</small>
            </div>
        </div>

        <div class="card-body p-0">
            <DxGrid Data="@reglas"
                    TData="ReglaIntegracionDto"
                    KeyFieldName="@nameof(ReglaIntegracionDto.RuleId)"
                    ShowFilterRow="true"
                    ShowSearchBox="true"
                    PageSize="10"
                    ColumnResizeMode="GridColumnResizeMode.NextColumn"
                    PagerPosition="GridPagerPosition.Bottom"
                    CssClass="border-top">
                <Columns>
                    <DxGridCommandColumn Caption=" " Width="90px">
                        <CellDisplayTemplate Context="cell">
                            <div class="d-flex gap-2 justify-content-center">
                                <button class="btn btn-link p-0 text-info"
                                        title="Editar"
                                        @onclick="@(() => OpenForm((ReglaIntegracionDto)cell.DataItem))">
                                    <i class="bi bi-pencil-square"></i>
                                </button>
                                <button class="btn btn-link p-0 text-danger"
                                        title="Eliminar"
                                        @onclick="@(() => OpenDeleteConfirm((ReglaIntegracionDto)cell.DataItem))">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </CellDisplayTemplate>
                    </DxGridCommandColumn>

                    <DxGridDataColumn FieldName="@nameof(ReglaIntegracionDto.Module)" Caption="Módulo" Width="110px" />
                    <DxGridDataColumn Caption="Documento" MinWidth="160">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is ReglaIntegracionDto item)
                            {
                                <span class="font-monospace">@item.DocumentTypeCode</span>
                                <span class="text-muted"> - @item.DocumentTypeName</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="@nameof(ReglaIntegracionDto.ScenarioCode)" Caption="Escenario" Width="140px" />
                    <DxGridDataColumn Caption="Débito" MinWidth="180">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is ReglaIntegracionDto item)
                            {
                                <span class="font-monospace">@item.DebitAccountCode</span>
                                <span class="text-muted"> - @item.DebitAccountName</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn Caption="Crédito" MinWidth="180">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is ReglaIntegracionDto item)
                            {
                                <span class="font-monospace">@item.CreditAccountCode</span>
                                <span class="text-muted"> - @item.CreditAccountName</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn Caption="Centro costo" Width="160px">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is ReglaIntegracionDto item)
                            {
                                @if (!string.IsNullOrWhiteSpace(item.CostCenterCode))
                                {
                                    <span class="font-monospace">@item.CostCenterCode</span>
                                    <span class="text-muted"> - @item.CostCenterName</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                    <DxGridDataColumn FieldName="@nameof(ReglaIntegracionDto.IsActive)" Caption="Activa" Width="70px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @if (((ReglaIntegracionDto)cell.DataItem).IsActive)
                            {
                                <i class="bi bi-check-circle-fill text-success" title="Activa"></i>
                            }
                            else
                            {
                                <i class="bi bi-circle text-muted" title="Inactiva"></i>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>
            </DxGrid>
        </div>
    </div>
</div>

<DxPopup @bind-Visible="formVisible"
         ShowFooter="false"
         Width="min(920px, 96vw)"
         ShowCloseButton="true"
         CloseOnOutsideClick="false">
    <BodyContentTemplate Context="popupCtx">
        <div class="p-4">
            <div class="mb-3">
                <h6 class="fw-bold mb-1">@((formModel.IsNew ? "Nueva regla" : "Editar regla"))</h6>
                <div class="text-muted small">Defina la cuenta débito y crédito por documento</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(formError))
            {
                <div class="alert alert-danger py-2 mb-3">@formError</div>
            }

            <DxFormLayout>
                <DxFormLayoutGroup Caption="Información general" ColSpanMd="12">
                    <DxFormLayoutItem ColSpanMd="4" ColSpanXs="12" Caption="Módulo">
                        <DxComboBox Data="@moduleOptions"
                                    @bind-Value="formModel.Module"
                                    @bind-Value:after="OnFormModuleChanged"
                                    NullText="Seleccione" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="8" ColSpanXs="12" Caption="Documento">
                        <DxComboBox Data="@formDocumentTypeOptions"
                                    TextFieldName="Display"
                                    ValueFieldName="DocumentTypeId"
                                    @bind-Value="formModel.DocumentTypeId"
                                    NullText="Seleccione" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="4" ColSpanXs="12" Caption="Escenario">
                        <DxTextBox @bind-Text="formModel.ScenarioCode" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="8" ColSpanXs="12" Caption="Descripción">
                        <DxTextBox @bind-Text="formModel.Description" />
                    </DxFormLayoutItem>
                </DxFormLayoutGroup>

                <DxFormLayoutGroup Caption="Cuentas contables" ColSpanMd="12" CssClass="mt-3">
                    <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12" Caption="Cuenta débito">
                        <DxComboBox Data="@accountOptions"
                                    TextFieldName="Display"
                                    ValueFieldName="AccountId"
                                    @bind-Value="formModel.DebitAccountId"
                                    NullText="Seleccione" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12" Caption="Cuenta crédito">
                        <DxComboBox Data="@accountOptions"
                                    TextFieldName="Display"
                                    ValueFieldName="AccountId"
                                    @bind-Value="formModel.CreditAccountId"
                                    NullText="Seleccione" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12" Caption="Centro de costo (opcional)">
                        <DxComboBox Data="@costCenterOptions"
                                    TextFieldName="Display"
                                    ValueFieldName="CostCenterId"
                                    @bind-Value="formModel.CostCenterId"
                                    NullText="Ninguno"
                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                    </DxFormLayoutItem>
                    <DxFormLayoutItem ColSpanMd="6" ColSpanXs="12">
                        <DxCheckBox @bind-Checked="formModel.IsActive" CheckType="CheckType.Switch">Regla activa</DxCheckBox>
                    </DxFormLayoutItem>
                </DxFormLayoutGroup>
            </DxFormLayout>

            <div class="d-flex justify-content-end gap-2 mt-4">
                <DxButton Text="Cancelar"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                          Click="@CloseForm" />
                <DxButton Text="Guardar"
                          RenderStyle="ButtonRenderStyle.Primary"
                          RenderStyleMode="ButtonRenderStyleMode.Contained"
                          Click="@SaveFormAsync" />
            </div>
        </div>
    </BodyContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="deleteConfirmVisible"
         ShowFooter="false"
         Width="420px"
         ShowCloseButton="true"
         CloseOnOutsideClick="false">
    <BodyContentTemplate Context="deletePopupCtx">
        <div class="p-4">
            <p class="fw-bold mb-1">¿Eliminar regla?</p>
            <p class="text-muted mb-3">@deleteTarget?.ScenarioCode</p>
            <div class="d-flex justify-content-end gap-2">
                <DxButton Text="Cancelar"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                          Click="@CloseDeleteConfirm" />
                <DxButton Text="Eliminar"
                          RenderStyle="ButtonRenderStyle.Danger"
                          RenderStyleMode="ButtonRenderStyleMode.Contained"
                          Click="@DeleteRuleAsync" />
            </div>
        </div>
    </BodyContentTemplate>
</DxPopup>

@code {
    private List<ReglaIntegracionDto> reglas = new();
    private List<DocumentTypeLookupDto> docTypes = new();
    private List<PlanCuentaDto> cuentas = new();
    private List<CentroCostoDto> centrosCosto = new();

    private string? filterModule;
    private long? filterDocumentTypeId;
    private string? filterSearch;

    private string? pageError;

    private bool formVisible;
    private string? formError;
    private ReglaFormModel formModel = new();

    private bool deleteConfirmVisible;
    private ReglaIntegracionDto? deleteTarget;

    private IEnumerable<string> moduleOptions => docTypes
        .Select(d => d.Module)
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(m => m);

    private List<DocumentTypeOption> documentTypeOptions =>
        docTypes
            .Where(d => string.IsNullOrWhiteSpace(filterModule) || d.Module.Equals(filterModule, StringComparison.OrdinalIgnoreCase))
            .Select(d => new DocumentTypeOption(d.DocumentTypeId, $"{d.Code} - {d.Name}"))
            .ToList();

    private List<DocumentTypeOption> formDocumentTypeOptions =>
        docTypes
            .Where(d => string.IsNullOrWhiteSpace(formModel.Module) || d.Module.Equals(formModel.Module, StringComparison.OrdinalIgnoreCase))
            .Select(d => new DocumentTypeOption(d.DocumentTypeId, $"{d.Code} - {d.Name}"))
            .ToList();

    private List<AccountOption> accountOptions =>
        cuentas
            .Where(c => c.AllowsPosting && string.Equals(c.Status, "ACTIVE", StringComparison.OrdinalIgnoreCase))
            .Select(c => new AccountOption(c.AccountId, $"{c.Code} - {c.Name}"))
            .ToList();

    private List<CostCenterOption> costCenterOptions =>
        centrosCosto
            .Where(c => string.Equals(c.Status, "ACTIVE", StringComparison.OrdinalIgnoreCase))
            .Select(c => new CostCenterOption(c.CostCenterId, $"{c.Code} - {c.Name}"))
            .ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadCatalogsAsync();
        await LoadRulesAsync();
    }

    private async Task LoadCatalogsAsync()
    {
        try
        {
            docTypes = await Http.GetFromJsonAsync<List<DocumentTypeLookupDto>>("api/contabilidad/catalogos/documentos")
                ?? new List<DocumentTypeLookupDto>();

            cuentas = await Http.GetFromJsonAsync<List<PlanCuentaDto>>("api/contabilidad/catalogos/plan-cuentas")
                ?? new List<PlanCuentaDto>();

            centrosCosto = await Http.GetFromJsonAsync<List<CentroCostoDto>>("api/contabilidad/catalogos/centros-costo")
                ?? new List<CentroCostoDto>();
        }
        catch (Exception ex)
        {
            pageError = $"Error cargando catálogos: {ex.Message}";
        }
    }

    private async Task LoadRulesAsync()
    {
        try
        {
            pageError = null;
            var query = new Dictionary<string, string?>();
            if (!string.IsNullOrWhiteSpace(filterModule)) query["module"] = filterModule;
            if (filterDocumentTypeId.HasValue) query["documentTypeId"] = filterDocumentTypeId.Value.ToString();
            if (!string.IsNullOrWhiteSpace(filterSearch)) query["search"] = filterSearch;

            var url = BuildQueryString("api/contabilidad/catalogos/reglas-integracion", query);
            reglas = await Http.GetFromJsonAsync<List<ReglaIntegracionDto>>(url)
                ?? new List<ReglaIntegracionDto>();
        }
        catch (Exception ex)
        {
            pageError = $"Error cargando reglas: {ex.Message}";
        }
    }

    private async Task OnRefreshClick()
    {
        await LoadCatalogsAsync();
        await LoadRulesAsync();
    }

    private async Task OnFilterClick()
    {
        await LoadRulesAsync();
    }

    private void OpenForm(ReglaIntegracionDto? item)
    {
        formError = null;
        if (item is null)
        {
            formModel = new ReglaFormModel
            {
                Module = filterModule ?? "VENTAS",
                IsActive = true
            };
        }
        else
        {
            formModel = new ReglaFormModel
            {
                RuleId = item.RuleId,
                Module = item.Module,
                DocumentTypeId = item.DocumentTypeId,
                ScenarioCode = item.ScenarioCode,
                Description = item.Description,
                DebitAccountId = item.DebitAccountId,
                CreditAccountId = item.CreditAccountId,
                CostCenterId = item.CostCenterId,
                IsActive = item.IsActive
            };
        }
        formVisible = true;
    }

    private void CloseForm()
    {
        formVisible = false;
        formError = null;
    }

    private void OnFormModuleChanged()
    {
        formModel.DocumentTypeId = null;
    }

    private async Task SaveFormAsync()
    {
        var validation = ValidateForm(formModel);
        if (!string.IsNullOrWhiteSpace(validation))
        {
            formError = validation;
            return;
        }

        var payload = new ReglaIntegracionUpsertDto(
            formModel.Module!,
            formModel.DocumentTypeId!.Value,
            formModel.ScenarioCode!,
            formModel.Description,
            formModel.DebitAccountId!.Value,
            formModel.CreditAccountId!.Value,
            formModel.CostCenterId,
            formModel.IsActive,
            "system",
            formModel.RuleId);

        var response = await Http.PostAsJsonAsync("api/contabilidad/catalogos/reglas-integracion", payload);
        if (response.IsSuccessStatusCode)
        {
            formVisible = false;
            await LoadRulesAsync();
            return;
        }

        var msg = await response.Content.ReadAsStringAsync();
        formError = string.IsNullOrWhiteSpace(msg) ? "Error al guardar la regla." : msg;
    }

    private static string? ValidateForm(ReglaFormModel model)
    {
        if (string.IsNullOrWhiteSpace(model.Module)) return "El módulo es obligatorio.";
        if (!model.DocumentTypeId.HasValue) return "El documento es obligatorio.";
        if (string.IsNullOrWhiteSpace(model.ScenarioCode)) return "El escenario es obligatorio.";
        if (!model.DebitAccountId.HasValue) return "La cuenta débito es obligatoria.";
        if (!model.CreditAccountId.HasValue) return "La cuenta crédito es obligatoria.";
        return null;
    }

    private void OpenDeleteConfirm(ReglaIntegracionDto item)
    {
        deleteTarget = item;
        deleteConfirmVisible = true;
    }

    private void CloseDeleteConfirm()
    {
        deleteConfirmVisible = false;
        deleteTarget = null;
    }

    private async Task DeleteRuleAsync()
    {
        if (deleteTarget is null) return;
        var response = await Http.DeleteAsync($"api/contabilidad/catalogos/reglas-integracion/{deleteTarget.RuleId}");
        if (response.IsSuccessStatusCode)
        {
            CloseDeleteConfirm();
            await LoadRulesAsync();
            return;
        }

        pageError = await response.Content.ReadAsStringAsync();
    }

    private static string BuildQueryString(string baseUrl, Dictionary<string, string?> query)
    {
        if (query is null || query.Count == 0) return baseUrl;
        var parts = new List<string>();
        foreach (var kv in query)
        {
            if (string.IsNullOrWhiteSpace(kv.Value)) continue;
            parts.Add($"{Uri.EscapeDataString(kv.Key)}={Uri.EscapeDataString(kv.Value!)}");
        }
        if (parts.Count == 0) return baseUrl;
        return $"{baseUrl}?{string.Join("&", parts)}";
    }

    private sealed class ReglaFormModel
    {
        public long? RuleId { get; set; }
        public string Module { get; set; } = string.Empty;
        public long? DocumentTypeId { get; set; }
        public string? ScenarioCode { get; set; }
        public string? Description { get; set; }
        public long? DebitAccountId { get; set; }
        public long? CreditAccountId { get; set; }
        public long? CostCenterId { get; set; }
        public bool IsActive { get; set; } = true;
        public bool IsNew => !RuleId.HasValue;
    }

    private sealed record AccountOption(long AccountId, string Display);
    private sealed record CostCenterOption(long CostCenterId, string Display);
    private sealed record DocumentTypeOption(long DocumentTypeId, string Display);
}
