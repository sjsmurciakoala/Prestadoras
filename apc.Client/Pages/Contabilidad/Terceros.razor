@page "/contabilidad/terceros"
@attribute [Authorize]

@using SIAD.Core.DTOs.Contabilidad
@using DevExpress.Blazor
@using System.Net.Http.Json

@inject HttpClient Http

<PageTitle>Terceros</PageTitle>
<div class="contabilidad-page" id="terceros-view">

    <DxMessageBox @bind-Visible="statusMessageVisible"
                  Type="MessageBoxType.Alert"
                  Title="@statusMessageTitle"
                  Text="@statusMessageText"
                  RenderStyle="@statusMessageRenderStyle"
                  OkButtonText="Entendido"
                  ShowCloseButton="false"
                  CloseOnOutsideClick="false" />

    <div class="cc-toolbar-container">
        <DxStackLayout Orientation="Orientation.Horizontal" Wrap="true" Spacing="10px" Class="w-100 justify-content-between align-items-center">
            <Items>
                <DxStackLayoutItem>
                    <Template>
                        <h4 class="mb-0 fw-bold text-secondary"><i class="bi bi-people me-2 text-primary"></i>Terceros</h4>
                    </Template>
                </DxStackLayoutItem>
                <DxStackLayoutItem>
                    <Template>
                        <div class="d-flex gap-2">
                            <DxButton Text="Sincronizar Proveedores y Clientes"
                                      RenderStyle="ButtonRenderStyle.Warning"
                                      IconCssClass="bi bi-arrow-repeat"
                                      Click="@OnSincronizarClick" />
                            <DxButton Text="Actualizar"
                                      RenderStyle="ButtonRenderStyle.Secondary"
                                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                                      IconCssClass="bi bi-arrow-clockwise"
                                      Click="@OnActualizarClick" />
                            <DxButton Text="Nuevo"
                                      RenderStyle="ButtonRenderStyle.Primary"
                                      IconCssClass="bi bi-plus-lg"
                                      Click="@OnNuevoClick" />
                        </div>
                    </Template>
                </DxStackLayoutItem>
            </Items>
        </DxStackLayout>
    </div>

    <div class="cc-grid-wrapper shadow-sm">
        <DxGrid @ref="gridTerceros" Data="@terceros" KeyFieldName="@nameof(TerceroDto.ThirdPartyId)"
                ShowFilterRow="true"
                ShowPager="true" PageSize="20" PageSizeSelectorVisible="true"
                PageSizeSelectorItems="new int[] { 10, 20, 50, 100 }"
                SizeMode="SizeMode.Medium"
                EditMode="GridEditMode.PopupEditForm"
                PopupEditFormHeaderText="@popupHeaderText"
                PopupEditFormCssClass="cc-popup-responsive"
                EditFormButtonsVisible="false"
                CustomizeEditModel="OnCustomizeEditModel"
                EditModelSaving="OnEditModelSaving">

            <Columns>
                <DxGridCommandColumn Caption="Acciones" Width="140px" VisibleIndex="99">
                    <CellDisplayTemplate Context="cellContext">
                        <div class="d-flex gap-1 justify-content-center">
                            <DxButton RenderStyle="ButtonRenderStyle.Info" RenderStyleMode="ButtonRenderStyleMode.Text" SizeMode="SizeMode.Small"
                                      IconCssClass="bi bi-pencil-square fs-5"
                                      Click="@((MouseEventArgs e) => OnEditarClick(cellContext.VisibleIndex))"
                                      title="Editar" />
                            <DxButton RenderStyle="ButtonRenderStyle.Danger" RenderStyleMode="ButtonRenderStyleMode.Text" SizeMode="SizeMode.Small"
                                      IconCssClass="bi bi-trash fs-5"
                                      Click="@((MouseEventArgs e) => OpenDeleteConfirm((TerceroDto)cellContext.DataItem))"
                                      title="Eliminar" />
                        </div>
                    </CellDisplayTemplate>
                </DxGridCommandColumn>

                <DxGridDataColumn FieldName="@nameof(TerceroDto.Code)" Caption="Código" Width="160px">
                    <CellDisplayTemplate Context="cell">
                        <span class="fw-bold text-primary font-monospace">@cell.Value</span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(TerceroDto.Name)" Caption="Nombre" MinWidth="200" />
                <DxGridDataColumn FieldName="@nameof(TerceroDto.TaxId)" Caption="RTN" Width="160px" />

                <DxGridDataColumn FieldName="@nameof(TerceroDto.Category)" Caption="Categoría" Width="120px">
                    <CellDisplayTemplate Context="cell">
                        @{ var cat = (string?)cell.Value; }
                        <span class="badge @(cat == "SUPPLIER" ? "bg-info" : cat == "CUSTOMER" ? "bg-success" : "bg-secondary")">
                            @(cat == "SUPPLIER" ? "Proveedor" : cat == "CUSTOMER" ? "Cliente" : cat == "BOTH" ? "Ambos" : cat)
                        </span>
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(TerceroDto.IsSupplier)" Caption="Proveedor" Width="100px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate>
                        @if ((bool)context.Value) { <i class="bi bi-check-circle-fill text-info"></i> } else { <span class="text-muted">-</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(TerceroDto.IsCustomer)" Caption="Cliente" Width="100px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate>
                        @if ((bool)context.Value) { <i class="bi bi-check-circle-fill text-success"></i> } else { <span class="text-muted">-</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>

                <DxGridDataColumn FieldName="@nameof(TerceroDto.Status)" Caption="Estado" Width="100px" TextAlignment="GridTextAlignment.Center">
                    <CellDisplayTemplate Context="cell">
                        @if ((string?)cell.Value == "ACTIVE") { <span class="badge bg-success">Activo</span> } else { <span class="badge bg-secondary">Inactivo</span> }
                    </CellDisplayTemplate>
                </DxGridDataColumn>
            </Columns>

            <EditFormTemplate Context="ctx">
                @{ var model = (TerceroEditModel)ctx.EditModel; }
                <div class="d-flex flex-column h-100">

                    @if (!string.IsNullOrWhiteSpace(formErrorMessage))
                    {
                        <DxAlert AlertType="AlertType.Danger" CssClass="mb-3 mx-2 mt-2">
                            <span>@formErrorMessage</span>
                            <DxButton RenderStyle="ButtonRenderStyle.None" CssClass="btn-close ms-2 float-end" SizeMode="SizeMode.Small"
                                      Click="@(() => formErrorMessage = null)" />
                        </DxAlert>
                    }

                    <div class="flex-grow-1 p-3 overflow-auto custom-scrollbar">
                        <DxFormLayout SizeMode="SizeMode.Medium" CaptionPosition="CaptionPosition.Vertical">

                            <DxFormLayoutGroup Caption="Información General" HeaderIconCssClass="bi bi-card-heading">
                                <DxFormLayoutItem ColSpanMd="6" ColSpanSm="12">
                                    <CaptionTemplate><span class="fw-semibold">Código</span></CaptionTemplate>
                                    <Template>
                                        <DxTextBox @bind-Text="model.Code" NullText="Ej. PRV-001" />
                                    </Template>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem ColSpanMd="6" ColSpanSm="12">
                                    <CaptionTemplate><span class="fw-semibold">Nombre</span></CaptionTemplate>
                                    <Template>
                                        <DxTextBox @bind-Text="model.Name" NullText="Nombre del tercero" />
                                    </Template>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem ColSpanMd="6" ColSpanSm="12">
                                    <CaptionTemplate><span class="fw-semibold">RTN / Identidad Fiscal</span></CaptionTemplate>
                                    <Template>
                                        <DxTextBox @bind-Text="model.TaxId" NullText="RTN" />
                                    </Template>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem ColSpanMd="6" ColSpanSm="12">
                                    <CaptionTemplate><span class="fw-semibold">Categoría</span></CaptionTemplate>
                                    <Template>
                                        <DxComboBox Data="@categorias" @bind-Value="model.Category"
                                                    TextFieldName="Label" ValueFieldName="Value" />
                                    </Template>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem ColSpanMd="12">
                                    <CaptionTemplate><span class="fw-semibold">Descripción</span></CaptionTemplate>
                                    <Template>
                                        <DxMemo @bind-Text="model.Description" Rows="2" />
                                    </Template>
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>

                            <DxFormLayoutGroup Caption="Clasificación" HeaderIconCssClass="bi bi-tags" CssClass="mt-3">
                                <DxFormLayoutItem ColSpanMd="4" ColSpanSm="6">
                                    <Template>
                                        <DxCheckBox @bind-Checked="model.IsSupplier" CheckType="CheckType.Switch">Es Proveedor</DxCheckBox>
                                    </Template>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem ColSpanMd="4" ColSpanSm="6">
                                    <Template>
                                        <DxCheckBox @bind-Checked="model.IsCustomer" CheckType="CheckType.Switch">Es Cliente</DxCheckBox>
                                    </Template>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem ColSpanMd="4" ColSpanSm="6">
                                    <Template>
                                        <DxCheckBox @bind-Checked="model.IsActive" CheckType="CheckType.Switch">Activo</DxCheckBox>
                                    </Template>
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>

                        </DxFormLayout>
                    </div>

                    <div class="modal-footer-custom d-flex justify-content-between align-items-center p-3 border-top bg-light">
                        <div>
                            @if (model.ThirdPartyId.HasValue)
                            {
                                <DxButton Text="Eliminar"
                                          RenderStyle="ButtonRenderStyle.Danger"
                                          RenderStyleMode="ButtonRenderStyleMode.Outline"
                                          IconCssClass="bi bi-trash"
                                          Click="@((MouseEventArgs e) => OpenDeleteConfirmFromEdit(model))" />
                            }
                        </div>
                        <div class="d-flex gap-2">
                            <DxButton Text="Cancelar" RenderStyle="ButtonRenderStyle.Secondary" Click="@OnCancelarClick" />
                            <DxButton Text="Guardar" RenderStyle="ButtonRenderStyle.Primary" IconCssClass="bi bi-check-lg" SubmitFormOnClick="true" />
                        </div>
                    </div>
                </div>
            </EditFormTemplate>
        </DxGrid>
    </div>

    @* ── Popup de resultado de sincronización ── *@
    <DxPopup @bind-Visible="syncResultVisible"
             HeaderText="Resultado de sincronización"
             ShowFooter="false"
             ShowCloseButton="true"
             CloseOnOutsideClick="true"
             Width="min(500px, 90vw)">
        <BodyTemplate>
            <div class="p-4">
                @if (syncResult != null)
                {
                    <div class="mb-3 text-center">
                        <i class="bi bi-arrow-repeat text-warning" style="font-size: 3rem;"></i>
                    </div>
                    <div class="row text-center mb-3">
                        <div class="col-6">
                            <div class="border rounded p-3">
                                <div class="fs-3 fw-bold text-info">@syncResult.ProveedoresSincronizados</div>
                                <div class="text-muted small">Proveedores sincronizados</div>
                                <div class="text-muted small">(@syncResult.ProveedoresOmitidos sin cambios)</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="border rounded p-3">
                                <div class="fs-3 fw-bold text-success">@syncResult.ClientesSincronizados</div>
                                <div class="text-muted small">Clientes sincronizados</div>
                                <div class="text-muted small">(@syncResult.ClientesOmitidos sin cambios)</div>
                            </div>
                        </div>
                    </div>
                    @if (syncResult.Errores > 0)
                    {
                        <div class="alert alert-danger">@syncResult.Errores errores durante la sincronización</div>
                    }
                    <ul class="list-unstyled mb-0">
                        @foreach (var msg in syncResult.Mensajes)
                        {
                            <li class="mb-1"><i class="bi bi-info-circle me-1 text-primary"></i>@msg</li>
                        }
                    </ul>
                    <div class="mt-4 text-start">
                        <DxButton Text="Entendido"
                                  RenderStyle="ButtonRenderStyle.Primary"
                                  Click="@(() => syncResultVisible = false)" />
                    </div>
                }
            </div>
        </BodyTemplate>
    </DxPopup>

    @* ── Popup de confirmación de eliminación ── *@
    <DxPopup @bind-Visible="deleteConfirmVisible"
             HeaderText=" "
             ShowCloseButton="true"
             CloseOnOutsideClick="true"
             Width="min(450px, 90vw)"
             ShowFooter="false"
             CssClass="cc-confirm-popup">
        <BodyTemplate>
            <div class="cc-modal-wrapper">
                <div class="cc-confirm-body">
                    <div class="cc-icon-circle">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <div class="flex-grow-1">
                        <div class="cc-confirm-title">¿Eliminar tercero?</div>
                        <div class="cc-confirm-subtitle">
                            Esta acción eliminará el tercero permanentemente. No se puede deshacer.
                        </div>
                        @if (deleteItem is not null)
                        {
                            <div class="cc-details-card">
                                <div class="cc-detail-row">
                                    <span class="cc-label">Código:</span>
                                    <span class="cc-value">@deleteItem.Code</span>
                                </div>
                                <div class="cc-detail-row mb-0">
                                    <span class="cc-label">Nombre:</span>
                                    <span class="cc-value text-end">@deleteItem.Name</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="cc-modal-footer">
                    <DxButton Text="Cancelar"
                              RenderStyle="ButtonRenderStyle.Secondary"
                              RenderStyleMode="ButtonRenderStyleMode.Outline"
                              Click="@(() => deleteConfirmVisible = false)"
                              CssClass="cc-btn-cancel" />
                    <DxButton Text="Sí, Eliminar"
                              RenderStyle="ButtonRenderStyle.None"
                              CssClass="dx-btn dx-btn-danger cc-btn-delete"
                              IconCssClass="bi bi-trash3-fill"
                              Click="@OnConfirmDeleteClick" />
                </div>
            </div>
        </BodyTemplate>
    </DxPopup>

    <DxLoadingPanel Visible="@cargando" PositionTarget="#terceros-view"
                    ApplyBackgroundShading="true" IsContentBlocked="true"
                    Text="Cargando terceros..." IndicatorVisible="true" />

</div>

@code {
    private IList<TerceroDto> terceros = new List<TerceroDto>();
    private bool cargando;

    private DxGrid? gridTerceros;
    private string? formErrorMessage;
    private string popupHeaderText = "Tercero";

    private bool statusMessageVisible;
    private string statusMessageTitle = string.Empty;
    private string statusMessageText = string.Empty;
    private MessageBoxRenderStyle statusMessageRenderStyle = MessageBoxRenderStyle.Info;

    private bool deleteConfirmVisible;
    private TerceroDto? deleteItem;
    private long? deleteFromEditId;

    private bool syncResultVisible;
    private SincronizarTercerosResultDto? syncResult;

    private static readonly List<CategoriaOption> categorias = new()
    {
        new("SUPPLIER", "Proveedor"),
        new("CUSTOMER", "Cliente"),
        new("BOTH", "Ambos"),
        new("OTHER", "Otro")
    };

    private record CategoriaOption(string Value, string Label);

    protected override async Task OnInitializedAsync()
    {
        await LoadTercerosAsync();
    }

    private async Task LoadTercerosAsync()
    {
        cargando = true;
        try
        {
            terceros = await Http.GetFromJsonAsync<List<TerceroDto>>("api/contabilidad/terceros") ?? new();
        }
        catch (Exception ex)
        {
            ShowStatus("Error", $"No se pudieron cargar los terceros: {ex.Message}", MessageBoxRenderStyle.Danger);
        }
        finally { cargando = false; }
    }

    private async Task OnActualizarClick() => await LoadTercerosAsync();

    private async Task OnNuevoClick()
    {
        if (gridTerceros != null)
            await gridTerceros.StartEditNewRowAsync();
        popupHeaderText = "Nuevo Tercero";
    }

    private async Task OnEditarClick(int visibleIndex)
    {
        if (gridTerceros != null)
            await gridTerceros.StartEditRowAsync(visibleIndex);
        popupHeaderText = "Editar Tercero";
    }

    private void OnCustomizeEditModel(GridCustomizeEditModelEventArgs e)
    {
        var model = new TerceroEditModel();
        if (e.DataItem is TerceroDto dto)
        {
            model.ThirdPartyId = dto.ThirdPartyId;
            model.Code = dto.Code;
            model.Name = dto.Name;
            model.Description = dto.Description;
            model.TaxId = dto.TaxId;
            model.Category = dto.Category;
            model.IsSupplier = dto.IsSupplier;
            model.IsCustomer = dto.IsCustomer;
            model.IsActive = dto.Status == "ACTIVE";
        }
        else
        {
            model.Category = "SUPPLIER";
            model.IsActive = true;
        }
        e.EditModel = model;
    }

    private async Task OnEditModelSaving(GridEditModelSavingEventArgs e)
    {
        formErrorMessage = null;
        var model = (TerceroEditModel)e.EditModel;

        if (string.IsNullOrWhiteSpace(model.Code))
        { formErrorMessage = "El código es obligatorio"; e.Cancel = true; return; }
        if (string.IsNullOrWhiteSpace(model.Name))
        { formErrorMessage = "El nombre es obligatorio"; e.Cancel = true; return; }

        try
        {
            var dto = new TerceroUpsertDto(
                model.Code.Trim(),
                model.Name.Trim(),
                model.Description?.Trim(),
                model.TaxId?.Trim(),
                model.Category ?? "OTHER",
                model.IsSupplier,
                model.IsCustomer,
                model.IsActive ? "ACTIVE" : "INACTIVE",
                "USER",
                model.ThirdPartyId);

            var response = await Http.PostAsJsonAsync("api/contabilidad/terceros", dto);
            if (!response.IsSuccessStatusCode)
            {
                var problem = await response.Content.ReadFromJsonAsync<ProblemDetails>();
                formErrorMessage = problem?.Detail ?? "Error al guardar";
                e.Cancel = true;
                return;
            }

            ShowStatus("Éxito", model.ThirdPartyId.HasValue ? "Tercero actualizado" : "Tercero creado", MessageBoxRenderStyle.Success);
            await LoadTercerosAsync();
        }
        catch (Exception ex)
        {
            formErrorMessage = ex.Message;
            e.Cancel = true;
        }
    }

    private void OnCancelarClick()
    {
        formErrorMessage = null;
        gridTerceros?.CancelEditAsync();
    }

    // ── Sincronizar ──
    private async Task OnSincronizarClick()
    {
        cargando = true;
        try
        {
            var response = await Http.PostAsync("api/contabilidad/terceros/sincronizar", null);
            if (response.IsSuccessStatusCode)
            {
                syncResult = await response.Content.ReadFromJsonAsync<SincronizarTercerosResultDto>();
                syncResultVisible = true;
                await LoadTercerosAsync();
            }
            else
            {
                var problem = await response.Content.ReadFromJsonAsync<ProblemDetails>();
                ShowStatus("Error", problem?.Detail ?? "Error al sincronizar", MessageBoxRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            ShowStatus("Error", $"Error de sincronización: {ex.Message}", MessageBoxRenderStyle.Danger);
        }
        finally { cargando = false; }
    }

    // ── Eliminar ──
    private void OpenDeleteConfirm(TerceroDto item)
    {
        deleteItem = item;
        deleteFromEditId = null;
        deleteConfirmVisible = true;
    }

    private void OpenDeleteConfirmFromEdit(TerceroEditModel model)
    {
        if (!model.ThirdPartyId.HasValue) return;
        deleteItem = new TerceroDto(model.ThirdPartyId.Value, model.Code ?? "", model.Name ?? "", null, null, "", false, false, "", DateTime.MinValue, "");
        deleteFromEditId = model.ThirdPartyId;
        deleteConfirmVisible = true;
    }

    private async Task OnConfirmDeleteClick()
    {
        deleteConfirmVisible = false;
        if (deleteItem == null) return;

        try
        {
            var response = await Http.DeleteAsync($"api/contabilidad/terceros/{deleteItem.ThirdPartyId}");
            if (response.IsSuccessStatusCode)
            {
                ShowStatus("Eliminado", $"Tercero '{deleteItem.Code}' eliminado", MessageBoxRenderStyle.Success);
                if (deleteFromEditId.HasValue)
                    await gridTerceros!.CancelEditAsync();
                await LoadTercerosAsync();
            }
            else
            {
                var problem = await response.Content.ReadFromJsonAsync<ProblemDetails>();
                ShowStatus("Error", problem?.Detail ?? "No se pudo eliminar", MessageBoxRenderStyle.Danger);
            }
        }
        catch (Exception ex)
        {
            ShowStatus("Error", ex.Message, MessageBoxRenderStyle.Danger);
        }
        deleteItem = null;
        deleteFromEditId = null;
    }

    private void ShowStatus(string title, string text, MessageBoxRenderStyle style)
    {
        statusMessageTitle = title;
        statusMessageText = text;
        statusMessageRenderStyle = style;
        statusMessageVisible = true;
    }

    // ── Edit model ──
    public class TerceroEditModel
    {
        public long? ThirdPartyId { get; set; }
        public string? Code { get; set; }
        public string? Name { get; set; }
        public string? Description { get; set; }
        public string? TaxId { get; set; }
        public string? Category { get; set; }
        public bool IsSupplier { get; set; }
        public bool IsCustomer { get; set; }
        public bool IsActive { get; set; } = true;
    }

    public class ProblemDetails
    {
        public string? Title { get; set; }
        public string? Detail { get; set; }
    }
}
