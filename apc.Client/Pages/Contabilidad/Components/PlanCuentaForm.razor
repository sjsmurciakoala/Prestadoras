@using SIAD.Core.DTOs.Contabilidad
@inject HttpClient Http
@inject IToastNotificationService ToastService

<DxFormLayout>
    <DxFormLayoutItem Caption="Codigo *">
        <DxTextBox Text="@codigoDisplay" TextChanged="OnCodeChanged" TextExpression="@(() => codigoDisplay)"
                   ReadOnly="@(formModel.AccountId is not null)" />
        @if (codigoInvalido)
        {
            <div class="text-danger small">Codigo es obligatorio.</div>
        }
    </DxFormLayoutItem>

    @if (formModel.AccountId is null)
    {
        <DxFormLayoutItem Caption="Cuenta padre (opcional)">
            <DxComboBox Data="@CuentaPadreOpciones"
                        TData="CuentaLookup"
                        TValue="long?"
                        Value="@formModel.ParentAccountId"
                        ValueChanged="OnParentChanged"
                        ValueExpression="@(() => formModel.ParentAccountId)"
                        TextFieldName="@nameof(CuentaLookup.Display)"
                        ValueFieldName="@nameof(CuentaLookup.Id)"
                        NullText="Sin padre"
                        AllowUserInput="true"
                        DropDownStyle="DropDownStyle.DropDown"
                        FilterCondition="DataEditorFilterCondition.Contains"
                        FilterMinLength="0"
                        FilterDelay="250"
                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto">
                <ItemTemplate Context="cuenta">
                    <div class="combo-item">
                        <span class="combo-item-text">@cuenta.Code</span>
                        <small class="combo-item-hint">@cuenta.Name</small>
                    </div>
                </ItemTemplate>
            </DxComboBox>
            @if (!string.IsNullOrWhiteSpace(parentValidationMessage))
            {
                <div class="text-danger small">@parentValidationMessage</div>
            }
            @if (!string.IsNullOrWhiteSpace(parentSuggestionMessage))
            {
                <div class="text-muted small d-flex align-items-center gap-2 mt-1">
                    <span>@parentSuggestionMessage</span>
                    <DxButton Text="Usar sugerencia" RenderStyle="ButtonRenderStyle.Secondary" Click="UseSuggestedCode" />
                </div>
            }
        </DxFormLayoutItem>
    }

    <DxFormLayoutItem Caption="Descripcion *">
        <DxTextBox Text="@formModel.Description" TextChanged="OnDescriptionChanged" TextExpression="@(() => formModel.Description)" />
        @if (descripcionInvalida)
        {
            <div class="text-danger small">Descripcion es obligatoria.</div>
        }
    </DxFormLayoutItem>

    <DxFormLayoutItem Caption="Descripcion corta">
        <DxTextBox @bind-Text="formModel.ShortDescription" />
    </DxFormLayoutItem>

    <DxFormLayoutItem Caption="Actividad">
        <DxComboBox Data="@AccountTypes"
                    TData="string"
                    TValue="string"
                    @bind-Value="formModel.Activity"
                    NullText="Selecciona"
                    AllowUserInput="false" />
    </DxFormLayoutItem>

    <DxFormLayoutItem Caption="Clasificacion">
        <DxComboBox Data="@CategoryOptions"
                    TData="string"
                    TValue="string"
                    @bind-Value="formModel.Category"
                    NullText="Opcional"
                    AllowUserInput="true"
                    DropDownStyle="DropDownStyle.DropDown"
                    FilterCondition="DataEditorFilterCondition.Contains"
                    FilterMinLength="0"
                    FilterDelay="250"
                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
    </DxFormLayoutItem>

    <DxFormLayoutItem Caption="Cuenta de ajuste">
        <DxComboBox Data="@CuentaOpciones"
                    TData="CuentaLookup"
                    TValue="long?"
                    @bind-Value="formModel.AdjustmentAccountId"
                    TextFieldName="@nameof(CuentaLookup.Display)"
                    ValueFieldName="@nameof(CuentaLookup.Id)"
                    NullText="Buscar cuenta"
                    AllowUserInput="true"
                    DropDownStyle="DropDownStyle.DropDown"
                    FilterCondition="DataEditorFilterCondition.Contains"
                    FilterMinLength="0"
                    FilterDelay="250"
                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto">
            <ItemTemplate Context="cuenta">
                <div class="combo-item">
                    <span class="combo-item-text">@cuenta.Code</span>
                    <small class="combo-item-hint">@cuenta.Name</small>
                </div>
            </ItemTemplate>
        </DxComboBox>
    </DxFormLayoutItem>

    <DxFormLayoutItem Caption="Cuenta de correccion">
        <DxComboBox Data="@CuentaOpciones"
                    TData="CuentaLookup"
                    TValue="long?"
                    @bind-Value="formModel.CorrectionAccountId"
                    TextFieldName="@nameof(CuentaLookup.Display)"
                    ValueFieldName="@nameof(CuentaLookup.Id)"
                    NullText="Buscar cuenta"
                    AllowUserInput="true"
                    DropDownStyle="DropDownStyle.DropDown"
                    FilterCondition="DataEditorFilterCondition.Contains"
                    FilterMinLength="0"
                    FilterDelay="250"
                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto">
            <ItemTemplate Context="cuenta">
                <div class="combo-item">
                    <span class="combo-item-text">@cuenta.Code</span>
                    <small class="combo-item-hint">@cuenta.Name</small>
                </div>
            </ItemTemplate>
        </DxComboBox>
    </DxFormLayoutItem>

    <DxFormLayoutItem Caption="Opciones" ColSpanMd="12">
        <div class="d-flex flex-wrap gap-3">
            <DxCheckBox @bind-Checked="formModel.IsDetailAccount">Cuenta de detalle</DxCheckBox>
            <DxCheckBox @bind-Checked="formModel.AllowsBudget">Presupuesto</DxCheckBox>
            <DxCheckBox @bind-Checked="formModel.AllowsThird">Uso de terceros</DxCheckBox>
            <DxCheckBox @bind-Checked="formModel.IsTaxBase">Usa bases</DxCheckBox>
            <DxCheckBox @bind-Checked="formModel.AllowsCostCenter">Centro de costos</DxCheckBox>
            <DxCheckBox @bind-Checked="formModel.AllowsMultiCurrency">Usa moneda referencial</DxCheckBox>
            <DxCheckBox @bind-Checked="formModel.IsActive">Activa</DxCheckBox>
        </div>
    </DxFormLayoutItem>

    <DxFormLayoutItem Caption="Saldo inicial">
        <DxSpinEdit @bind-Value="formModel.SaldoInicial" ReadOnly="true" DisplayFormat="n2" />
    </DxFormLayoutItem>

    <DxFormLayoutItem Caption="Saldo actual">
        <DxSpinEdit @bind-Value="formModel.SaldoActual" ReadOnly="true" DisplayFormat="n2" />
    </DxFormLayoutItem>

    <DxFormLayoutItem Caption="Acciones" ColSpanMd="12">
        <DxButton Text="Guardar" RenderStyle="ButtonRenderStyle.Primary" Click="GuardarAsync" Enabled="@(!isSaving)" />
        <DxButton Text="Cancelar" CssClass="ms-2" Click="Cancelar" Enabled="@(!isSaving)" />
    </DxFormLayoutItem>
</DxFormLayout>

<style>
    .combo-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.75rem;
    }

    .combo-item-text {
        flex: 1;
        min-width: 0;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .combo-item-hint {
        font-size: 0.75rem;
        color: #6c757d;
        white-space: nowrap;
    }
</style>

@code {
    [Parameter]
    public PlanCuentaDto? Cuenta { get; set; }

    [Parameter]
    public IReadOnlyList<PlanCuentaDto> Accounts { get; set; } = Array.Empty<PlanCuentaDto>();

    [Parameter]
    public IReadOnlyList<string> AccountTypes { get; set; } = Array.Empty<string>();

    [Parameter]
    public IReadOnlyList<string> CategoryOptions { get; set; } = Array.Empty<string>();

    [Parameter]
    public EventCallback<long> OnSaved { get; set; }

    [Parameter]
    public EventCallback<string> OnError { get; set; }

    [Parameter]
    public EventCallback OnCanceled { get; set; }

    [Parameter]
    public string SeparadorCodigo { get; set; } = "-";

    [Parameter]
    public IReadOnlyList<int> NivelesFormato { get; set; } = Array.Empty<int>();

    private readonly PlanCuentaFormModel formModel = new();
    private bool isSaving;
    private bool codigoInvalido;
    private bool descripcionInvalida;
    private string codigoDisplay = string.Empty;
    private Dictionary<long, PlanCuentaDto> accountsById = new();
    private Dictionary<string, PlanCuentaDto> accountsByCode = new(StringComparer.OrdinalIgnoreCase);
    private string? parentValidationMessage;
    private string? parentSuggestionMessage;
    private string? suggestedCode;

    private IReadOnlyList<CuentaLookup> CuentaOpciones => Accounts
        .Where(c => formModel.AccountId == null || c.AccountId != formModel.AccountId)
        .Select(c =>
        {
            var formatted = FormatCodeDisplay(NormalizeCode(c.Code));
            var display = $"{formatted} - {c.Name}";
            return new CuentaLookup(c.AccountId, display, formatted, c.Name);
        })
        .ToList();

    private IReadOnlyList<CuentaLookup> CuentaPadreOpciones => Accounts
        .Where(c => formModel.AccountId == null || c.AccountId != formModel.AccountId)
        .Select(c =>
        {
            var formatted = FormatCodeDisplay(NormalizeCode(c.Code));
            var display = $"{formatted} - {c.Name}";
            return new CuentaLookup(c.AccountId, display, formatted, c.Name);
        })
        .ToList();

    protected override void OnParametersSet()
    {
        accountsById = Accounts.ToDictionary(c => c.AccountId);
        accountsByCode = Accounts
            .Select(c => new { Cuenta = c, Codigo = NormalizeCode(c.Code) })
            .Where(x => !string.IsNullOrWhiteSpace(x.Codigo))
            .GroupBy(x => x.Codigo)
            .ToDictionary(g => g.Key, g => g.First().Cuenta, StringComparer.OrdinalIgnoreCase);

        if (Cuenta == null)
        {
            formModel.Reset();
            if (AccountTypes.Count > 0)
            {
                formModel.Activity = AccountTypes[0];
            }
        }
        else
        {
            formModel.LoadFrom(Cuenta);
        }

        formModel.Code = NormalizeCode(formModel.Code);
        codigoDisplay = FormatCodeDisplay(formModel.Code);

        parentValidationMessage = null;
        parentSuggestionMessage = null;
        suggestedCode = null;

        codigoInvalido = false;
        descripcionInvalida = false;

        if (formModel.ParentAccountId.HasValue)
        {
            UpdateParentSuggestion();
            ValidateParentSelection();
        }
    }

    private void OnCodeChanged(string? value)
    {
        var normalized = NormalizeCode(value);
        formModel.Code = normalized;
        codigoDisplay = FormatCodeDisplay(normalized);
        ValidateParentSelection();
        if (!string.IsNullOrWhiteSpace(normalized))
        {
            codigoInvalido = false;
        }
    }

    private void OnDescriptionChanged(string? value)
    {
        formModel.Description = value ?? string.Empty;
        if (!string.IsNullOrWhiteSpace(formModel.Description))
        {
            descripcionInvalida = false;
        }
    }

    private async Task GuardarAsync()
    {
        if (!Validar())
        {
            return;
        }

        try
        {
            isSaving = true;

            var payload = new PlanCuentaUpsertDto(
                formModel.Code.Trim(),
                formModel.Description.Trim(),
                formModel.Activity,
                formModel.IsDetailAccount,
                formModel.AllowsBudget,
                formModel.AllowsThird,
                formModel.IsTaxBase,
                formModel.AllowsCostCenter,
                formModel.AllowsMultiCurrency,
                formModel.IsActive ? "ACTIVE" : "INACTIVE",
                string.Empty,
                formModel.AccountId,
                formModel.AccountId is null ? formModel.ParentAccountId : null,
                string.IsNullOrWhiteSpace(formModel.Category) ? null : formModel.Category.Trim(),
                string.IsNullOrWhiteSpace(formModel.ShortDescription) ? null : formModel.ShortDescription.Trim(),
                null,
                formModel.AdjustmentAccountId,
                formModel.CorrectionAccountId);

            var response = await Http.PostAsJsonAsync("api/contabilidad/catalogos/plan-cuentas", payload);
            if (!response.IsSuccessStatusCode)
            {
                var detail = await response.Content.ReadAsStringAsync();
                var message = string.IsNullOrWhiteSpace(detail)
                    ? $"No se pudo guardar la cuenta. Codigo: {response.StatusCode}"
                    : detail;
                ToastService.ShowToast(new ToastOptions { Title = "Plan de cuentas", Text = message, RenderStyle = ToastRenderStyle.Danger });
                await OnError.InvokeAsync(message);
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<SaveResult>();
            var savedId = result?.Id ?? 0;
            ToastService.ShowToast(new ToastOptions { Title = "Plan de cuentas", Text = "Cuenta guardada correctamente.", RenderStyle = ToastRenderStyle.Success });
            await OnSaved.InvokeAsync(savedId);
        }
        catch (Exception ex)
        {
            var message = $"No se pudo guardar la cuenta: {ex.Message}";
            ToastService.ShowToast(new ToastOptions { Title = "Plan de cuentas", Text = message, RenderStyle = ToastRenderStyle.Danger });
            await OnError.InvokeAsync(message);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task Cancelar()
    {
        await OnCanceled.InvokeAsync();
    }

    private void OnParentChanged(long? value)
    {
        formModel.ParentAccountId = value;
        UpdateParentSuggestion();
        ValidateParentSelection();
    }

    private void UpdateParentSuggestion()
    {
        suggestedCode = null;
        parentSuggestionMessage = null;

        if (!formModel.ParentAccountId.HasValue ||
            !accountsById.TryGetValue(formModel.ParentAccountId.Value, out var parent))
        {
            return;
        }

        var nextCode = SuggestNextCode(parent);
        if (string.IsNullOrWhiteSpace(nextCode))
        {
            return;
        }

        suggestedCode = nextCode;
        parentSuggestionMessage = $"Sugerencia: {FormatCodeDisplay(nextCode)}";
    }

    private void UseSuggestedCode()
    {
        if (string.IsNullOrWhiteSpace(suggestedCode))
        {
            return;
        }

        formModel.Code = suggestedCode;
        codigoDisplay = FormatCodeDisplay(suggestedCode);
        codigoInvalido = false;
        ValidateParentSelection();
    }

    private bool Validar()
    {
        codigoInvalido = string.IsNullOrWhiteSpace(formModel.Code);
        descripcionInvalida = string.IsNullOrWhiteSpace(formModel.Description);

        // La validación de padre solo aplica en modo creación
        // (en edición el campo padre está oculto y no puede modificarse)
        if (formModel.AccountId is null)
        {
            ValidateParentSelection();
        }
        else
        {
            parentValidationMessage = null;
        }

        return !(codigoInvalido || descripcionInvalida || !string.IsNullOrWhiteSpace(parentValidationMessage));
    }

    private static string NormalizeCode(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;
        return new string(value.Where(char.IsLetterOrDigit).ToArray());
    }

    private string FormatCodeDisplay(string normalized)
    {
        if (string.IsNullOrWhiteSpace(normalized))
            return string.Empty;

        if (NivelesFormato.Count > 0)
            return FormatFromMask(normalized);

        var parent = FindParentByPrefix(normalized);
        if (parent is null)
            return FormatFromMask(normalized);

        return FormatFromParentChain(parent, normalized);
    }

    private PlanCuentaDto? FindParentByPrefix(string normalized)
    {
        PlanCuentaDto? best = null;
        var bestLen = 0;

        foreach (var kvp in accountsByCode)
        {
            var code = kvp.Key;
            if (code.Length >= normalized.Length)
                continue;

            if (normalized.StartsWith(code, StringComparison.OrdinalIgnoreCase) && code.Length > bestLen)
            {
                best = kvp.Value;
                bestLen = code.Length;
            }
        }

        return best;
    }

    private string FormatFromParentChain(PlanCuentaDto parent, string normalized)
    {
        var sep = string.IsNullOrWhiteSpace(SeparadorCodigo) ? "-" : SeparadorCodigo;
        var segments = new Stack<string>();
        var current = parent;
        var currentCode = NormalizeCode(parent.Code);

        if (string.IsNullOrWhiteSpace(currentCode) ||
            !normalized.StartsWith(currentCode, StringComparison.OrdinalIgnoreCase))
        {
            return FormatFromMask(normalized);
        }

        var suffix = normalized.Substring(currentCode.Length);
        if (string.IsNullOrWhiteSpace(suffix))
            return FormatFromMask(normalized);

        segments.Push(suffix);

        var visited = new HashSet<long>();
        while (true)
        {
            if (!visited.Add(current.AccountId))
                return FormatFromMask(normalized);

            if (current.ParentAccountId is null || current.ParentAccountId == 0 ||
                !accountsById.TryGetValue(current.ParentAccountId.Value, out var parentAccount))
            {
                segments.Push(currentCode);
                break;
            }

            var parentCode = NormalizeCode(parentAccount.Code);
            if (string.IsNullOrWhiteSpace(parentCode) ||
                !currentCode.StartsWith(parentCode, StringComparison.OrdinalIgnoreCase))
            {
                return FormatFromMask(normalized);
            }

            var currentSuffix = currentCode.Substring(parentCode.Length);
            if (string.IsNullOrWhiteSpace(currentSuffix))
                return FormatFromMask(normalized);

            segments.Push(currentSuffix);
            current = parentAccount;
            currentCode = parentCode;
        }

        return string.Join(sep, segments);
    }

    private string FormatFromMask(string normalized)
    {
        if (string.IsNullOrWhiteSpace(normalized))
            return string.Empty;

        if (NivelesFormato.Count == 0)
            return normalized;

        var sep = string.IsNullOrWhiteSpace(SeparadorCodigo) ? "-" : SeparadorCodigo;
        var parts = new List<string>();
        var index = 0;

        foreach (var len in NivelesFormato)
        {
            if (index >= normalized.Length)
                break;

            var take = Math.Min(len, normalized.Length - index);
            parts.Add(normalized.Substring(index, take));
            index += take;
        }

        if (index < normalized.Length)
            parts.Add(normalized.Substring(index));

        return string.Join(sep, parts);
    }

    private void ValidateParentSelection()
    {
        parentValidationMessage = null;

        if (!formModel.ParentAccountId.HasValue ||
            !accountsById.TryGetValue(formModel.ParentAccountId.Value, out var parent))
        {
            return;
        }

        var parentCode = NormalizeCode(parent.Code);
        if (string.IsNullOrWhiteSpace(parentCode))
        {
            parentValidationMessage = "La cuenta padre no tiene codigo valido.";
            return;
        }

        if (string.IsNullOrWhiteSpace(formModel.Code))
        {
            return;
        }

        if (!formModel.Code.StartsWith(parentCode, StringComparison.OrdinalIgnoreCase) ||
            formModel.Code.Length <= parentCode.Length)
        {
            parentValidationMessage = $"El codigo debe iniciar con {FormatCodeDisplay(parentCode)}.";
        }
    }

    private string? SuggestNextCode(PlanCuentaDto parent)
    {
        var parentCode = NormalizeCode(parent.Code);
        if (string.IsNullOrWhiteSpace(parentCode))
        {
            return null;
        }

        var children = Accounts.Where(c => c.ParentAccountId == parent.AccountId).ToList();
        var segmentLength = 0;
        if (parent.Level > 0 && NivelesFormato.Count >= parent.Level + 1)
        {
            segmentLength = NivelesFormato[parent.Level];
        }

        if (segmentLength <= 0)
        {
            var maxLen = 1;
            foreach (var child in children)
            {
                var childCode = NormalizeCode(child.Code);
                if (!childCode.StartsWith(parentCode, StringComparison.OrdinalIgnoreCase))
                {
                    continue;
                }

                var suffix = childCode.Substring(parentCode.Length);
                if (suffix.Length > maxLen)
                {
                    maxLen = suffix.Length;
                }
            }

            segmentLength = maxLen;
        }

        var maxValue = 0;
        foreach (var child in children)
        {
            var childCode = NormalizeCode(child.Code);
            if (!childCode.StartsWith(parentCode, StringComparison.OrdinalIgnoreCase))
            {
                continue;
            }

            var suffix = childCode.Substring(parentCode.Length);
            if (suffix.Length == 0 || !suffix.All(char.IsDigit))
            {
                continue;
            }

            if (int.TryParse(suffix, out var value) && value > maxValue)
            {
                maxValue = value;
            }
        }

        var nextValue = maxValue + 1;
        var suffixText = segmentLength > 0
            ? nextValue.ToString().PadLeft(segmentLength, '0')
            : nextValue.ToString();

        return parentCode + suffixText;
    }

    private sealed record CuentaLookup(long Id, string Display, string Code, string Name);

    private sealed class SaveResult
    {
        public long Id { get; set; }
    }

    private sealed class PlanCuentaFormModel
    {
        public long? AccountId { get; set; }
        public long? ParentAccountId { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string? ShortDescription { get; set; }
        public string Activity { get; set; } = string.Empty;
        public string Category { get; set; } = string.Empty;
        public bool IsDetailAccount { get; set; } = true;
        public bool AllowsBudget { get; set; }
        public bool AllowsThird { get; set; }
        public bool IsTaxBase { get; set; }
        public bool AllowsCostCenter { get; set; }
        public bool AllowsMultiCurrency { get; set; }
        public bool IsActive { get; set; } = true;
        public long? AdjustmentAccountId { get; set; }
        public long? CorrectionAccountId { get; set; }
        public decimal SaldoInicial { get; set; }
        public decimal SaldoActual { get; set; }

        public void Reset()
        {
            AccountId = null;
            ParentAccountId = null;
            Code = string.Empty;
            Description = string.Empty;
            ShortDescription = null;
            Activity = string.Empty;
            Category = string.Empty;
            IsDetailAccount = true;
            AllowsBudget = false;
            AllowsThird = false;
            IsTaxBase = false;
            AllowsCostCenter = false;
            AllowsMultiCurrency = false;
            IsActive = true;
            AdjustmentAccountId = null;
            CorrectionAccountId = null;
            SaldoInicial = 0m;
            SaldoActual = 0m;
        }

        public void LoadFrom(PlanCuentaDto cuenta)
        {
            AccountId = cuenta.AccountId;
            ParentAccountId = cuenta.ParentAccountId;
            Code = cuenta.Code;
            Description = cuenta.Name;
            ShortDescription = cuenta.Description;
            Activity = cuenta.AccountType;
            Category = cuenta.Category ?? string.Empty;
            IsDetailAccount = cuenta.AllowsPosting;
            AllowsBudget = cuenta.AllowsBudget;
            AllowsThird = cuenta.AllowsThird;
            IsTaxBase = cuenta.IsTaxBase;
            AllowsCostCenter = cuenta.AllowsCostCenter;
            AllowsMultiCurrency = cuenta.AllowsMultiCurrency;
            IsActive = string.Equals(cuenta.Status, "ACTIVE", StringComparison.OrdinalIgnoreCase);
            AdjustmentAccountId = cuenta.AdjustmentAccountId;
            CorrectionAccountId = cuenta.CorrectionAccountId;
            SaldoInicial = 0m;
            SaldoActual = 0m;
        }
    }
}
