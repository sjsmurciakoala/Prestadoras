@page "/contabilidad/plan-cuentas"
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager NavigationManager

@using apc.Client.Pages.Contabilidad.Components
@using System.Net.Http.Headers
@using System.Collections.Generic
@using apc.Client.Services.Contabilidad
@using apc.Client.Services.Tenant
@using System.Text

@inject ConfiguracionSistemaClient ConfiguracionClient
@inject TenantState TenantState

<PageTitle>Plan de Cuentas</PageTitle>
<DxLayoutBreakpoint DeviceSize="DeviceSize.XSmall" @bind-IsActive="isXSmallScreen" />
<DxMessageBox @bind-Visible="statusMessageVisible"
              Type="MessageBoxType.Alert"
              Title="@statusMessageTitle"
              Text="@statusMessageText"
              RenderStyle="@statusMessageRenderStyle"
              OkButtonText="Entendido"
              ShowCloseButton="false"
              CloseOnOutsideClick="false" />

<div class="pc-page" id="plan-cuentas-view">

    @* ── Encabezado ── *@
    <div class="d-flex align-items-start flex-wrap gap-3 mb-3">
        <div class="flex-grow-1">
            <h4 class="mb-1 fw-bold text-secondary">
                <i class="bi bi-journal-text me-2 text-primary"></i>Plan de Cuentas
            </h4>
        </div>
        <div class="d-flex flex-wrap gap-2 flex-shrink-0">
            <DxButton Text="Actualizar"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                      IconCssClass="bi bi-arrow-clockwise"
                      Click="@(() => LoadPlanCuentasAsync())"
                      Enabled="@(!IsBusy)" />
            <DxButton Text="Nuevo"
                      RenderStyle="ButtonRenderStyle.Primary"
                      IconCssClass="bi bi-plus-lg"
                      Click="@(() => OpenForm(null))"
                      Enabled="@(!IsBusy)" />
        </div>
    </div>

    @* ── Indicadores rápidos ── *@
    <div class="d-flex flex-wrap gap-2 mb-3">
        <span class="pc-stat-badge">
            <i class="bi bi-journal-text"></i> Total: <strong>@planCuentas.Length.ToString("N0")</strong>
        </span>
        <span class="pc-stat-badge pc-stat-badge--success">
            <i class="bi bi-arrow-left-right"></i> Con movimiento: <strong>@CuentasConMovimiento</strong>
        </span>
        <span class="pc-stat-badge pc-stat-badge--info">
            <i class="bi bi-people"></i> Con tercero: <strong>@CuentasConTercero</strong>
        </span>
        <span class="pc-stat-badge pc-stat-badge--warning">
            <i class="bi bi-diagram-3"></i> Con centro: <strong>@CuentasConCentro</strong>
        </span>
    </div>

    @* ── Barra de acciones secundarias ── *@
    <div class="pc-actions-bar mb-3">
        <DxToolbar ItemRenderStyleMode="ToolbarRenderStyleMode.Contained">
            <Items>
                <DxToolbarItem Text="Editar"
                               IconCssClass="bi bi-pencil"
                               Disabled="@(cuentaSeleccionada == null || isFormVisible || IsBusy)"
                               Click="@(() => OpenForm(cuentaSeleccionada))" />
                <DxToolbarItem Text="Eliminar"
                               IconCssClass="bi bi-trash"
                               RenderStyle="ButtonRenderStyle.Danger"
                               Disabled="@(cuentaSeleccionada == null || isFormVisible || IsBusy)"
                               Click="@DeleteCuentaAsync" />
                <DxToolbarItem Text="Plantilla"
                               IconCssClass="bi bi-file-earmark-excel"
                               Alignment="ToolbarItemAlignment.Right"
                               Click="@DownloadTemplate" />
                <DxToolbarItem Alignment="ToolbarItemAlignment.Right">
                    <Template>
                        <div class="d-flex align-items-center px-2">
                            <InputFile OnChange="@OnImportFileSelected" accept=".xlsx"
                                class="form-control form-control-sm" style="max-width: 220px;" />
                        </div>
                    </Template>
                </DxToolbarItem>
                <DxToolbarItem Text="Importar"
                               IconCssClass="bi bi-cloud-arrow-up"
                               RenderStyle="ButtonRenderStyle.Success"
                               Alignment="ToolbarItemAlignment.Right"
                               Disabled="@(importFile == null || importInProgress)"
                               Click="@ImportPlanCuentasAsync" />
            </Items>
        </DxToolbar>
    </div>

    @* ── Filtros ── *@
    <div class="pc-filter-bar mb-3">
        <DxFormLayout ColCount="12" CaptionPosition="CaptionPosition.Vertical">
            <DxFormLayoutItem Caption="Cuenta" ColSpanSm="12" ColSpanMd="3">
                <DxTextBox Placeholder="Código..." Text="@filtroCuenta" TextChanged="@OnCuentaFilterChanged"
                    TextExpression="@(() => filtroCuenta)"
                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Descripción" ColSpanSm="12" ColSpanMd="3">
                <DxTextBox Placeholder="Nombre..." Text="@filtroDescripcion"
                    TextChanged="@OnDescripcionFilterChanged"
                    TextExpression="@(() => filtroDescripcion)"
                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Mov" ColSpanSm="4" ColSpanMd="2">
                <DxComboBox Data="@boolFilterOptions" TData="BoolFilterOption" TValue="bool?"
                    Value="@filtroMov" ValueChanged="@OnMovFilterChanged"
                    TextFieldName="Text" ValueFieldName="Value" NullText="Todos" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Tercero" ColSpanSm="4" ColSpanMd="2">
                <DxComboBox Data="@boolFilterOptions" TData="BoolFilterOption" TValue="bool?"
                    Value="@filtroTercero" ValueChanged="@OnTerceroFilterChanged"
                    TextFieldName="Text" ValueFieldName="Value" NullText="Todos" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Centro" ColSpanSm="4" ColSpanMd="2">
                <DxComboBox Data="@boolFilterOptions" TData="BoolFilterOption" TValue="bool?"
                    Value="@filtroCentro" ValueChanged="@OnCentroFilterChanged"
                    TextFieldName="Text" ValueFieldName="Value" NullText="Todos" />
            </DxFormLayoutItem>
        </DxFormLayout>
    </div>

    @* ── Layout master-detail ── *@
    <div class="row g-0 pc-master-detail" style="min-height: 400px;">

        @* ── Grid principal ── *@
        <div class="col-12 col-md-7 pe-md-3 d-flex flex-column pc-grid-pane">
            <div class="pc-grid-wrapper shadow-sm">
                <DxGrid Data="@cuentasFiltradas"
                        KeyFieldName="@nameof(PlanCuentaDto.AccountId)"
                        SelectionMode="GridSelectionMode.Single"
                        AllowSelectRowByClick="true"
                        @bind-SelectedDataItem="SelectedRow"
                        ShowFilterRow="true"
                        ShowSearchBox="true"
                        ShowPager="true"
                        PagerPosition="GridPagerPosition.Bottom"
                        PageSizeSelectorVisible="true"
                        PageSizeSelectorItems="@(new int[] { 25, 50, 100 })"
                        PageSize="25"
                        SizeMode="SizeMode.Medium"
                        ColumnResizeMode="GridColumnResizeMode.ColumnsContainer"
                        CssClass="border-0">
                    <Columns>
                        <DxGridDataColumn FieldName="@nameof(PlanCuentaDto.Code)" Caption="Cuenta" Width="140px">
                            <CellDisplayTemplate Context="cell">
                                @if (cell.DataItem is PlanCuentaDto item)
                                {
                                    <span class="fw-bold text-primary font-monospace">@FormatAccountCode(item)</span>
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn FieldName="@nameof(PlanCuentaDto.Name)" Caption="Descripción" />
                        <DxGridDataColumn FieldName="@nameof(PlanCuentaDto.AllowsPosting)" Caption="Flags" Width="110px"
                                          TextAlignment="GridTextAlignment.Center">
                            <CellDisplayTemplate Context="cell">
                                @if (cell.DataItem is PlanCuentaDto item)
                                {
                                    <div class="d-flex gap-1 justify-content-center flex-wrap">
                                        @if (item.AllowsPosting)
                                        {
                                            <span class="pc-flag-badge pc-flag-badge--primary" title="Movimiento">M</span>
                                        }
                                        @if (item.AllowsThird)
                                        {
                                            <span class="pc-flag-badge pc-flag-badge--info" title="Terceros">T</span>
                                        }
                                        @if (item.AllowsCostCenter)
                                        {
                                            <span class="pc-flag-badge pc-flag-badge--warning" title="Centros">C</span>
                                        }
                                        @if (HasChildren(item))
                                        {
                                            <span class="pc-flag-badge pc-flag-badge--danger" title="Cuenta padre">P</span>
                                        }
                                        @if (item.AllowsBudget)
                                        {
                                            <span class="pc-flag-badge pc-flag-badge--secondary" title="Presupuesto">B</span>
                                        }
                                        @if (item.AllowsMultiCurrency)
                                        {
                                            <span class="pc-flag-badge pc-flag-badge--dark" title="Multimoneda">MC</span>
                                        }
                                    </div>
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                    </Columns>
                    <EmptyDataAreaTemplate>
                        <div class="text-center p-5 text-muted">
                            <i class="bi bi-journal-text fs-1 d-block mb-2"></i>
                            <h5 class="fw-bold text-dark">No hay cuentas</h5>
                            <p class="mb-0">Agrega la primera cuenta o ajusta los filtros.</p>
                        </div>
                    </EmptyDataAreaTemplate>
                </DxGrid>
            </div>
        </div>

        @* ── Panel de detalle / formulario ── *@
        <div class="col-12 col-md-5 ps-md-4 pt-3 pc-detail-pane">
            @if (isFormVisible)
            {
                <div class="pc-detail-card shadow-sm">
                    <div class="pc-detail-card-header">
                        <h6 class="mb-0 fw-bold text-primary">
                            <i class="bi bi-pencil-square me-2"></i>
                            @(cuentaSeleccionada == null ? "Nueva Cuenta" : "Editar Cuenta")
                        </h6>
                    </div>
                    <div class="p-3">
                        <PlanCuentaForm Cuenta="cuentaSeleccionada" Accounts="planCuentas"
                            AccountTypes="accountTypes" CategoryOptions="categoryOptions"
                            SeparadorCodigo="@separadorCodigo" NivelesFormato="@nivelesFormato"
                            OnSaved="HandleFormSavedAsync" OnCanceled="HandleFormCanceled"
                            OnError="HandleFormError" />
                    </div>
                </div>
            }
            else if (cuentaSeleccionada != null)
            {
                <div class="pc-detail-card shadow-sm">
                    <div class="pc-detail-card-header">
                        <h6 class="mb-0 fw-bold text-secondary">
                            <i class="bi bi-info-circle me-2 text-primary"></i>Detalle de cuenta
                        </h6>
                    </div>
                    <div class="p-3">
                        <DxFormLayout CssClass="w-100" CaptionPosition="CaptionPosition.Vertical" ItemSpacing="15px">
                            <DxFormLayoutGroup Caption="Información General" ColCount="1"
                                HeaderCssClass="text-primary fw-bold border-bottom mb-3 pb-2">
                                <DxFormLayoutItem Caption="Identificación">
                                    <Template Context="flc">
                                        <div class="d-flex gap-2">
                                            <div class="flex-grow-1">
                                                <label class="small text-muted mb-1">Código</label>
                                                <DxTextBox Text="@FormatAccountCode(cuentaSeleccionada)" ReadOnly="true" />
                                            </div>
                                            <div style="width: 120px;">
                                                <label class="small text-muted mb-1">Tipo</label>
                                                <DxTextBox Text="@cuentaSeleccionada.AccountType" ReadOnly="true" />
                                            </div>
                                        </div>
                                    </Template>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Nombre de la Cuenta">
                                    <DxTextBox Text="@cuentaSeleccionada.Name" ReadOnly="true" />
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Detalles">
                                    <Template Context="flc">
                                        <div class="row g-2">
                                            <div class="col-6">
                                                <label class="small text-muted mb-1">Moneda</label>
                                                <DxTextBox Text="@GetCurrencyDisplay(cuentaSeleccionada)" ReadOnly="true" />
                                            </div>
                                            <div class="col-6">
                                                <label class="small text-muted mb-1">Clasificación</label>
                                                <DxTextBox Text="@GetCategoryDisplay(cuentaSeleccionada)" ReadOnly="true" />
                                            </div>
                                        </div>
                                    </Template>
                                </DxFormLayoutItem>
                                <DxFormLayoutItem Caption="Descripción Corta">
                                    <DxMemo Text="@GetDescriptionDisplay(cuentaSeleccionada)" ReadOnly="true"
                                        Rows="2" ResizeMode="MemoResizeMode.Disabled" />
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>

                            <DxFormLayoutGroup Caption="Configuración" ColCount="1"
                                HeaderCssClass="text-secondary fw-bold border-bottom mb-3 pb-2 mt-2">
                                <DxFormLayoutItem>
                                    <Template Context="flc">
                                        <div class="row g-3">
                                            <div class="col-6">
                                                <DxCheckBox Checked="@cuentaSeleccionada.AllowsPosting" Enabled="false">Movimientos</DxCheckBox>
                                            </div>
                                            <div class="col-6">
                                                <DxCheckBox Checked="@cuentaSeleccionada.AllowsBudget" Enabled="false">Presupuesto</DxCheckBox>
                                            </div>
                                            <div class="col-6">
                                                <DxCheckBox Checked="@cuentaSeleccionada.AllowsThird" Enabled="false">Terceros</DxCheckBox>
                                            </div>
                                            <div class="col-6">
                                                <DxCheckBox Checked="@cuentaSeleccionada.IsTaxBase" Enabled="false">Impuestos</DxCheckBox>
                                            </div>
                                            <div class="col-6">
                                                <DxCheckBox Checked="@cuentaSeleccionada.AllowsCostCenter" Enabled="false">C. Costos</DxCheckBox>
                                            </div>
                                            <div class="col-6">
                                                <DxCheckBox Checked="@cuentaSeleccionada.AllowsMultiCurrency" Enabled="false">Multimoneda</DxCheckBox>
                                            </div>
                                        </div>
                                    </Template>
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>

                            <DxFormLayoutGroup Caption="Auditoría" ColCount="1"
                                HeaderCssClass="text-muted small border-bottom mb-3 pb-2 mt-2">
                                <DxFormLayoutItem>
                                    <Template Context="flc">
                                        <div class="d-flex justify-content-between align-items-center bg-white p-2 border rounded">
                                            <div>
                                                <small class="text-muted d-block">Nivel Jerárquico</small>
                                                <span class="fw-bold">@cuentaSeleccionada.Level</span>
                                            </div>
                                            <div>
                                                <small class="text-muted d-block text-end">Estado</small>
                                                <span class="@(cuentaSeleccionada.Status == "ACTIVO" ? "pc-badge pc-badge--success" : "pc-badge pc-badge--neutral")">
                                                    @cuentaSeleccionada.Status
                                                </span>
                                            </div>
                                        </div>
                                    </Template>
                                </DxFormLayoutItem>
                            </DxFormLayoutGroup>
                        </DxFormLayout>
                    </div>
                </div>
            }
            else
            {
                <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted opacity-50 py-5">
                    <i class="bi bi-hand-index-thumb fs-1 mb-3"></i>
                    <p class="text-center">Selecciona una cuenta del listado<br />para ver sus propiedades.</p>
                </div>
            }
        </div>
    </div>

    <DxLoadingPanel Visible="@cargando"
                    PositionTarget="#plan-cuentas-view"
                    CssClass="w-100"
                    ApplyBackgroundShading="true"
                    IsContentBlocked="true"
                    Text="Cargando plan de cuentas..." />
    <DxLoadingPanel Visible="@importInProgress"
                    PositionTarget="#plan-cuentas-view"
                    CssClass="w-100"
                    ApplyBackgroundShading="true"
                    IsContentBlocked="true"
                    Text="@importStatusMessage" />
</div>

@code {
    // --- Estado ---
    private bool isXSmallScreen;
    private bool statusMessageVisible;
    private string statusMessageTitle = string.Empty;
    private string statusMessageText = string.Empty;
    private MessageBoxRenderStyle statusMessageRenderStyle = MessageBoxRenderStyle.Info;

    private bool IsBusy => cargando || importInProgress;
    private int CuentasConMovimiento => planCuentas.Count(c => c.AllowsPosting);
    private int CuentasConTercero => planCuentas.Count(c => c.AllowsThird);
    private int CuentasConCentro => planCuentas.Count(c => c.AllowsCostCenter);

    private string formatoCuentas = "###-###-##";
    private string separadorCodigo = "-";

    private async Task LoadConfiguracionAsync()
    {
        try
        {
            var companyId = await TenantState.EnsureCompanyAsync();
            if (companyId <= 0)
            {
                return;
            }
            var config = await ConfiguracionClient.ObtenerAsync(companyId);
            if (config?.Principal != null)
            {
                formatoCuentas = string.IsNullOrWhiteSpace(config.Principal.FormatoCuentas)
                ? formatoCuentas
                : config.Principal.FormatoCuentas;

                separadorCodigo = string.IsNullOrWhiteSpace(config.Principal.SeparadorCodigo)
                ? separadorCodigo
                : config.Principal.SeparadorCodigo;
            }
        }
        catch (Exception ex)
        {
            ShowStatusMessage("Error de configuración", $"Error al cargar configuración: {ex.Message}. Se utilizó la configuración predeterminada.", MessageBoxRenderStyle.Danger);
        }
    }

    private static string NormalizeCode(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;
        return new string(value.Where(char.IsLetterOrDigit).ToArray());

    }
    private IReadOnlyList<int> nivelesFormato = Array.Empty<int>();
    private void RecalcularNivelesFormato()
    {
        //1) intentar desde formatocuentas (ej. x.x.xx.xx o #.###.##);
        var config = ParseFormatoNiveles(formatoCuentas);
        if (config.Count > 0)
        {
            nivelesFormato = config;
            return;
        }
        // 2) Inferir desde el plan si no hay formato válido
        var porNivel = planCuentas
        .Where(c => c.Level > 0)
        .GroupBy(c => c.Level)
        .OrderBy(g => g.Key)
        .Select(g =>
        g.Select(x => NormalizeCode(x.Code).Length)
        .Where(l => l > 0)
        .GroupBy(l => l)
        .OrderByDescending(x => x.Count())
        .FirstOrDefault()?.Key ?? 0)
        .ToList();
        // calcular deltas
        var deltas = new List<int>();
        var prev = 0;
        foreach (var len in porNivel)
        {
            if (len <= 0) break;
            deltas.Add(Math.Max(1, len - prev));
            prev = len;
        }
        nivelesFormato = deltas;
    }

    private static List<int> ParseFormatoNiveles(string? formato)
    {
        if (string.IsNullOrWhiteSpace(formato))
            return new();
        //acepta x 0 # como placeholder de digito
        var grupos = new List<int>();
        var current = 0;
        foreach (var ch in formato)
        {
            if (ch == '#' || ch == 'X' || ch == 'x')
            {
                current++;
            }
            else
            {
                if (current > 0)
                {
                    grupos.Add(current);
                    current = 0;
                }
            }
        }
        if (current > 0)
        {
            grupos.Add(current);
        }
        return grupos;
    }
    private string FormatAccountCode(PlanCuentaDto cuenta)
    {
        var normalized = NormalizeCode(cuenta.Code);
        if (string.IsNullOrWhiteSpace(normalized))
            return string.Empty;

        if (nivelesFormato.Count > 0)
            return FormatAccountCodeFromMask(normalized, cuenta.Level);

        if (cuenta.ParentAccountId is null || cuenta.ParentAccountId == 0)
        {
            var inferredParent = FindParentByPrefix(normalized, cuenta.AccountId);
            if (inferredParent is null)
                return FormatAccountCodeFromMask(normalized, cuenta.Level);

            return FormatAccountCodeFromParentChain(inferredParent, normalized, cuenta.Level);
        }

        if (planCuentasById.Count == 0)
            return FormatAccountCodeFromMask(normalized, cuenta.Level);

        var sep = string.IsNullOrWhiteSpace(separadorCodigo) ? "-" : separadorCodigo;
        var segments = new Stack<string>();
        var current = cuenta;
        var currentCode = normalized;
        var visited = new HashSet<long>();

        while (true)
        {
            if (!visited.Add(current.AccountId))
                return FormatAccountCodeFromMask(normalized, cuenta.Level);

            if (current.ParentAccountId is null || current.ParentAccountId == 0 ||
                !planCuentasById.TryGetValue(current.ParentAccountId.Value, out var parent))
            {
                segments.Push(currentCode);
                break;
            }

            var parentCode = NormalizeCode(parent.Code);
            if (string.IsNullOrWhiteSpace(parentCode) ||
                !currentCode.StartsWith(parentCode, StringComparison.OrdinalIgnoreCase))
            {
                return FormatAccountCodeFromMask(normalized, cuenta.Level);
            }

            var suffix = currentCode.Substring(parentCode.Length);
            if (string.IsNullOrWhiteSpace(suffix))
            {
                return FormatAccountCodeFromMask(normalized, cuenta.Level);
            }

            segments.Push(suffix);
            current = parent;
            currentCode = parentCode;
        }

        return string.Join(sep, segments);
    }

    private PlanCuentaDto? FindParentByPrefix(string normalized, long? accountId)
    {
        PlanCuentaDto? best = null;
        var bestLen = 0;

        foreach (var kvp in planCuentasByCode)
        {
            var code = kvp.Key;
            var cuenta = kvp.Value;

            if (accountId.HasValue && cuenta.AccountId == accountId.Value)
                continue;

            if (code.Length >= normalized.Length)
                continue;

            if (normalized.StartsWith(code, StringComparison.OrdinalIgnoreCase) && code.Length > bestLen)
            {
                best = cuenta;
                bestLen = code.Length;
            }
        }

        return best;
    }

    private string FormatAccountCodeFromParentChain(PlanCuentaDto parent, string normalized, short level)
    {
        var sep = string.IsNullOrWhiteSpace(separadorCodigo) ? "-" : separadorCodigo;
        var segments = new Stack<string>();
        var current = parent;
        var currentCode = NormalizeCode(parent.Code);

        if (string.IsNullOrWhiteSpace(currentCode) ||
            !normalized.StartsWith(currentCode, StringComparison.OrdinalIgnoreCase))
        {
            return FormatAccountCodeFromMask(normalized, level);
        }

        var suffix = normalized.Substring(currentCode.Length);
        if (string.IsNullOrWhiteSpace(suffix))
            return FormatAccountCodeFromMask(normalized, level);

        segments.Push(suffix);

        var visited = new HashSet<long>();
        while (true)
        {
            if (!visited.Add(current.AccountId))
                return FormatAccountCodeFromMask(normalized, level);

            if (current.ParentAccountId is null || current.ParentAccountId == 0 ||
                !planCuentasById.TryGetValue(current.ParentAccountId.Value, out var parentAccount))
            {
                segments.Push(currentCode);
                break;
            }

            var parentCode = NormalizeCode(parentAccount.Code);
            if (string.IsNullOrWhiteSpace(parentCode) ||
                !currentCode.StartsWith(parentCode, StringComparison.OrdinalIgnoreCase))
            {
                return FormatAccountCodeFromMask(normalized, level);
            }

            var currentSuffix = currentCode.Substring(parentCode.Length);
            if (string.IsNullOrWhiteSpace(currentSuffix))
                return FormatAccountCodeFromMask(normalized, level);

            segments.Push(currentSuffix);
            current = parentAccount;
            currentCode = parentCode;
        }

        return string.Join(sep, segments);
    }

    private string FormatAccountCodeFromMask(string normalized, short level)
    {
        if (string.IsNullOrWhiteSpace(normalized))
            return string.Empty;

        if (nivelesFormato.Count == 0)
            return normalized;

        var sep = string.IsNullOrWhiteSpace(separadorCodigo) ? "-" : separadorCodigo;
        var parts = new List<string>();
        var index = 0;

        foreach (var len in nivelesFormato)
        {
            if (index >= normalized.Length) break;

            var take = Math.Min(len, normalized.Length - index);
            parts.Add(normalized.Substring(index, take));
            index += take;
        }

        if (index < normalized.Length)
            parts.Add(normalized.Substring(index));

        return string.Join(sep, parts);
    }
    private void ShowStatusMessage(string title, string text, MessageBoxRenderStyle renderStyle = MessageBoxRenderStyle.Info)
    {
        statusMessageTitle = title;
        statusMessageText = text;
        statusMessageRenderStyle = renderStyle;
        statusMessageVisible = true;
    }

    private static readonly BoolFilterOption[] boolFilterOptions = new[]
    {
new BoolFilterOption("Todos", null),
new BoolFilterOption("Si", true),
new BoolFilterOption("No", false)
};

    private readonly string[] accountTypes = new[] { "ACTIVO", "PASIVO", "CAPITAL", "INGRESO", "GASTO" };
    private PlanCuentaDto[] planCuentas = Array.Empty<PlanCuentaDto>();
    private Dictionary<long, PlanCuentaDto> planCuentasById = new();
    private Dictionary<string, PlanCuentaDto> planCuentasByCode = new(StringComparer.OrdinalIgnoreCase);
    private List<PlanCuentaDto> cuentasFiltradas = new();
    private IReadOnlyList<string> categoryOptions = Array.Empty<string>();
    private PlanCuentaDto? cuentaSeleccionada;
    private bool isFormVisible;
    private bool cargando;

    // Filtros
    private string filtroCuenta = string.Empty;
    private string filtroDescripcion = string.Empty;
    private bool? filtroMov;
    private bool? filtroTercero;
    private bool? filtroCentro;
    private object? selectedRow;

    // Importación
    private IBrowserFile? importFile;
    private bool importInProgress = false;
    private string importStatusMessage = string.Empty;

    private object? SelectedRow
    {
        get => selectedRow;
        set
        {
            if (!ReferenceEquals(selectedRow, value))
            {
                selectedRow = value;
                cuentaSeleccionada = value as PlanCuentaDto;
                isFormVisible = false;
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadConfiguracionAsync();
        await LoadPlanCuentasAsync();
        RecalcularNivelesFormato();
    }

    private async Task LoadPlanCuentasAsync(long? selectAccountId = null)
    {
        try
        {
            cargando = true;
            planCuentas = await Http.GetFromJsonAsync<PlanCuentaDto[]>("api/contabilidad/catalogos/plan-cuentas") ??
            Array.Empty<PlanCuentaDto>();
            planCuentasById = planCuentas.ToDictionary(c => c.AccountId);
            planCuentasByCode = planCuentas
                .Select(c => new { Cuenta = c, Codigo = NormalizeCode(c.Code) })
                .Where(x => !string.IsNullOrWhiteSpace(x.Codigo))
                .GroupBy(x => x.Codigo, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(g => g.Key, g => g.First().Cuenta, StringComparer.OrdinalIgnoreCase);

            categoryOptions = planCuentas.Select(c => c.Category)
            .Where(c => !string.IsNullOrWhiteSpace(c))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(c => c)
            .ToList()!;

            RecalcularNivelesFormato();
            ApplyFilters();

            SelectedRow = selectAccountId.HasValue
            ? planCuentas.FirstOrDefault(c => c.AccountId == selectAccountId.Value)
            : null;
        }
        catch (Exception ex)
        {
            ShowStatusMessage("Error", $"Error al cargar: {ex.Message}", MessageBoxRenderStyle.Danger);
        }
        finally
        {
            cargando = false;
        }
    }

    private void OnCuentaFilterChanged(string? value)
    {
        filtroCuenta = value ?? string.Empty;
        ApplyFilters();
    }

    private void OnDescripcionFilterChanged(string? value)
    {
        filtroDescripcion = value ?? string.Empty;
        ApplyFilters();
    }

    private void OnMovFilterChanged(bool? value)
    {
        filtroMov = value;
        ApplyFilters();
    }

    private void OnTerceroFilterChanged(bool? value)
    {
        filtroTercero = value;
        ApplyFilters();
    }

    private void OnCentroFilterChanged(bool? value)
    {
        filtroCentro = value;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        var query = planCuentas.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(filtroCuenta))
        {
            var filtroNormalizado = NormalizeCode(filtroCuenta);
            query = query.Where(c =>
            NormalizeCode(c.Code).Contains(filtroNormalizado, StringComparison.OrdinalIgnoreCase));
        }
        if (!string.IsNullOrWhiteSpace(filtroDescripcion))
            query = query.Where(c => c.Name.Contains(filtroDescripcion, StringComparison.OrdinalIgnoreCase));
        if (filtroMov.HasValue)
            query = query.Where(c => c.AllowsPosting == filtroMov.Value);
        if (filtroTercero.HasValue)
            query = query.Where(c => c.AllowsThird == filtroTercero.Value);
        if (filtroCentro.HasValue)
            query = query.Where(c => c.AllowsCostCenter == filtroCentro.Value);
        cuentasFiltradas = query.OrderBy(c => c.Code).ToList();
    }

    private void OpenForm(PlanCuentaDto? cuenta)
    {
        cuentaSeleccionada = cuenta;
        isFormVisible = true;
    }

    private async Task HandleFormSavedAsync(long savedId)
    {
        await LoadPlanCuentasAsync(savedId == 0 ? null : savedId);
        isFormVisible = false;
        ShowStatusMessage("Éxito", "Cuenta guardada correctamente.", MessageBoxRenderStyle.Success);
    }

    private Task HandleFormError(string message)
    {
        ShowStatusMessage("Error", message, MessageBoxRenderStyle.Danger);
        return Task.CompletedTask;
    }

    private Task HandleFormCanceled()
    {
        isFormVisible = false;
        return Task.CompletedTask;
    }

    private async Task DeleteCuentaAsync()
    {
        if (cuentaSeleccionada == null)
            return;
        ShowStatusMessage("Info", "Función de eliminar en desarrollo.", MessageBoxRenderStyle.Info);
        await Task.CompletedTask;
    }

    private void OnImportFileSelected(InputFileChangeEventArgs args)
    {
        importFile = args.File;
    }

    private async Task ImportPlanCuentasAsync()
    {
        if (importFile is null)
        {
            ShowStatusMessage("Atención", "Selecciona un archivo primero.", MessageBoxRenderStyle.Warning);
            return;
        }

        importInProgress = true;
        importStatusMessage = "Importando...";
        await InvokeAsync(StateHasChanged);

        try
        {
            using var content = new MultipartFormDataContent();
            using var stream = importFile.OpenReadStream(10 * 1024 * 1024);
            using var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new MediaTypeHeaderValue(importFile.ContentType);
            content.Add(streamContent, "file", importFile.Name);
            content.Add(new StringContent("false"), "dryRun");

            var response = await Http.PostAsync("api/contabilidad/catalogos/plan-cuentas/import", content);
            if (!response.IsSuccessStatusCode)
            {
                ShowStatusMessage("Error en importación", $"Falló la importación: {response.ReasonPhrase}", MessageBoxRenderStyle.Danger);
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<PlanCuentasImportResult>();
            if (result?.Errors.Count > 0)
            {
                var firstError = result.Errors.First();
                var rowLabel = firstError.RowNumber > 0 ? $"Fila {firstError.RowNumber}" : "Importación";
                var codeLabel = string.IsNullOrWhiteSpace(firstError.Code) ? string.Empty : $" ({firstError.Code})";
                var extraErrors = result.Errors.Count > 1 ? $" Se detectaron {result.Errors.Count} errores." : string.Empty;
                ShowStatusMessage("Error en archivo", $"{rowLabel}{codeLabel}: {firstError.Message}{extraErrors}", MessageBoxRenderStyle.Danger);
            }
            else
            {
                ShowStatusMessage("Importación completada", $"Insertadas: {result?.Inserted ?? 0}. Actualizadas: {result?.Updated ?? 0}.", MessageBoxRenderStyle.Success);
                await LoadPlanCuentasAsync();
            }
        }
        catch (Exception ex)
        {
            ShowStatusMessage("Error crítico", ex.Message, MessageBoxRenderStyle.Danger);
        }
        finally
        {
            importInProgress = false;
        }
    }

    private void DownloadTemplate()
    {
        NavigationManager.NavigateTo("api/contabilidad/catalogos/plan-cuentas/plantilla", true);
    }

    /// <summary>
    /// Determina si una cuenta tiene cuentas hijas en el plan de cuentas actual. Devuelve true si existe alguna
    /// cuenta cuyo ParentAccountId coincida con el AccountId de la cuenta suministrada.
    /// </summary>
    private bool HasChildren(PlanCuentaDto cuenta)
    {
        if (planCuentas is null || cuenta is null)
            return false;
        return planCuentas.Any(c => c.ParentAccountId == cuenta.AccountId);
    }

    /// <summary>
    /// Devuelve la cadena a mostrar para la moneda de la cuenta. Si la cuenta o la propiedad CurrencyCode
    /// es nula o vacía, se devuelve "Local" como valor por defecto.
    /// </summary>
    private string GetCurrencyDisplay(PlanCuentaDto? cuenta)
    {
        var code = cuenta?.CurrencyCode;
        return string.IsNullOrWhiteSpace(code) ? "Local" : code!;
    }

    /// <summary>
    /// Devuelve la cadena a mostrar para la categoría de la cuenta. Si la cuenta o la propiedad Category
    /// es nula o vacía, se devuelve "-" como valor por defecto.
    /// </summary>
    private string GetCategoryDisplay(PlanCuentaDto? cuenta)
    {
        var category = cuenta?.Category;
        return string.IsNullOrWhiteSpace(category) ? "-" : category!;
    }

    /// <summary>
    /// Devuelve la descripción a mostrar para la cuenta. Si la descripción es nula o vacía, se devuelve "-".
    /// </summary>
    private string GetDescriptionDisplay(PlanCuentaDto? cuenta)
    {
        var desc = cuenta?.Description;
        return string.IsNullOrWhiteSpace(desc) ? "-" : desc!;
    }

    private sealed record BoolFilterOption(string Text, bool? Value);

    // DTOs auxiliares para deserializar la respuesta de importación
    public class PlanCuentasImportResult
    {
        public int Inserted { get; set; }
        public int Updated { get; set; }
        public List<ImportError> Errors { get; set; } = new();
    }
    public class ImportError
    {
        public int RowNumber { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
    }
