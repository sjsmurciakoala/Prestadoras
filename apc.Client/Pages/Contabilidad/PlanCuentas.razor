@page "/contabilidad/plan-cuentas"
@attribute [Authorize]
@inject HttpClient Http

<div class="contabilidad-page contabilidad-content">
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <DxAlert AlertType="AlertType.Danger">@errorMessage</DxAlert>
    }

    <DxStackLayout Orientation="Orientation.Vertical" Spacing="15px">
        <DxStackLayoutItem>
            <DxButton Text="Actualizar"
                      RenderStyle="ButtonRenderStyle.Primary"
                      Click="LoadPlanCuentasAsync"
                      Enabled="@( !isLoading )" />
        </DxStackLayoutItem>
        <DxStackLayoutItem>
            <div class="text-muted small">Total cuentas: @planCuentas.Length</div>
        </DxStackLayoutItem>
        <DxStackLayoutItem>
            <DxTreeList Data="@planCuentas"
                        KeyFieldName="@nameof(PlanCuentaDto.AccountId)"
                        ParentKeyFieldName="@nameof(PlanCuentaDto.ParentAccountId)"
                        ShowFilterRow="true"
                        ShowColumnLines="true"
                        ShowBorders="true"
                        AllowColumnResize="true"
                        KeyboardNavigationEnabled="true">
                <Columns>
                    <DxTreeListDataColumn FieldName="@nameof(PlanCuentaDto.Code)" Caption="Codigo" />
                    <DxTreeListDataColumn FieldName="@nameof(PlanCuentaDto.Name)" Caption="Nombre" />
                    <DxTreeListDataColumn FieldName="@nameof(PlanCuentaDto.AccountType)" Caption="Tipo" />
                    <DxTreeListDataColumn FieldName="@nameof(PlanCuentaDto.Category)" Caption="Categoria" />
                    <DxTreeListDataColumn FieldName="@nameof(PlanCuentaDto.Level)" Caption="Nivel" />
                    <DxTreeListDataColumn FieldName="@nameof(PlanCuentaDto.AllowsPosting)" Caption="Permite movimientos" />
                    <DxTreeListDataColumn FieldName="@nameof(PlanCuentaDto.Status)" Caption="Estado" />
                    <DxTreeListDataColumn FieldName="@nameof(PlanCuentaDto.CurrencyCode)" Caption="Moneda" />
                </Columns>
            </DxTreeList>
        </DxStackLayoutItem>
    </DxStackLayout>
</div>

@code {
    private PlanCuentaDto[] planCuentas = Array.Empty<PlanCuentaDto>();
    private string? errorMessage;
    private bool isLoading;

    protected override async Task OnInitializedAsync()
    {
        await LoadPlanCuentasAsync();
    }

    private async Task LoadPlanCuentasAsync()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            planCuentas = await Http.GetFromJsonAsync<PlanCuentaDto[]>("api/contabilidad/catalogos/plan-cuentas")
                ?? Array.Empty<PlanCuentaDto>();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            planCuentas = Array.Empty<PlanCuentaDto>();
        }
        finally
        {
            isLoading = false;
        }
    }
}
