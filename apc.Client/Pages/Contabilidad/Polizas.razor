@page "/contabilidad/partidas"
@page "/contabilidad/polizas"
@attribute [Authorize]
@using DevExpress.Blazor
@using System.Globalization
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Web
@using apc.Client.Services.Tenant
@using SIAD.Core.DTOs.Contabilidad
@inject HttpClient Http
@inject apc.Client.Services.Contabilidad.PolizasClient PolizasClient
@inject apc.Client.Services.Contabilidad.PeriodosContablesClient PeriodosClient
@inject TenantState TenantState

<PageTitle>SIAD - Partidas manuales</PageTitle>

<DxLoadingPanel @bind-Visible="IsSaving"
                IndicatorAnimationType="WaitIndicatorAnimationType.Spin"
                Text="Procesando partida..."
                ApplyBackgroundShading="true" 
                IsContentBlocked="true"
                PositionTarget="body" />

<DxMessageBox @bind-Visible="statusMessageVisible"
              Type="MessageBoxType.Alert"
              Title="@statusMessageTitle"
              Text="@statusMessageText"
              RenderStyle="@statusMessageRenderStyle"
              OkButtonText="Entendido"
              ShowCloseButton="false"
              CloseOnOutsideClick="false" />

<div class="partidas-page" id="partidas-view">
    <section class="partidas-hero">
        <div class="partidas-hero__copy">
            <span class="partidas-hero__eyebrow">Contabilidad</span>
            <h1 class="partidas-hero__title">Partidas manuales</h1>
            <p class="partidas-hero__subtitle">Registro de comprobantes contables manuales con validación de balance y reglas de tipo.</p>
        </div>
        <div class="partidas-hero__actions">
            <DxButton Text="Totalizar"
                      IconCssClass="bi bi-check-lg"
                      RenderStyle="ButtonRenderStyle.Primary"
                      Click="@(async _ => await GuardarAsync())"
                      Enabled="@(!IsSaving && CanGuardarEnContexto)" />
            <DxButton Text="Limpiar"
                      IconCssClass="bi bi-eraser"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      Click="@(async _ => await ResetFormAsync())"
                      Enabled="@(!IsSaving)" />
            <DxButton Text="Actualizar catálogos"
                      IconCssClass="bi bi-arrow-clockwise"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      Click="@(async _ => await LoadCatalogosAsync())"
                      Enabled="@(!IsSaving)" />
        </div>
    </section>

    <section class="partidas-context mb-3">
        @if (PeriodoActivo is not null)
        {
            <div class="periodo-contexto">
                <div>
                    <span class="periodo-contexto__eyebrow">Periodo contable activo</span>
                    <strong>@PeriodoActivo.Code - @PeriodoActivo.Name</strong>
                    <span>@PeriodoActivo.StartDate.ToString("dd/MM/yyyy") - @PeriodoActivo.EndDate.ToString("dd/MM/yyyy")</span>
                </div>
                <div class="periodo-contexto__meta">
                    <span>Diario manual por defecto: @DiarioManualDescripcion</span>
                </div>
            </div>
        }
        else
        {
            <div class="partidas-warning-box">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <span>No hay un periodo contable abierto. No se podrán guardar partidas hasta abrir uno en Contabilidad.</span>
            </div>
        }

        @if (FechaFueraDePeriodo)
        {
            <small class="text-danger d-block mt-2 px-1">
                La fecha debe estar dentro del periodo activo @PeriodoActivoRango.
            </small>
        }

        @if (PeriodoActivo is not null && DiarioManualActivo is null)
        {
            <small class="text-danger d-block mt-2 px-1">
                Configure un diario manual por defecto en Catálogos &gt; Diarios para habilitar el registro manual.
            </small>
        }
    </section>

    <section class="partidas-shell mb-3">
        <div class="partidas-shell__header">
            <i class="bi bi-card-heading me-2 text-primary"></i>
            <span class="fw-bold">Encabezado</span>
        </div>
        <div class="partidas-shell__body">
            <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                <DxFormLayoutItem Caption="Tipo de comprobante *" ColSpanLg="4" ColSpanMd="6" ColSpanSm="12">
                    <DxComboBox Data="@TiposTransaccion"
                                TData="TipoTransaccionDto"
                                TValue="long?"
                                Value="@Form.TypeId"
                                ValueChanged="@(async (long? v) => { Form.TypeId = v; await LoadRulesForTypeAsync(v); foreach (var l in Form.Lineas) NormalizarLineaPorConfiguracion(l); })"
                                ValueExpression="@(() => Form.TypeId)"
                                ValueFieldName="@nameof(TipoTransaccionDto.TypeId)"
                                TextFieldName="@nameof(TipoTransaccionDto.Name)"
                                SearchMode="ListSearchMode.AutoSearch"
                                SearchFilterCondition="ListSearchFilterCondition.Contains"
                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                NullText="-- Seleccione --">
                        <Columns>
                            <DxListEditorColumn FieldName="@nameof(TipoTransaccionDto.Code)" Caption="Codigo" Width="80px" />
                            <DxListEditorColumn FieldName="@nameof(TipoTransaccionDto.Name)" Caption="Nombre" />
                        </Columns>
                    </DxComboBox>
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Fecha *" ColSpanLg="3" ColSpanMd="3" ColSpanSm="6">
                    <DxDateEdit @bind-Date="Form.PolizaDate"
                                Format="dd/MM/yyyy"
                                MinDate="@PeriodoMinDate"
                                MaxDate="@PeriodoMaxDate"
                                OutOfRangeNotificationText="La fecha debe estar dentro del periodo contable abierto." />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Próximo No. documento" ColSpanLg="5" ColSpanMd="3" ColSpanSm="6">
                    <DxSpinEdit T="long"
                                Value="@DocumentNumberPreview"
                                ReadOnly="true"
                                ShowSpinButtons="false"
                                CssClass="correlativo-field" />
                </DxFormLayoutItem>
                <DxFormLayoutItem Caption="Descripción *" ColSpanLg="12" ColSpanMd="12" ColSpanSm="12">
                    <DxTextBox @bind-Text="Form.Description" NullText="Concepto del comprobante" />
                </DxFormLayoutItem>
            </DxFormLayout>
        </div>
    </section>

    <section class="partidas-shell mb-3">
        <div class="partidas-shell__header d-flex justify-content-between align-items-center">
            <div>
                <i class="bi bi-list-ol me-2 text-primary"></i>
                <span class="fw-bold">Detalle de líneas</span>
                <small class="text-muted ms-2">@Form.Lineas.Count línea(s)</small>
            </div>
            <DxButton Text="Agregar línea"
                      IconCssClass="bi bi-plus"
                      RenderStyle="ButtonRenderStyle.Primary"
                      SizeMode="SizeMode.Small"
                      Click="AddLinea"
                      Enabled="@(!IsSaving)" />
        </div>
        <div class="partidas-shell__body p-0">
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width:40px">#</th>
                            <th style="min-width:260px">Codigo *</th>
                            <th style="min-width:180px">Descripcion</th>
                            <th style="min-width:120px">Ref. línea</th>
                            <th style="min-width:120px">Debito</th>
                            <th style="min-width:120px">Credito</th>
                            <th style="width:90px" class="text-center">Accion</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Form.Lineas.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted py-4">No hay lineas cargadas. Use Agregar línea para iniciar el detalle.</td>
                            </tr>
                        }
                        else
                        {
                            @for (var i = 0; i < Form.Lineas.Count; i++)
                            {
                                var linea = Form.Lineas[i];
                                var rowNum = i + 1;
                                var needsExtra = NecesitaCamposExtra(linea);

                                <tr @onkeydown="e => OnLineaKeyDown(e, linea)">
                                    <td class="text-muted small">@rowNum</td>
                                    <td>
                                        <div class="d-flex gap-1 align-items-start">
                                            <div style="flex:1">
                                                <DxMaskedInput T="string"
                                                               Value="@linea.AccountCode"
                                                               ValueChanged="@((string v) => OnAccountCodeChanged(linea, v))"
                                                               ValueExpression="@(() => linea.AccountCode)"
                                                               Mask="@AccountMask"
                                                               SizeMode="SizeMode.Small">
                                                    <DxTextMaskProperties Placeholder="@('_')" />
                                                </DxMaskedInput>
                                            </div>
                                            <DxButton RenderStyle="ButtonRenderStyle.Secondary"
                                                      RenderStyleMode="ButtonRenderStyleMode.Outline"
                                                      IconCssClass="bi bi-search"
                                                      SizeMode="SizeMode.Small"
                                                      title="Buscar cuenta"
                                                      Click="@(() => ToggleBuscarCuenta(linea))" />
                                        </div>

                                        @if (linea.ShowBuscarCuenta)
                                        {
                                            <DxComboBox Data="@CuentasLookup"
                                                        TData="CuentaLookupItem"
                                                        TValue="long?"
                                                        Value="linea.AccountId"
                                                        ValueChanged="@((long? v) => OnCuentaSelectedFromSearch(linea, v))"
                                                        ValueExpression="@(() => linea.AccountId)"
                                                        ValueFieldName="@nameof(CuentaLookupItem.AccountId)"
                                                        TextFieldName="@nameof(CuentaLookupItem.Display)"
                                                        SearchMode="ListSearchMode.AutoSearch"
                                                        SearchFilterCondition="ListSearchFilterCondition.Contains"
                                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                        DropDownWidthMode="DropDownWidthMode.ContentOrEditorWidth"
                                                        NullText="Buscar por codigo o nombre..."
                                                        SizeMode="SizeMode.Small"
                                                        CssClass="mt-1">
                                                <Columns>
                                                    <DxListEditorColumn FieldName="@nameof(CuentaLookupItem.Code)" Caption="Codigo" Width="140px" />
                                                    <DxListEditorColumn FieldName="@nameof(CuentaLookupItem.Name)" Caption="Cuenta" />
                                                </Columns>
                                            </DxComboBox>
                                        }

                                        @if (!linea.AccountId.HasValue && !string.IsNullOrWhiteSpace(linea.AccountName))
                                        {
                                            <small class="text-danger d-block mt-1">@linea.AccountName</small>
                                        }
                                    </td>
                                    <td>
                                        <DxTextBox @bind-Text="linea.Description"
                                                   NullText="Detalle"
                                                   SizeMode="SizeMode.Small" />
                                    </td>
                                    <td>
                                        <DxTextBox @bind-Text="linea.SourceDocument"
                                                   NullText="Factura/Ref"
                                                   SizeMode="SizeMode.Small" />
                                    </td>
                                    <td>
                                        <DxSpinEdit T="decimal"
                                                    @bind-Value="linea.DebitAmount"
                                                    MinValue="0"
                                                    Increment="0.01m"
                                                    SizeMode="SizeMode.Small" />
                                    </td>
                                    <td>
                                        <DxSpinEdit T="decimal"
                                                    @bind-Value="linea.CreditAmount"
                                                    MinValue="0"
                                                    Increment="0.01m"
                                                    SizeMode="SizeMode.Small" />
                                    </td>
                                    <td class="text-center">
                                        <div class="d-flex gap-1 justify-content-center">
                                            @if (needsExtra)
                                            {
                                                <DxButton RenderStyle="ButtonRenderStyle.Info"
                                                          RenderStyleMode="ButtonRenderStyleMode.Text"
                                                          IconCssClass="@(linea.ShowDetalle ? "bi bi-chevron-up" : "bi bi-chevron-down")"
                                                          SizeMode="SizeMode.Small"
                                                          title="@(linea.ShowDetalle ? "Ocultar detalle" : "Mostrar CC/Tercero")"
                                                          Click="@(() => ToggleDetalle(linea))" />
                                            }
                                            <DxButton RenderStyle="ButtonRenderStyle.Danger"
                                                      RenderStyleMode="ButtonRenderStyleMode.Text"
                                                      IconCssClass="bi bi-trash"
                                                      SizeMode="SizeMode.Small"
                                                      title="Quitar linea"
                                                      Click="@(() => RemoveLinea(linea))" />
                                        </div>
                                    </td>
                                </tr>

                                @if (linea.ShowDetalle && needsExtra)
                                {
                                    var cuentaDetalle = GetCuenta(linea.AccountId);
                                    var mostrarCC = CuentaRequiereCentroCosto(cuentaDetalle, linea);
                                    var mostrarTercero = CuentaRequiereTercero(cuentaDetalle, linea);

                                    <tr class="detail-row">
                                        <td></td>
                                        <td colspan="6">
                                            <div class="d-flex flex-wrap gap-3 p-2 bg-light rounded-2 align-items-end">
                                                @if (mostrarCC)
                                                {
                                                    <div style="min-width:230px; flex:1;">
                                                        <label class="form-label small fw-bold mb-1">Centro de Costo</label>
                                                        <DxComboBox Data="@CentrosCostoLookup"
                                                                    TData="CentroCostoLookupItem"
                                                                    TValue="long?"
                                                                    Value="linea.CostCenterId"
                                                                    ValueChanged="@(v => OnLineaCostCenterChanged(linea, v))"
                                                                    ValueExpression="@(() => linea.CostCenterId)"
                                                                    ValueFieldName="@nameof(CentroCostoLookupItem.CostCenterId)"
                                                                    TextFieldName="@nameof(CentroCostoLookupItem.Display)"
                                                                    SearchMode="ListSearchMode.AutoSearch"
                                                                    SearchFilterCondition="ListSearchFilterCondition.Contains"
                                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                    NullText="Seleccione CC"
                                                                    SizeMode="SizeMode.Small">
                                                            <Columns>
                                                                <DxListEditorColumn FieldName="@nameof(CentroCostoLookupItem.Code)" Caption="Codigo" Width="100px" />
                                                                <DxListEditorColumn FieldName="@nameof(CentroCostoLookupItem.Name)" Caption="Centro" />
                                                            </Columns>
                                                        </DxComboBox>
                                                    </div>
                                                }

                                                @if (mostrarTercero)
                                                {
                                                    <div style="min-width:320px; flex:2;">
                                                        <label class="form-label small fw-bold mb-1">Tercero</label>
                                                        <DxComboBox Data="@TercerosLookup"
                                                                    TData="TerceroDto"
                                                                    TValue="long?"
                                                                    Value="linea.ThirdPartyId"
                                                                    ValueChanged="@((long? v) => OnTerceroSelected(linea, v))"
                                                                    ValueExpression="@(() => linea.ThirdPartyId)"
                                                                    ValueFieldName="@nameof(TerceroDto.ThirdPartyId)"
                                                                    TextFieldName="@nameof(TerceroDto.Name)"
                                                                    SearchMode="ListSearchMode.AutoSearch"
                                                                    SearchFilterCondition="ListSearchFilterCondition.Contains"
                                                                    ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                                    NullText="Buscar tercero..."
                                                                    SizeMode="SizeMode.Small">
                                                            <Columns>
                                                                <DxListEditorColumn FieldName="@nameof(TerceroDto.Code)" Caption="Código" Width="140px" />
                                                                <DxListEditorColumn FieldName="@nameof(TerceroDto.Name)" Caption="Nombre" />
                                                                <DxListEditorColumn FieldName="@nameof(TerceroDto.Category)" Caption="Tipo" Width="100px" />
                                                            </Columns>
                                                        </DxComboBox>

                                                        @if (!string.IsNullOrEmpty(linea.TerceroLabel))
                                                        {
                                                            <small class="text-muted d-block mt-1">
                                                                <i class="bi bi-person-check me-1"></i>@linea.TerceroLabel
                                                            </small>
                                                        }
                                                    </div>
                                                }

                                                <div class="ms-auto align-self-end">
                                                    <DxButton Text="Listo"
                                                              IconCssClass="bi bi-check"
                                                              RenderStyle="ButtonRenderStyle.Success"
                                                              SizeMode="SizeMode.Small"
                                                              Click="@(() => ConfirmDetalle(linea))" />
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-light fw-bold">
                            <td></td>
                            <td colspan="2" class="text-end">Totales</td>
                            <td></td>
                            <td class="text-end">@TotalDebito.ToString("N2", HnCulture)</td>
                            <td class="text-end">@TotalCredito.ToString("N2", HnCulture)</td>
                            <td class="text-end @(BalanceExacto ? "text-success" : "text-warning")">
                                @FormatHnl(TotalDebito - TotalCredito)
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </section>
</div>

<DxPopup @bind-Visible="validationErrorsVisible"
         Width="min(480px, 90vw)"
         HeaderText="Errores de validacion"
         ShowFooter="false"
         ShowCloseButton="true"
         CloseOnOutsideClick="true">
    <BodyTemplate>
        <div class="text-center p-4">
            <div class="mb-3 text-warning">
                <i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i>
            </div>
            <ul class="text-start mb-0 ps-3">
                @foreach (var err in validationErrors)
                {
                    <li class="mb-1">@err</li>
                }
            </ul>
            <div class="mt-4 text-start">
                <DxButton Text="Entendido"
                          RenderStyle="ButtonRenderStyle.Warning"
                          Click="@(() => validationErrorsVisible = false)" />
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    private List<PlanCuentaDto> PlanCuentas = new();
    private List<CentroCostoDto> CentrosCosto = new();
    private List<TipoTransaccionDto> TiposTransaccion = new();
    private List<TipoTransaccionRuleDto> TipoRules = new();
    private List<DiarioDto> Diarios = new();
    private List<CuentaLookupItem> CuentasLookup = new();
    private List<CentroCostoLookupItem> CentrosCostoLookup = new();
    private List<TerceroDto> TercerosLookup = new();
    private PeriodoContableDto? PeriodoActivo;
    private DiarioDto? DiarioManualActivo;

    private string AccountMask => BuildAccountMask();

    private string formatoCuentas = "###-###-##";
    private string separadorCodigo = "-";
    private IReadOnlyList<int> nivelesFormatoCuentas = Array.Empty<int>();

    // DxMessageBox state
    private bool statusMessageVisible;
    private string statusMessageTitle = string.Empty;
    private string statusMessageText = string.Empty;
    private MessageBoxRenderStyle statusMessageRenderStyle = MessageBoxRenderStyle.Info;

    private bool IsSaving;
    private List<string> validationErrors = new();
    private bool validationErrorsVisible;

    private PolizaForm Form = new();
    private static readonly CultureInfo HnCulture = new("es-HN");

    private TipoTransaccionDto? SelectedTipo => Form.TypeId is null
        ? null
        : TiposTransaccion.FirstOrDefault(t => t.TypeId == Form.TypeId.Value);

    private decimal TotalDebito => Form.Lineas.Sum(l => l.DebitAmount);
    private decimal TotalCredito => Form.Lineas.Sum(l => l.CreditAmount);
    private bool BalanceExacto => Math.Abs(TotalDebito - TotalCredito) < 0.01m;
    private bool CanGuardarEnContexto => PeriodoActivo is not null && DiarioManualActivo is not null;
    private DateTime PeriodoMinDate => PeriodoActivo?.StartDate.Date ?? DateTime.MinValue;
    private DateTime PeriodoMaxDate => PeriodoActivo?.EndDate.Date ?? DateTime.MaxValue;
    private bool FechaFueraDePeriodo => PeriodoActivo is not null &&
                                        (Form.PolizaDate.Date < PeriodoMinDate || Form.PolizaDate.Date > PeriodoMaxDate);
    private string PeriodoActivoRango => PeriodoActivo is null
        ? "sin periodo activo"
        : $"{PeriodoActivo.StartDate:dd/MM/yyyy} - {PeriodoActivo.EndDate:dd/MM/yyyy}";
    private string DiarioManualDescripcion => DiarioManualActivo is null
        ? "Sin diario manual por defecto"
        : $"{DiarioManualActivo.Code} - {DiarioManualActivo.Name}";

    private long DocumentNumberPreview => SelectedTipo?.NextDocumentNumber ?? 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadCatalogosAsync();
    }

    private async Task LoadCatalogosAsync()
    {
        try
        {
            ClearStatusMessage();

            var companyId = await TenantState.EnsureCompanyAsync();
            if (companyId <= 0)
            {
                ShowStatusMessage("Error", "No se pudo determinar la empresa activa.", MessageBoxRenderStyle.Danger);
                return;
            }

            var tiposTask = Http.GetFromJsonAsync<List<TipoTransaccionDto>>("api/contabilidad/catalogos/tipos-transaccion");
            var cuentasTask = Http.GetFromJsonAsync<List<PlanCuentaDto>>("api/contabilidad/catalogos/plan-cuentas");
            var centrosTask = Http.GetFromJsonAsync<List<CentroCostoDto>>("api/contabilidad/catalogos/centros-costo");
            var tercerosTask = Http.GetFromJsonAsync<List<TerceroDto>>("api/contabilidad/terceros");
            var diariosTask = Http.GetFromJsonAsync<List<DiarioDto>>("api/contabilidad/catalogos/diarios");
            var periodoTask = PeriodosClient.ObtenerPeriodoActivoAsync(companyId);
            await LoadConfiguracionFormatoAsync();

            await Task.WhenAll(tiposTask!, cuentasTask!, centrosTask!, tercerosTask!, diariosTask!, periodoTask);

            TiposTransaccion = (tiposTask?.Result ?? new List<TipoTransaccionDto>())
                .OrderBy(t => t.Code)
                .ToList();
            PlanCuentas = (cuentasTask?.Result ?? new List<PlanCuentaDto>())
                .Where(c => c.AllowsPosting)
                .OrderBy(c => c.Code)
                .ToList();
            CentrosCosto = (centrosTask?.Result ?? new List<CentroCostoDto>())
                .OrderBy(c => c.Code)
                .ToList();

            nivelesFormatoCuentas = ParseFormatoNiveles(formatoCuentas);
            RefreshCuentasLookup();
            CentrosCostoLookup = CentrosCosto
                .Select(c => new CentroCostoLookupItem(
                    c.CostCenterId,
                    c.Code,
                    c.Name,
                    $"{c.Code} - {c.Name}"))
                .ToList();

            TercerosLookup = (tercerosTask?.Result ?? new List<TerceroDto>())
                .Where(t => t.Status == "ACTIVE")
                .OrderBy(t => t.Code)
                .ToList();
            Diarios = (diariosTask?.Result ?? new List<DiarioDto>())
                .Where(d => d.IsActive)
                .OrderBy(d => d.Code)
                .ToList();
            PeriodoActivo = periodoTask.Result;
            DiarioManualActivo = ResolveManualJournal(Diarios);

            await LoadRulesForTypeAsync(Form.TypeId);

            if (Form.TypeId is null)
            {
                var defaultTipo = TiposTransaccion.FirstOrDefault(t => t.IsDefault);
                if (defaultTipo is not null)
                {
                    Form.TypeId = defaultTipo.TypeId;
                    await LoadRulesForTypeAsync(Form.TypeId);
                }
            }

            AjustarFechaAlPeriodoActivo();
        }
        catch (Exception ex)
        {
            ShowStatusMessage("Error", $"No se pudieron cargar catalogos: {ex.Message}", MessageBoxRenderStyle.Danger);
        }
    }

    private void AddLinea()
    {
        var linea = new PolizaLineaVm();
        NormalizarLineaPorConfiguracion(linea);
        Form.Lineas.Add(linea);
    }

    private void RemoveLinea(PolizaLineaVm linea)
    {
        Form.Lineas.Remove(linea);
    }

    private void OnAccountCodeChanged(PolizaLineaVm linea, string maskedCode)
    {
        linea.AccountCode = maskedCode;
        var normalized = NormalizeCode(maskedCode);

        if (string.IsNullOrWhiteSpace(normalized))
        {
            linea.AccountId = null;
            linea.AccountName = null;
            linea.ShowDetalle = false;
            return;
        }

        var match = GetPlanCuentasPermitidas().FirstOrDefault(c => NormalizeCode(c.Code) == normalized);
        if (match != null)
        {
            linea.AccountId = match.AccountId;
            linea.AccountName = match.Name;
            NormalizarLineaPorConfiguracion(linea);

            if (NecesitaCamposExtra(linea))
            {
                linea.ShowDetalle = true;
            }
        }
        else
        {
            var existingAccount = PlanCuentas.FirstOrDefault(c => NormalizeCode(c.Code) == normalized);
            linea.AccountId = null;
            linea.AccountName = existingAccount is null
                ? $"Cuenta '{maskedCode}' no encontrada"
                : $"Cuenta {FormatCuentaCode(existingAccount.Code)} fuera de las reglas de {SelectedTipo?.Name ?? "este tipo"}";
            linea.ShowDetalle = false;
        }
    }

    private bool NecesitaCamposExtra(PolizaLineaVm linea)
    {
        if (linea.AccountId is null) return false;
        var cuenta = GetCuenta(linea.AccountId);
        if (cuenta is null) return false;
        return CuentaRequiereCentroCosto(cuenta, linea) || CuentaRequiereTercero(cuenta, linea);
    }

    private bool CuentaRequiereCentroCosto(PlanCuentaDto? cuenta, PolizaLineaVm linea)
    {
        if (cuenta is null) return false;
        if (cuenta.AllowsCostCenter) return true;
        if (SelectedTipo?.AllowsCostCenter == true) return true;
        return RequiereCentroCostoPorRegla(linea);
    }

    private bool CuentaRequiereTercero(PlanCuentaDto? cuenta, PolizaLineaVm linea)
    {
        if (cuenta is null) return false;
        if (cuenta.AllowsThird) return true;
        if (SelectedTipo?.AllowsThirdParty == true) return true;
        return RequiereTerceroPorRegla(linea);
    }

