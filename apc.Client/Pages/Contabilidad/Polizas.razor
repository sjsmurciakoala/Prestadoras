    private void OnCuentaSelectedFromSearch(PolizaLineaVm linea, long? accountId)
    {
        linea.ShowBuscarCuenta = false;

        if (accountId is null or <= 0)
        {
            linea.AccountId = null;
            linea.AccountCode = null;
            linea.AccountName = null;
            linea.ShowDetalle = false;
            return;
        }

        var cuenta = GetPlanCuentasPermitidas().FirstOrDefault(c => c.AccountId == accountId.Value);
        if (cuenta is not null)
        {
            linea.AccountId = cuenta.AccountId;
            linea.AccountCode = FormatCuentaCode(cuenta.Code);
            linea.AccountName = cuenta.Name;
            NormalizarLineaPorConfiguracion(linea);

            if (NecesitaCamposExtra(linea))
            {
                linea.ShowDetalle = true;
            }
        }
    }

