        {
            linea.TerceroLabel = null;
        }
    }

    private string BuildAccountMask()
    {
        if (string.IsNullOrWhiteSpace(formatoCuentas))
            return string.Empty;

        var sep = string.IsNullOrWhiteSpace(separadorCodigo) ? "-" : separadorCodigo;
        var niveles = ParseFormatoNiveles(formatoCuentas);
        if (niveles.Count == 0)
            return new string('0', formatoCuentas.Count(c => c == '#' || c == 'X' || c == 'x'));

        return string.Join(sep, niveles.Select(n => new string('0', n)));
    }

