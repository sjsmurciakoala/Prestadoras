    private async Task LoadConfiguracionFormatoAsync()
    {
        try
        {
            var companyId = await TenantState.EnsureCompanyAsync();
            if (companyId <= 0)
            {
                return;
            }

            var config = await Http.GetFromJsonAsync<ConfiguracionSistemaDto>($"api/contabilidad/configuracion/{companyId}");
            if (config?.Principal is null)
            {
                return;
            }

            if (!string.IsNullOrWhiteSpace(config.Principal.FormatoCuentas))
            {
                formatoCuentas = config.Principal.FormatoCuentas;
            }

            if (!string.IsNullOrWhiteSpace(config.Principal.SeparadorCodigo))
            {
                separadorCodigo = config.Principal.SeparadorCodigo;
            }
        }
        catch
        {
            // Mantiene formato por defecto si la configuracion no esta disponible.
        }
    }

    private string FormatCuentaCode(string? raw)
    {
        var normalized = NormalizeCode(raw);
        if (string.IsNullOrWhiteSpace(normalized))
        {
            return string.Empty;
        }

        if (nivelesFormatoCuentas.Count == 0)
        {
            return normalized;
        }

        var separator = string.IsNullOrWhiteSpace(separadorCodigo) ? "-" : separadorCodigo;
        var parts = new List<string>();
        var index = 0;

        foreach (var length in nivelesFormatoCuentas)
        {
            if (index >= normalized.Length)
            {
                break;
            }

            var take = Math.Min(length, normalized.Length - index);
            parts.Add(normalized.Substring(index, take));
            index += take;
        }

        if (index < normalized.Length)
        {
            parts.Add(normalized.Substring(index));
        }

        return string.Join(separator, parts);
    }

    private static string NormalizeCode(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value.Where(char.IsLetterOrDigit).ToArray());
    }

    private static IReadOnlyList<int> ParseFormatoNiveles(string? format)
    {
        if (string.IsNullOrWhiteSpace(format))
        {
            return Array.Empty<int>();
        }

        var groups = new List<int>();
        var current = 0;

        foreach (var ch in format)
        {
            if (ch == '#' || ch == 'X' || ch == 'x')
            {
                current++;
            }
            else if (current > 0)
            {
                groups.Add(current);
                current = 0;
            }
        }

        if (current > 0)
        {
            groups.Add(current);
        }

        return groups;
    }

    private bool PermiteCentroCosto() => SelectedTipo?.AllowsCostCenter ?? true;

    private bool PermiteTercero() => SelectedTipo?.AllowsThirdParty ?? true;

    private bool RequiereCentroCosto(PolizaLineaVm linea)
    {
        var cuenta = GetCuenta(linea.AccountId);
        return (cuenta?.AllowsCostCenter ?? false) || RequiereCentroCostoPorRegla(linea);
    }

    private bool RequiereTercero(PolizaLineaVm linea)
    {
        var cuenta = GetCuenta(linea.AccountId);
        return (cuenta?.AllowsThird ?? false) || RequiereTerceroPorRegla(linea);
    }

    private void NormalizarLineaPorConfiguracion(PolizaLineaVm linea)
    {
        var cuenta = GetCuenta(linea.AccountId);
        if (!CuentaRequiereCentroCosto(cuenta, linea))
        {
            linea.CostCenterId = null;
        }

        if (!CuentaRequiereTercero(cuenta, linea))
        {
            linea.ThirdPartyId = null;
            linea.TerceroLabel = null;
        }
    }

    private async Task LoadRulesForTypeAsync(long? typeId)
    {
        TipoRules = new();
        if (typeId is null or <= 0)
        {
            RefreshCuentasLookup();
            return;
        }

        try
        {
            TipoRules = await Http.GetFromJsonAsync<List<TipoTransaccionRuleDto>>(
                    $"api/contabilidad/catalogos/tipos-transaccion/{typeId.Value}/rules")
                ?? new List<TipoTransaccionRuleDto>();
        }
        catch
        {
            TipoRules = new();
        }

        RefreshCuentasLookup();
    }

    private bool RequiereCentroCostoPorRegla(PolizaLineaVm linea)
    {
        var cuenta = GetCuenta(linea.AccountId);
        if (cuenta is null)
        {
            return false;
        }

        var reglasActivas = TipoRules.Where(r => r.IsActive).ToList();
        if (reglasActivas.Count == 0)
        {
            return false;
        }

        return reglasActivas.Any(r =>
            CuentaEnRango(cuenta.Code, r.AccountCodeFrom, r.AccountCodeTo) &&
            (!string.IsNullOrWhiteSpace(r.CostCenterCodeFrom) || !string.IsNullOrWhiteSpace(r.CostCenterCodeTo)));
    }

    private bool RequiereTerceroPorRegla(PolizaLineaVm linea)
    {
        var cuenta = GetCuenta(linea.AccountId);
        if (cuenta is null)
        {
            return false;
        }

        var reglasActivas = TipoRules.Where(r => r.IsActive).ToList();
        if (reglasActivas.Count == 0)
        {
            return false;
        }

        return reglasActivas.Any(r =>
            CuentaEnRango(cuenta.Code, r.AccountCodeFrom, r.AccountCodeTo) &&
            (!string.IsNullOrWhiteSpace(r.ThirdPartyCodeFrom) || !string.IsNullOrWhiteSpace(r.ThirdPartyCodeTo)));
    }

    private bool CumpleReglasTipo(PolizaLineaVm linea)
        => GetRuleValidationMessage(linea) is null;

    private string? GetRuleValidationMessage(PolizaLineaVm linea)
    {
        var reglasActivas = GetActiveRules();
        if (reglasActivas.Count == 0)
        {
            return null;
        }

        var cuenta = GetCuenta(linea.AccountId);
        if (cuenta is null)
        {
            return "la cuenta seleccionada no es valida.";
        }

        var nombreTipo = SelectedTipo?.Name ?? "el tipo seleccionado";
        var reglasCuenta = reglasActivas
            .Where(r => CuentaEnRango(cuenta.Code, r.AccountCodeFrom, r.AccountCodeTo))
            .ToList();

        if (reglasCuenta.Count == 0)
        {
            return $"la cuenta {FormatCuentaCode(cuenta.Code)} esta fuera de las cuentas permitidas para {nombreTipo}. Rangos validos: {DescribeAccountRanges(reglasActivas)}.";
        }

        var centro = linea.CostCenterId.HasValue
            ? CentrosCosto.FirstOrDefault(c => c.CostCenterId == linea.CostCenterId.Value)
            : null;

        var reglasCentro = reglasCuenta
            .Where(r => !RuleRequiresCostCenter(r) ||
                        (centro is not null && CuentaEnRango(centro.Code, r.CostCenterCodeFrom, r.CostCenterCodeTo)))
            .ToList();

        if (reglasCentro.Count == 0)
        {
            if (centro is null && reglasCuenta.Any(RuleRequiresCostCenter))
            {
                return $"la cuenta {FormatCuentaCode(cuenta.Code)} requiere un centro de costo dentro de: {DescribeCostCenterRanges(reglasCuenta)}.";
            }

            return $"el centro de costo seleccionado no esta dentro del rango permitido para la cuenta {FormatCuentaCode(cuenta.Code)}. Rangos validos: {DescribeCostCenterRanges(reglasCuenta)}.";
        }

        var tercero = linea.ThirdPartyId.HasValue
            ? TercerosLookup.FirstOrDefault(t => t.ThirdPartyId == linea.ThirdPartyId.Value)
            : null;

        var reglasTercero = reglasCentro
            .Where(r => !RuleRequiresThirdParty(r) ||
                        (tercero is not null && CuentaEnRango(tercero.Code, r.ThirdPartyCodeFrom, r.ThirdPartyCodeTo)))
            .ToList();

        if (reglasTercero.Count == 0)
        {
            if (tercero is null && reglasCentro.Any(RuleRequiresThirdParty))
            {
                return $"la cuenta {FormatCuentaCode(cuenta.Code)} requiere un tercero dentro de: {DescribeThirdPartyRanges(reglasCentro)}.";
            }

            return $"el tercero seleccionado no esta dentro del rango permitido para la cuenta {FormatCuentaCode(cuenta.Code)}. Rangos validos: {DescribeThirdPartyRanges(reglasCentro)}.";
        }

        return null;
    }

    private List<TipoTransaccionRuleDto> GetActiveRules()
        => TipoRules.Where(r => r.IsActive).OrderBy(r => r.LineNumber).ToList();

    private IReadOnlyList<PlanCuentaDto> GetPlanCuentasPermitidas()
    {
        var reglasActivas = GetActiveRules();
        if (reglasActivas.Count == 0)
        {
            return PlanCuentas;
        }

        return PlanCuentas
            .Where(c => reglasActivas.Any(r => CuentaEnRango(c.Code, r.AccountCodeFrom, r.AccountCodeTo)))
            .ToList();
    }

    private void RefreshCuentasLookup()
    {
        CuentasLookup = GetPlanCuentasPermitidas()
            .Select(c => new CuentaLookupItem(
                c.AccountId,
                FormatCuentaCode(c.Code),
                c.Name,
                $"{FormatCuentaCode(c.Code)} - {c.Name}"))
            .ToList();
    }

    private static bool RuleRequiresCostCenter(TipoTransaccionRuleDto regla)
        => !string.IsNullOrWhiteSpace(regla.CostCenterCodeFrom) || !string.IsNullOrWhiteSpace(regla.CostCenterCodeTo);

    private static bool RuleRequiresThirdParty(TipoTransaccionRuleDto regla)
        => !string.IsNullOrWhiteSpace(regla.ThirdPartyCodeFrom) || !string.IsNullOrWhiteSpace(regla.ThirdPartyCodeTo);

    private string DescribeAccountRanges(IEnumerable<TipoTransaccionRuleDto> reglas)
        => DescribeRanges(reglas, r => r.AccountCodeFrom, r => r.AccountCodeTo, FormatCuentaCode);

    private string DescribeCostCenterRanges(IEnumerable<TipoTransaccionRuleDto> reglas)
        => DescribeRanges(reglas.Where(RuleRequiresCostCenter), r => r.CostCenterCodeFrom, r => r.CostCenterCodeTo, value => value ?? string.Empty);

    private string DescribeThirdPartyRanges(IEnumerable<TipoTransaccionRuleDto> reglas)
        => DescribeRanges(reglas.Where(RuleRequiresThirdParty), r => r.ThirdPartyCodeFrom, r => r.ThirdPartyCodeTo, value => value ?? string.Empty);

    private static string DescribeRanges(
        IEnumerable<TipoTransaccionRuleDto> reglas,
        Func<TipoTransaccionRuleDto, string?> fromSelector,
        Func<TipoTransaccionRuleDto, string?> toSelector,
        Func<string?, string> formatter)
    {
        var ranges = reglas
            .Select(r => FormatRange(fromSelector(r), toSelector(r), formatter))
            .Where(r => !string.IsNullOrWhiteSpace(r))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToList();

        return ranges.Count == 0 ? "cualquier valor" : string.Join(", ", ranges);
    }

    private static string FormatRange(string? from, string? to, Func<string?, string> formatter)
    {
        var hasFrom = !string.IsNullOrWhiteSpace(from);
        var hasTo = !string.IsNullOrWhiteSpace(to);

        if (!hasFrom && !hasTo)
        {
            return "cualquier valor";
        }

        if (hasFrom && hasTo)
        {
            return string.Equals(from, to, StringComparison.OrdinalIgnoreCase)
                ? formatter(from)
                : $"{formatter(from)} a {formatter(to)}";
        }

        if (hasFrom)
        {
            return $"desde {formatter(from)}";
        }

        return $"hasta {formatter(to)}";
    }

    private static bool CuentaEnRango(string value, string? from, string? to)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return false;
        }

        var hasFrom = !string.IsNullOrWhiteSpace(from);
        var hasTo = !string.IsNullOrWhiteSpace(to);
        if (!hasFrom && !hasTo)
        {
            return true;
        }

        var compareFrom = hasFrom
            ? string.Compare(value, from, StringComparison.OrdinalIgnoreCase) >= 0
            : true;
        var compareTo = hasTo
            ? string.Compare(value, to, StringComparison.OrdinalIgnoreCase) <= 0
            : true;

        return compareFrom && compareTo;
    }

