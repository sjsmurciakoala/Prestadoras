        }
    }

    private async Task CopyLineaFromPreviousAsync(PolizaLineaVm linea)
    {
        var indiceActual = Form.Lineas.IndexOf(linea);
        if (indiceActual <= 0)
        {
            ShowStatusMessage("Informacion", "No hay una linea anterior para copiar.", MessageBoxRenderStyle.Info);
            await InvokeAsync(StateHasChanged);
            return;
        }

        var anterior = Form.Lineas[indiceActual - 1];
        linea.Description = anterior.Description;
        linea.SourceDocument = anterior.SourceDocument;
        await InvokeAsync(StateHasChanged);
    }

    private async Task GuardarAsync()
    {
        ClearStatusMessage();
        var errors = Validar();
        if (errors.Count > 0)
        {
            validationErrors = errors;
            validationErrorsVisible = true;
            return;
        }

        IsSaving = true;
        try
        {
            var request = new PolizaCrearRequest(
                TypeId: Form.TypeId!.Value,
                PeriodId: PeriodoActivo?.PeriodId,
                JournalId: DiarioManualActivo?.JournalId,
                PolizaDate: Form.PolizaDate,
                Module: "MANUAL",
                DocumentType: "JE",
                DocumentId: null,
                DocumentNumber: null,
                Description: Form.Description?.Trim(),
                Lineas: Form.Lineas.Select(l => new PolizaLineaRequest(
                    AccountId: l.AccountId!.Value,
                    CostCenterId: l.CostCenterId,
                    ThirdPartyId: l.ThirdPartyId,
                    DebitAmount: l.DebitAmount,
                    CreditAmount: l.CreditAmount,
                    Description: l.Description,
                    CurrencyCode: null,
                    ExchangeRate: null,
                    SourceDocument: l.SourceDocument
                )).ToList()
            );

            var newId = await PolizasClient.CrearAsync(request);
            var polizaCreada = await PolizasClient.ObtenerAsync(newId);
            var documentNumberAsignado = polizaCreada?.DocumentNumber;

            await LoadCatalogosAsync();
            await ResetFormAsync(clearStatusMessage: false);
            ShowStatusMessage(
                "Proceso completado",
                !string.IsNullOrWhiteSpace(documentNumberAsignado)
                    ? $"Partida registrada exitosamente con No. documento {documentNumberAsignado}."
                    : "Partida registrada exitosamente.",
                MessageBoxRenderStyle.Success);
        }
        catch (Exception ex)
        {
            ShowStatusMessage("Error", $"No se pudo guardar la partida: {ex.Message}", MessageBoxRenderStyle.Danger);
        }
        finally
        {
            IsSaving = false;
        }
    }

    private List<string> Validar()
    {
        var errors = new List<string>();

        if (PeriodoActivo is null)
            errors.Add("No hay un periodo contable abierto en Contabilidad.");

        if (DiarioManualActivo is null)
            errors.Add("No hay un diario manual activo configurado para registrar partidas.");

        if (FechaFueraDePeriodo)
            errors.Add($"La fecha del comprobante debe estar dentro del periodo activo {PeriodoActivoRango}.");

        if (Form.TypeId is null || Form.TypeId <= 0)
            errors.Add("Debe seleccionar el tipo de comprobante.");

        if (string.IsNullOrWhiteSpace(Form.Description))
            errors.Add("Debe ingresar la descripcion del encabezado.");

        if (Form.Lineas.Count == 0)
        {
            errors.Add("Debe agregar al menos una linea.");
            return errors;
        }

        foreach (var (linea, idx) in Form.Lineas.Select((item, index) => (item, index + 1)))
        {
            if (linea.AccountId is null || linea.AccountId <= 0)
            {
                errors.Add($"Linea {idx}: {(string.IsNullOrWhiteSpace(linea.AccountName) ? "seleccione una cuenta." : linea.AccountName)}");
                continue;
            }

            var cuenta = GetCuenta(linea.AccountId);
            if (cuenta is null)
            {
                errors.Add($"Linea {idx}: la cuenta seleccionada no existe en catalogos.");
                continue;
            }

            if (!cuenta.AllowsPosting)
                errors.Add($"Linea {idx}: la cuenta {FormatCuentaCode(cuenta.Code)} no permite movimiento.");

            if (CuentaRequiereCentroCosto(cuenta, linea) && (linea.CostCenterId is null || linea.CostCenterId <= 0))
                errors.Add($"Linea {idx}: debe seleccionar centro de costo.");

            if (CuentaRequiereTercero(cuenta, linea) && (linea.ThirdPartyId is null || linea.ThirdPartyId <= 0))
                errors.Add($"Linea {idx}: debe indicar tercero.");

            if (linea.DebitAmount <= 0 && linea.CreditAmount <= 0)
                errors.Add($"Linea {idx}: indique debito o credito.");

            if (linea.DebitAmount < 0 || linea.CreditAmount < 0)
                errors.Add($"Linea {idx}: debito y credito deben ser positivos.");

            if (linea.DebitAmount > 0 && linea.CreditAmount > 0)
                errors.Add($"Linea {idx}: use solo debito o credito por linea.");

            var reglaError = GetRuleValidationMessage(linea);
            if (reglaError is not null)
                errors.Add($"Linea {idx}: {reglaError}");
        }

        if (!BalanceExacto)
            errors.Add("Los debitos y creditos deben balancear.");

        return errors;
    }

    private Task ResetFormAsync()
    {
        return ResetFormAsync(clearStatusMessage: true);
    }

    private async Task ResetFormAsync(bool clearStatusMessage)
    {
        var preservedTypeId = Form.TypeId ?? TiposTransaccion.FirstOrDefault(t => t.IsDefault)?.TypeId;
        Form = new PolizaForm
        {
            TypeId = preservedTypeId,
            PolizaDate = GetDefaultPolizaDate()
        };
        TipoRules = new();

        if (preservedTypeId.HasValue)
        {
            await LoadRulesForTypeAsync(preservedTypeId);
        }

        if (clearStatusMessage)
        {
            ClearStatusMessage();
        }
    }

    private DateTime GetDefaultPolizaDate()
    {
        if (PeriodoActivo is null)
        {
            return DateTime.Today;
        }

        var today = DateTime.Today;
        if (today < PeriodoMinDate)
        {
            return PeriodoMinDate;
        }

        if (today > PeriodoMaxDate)
        {
            return PeriodoMaxDate;
        }

        return today;
    }

    private void AjustarFechaAlPeriodoActivo()
    {
        if (PeriodoActivo is null)
        {
            return;
        }

        if (Form.PolizaDate.Date < PeriodoMinDate)
        {
            Form.PolizaDate = PeriodoMinDate;
            return;
        }

        if (Form.PolizaDate.Date > PeriodoMaxDate)
        {
            Form.PolizaDate = PeriodoMaxDate;
        }
    }

    private static DiarioDto? ResolveManualJournal(IEnumerable<DiarioDto> diarios)
    {
        var defaults = diarios
            .Where(d => d.IsActive && d.AllowsManual && d.IsDefaultManual)
            .ToList();

        return defaults.Count == 1 ? defaults[0] : null;
    }

