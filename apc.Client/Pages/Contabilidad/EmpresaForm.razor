@page "/contabilidad/empresas/nueva"
@page "/contabilidad/empresas/editar/{EmpresaId:long}"

@using System.Linq
@using Microsoft.AspNetCore.Components.Forms
@using DevExpress.Blazor
@using SIAD.Core.DTOs.Contabilidad
@using apc.Client.Services.Contabilidad
@inject EmpresasContabilidadClient EmpresaClient
@inject NavigationManager NavigationManager
@rendermode InteractiveServer
<h3>Formulario de Empresa</h3>

<EditForm Model="@empresa" OnValidSubmit="HandleValidSubmit" Context="editContext">
    <DataAnnotationsValidator />
    <DxFormLayout>
        <DxFormLayoutItem Caption="Código:" ColSpanMd="6">
            <DxTextBox @bind-Text="empresa.Codigo" Enabled="@(!EmpresaId.HasValue)" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Descripción:" ColSpanMd="6">
            <DxTextBox @bind-Text="empresa.Descripcion" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Tipo de Empresa:" ColSpanMd="6">
            <DxTextBox @bind-Text="empresa.TipoEmpresa" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="País:" ColSpanMd="6">
            <DxTextBox @bind-Text="empresa.Pais" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Siglas ID Fiscal:" ColSpanMd="6">
            <DxTextBox @bind-Text="empresa.IdFiscalSiglas" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Valor ID Fiscal:" ColSpanMd="6">
            <DxTextBox @bind-Text="empresa.IdFiscalValor" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Tamaño:" ColSpanMd="6">
            <DxComboBox Data="@(Enum.GetValues(typeof(CompanySizeType)).Cast<CompanySizeType>())"
                        TData="CompanySizeType"
                        TValue="CompanySizeType?"
                        @bind-Value="empresa.Tamano" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Capital:" ColSpanMd="6">
            <DxComboBox Data="@(Enum.GetValues(typeof(CompanyCapitalType)).Cast<CompanyCapitalType>())"
                        TData="CompanyCapitalType"
                        TValue="CompanyCapitalType?"
                        @bind-Value="empresa.Capital" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Fecha de Constitución:" ColSpanMd="6">
            <DxDateEdit T="DateTime?" @bind-Date="empresa.FechaConstitucion" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Activa:" ColSpanMd="6">
            <DxCheckBox T="bool" @bind-Checked="empresa.Activa" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Contacto:" ColSpanMd="12">
            <DxTextBox @bind-Text="empresa.Contacto" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Dirección:" ColSpanMd="12">
            <DxMemo @bind-Text="empresa.Direccion" Rows="3" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Teléfonos:" ColSpanMd="6">
            <DxTextBox @bind-Text="empresa.Telefonos" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Email:" ColSpanMd="6">
            <DxTextBox @bind-Text="empresa.Email" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Página Web:" ColSpanMd="12">
            <DxTextBox @bind-Text="empresa.PaginaWeb" />
        </DxFormLayoutItem>

        <DxFormLayoutItem ColSpanMd="12">
            <div class="d-flex justify-content-end">
                <DxButton SubmitFormOnClick="true" 
                          Text="@(isSubmitting ? "Guardando..." : "Guardar")" 
                          Enabled="@(!isSubmitting)"
                          CssClass="mr-2" />
                <DxButton RenderStyle="ButtonRenderStyle.Link" 
                          Text="Cancelar" 
                          Enabled="@(!isSubmitting)"
                          @onclick="() => NavigationManager.NavigateTo(cancelNavigationUrl)" />
            </div>
        </DxFormLayoutItem>
     

        <DxFormLayoutItem Caption="Logo de la Empresa:" ColSpanMd="12">
    <div class="upload-container">
        <div class="logo-upload-wrapper">
            @if (EmpresaId.HasValue)
            {
                <div class="logo-current-container">
                    <div class="position-relative border rounded p-3 bg-white shadow-sm">
                        <img src="@($"/api/contabilidad/empresas/{EmpresaId}/logo")"
                             alt="Logo Actual"
                             class="logo-image"
                             onerror="this.style.display='none'" />
                        
                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-info">
                            Actual
                        </span>
                    </div>
                </div>
            }

            <div class="logo-upload-form">
                <div id="dropZone" class="card custom-drop-zone rounded-3 mb-3">
                    
                    <i class="bi bi-cloud-arrow-up-fill upload-icon"></i> 
                    
                    <span class="drop-file-label">Arrastra y suelta el logo aquí</span>
                    
                    @if (EmpresaId.HasValue)
                    {
                        <span class="drop-file-sublabel">para reemplazar el anterior</span>
                    }
                    else
                    {
                        <span class="drop-file-sublabel">o haz clic en el botón inferior</span>
                    }

                    <DxButton id="selectButton"
                              RenderStyle="ButtonRenderStyle.Primary"
                              RenderStyleMode="ButtonRenderStyleMode.Outline"
                              CssClass="mt-3 px-4 rounded-pill" 
                              Text="Seleccionar Logo" />
                </div>

                <DxUpload UploadUrl="@uploadUrl"
                          AllowedFileExtensions="@(new List<string> { ".png", ".jpg", ".jpeg", ".webp", ".svg" })"
                          MaxFileSize="5242880"
                          ShowFileList="true"
                          AllowMultiFileUpload="false"
                          UploadInputName="logoUpload"
                          ExternalSelectButtonCssSelector="#selectButton"
                          ExternalDropZoneCssSelector="#dropZone"
                          CssClass="mt-2" />

                @if (!string.IsNullOrWhiteSpace(uploadError))
                {
                    <DxAlert AlertType="AlertType.Danger" CssClass="mt-3 shadow-sm">@uploadError</DxAlert>
                }
            </div>
        </div>
    </div>
</DxFormLayoutItem>
    </DxFormLayout>
    @if (!string.IsNullOrWhiteSpace(loadError))
    {
        <DxAlert AlertType="AlertType.Danger" CssClass="mt-2">@loadError</DxAlert>
    }
    <ValidationSummary />
</EditForm>

@code {
    [Parameter]
    public long? EmpresaId { get; set; }

    private CompanyCreationDto empresa = new();
    private string cancelNavigationUrl = "/contabilidad/empresas";
    private string? loadError;
    private string? uploadError;
    private const long MaxLogoSize = 5 * 1024 * 1024; // 5MB
    private bool isSubmitting = false;
    private string uploadUrl => EmpresaId.HasValue 
        ? $"api/contabilidad/empresas/{EmpresaId.Value}/logo" 
        : string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (EmpresaId.HasValue)
        {
            try
            {
                var loadedEmpresa = await EmpresaClient.ObtenerAsync(EmpresaId.Value);
                if (loadedEmpresa != null)
                {
                    empresa = loadedEmpresa;
                }
                else
                {
                    loadError = "La empresa no existe o fue eliminada.";
                    NavigationManager.NavigateTo(cancelNavigationUrl);
                }
            }
            catch (UnauthorizedAccessException)
            {
                NavigationManager.NavigateTo("/Account/Login");
            }
            catch (HttpRequestException ex)
            {
                loadError = ex.Message;
                NavigationManager.NavigateTo(cancelNavigationUrl);
            }
        }
    }

    private async Task HandleValidSubmit()
    {
        if (isSubmitting) return; // Prevenir doble envío
        
        isSubmitting = true;
        uploadError = null;
        loadError = null;
        
        try
        {
            long savedCompanyId;
            
            if (EmpresaId.HasValue)
            {
                await EmpresaClient.ActualizarAsync(EmpresaId.Value, empresa);
                savedCompanyId = EmpresaId.Value;
            }
            else
            {
                var created = await EmpresaClient.CrearAsync(empresa);
                savedCompanyId = created.CompanyId;
            }

            NavigationManager.NavigateTo(cancelNavigationUrl);
        }
        catch (HttpRequestException ex)
        {
            loadError = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
