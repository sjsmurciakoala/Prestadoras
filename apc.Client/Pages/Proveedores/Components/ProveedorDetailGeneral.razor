@using SIAD.Core.DTOs.Proveedores

<DxFormLayout>
    <DxFormLayoutGroup Caption="Datos generales" ColSpanMd="12">
        <DxFormLayoutItem Caption="Codigo">@Proveedor.Codigo</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Nombre">@Proveedor.Nombre</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Razon social">@Proveedor.RazonSocial</DxFormLayoutItem>
        <DxFormLayoutItem Caption="RTN">@Proveedor.Rtn</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Direccion">@Proveedor.Direccion</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Nombre contacto">@Proveedor.NombreContacto</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Telefono">@Proveedor.Telefono</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Fax">@Proveedor.Fax</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Email">@Proveedor.Email</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Pagina web">@Proveedor.PaginaWeb</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Tipo proveedor">@Proveedor.TipoProveedor</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Cuenta contable">@Proveedor.CuentaContable</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Cuenta bancaria">@Proveedor.CuentaBancaria</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Banco 1">@Proveedor.Banco1</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Banco 2">@Proveedor.Banco2</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Fecha creacion">@Proveedor.FechaCreacion.ToString("dd/MM/yyyy")</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Fecha modificacion">@(Proveedor.FechaModificacion?.ToString("dd/MM/yyyy") ?? "-")</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Activo">
            <span>@(Proveedor.Activo ? "Si" : "No")</span>
        </DxFormLayoutItem>
    </DxFormLayoutGroup>

    <DxFormLayoutGroup Caption="Estadisticas" ColSpanMd="12">
        <DxFormLayoutItem Caption="Compras acumuladas">@FormatMonto(Proveedor.ComprasAcum)</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Compras dolares">@FormatMonto(Proveedor.ComprasDolares)</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Saldo anterior">@FormatMonto(Proveedor.SaldoAnterior)</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Saldo anterior dolares">@FormatMonto(Proveedor.SaldoAnteriorDolares)</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Saldo actual">@FormatMonto(Proveedor.SaldoActual)</DxFormLayoutItem>
        <DxFormLayoutItem Caption="Saldo actual dolares">@FormatMonto(Proveedor.SaldoActualDolares)</DxFormLayoutItem>
    </DxFormLayoutGroup>
</DxFormLayout>

@code {
    [Parameter]
    [EditorRequired]
    public ProveedorDetailDto Proveedor { get; set; } = default!;

    private static string FormatMonto(double? value) =>
        value.HasValue ? value.Value.ToString("N2") : "-";
}
