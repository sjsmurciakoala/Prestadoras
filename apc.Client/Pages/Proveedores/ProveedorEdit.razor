@page "/proveedores/nuevo"
@page "/proveedores/{codigo}/editar"
@attribute [Authorize]
@inject ProveedoresClient ProveedoresClient
@inject NavigationManager Navigation
@inject ILogger<ProveedorEdit> Logger
@inject IToastNotificationService ToastService
@using apc.Client.Services.Proveedores
@using Microsoft.AspNetCore.Authorization
@using SIAD.Core.DTOs.Contabilidad
@using SIAD.Core.DTOs.Proveedores

<PageTitle>SIAD - Editar Proveedor</PageTitle>

<div class="page-container">
    <ErrorNotice @ref="errorNotice" />

    <div class="d-flex justify-content-between align-items-center mb-4 header-section">
        <div>
            <h2 class="page-title">@TituloPagina</h2>
            <p class="page-subtitle">@SubtituloPagina</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <DxButton Text="Volver"
                      Click="Volver"
                      IconCssClass="bi bi-arrow-left"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      CssClass="btn-modern" />
        </div>
    </div>

    <div class="modern-card">
        @if (isLoading)
        {
            <DxSkeletonLine />
            <DxSkeletonLine />
            <DxSkeletonLine />
        }
        else
        {
            <ProveedorForm Model="model"
                           Tipos="tipos"
                           Bancos="bancos"
                           CuentasContables="cuentasContables"
                           IsEdit="IsEdit"
                           OnValidSubmit="GuardarAsync"
                           OnInvalidSubmit="MostrarErroresValidacion"
                           OnCancel="Volver"
                           IsBusy="isSaving" />
        }
    </div>
</div>

@code {
    private ErrorNotice errorNotice = default!;

    [Parameter]
    public string? Codigo { get; set; }

    private readonly List<ProveedorTipoLookupDto> tipos = new();
    private readonly List<ProveedorBancoLookupDto> bancos = new();
    private readonly List<CuentaContableLookupDto> cuentasContables = new();
    private ProveedorUpsertDto model = new();
    private bool isLoading = true;
    private bool isSaving;

    private bool IsEdit => !string.IsNullOrWhiteSpace(Codigo);
    private string SubtituloPagina => IsEdit
        ? "Actualice la informacion del proveedor."
        : "Registre un nuevo proveedor.";
    private string TituloPagina
    {
        get
        {
            if (!IsEdit)
            {
                return "Nuevo proveedor";
            }

            var codigoMostrar = string.IsNullOrWhiteSpace(model.Codigo)
                ? Codigo?.Trim()
                : model.Codigo.Trim();

            var nombreMostrar = model.Nombre?.Trim();
            if (string.IsNullOrWhiteSpace(nombreMostrar))
            {
                return $"Editar proveedor {codigoMostrar}";
            }

            return $"Editar proveedor {codigoMostrar} - {nombreMostrar}";
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        await CargarDatosAsync();
    }

    private async Task CargarDatosAsync()
    {
        isLoading = true;

        try
        {
            await Task.WhenAll(
                CargarTiposAsync(),
                CargarBancosAsync(),
                CargarCuentasContablesAsync());
            if (IsEdit)
            {
                await CargarProveedorAsync();
            }
            else
            {
                model = new ProveedorUpsertDto
                {
                    Activo = true,
                    CodTipoProveedor = 0,
                    CuentasBancarias = new List<ProveedorCuentaBancariaDto>
                    {
                        CreateEmptyCuenta(1)
                    }
                };
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions { Title = "Proveedores", Text = $"No se pudo cargar la pantalla: {ex.Message}", RenderStyle = ToastRenderStyle.Danger });
            Logger.LogError(ex, "Error al cargar pantalla de proveedor.");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task CargarTiposAsync()
    {
        var data = await ProveedoresClient.ObtenerTiposAsync();
        tipos.Clear();
        tipos.AddRange(data ?? Array.Empty<ProveedorTipoLookupDto>());
    }

    private async Task CargarCuentasContablesAsync()
    {
        var data = await ProveedoresClient.ObtenerCuentasContablesAsync();
        cuentasContables.Clear();
        cuentasContables.AddRange(data ?? Array.Empty<CuentaContableLookupDto>());
    }

    private async Task CargarBancosAsync()
    {
        var data = await ProveedoresClient.ObtenerBancosAsync();
        bancos.Clear();
        bancos.AddRange((data ?? Array.Empty<ProveedorBancoLookupDto>())
            .Where(x => !string.IsNullOrWhiteSpace(x.Nombre))
            .OrderBy(x => x.Nombre, StringComparer.OrdinalIgnoreCase)
            .Select(x => new ProveedorBancoLookupDto
            {
                Nombre = x.Nombre.Trim()
            }));
    }

    private async Task CargarProveedorAsync()
    {
        var codigo = Codigo?.Trim();
        if (string.IsNullOrWhiteSpace(codigo))
        {
            ToastService.ShowToast(new ToastOptions { Title = "Proveedores", Text = "Codigo invalido.", RenderStyle = ToastRenderStyle.Danger });
            return;
        }

        var detail = await ProveedoresClient.ObtenerPorCodigoAsync(codigo);
        if (detail is null)
        {
            ToastService.ShowToast(new ToastOptions { Title = "Proveedores", Text = $"No se encontro el proveedor {codigo}.", RenderStyle = ToastRenderStyle.Danger });
            return;
        }

        model = new ProveedorUpsertDto
        {
            Codigo = detail.Codigo,
            CodTipoProveedor = detail.CodTipoProveedor > 0 ? detail.CodTipoProveedor : 0,
            Nombre = detail.Nombre,
            RazonSocial = detail.RazonSocial,
            Rtn = detail.Rtn,
            Direccion = detail.Direccion ?? string.Empty,
            NombreContacto = detail.NombreContacto,
            Telefono = detail.Telefono,
            Email = detail.Email,
            CuentaContable = detail.CuentaContable ?? string.Empty,
            CuentasBancarias = detail.CuentasBancarias.Count > 0
                ? detail.CuentasBancarias
                    .OrderBy(x => x.Orden)
                    .Select((x, index) => new ProveedorCuentaBancariaDto
                    {
                        ProveedorCuentaBancariaId = x.ProveedorCuentaBancariaId,
                        Banco = x.Banco,
                        CuentaBancaria = x.CuentaBancaria,
                        Orden = index + 1
                    })
                    .ToList()
                : new List<ProveedorCuentaBancariaDto> { CreateEmptyCuenta(1) },
            Activo = detail.Activo
        };
    }

    private async Task GuardarAsync()
    {
        var validationError = NormalizeCuentaBancarias();
        if (!string.IsNullOrWhiteSpace(validationError))
        {
            errorNotice.Show("Validación", validationError, ToastRenderStyle.Warning);
            return;
        }

        try
        {
            isSaving = true;

            if (IsEdit)
            {
                await ProveedoresClient.ActualizarAsync(model.Codigo, model);
            }
            else
            {
                await ProveedoresClient.CrearAsync(model);
            }

            Navigation.NavigateTo("/proveedores");
        }
        catch (UnauthorizedAccessException)
        {
            errorNotice.ShowError(
                "La sesión expiró. Vuelve a iniciar sesión e inténtalo de nuevo.",
                titulo: "Sesión expirada");
        }
        catch (Exception ex)
        {
            errorNotice.ShowError("No se pudo guardar el proveedor.", ex);
            Logger.LogError(ex, "Error al guardar proveedor {ProveedorCodigo}", model.Codigo);
        }
        finally
        {
            isSaving = false;
        }
    }

    private void MostrarErroresValidacion(IReadOnlyList<string> mensajes)
    {
        var texto = mensajes is { Count: > 0 }
            ? string.Join(Environment.NewLine, mensajes)
            : "Revise los campos obligatorios del formulario.";

        errorNotice.Show("Validación", texto, ToastRenderStyle.Warning);
    }

    private void Volver() => Navigation.NavigateTo("/proveedores");

    private string? NormalizeCuentaBancarias()
    {
        var cuentas = new List<ProveedorCuentaBancariaDto>();
        var source = model.CuentasBancarias ?? new List<ProveedorCuentaBancariaDto>();

        for (var i = 0; i < source.Count; i++)
        {
            var banco = source[i].Banco?.Trim();
            var cuenta = source[i].CuentaBancaria?.Trim();

            if (string.IsNullOrWhiteSpace(banco) && string.IsNullOrWhiteSpace(cuenta))
            {
                continue;
            }

            if (string.IsNullOrWhiteSpace(banco) || string.IsNullOrWhiteSpace(cuenta))
            {
                return $"Complete banco y cuenta bancaria en la fila {i + 1}.";
            }

            cuentas.Add(new ProveedorCuentaBancariaDto
            {
                ProveedorCuentaBancariaId = source[i].ProveedorCuentaBancariaId,
                Banco = banco,
                CuentaBancaria = cuenta,
                Orden = cuentas.Count + 1
            });
        }

        model.CuentasBancarias = cuentas;
        return null;
    }

    private static ProveedorCuentaBancariaDto CreateEmptyCuenta(int orden)
    {
        return new ProveedorCuentaBancariaDto
        {
            Orden = orden
        };
    }
}
