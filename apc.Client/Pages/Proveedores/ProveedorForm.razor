@using SIAD.Core.DTOs.Proveedores
@using SIAD.Core.DTOs.Contabilidad
@using DevExpress.Blazor

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" OnInvalidSubmit="HandleInvalidSubmit" Context="editContext">
    <DataAnnotationsValidator />

    <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
        <DxFormLayoutGroup Caption="Identificacion" ColSpanXs="12">
            <DxFormLayoutItem Caption="Codigo" ColSpanXs="12" ColSpanMd="4">
                <DxTextBox @bind-Text="Model.Codigo"
                           ReadOnly="true"
                           NullText="Autogenerado"
                           MaxLength="20" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Tipo proveedor *" ColSpanXs="12" ColSpanMd="8">
                <DxComboBox TData="ProveedorTipoLookupDto"
                            TValue="int"
                            Data="@TiposConPlaceholder"
                            ValueFieldName="@nameof(ProveedorTipoLookupDto.Id)"
                            TextFieldName="@nameof(ProveedorTipoLookupDto.Nombre)"
                            @bind-Value="Model.CodTipoProveedor"
                            NullText="Seleccionar tipo"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Never"
                            DropDownStyle="DropDownStyle.DropDownList" />
                <ValidationMessage For="() => Model.CodTipoProveedor" />
            </DxFormLayoutItem>
        </DxFormLayoutGroup>

        <DxFormLayoutGroup Caption="Datos generales" ColSpanXs="12">
            <DxFormLayoutItem Caption="Nombre *" ColSpanXs="12" ColSpanMd="6">
                <DxTextBox @bind-Text="Model.Nombre" MaxLength="150" />
                <ValidationMessage For="() => Model.Nombre" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Razon social" ColSpanXs="12" ColSpanMd="6">
                <DxTextBox @bind-Text="Model.RazonSocial" MaxLength="150" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="RTN" ColSpanXs="12" ColSpanMd="4">
                <DxTextBox @bind-Text="Model.Rtn" MaxLength="20" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Direccion *" ColSpanXs="12">
                <DxMemo @bind-Text="Model.Direccion" Rows="2" MaxLength="1000" ResizeMode="MemoResizeMode.Vertical" />
                <ValidationMessage For="() => Model.Direccion" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Activo" ColSpanXs="12" ColSpanMd="4">
                <label class="toggle-switch">
                    <input type="checkbox" @bind="Model.Activo" disabled="@IsBusy" />
                    <span class="toggle-slider"></span>
                </label>
            </DxFormLayoutItem>
        </DxFormLayoutGroup>

        <DxFormLayoutGroup Caption="Contacto" ColSpanXs="12">
            <DxFormLayoutItem Caption="Nombre contacto" ColSpanXs="12" ColSpanMd="4">
                <DxTextBox @bind-Text="Model.NombreContacto" MaxLength="150" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Telefono" ColSpanXs="12" ColSpanMd="4">
                <DxTextBox @bind-Text="Model.Telefono" MaxLength="20" />
            </DxFormLayoutItem>
            <DxFormLayoutItem Caption="Email" ColSpanXs="12" ColSpanMd="4">
                <DxTextBox @bind-Text="Model.Email" MaxLength="150" />
            </DxFormLayoutItem>
        </DxFormLayoutGroup>

        <DxFormLayoutGroup Caption="Finanzas" ColSpanXs="12">
            <DxFormLayoutItem Caption="Cuenta contable *" ColSpanXs="12" ColSpanMd="4">
                <DxComboBox Data="@CuentasContables"
                            TData="CuentaContableLookupDto"
                            TValue="string"
                            @bind-Value="Model.CuentaContable"
                            ValueFieldName="@nameof(CuentaContableLookupDto.Code)"
                            TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                            NullText="Seleccione cuenta contable"
                            AllowUserInput="true"
                            DropDownStyle="DropDownStyle.DropDown"
                            DropDownTriggerMode="DropDownTriggerMode.Input"
                            SearchMode="ListSearchMode.AutoSearch"
                            SearchFilterCondition="ListSearchFilterCondition.Contains"
                            SearchDelay="200"
                            ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                            Enabled="@(CuentasContables.Count > 0)" />
                <ValidationMessage For="() => Model.CuentaContable" />
            </DxFormLayoutItem>
        </DxFormLayoutGroup>

        <DxFormLayoutGroup Caption="Cuentas bancarias" ColSpanXs="12">
            <DxFormLayoutItem ColSpanXs="12">
                <DxGrid @key="@Model.CuentasBancarias.Count"
                        Data="@Model.CuentasBancarias"
                        ShowFilterRow="false"
                        ShowGroupPanel="false"
                        PageSize="10"
                        CssClass="grid-modern">
                    <Columns>
                        <DxGridDataColumn FieldName="@nameof(ProveedorCuentaBancariaDto.Banco)" Caption="Banco">
                            <CellDisplayTemplate Context="cell">
                                @if (cell.DataItem is ProveedorCuentaBancariaDto item)
                                {
                                    <DxComboBox Data="@Bancos"
                                                TData="ProveedorBancoLookupDto"
                                                TValue="string"
                                                @bind-Value="item.Banco"
                                                ValueFieldName="@nameof(ProveedorBancoLookupDto.Nombre)"
                                                TextFieldName="@nameof(ProveedorBancoLookupDto.Nombre)"
                                                NullText="Seleccione o escriba banco"
                                                AllowUserInput="true"
                                                DropDownStyle="DropDownStyle.DropDown"
                                                DropDownTriggerMode="DropDownTriggerMode.Input"
                                                SearchMode="ListSearchMode.AutoSearch"
                                                SearchFilterCondition="ListSearchFilterCondition.Contains"
                                                SearchDelay="200"
                                                ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                Enabled="@(!IsBusy)" />
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn FieldName="@nameof(ProveedorCuentaBancariaDto.CuentaBancaria)" Caption="Cuenta bancaria">
                            <CellDisplayTemplate Context="cell">
                                @if (cell.DataItem is ProveedorCuentaBancariaDto item)
                                {
                                    <DxTextBox @bind-Text="item.CuentaBancaria"
                                               MaxLength="50"
                                               Enabled="@(!IsBusy)" />
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                        <DxGridDataColumn Caption="" Width="80px">
                            <CellDisplayTemplate Context="cell">
                                @if (cell.DataItem is ProveedorCuentaBancariaDto item)
                                {
                                    <button class="btn-icon btn-delete"
                                            title="Quitar"
                                            @onclick="() => RemoveCuenta(Model.CuentasBancarias.IndexOf(item))"
                                            disabled="@IsBusy">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </CellDisplayTemplate>
                        </DxGridDataColumn>
                    </Columns>
                </DxGrid>

                <div class="mt-2">
                    <DxButton Text="Agregar cuenta"
                              IconCssClass="bi bi-plus-lg"
                              Enabled="@(!IsBusy)"
                              Click="AddCuenta" />
                </div>
            </DxFormLayoutItem>
        </DxFormLayoutGroup>
    </DxFormLayout>

    <div class="d-flex justify-content-end">
        <DxButton SubmitFormOnClick="true"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  Enabled="@(!IsBusy)" />
        <DxButton ButtonType="ButtonType.Normal"
                  CssClass="ms-2"
                  Text="Cancelar"
                  Enabled="@(!IsBusy)"
                  Click="Cancel" />
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public ProveedorUpsertDto Model { get; set; } = default!;

    [Parameter]
    public IEnumerable<ProveedorTipoLookupDto> Tipos { get; set; } = Array.Empty<ProveedorTipoLookupDto>();

    [Parameter]
    public IReadOnlyList<ProveedorBancoLookupDto> Bancos { get; set; } = Array.Empty<ProveedorBancoLookupDto>();

    [Parameter]
    public IReadOnlyList<CuentaContableLookupDto> CuentasContables { get; set; } = Array.Empty<CuentaContableLookupDto>();

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback<IReadOnlyList<string>> OnInvalidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public bool IsEdit { get; set; }

    private IReadOnlyList<ProveedorTipoLookupDto> TiposConPlaceholder =>
        new[] { new ProveedorTipoLookupDto(0, "Seleccionar tipo") }
            .Concat(Tipos.Where(t => t.Id > 0))
            .ToList();

    protected override void OnParametersSet()
    {
        if (Model.CuentasBancarias.Count == 0)
        {
            AddCuenta();
        }
    }

    private async Task HandleValidSubmit()
    {
        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }

    private async Task HandleInvalidSubmit(EditContext context)
    {
        if (OnInvalidSubmit.HasDelegate)
        {
            var mensajes = context.GetValidationMessages()
                .Distinct(StringComparer.OrdinalIgnoreCase)
                .ToList();
            await OnInvalidSubmit.InvokeAsync(mensajes);
        }
    }

    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }

    private void AddCuenta()
    {
        Model.CuentasBancarias.Add(new ProveedorCuentaBancariaDto
        {
            Orden = Model.CuentasBancarias.Count + 1
        });
    }

    private void RemoveCuenta(int index)
    {
        if (index < 0 || index >= Model.CuentasBancarias.Count)
        {
            return;
        }

        Model.CuentasBancarias.RemoveAt(index);

        for (var i = 0; i < Model.CuentasBancarias.Count; i++)
        {
            Model.CuentasBancarias[i].Orden = i + 1;
        }
    }
}

