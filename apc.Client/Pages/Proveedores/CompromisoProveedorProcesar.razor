@page "/proveedores/compromisos-proveedor/{NumeroOrden:int}/procesar"
@attribute [Authorize(Policy = AuthorizationPolicies.Contabilidad)]

@using DevExpress.Blazor
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Authorization
@using SIAD.Core.Constants
@using SIAD.Core.DTOs.Contabilidad
@using SIAD.Core.DTOs.Presupuesto
@using apc.Client.Services.Contabilidad
@using apc.Client.Services.Presupuesto

@using Microsoft.JSInterop

@inject OrdenesPagoDirectoClient OrdenesPagoDirectoClient
@inject AccountFormatState AccountFormat
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject ILogger<CompromisoProveedorProcesar> Logger
@inject IToastNotificationService ToastService

<PageTitle>SIAD - Procesar Compromiso</PageTitle>

<div class="page-container">
    <DxToastProvider Name="CompromisoProveedorProcesarToast" MaxToastCount="4" />
    <ErrorNotice @ref="errorNotice" />

    <div class="d-flex justify-content-between align-items-center mb-4 header-section">
        <div>
            <h2 class="page-title">Procesar compromiso de proveedor</h2>
            <p class="page-subtitle">@SubtituloPagina</p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            @if (CanReturnToOrigin)
            {
                <DxButton Text="Volver al origen"
                          IconCssClass="bi bi-arrow-left-circle"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          CssClass="btn-modern shadow-sm"
                          Click="VolverAlOrigen" />
            }
            <DxButton Text="Volver"
                      IconCssClass="bi bi-arrow-left"
                      RenderStyle="ButtonRenderStyle.Secondary"
                      CssClass="btn-modern shadow-sm"
                      Click="Volver" />
            <DxButton Text="@(isProcessing ? "Emitiendo pago..." : "Emitir pago")"
                      IconCssClass="bi bi-check2-circle"
                      RenderStyle="ButtonRenderStyle.Success"
                      CssClass="btn-modern shadow-sm"
                      Click="ProcesarAsync"
                      Enabled="@CanProcess" />
        </div>
    </div>

    @if (isLoading)
    {
        <div class="modern-card">
            <DxSkeletonLine />
            <DxSkeletonLine />
            <DxSkeletonLine />
        </div>
    }
    else if (ordenDetalle is null)
    {
        <div class="alert alert-warning" role="alert">No se encontro el compromiso solicitado.</div>
    }
    else
    {
        <div class="summary-strip mb-3">
            <div class="summary-card">
                <div class="summary-label">Compromiso</div>
                <div class="summary-value">@ordenDetalle.NumeroOrden</div>
            </div>
            <div class="summary-card">
                <div class="summary-label">Proveedor</div>
                <div class="summary-value">@ProveedorResumenTexto</div>
            </div>
            <div class="summary-card">
                <div class="summary-label">Monto</div>
                <div class="summary-value">@ordenDetalle.Monto.ToString("N2")</div>
            </div>
            <div class="summary-card">
                <div class="summary-label">Estado</div>
                <div class="summary-value">
                    <span class="badge-status @(ordenDetalle.Procesada ? "inactive" : "active")">
                        @(ordenDetalle.Procesada ? "Procesada" : "Pendiente")
                    </span>
                </div>
            </div>
        </div>

        <div class="modern-card mb-3">
            <div class="d-flex justify-content-between align-items-center gap-2 mb-3 section-header">
                <div>
                    <h5 class="mb-0">Detalle del compromiso</h5>
                    <small class="text-muted">Informacion base del compromiso antes de generar la partida.</small>
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <span class="summary-pill">Lineas: <strong>@ordenDetalle.Detalles.Count</strong></span>
                    <span class="summary-pill">Cuenta de servicio: <strong>@FormatCuentaOrDash(ordenDetalle.CuentaContable)</strong></span>
                </div>
            </div>

            @if (ordenDetalle.Detalles.Count == 0)
            {
                <div class="alert alert-warning" role="alert">
                    El compromiso no tiene lineas presupuestarias asociadas.
                </div>
            }
            else
            {
                <div class="grid-wrapper">
                    <DxGrid Data="@ordenDetalle.Detalles"
                            TData="OrdenPagoDirectoDetalleLineaDto"
                            PageSize="10"
                            ShowFilterRow="false"
                            ShowSearchBox="false"
                            ShowGroupPanel="false"
                            SizeMode="SizeMode.Large"
                            CssClass="grid-modern">
                        <Columns>
                            <DxGridDataColumn Caption="Fecha"
                                              Width="130px">
                                <CellDisplayTemplate>
                                    @GetFechaTexto(ordenDetalle.FechaCompromiso)
                                </CellDisplayTemplate>
                            </DxGridDataColumn>
                            <DxGridDataColumn FieldName="@nameof(OrdenPagoDirectoDetalleLineaDto.CuentaContable)"
                                              Caption="Cuenta de gasto"
                                              Width="160px">
                                <CellDisplayTemplate Context="cell">
                                    @FormatCuentaOrDash(((OrdenPagoDirectoDetalleLineaDto)cell.DataItem).CuentaContable)
                                </CellDisplayTemplate>
                            </DxGridDataColumn>
                            <DxGridDataColumn FieldName="@nameof(OrdenPagoDirectoDetalleLineaDto.Descripcion)"
                                              Caption="Descripcion"
                                              MinWidth="220" />
                            <DxGridDataColumn FieldName="@nameof(OrdenPagoDirectoDetalleLineaDto.Monto)"
                                              Caption="Monto"
                                              Width="140px"
                                              DisplayFormat="N2"
                                              TextAlignment="GridTextAlignment.Right" />
                        </Columns>
                    </DxGrid>
                </div>
            }
        </div>

        @if (ordenDetalle.Procesada)
        {
            <div class="alert alert-warning" role="alert">
                Este compromiso ya fue procesado. Se muestra solo en modo consulta.
            </div>
        }
        else
        {
            <div class="modern-card mb-3">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-3 section-header">
                    <div>
                        <h5 class="mb-0">Medio de pago</h5>
                        <small class="text-muted">Seleccione la cuenta bancaria de origen y el metodo de pago del compromiso.</small>
                    </div>
                </div>

                @if (cuentasBanco.Count == 0)
                {
                    <div class="alert alert-warning mb-0" role="alert">
                        No hay cuentas bancarias configuradas en el modulo de Bancos.
                    </div>
                }
                else
                {
                    <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                        <DxFormLayoutItem Caption="Cuenta de banco" ColSpanMd="6">
                            <DxComboBox Data="@cuentasBanco"
                                        TData="CuentaContableLookupDto"
                                        TValue="long?"
                                        Value="@bancoCuentaSeleccionadaId"
                                        ValueChanged="@OnBancoCuentaChanged"
                                        ValueFieldName="@nameof(CuentaContableLookupDto.BancoCuentaId)"
                                        TextFieldName="@nameof(CuentaContableLookupDto.Display)"
                                        NullText="Seleccione la cuenta de banco"
                                        SearchMode="ListSearchMode.AutoSearch"
                                        SearchFilterCondition="ListSearchFilterCondition.Contains"
                                        SearchDelay="200"
                                        DropDownStyle="DropDownStyle.DropDown"
                                        DropDownTriggerMode="DropDownTriggerMode.Input"
                                        AllowUserInput="true"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                        ValidationEnabled="false"
                                        Enabled="@(!isProcessing)" />
                        </DxFormLayoutItem>
                        <DxFormLayoutItem Caption="Metodo de pago" ColSpanMd="6">
                            <DxComboBox Data="@MediosDisponibles"
                                        TData="MetodoPagoOption"
                                        TValue="string"
                                        @bind-Value="metodoPagoSeleccionado"
                                        ValueFieldName="@nameof(MetodoPagoOption.Valor)"
                                        TextFieldName="@nameof(MetodoPagoOption.Texto)"
                                        NullText="Seleccione el metodo"
                                        DropDownStyle="DropDownStyle.DropDownList"
                                        ValidationEnabled="false"
                                        Enabled="@(!isProcessing && bancoCuentaSeleccionadaId.HasValue)" />
                        </DxFormLayoutItem>
                    </DxFormLayout>

                    @if (CuentaBancoSeleccionada is not null)
                    {
                        <div class="text-muted mt-2">
                            Tipo de cuenta: <strong>@(GetTextOrDash(CuentaBancoSeleccionada.TipoCuenta))</strong>
                            @if (!EsCuentaCheque)
                            {
                                <span>&nbsp;&middot; Cuenta de ahorro: solo permite transferencia.</span>
                            }
                        </div>
                    }
                }
            </div>

            <div class="modern-card mb-3">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-3 section-header">
                    <div>
                        <h5 class="mb-0">Retenciones y deducciones</h5>
                        <small class="text-muted">Cargue las retenciones u otras deducciones que afectan el neto a pagar por banco.</small>
                    </div>
                    <DxButton Text="Agregar deduccion"
                              IconCssClass="bi bi-plus"
                              RenderStyle="ButtonRenderStyle.Secondary"
                              CssClass="btn-modern shadow-sm"
                              SizeMode="SizeMode.Small"
                              Click="AgregarDeduccion"
                              Enabled="@(!isProcessing)" />
                </div>

                @if (deducciones.Count == 0)
                {
                    <div class="text-muted small mb-0">No hay deducciones cargadas. El pago se procesara por el monto bruto del compromiso.</div>
                }
                else
                {
                    <div class="table-responsive detail-table mb-3">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th style="min-width:260px;">Cuenta</th>
                                    <th style="min-width:180px;">Descripcion</th>
                                    <th style="min-width:120px;">Debe</th>
                                    <th style="min-width:120px;">Haber</th>
                                    <th style="width:60px;" class="text-center">Quitar</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var deduccion in deducciones)
                                {
                                    <tr>
                                        <td>
                                            <DxComboBox Data="@cuentasContables"
                                                        TData="CuentaContableLookupDto"
                                                        TValue="long?"
                                                        Value="@deduccion.CuentaId"
                                                        ValueChanged="@((long? v) => deduccion.CuentaId = v)"
                                                        ValueFieldName="@nameof(CuentaContableLookupDto.AccountId)"
                                                        TextFieldName="@nameof(CuentaContableLookupDto.DisplayText)"
                                                        NullText="Seleccione la cuenta"
                                                        SearchMode="ListSearchMode.AutoSearch"
                                                        SearchFilterCondition="ListSearchFilterCondition.Contains"
                                                        SearchDelay="200"
                                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                                        ValidationEnabled="false"
                                                        SizeMode="SizeMode.Small"
                                                        Enabled="@(!isProcessing)" />
                                        </td>
                                        <td>
                                            <DxTextBox @bind-Text="deduccion.Descripcion"
                                                       NullText="Descripcion"
                                                       SizeMode="SizeMode.Small"
                                                       Enabled="@(!isProcessing)" />
                                        </td>
                                        <td>
                                            <DxSpinEdit T="decimal"
                                                        @bind-Value="deduccion.Debe"
                                                        MinValue="0"
                                                        Increment="0.01m"
                                                        SizeMode="SizeMode.Small"
                                                        Enabled="@(!isProcessing)" />
                                        </td>
                                        <td>
                                            <DxSpinEdit T="decimal"
                                                        @bind-Value="deduccion.Haber"
                                                        MinValue="0"
                                                        Increment="0.01m"
                                                        SizeMode="SizeMode.Small"
                                                        Enabled="@(!isProcessing)" />
                                        </td>
                                        <td class="text-center">
                                            <button type="button"
                                                    class="btn-icon btn-delete"
                                                    title="Quitar deduccion"
                                                    disabled="@isProcessing"
                                                    @onclick="@(() => EliminarDeduccion(deduccion))">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                    @if (FilaTieneAmbosMontos(deduccion))
                                    {
                                        <tr>
                                            <td colspan="5" class="text-danger small py-1">
                                                Esta fila no puede tener Debe y Haber a la vez. Deje solo uno de los dos en cero.
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-flex justify-content-end gap-2 flex-wrap mb-0">
                        <span class="summary-pill">Debe deducciones: <strong>@TotalDeduccionDebe.ToString("N2")</strong></span>
                        <span class="summary-pill">Haber deducciones: <strong>@TotalDeduccionHaber.ToString("N2")</strong></span>
                        <span class="summary-pill">Neto a pagar por banco: <strong>@NetoBanco.ToString("N2")</strong></span>
                    </div>

                    @if (NetoBanco <= 0m)
                    {
                        <div class="alert alert-warning mt-2 mb-0" role="alert">
                            El neto a pagar por banco debe ser mayor a cero. Revise las deducciones cargadas.
                        </div>
                    }
                }
            </div>

            <div class="modern-card">
                <div class="d-flex justify-content-between align-items-center gap-2 mb-3 section-header">
                    <div>
                        <h5 class="mb-0">Partida contable del compromiso a procesar</h5>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="summary-pill">Debito: <strong>@TotalDebitoTexto</strong></span>
                        <span class="summary-pill">Credito: <strong>@TotalCreditoTexto</strong></span>
                    </div>
                </div>

                @if (!TieneCuentaProveedorDisponible)
                {
                    <div class="alert alert-warning mb-3" role="alert">
                        El proveedor no tiene una cuenta contable valida configurada. No se puede procesar el compromiso.
                    </div>
                }

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
                    <span class="text-muted">Vista previa de la partida contable que se generara al procesar el pago.</span>
                </div>

                @if (PartidaNoCuadra)
                {
                    <div class="alert alert-warning mb-3" role="alert">
                        Precaucion: @PartidaNoCuadraMensaje
                    </div>
                }

                @{ var previewLineas = LineasPartida; }
                <div class="table-responsive detail-table mb-3">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="min-width:280px;">Cuenta</th>
                                <th style="min-width:200px;">Descripcion</th>
                                <th style="min-width:110px;">Debito</th>
                                <th style="min-width:110px;">Credito</th>
                            </tr>
                        </thead>
                        <tbody>
                            @for (var i = 0; i < previewLineas.Count; i++)
                            {
                                var rowIndex = i;
                                var linea = previewLineas[rowIndex];
                                var esLineaProveedor = IsProviderLine(rowIndex, previewLineas.Count);
                                var cuentaDisplay = ResolveLineaCuentaDisplay(linea, esLineaProveedor);
                                <tr>
                                    <td>
                                        <div class="d-flex flex-column">
                                            <span class="fw-semibold">@cuentaDisplay.Codigo</span>
                                            <small class="text-muted">@cuentaDisplay.Nombre</small>
                                        </div>
                                    </td>
                                    <td>@GetTextOrDash(linea.Descripcion)</td>
                                    <td class="text-end">@linea.Debito.ToString("N2")</td>
                                    <td class="text-end">@linea.Credito.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="fw-semibold">
                                <td colspan="2" class="text-end">Totales</td>
                                <td class="text-end">@TotalDebitoTexto</td>
                                <td class="text-end">@TotalCreditoTexto</td>
                            </tr>
                            @if (PartidaNoCuadra)
                            {
                                <tr class="partida-no-cuadra-message">
                                    <td colspan="4">@PartidaNoCuadraMensaje</td>
                                </tr>
                            }
                        </tfoot>
                    </table>
                </div>

                <div class="total-bar">
                    <div class="text-muted">
                        Usuario: <strong>@UsuarioActualTexto</strong>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        <DxButton Text="Cancelar"
                                  RenderStyle="ButtonRenderStyle.Secondary"
                                  CssClass="btn-modern shadow-sm"
                                  Click="Volver"
                                  Enabled="@(!isProcessing)" />
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public int NumeroOrden { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery(Name = "originUrl")]
    public string? OriginUrlQuery { get; set; }

    private readonly List<CuentaContableLookupDto> cuentasContables = new();
    private readonly List<CuentaContableLookupDto> cuentasBanco = new();
    private readonly List<DeduccionLinea> deducciones = new();

    private OrdenPagoDirectoDetalleDto? ordenDetalle;
    private long? cuentaProveedorId;
    private long? bancoCuentaSeleccionadaId;
    private string? metodoPagoSeleccionado;
    private bool isLoading = true;
    private bool isProcessing;
    private ErrorNotice errorNotice = default!;
    private readonly List<string> validationMessages = new();
    private string usuarioActual = "SISTEMA";

    // Vista previa de la partida (banco + deducciones + proveedor). Se recalcula en cada acceso a partir
    // del bruto, la cuenta de banco elegida y las deducciones cargadas: banco/proveedor NUNCA se editan
    // directamente, asi que no hace falta sincronizar un estado mutable aparte.
    private List<PartidaLineaOrdenPagoDto> LineasPartida
    {
        get
        {
            var lineas = new List<PartidaLineaOrdenPagoDto>();
            if (ordenDetalle is null || ordenDetalle.Procesada)
            {
                return lineas;
            }

            var cuentaBanco = CuentaBancoSeleccionada;
            lineas.Add(new PartidaLineaOrdenPagoDto
            {
                CuentaId = cuentaBanco?.AccountId ?? 0,
                BancoCuentaId = cuentaBanco?.BancoCuentaId,
                Descripcion = ordenDetalle.Concepto,
                Debito = 0m,
                Credito = NetoBanco
            });

            foreach (var deduccion in deducciones)
            {
                lineas.Add(new PartidaLineaOrdenPagoDto
                {
                    CuentaId = deduccion.CuentaId ?? 0,
                    Descripcion = string.IsNullOrWhiteSpace(deduccion.Descripcion) ? ordenDetalle.Concepto : deduccion.Descripcion.Trim(),
                    Debito = deduccion.Debe,
                    Credito = deduccion.Haber
                });
            }

            lineas.Add(new PartidaLineaOrdenPagoDto
            {
                CuentaId = cuentaProveedorId ?? 0,
                Descripcion = ordenDetalle.Concepto,
                Debito = ordenDetalle.Monto,
                Credito = 0m
            });

            return lineas;
        }
    }

    private decimal Bruto => ordenDetalle?.Monto ?? 0m;
    private decimal TotalDeduccionDebe => deducciones.Sum(x => x.Debe);
    private decimal TotalDeduccionHaber => deducciones.Sum(x => x.Haber);

    // neto = bruto + Sum(Debe deduccion) - Sum(Haber deduccion). Es el HABER que se le asienta al banco.
    private decimal NetoBanco => Bruto + TotalDeduccionDebe - TotalDeduccionHaber;

    private decimal TotalDebito => LineasPartida.Sum(x => x.Debito);
    private decimal TotalCredito => LineasPartida.Sum(x => x.Credito);
    private string TotalDebitoTexto => TotalDebito.ToString("N2");
    private string TotalCreditoTexto => TotalCredito.ToString("N2");
    private bool PartidaNoCuadra => Math.Abs(TotalDebito - TotalCredito) > 0.01m;
    private string PartidaNoCuadraMensaje => $"La partida contable no cuadra. Debito: {TotalDebito:N2}, Credito: {TotalCredito:N2}.";
    private string SubtituloPagina => "Genere la partida contable y cierre el compromiso seleccionado.";
    private string UsuarioActualTexto => string.IsNullOrWhiteSpace(usuarioActual) ? "SISTEMA" : usuarioActual;
    private bool TieneCuentaProveedorDisponible => cuentaProveedorId.HasValue && cuentaProveedorId.Value > 0;
    private int ContraLineCount => LineasPartida.Count > 0 ? LineasPartida.Count - 1 : 0;
    private string CuentaProveedorCodigoTexto => FormatCuentaOrDash(ordenDetalle?.CuentaContableProveedor);
    private string CuentaProveedorNombreTexto => GetCuentaNombre(cuentaProveedorId);
    private string ProveedorResumenTexto => BuildProveedorResumenTexto();

    private CuentaContableLookupDto? CuentaBancoSeleccionada =>
        cuentasBanco.FirstOrDefault(c => c.BancoCuentaId == bancoCuentaSeleccionadaId);

    private bool EsCuentaCheque
    {
        get
        {
            var tipoCuenta = CuentaBancoSeleccionada?.TipoCuenta;
            return !string.IsNullOrWhiteSpace(tipoCuenta) &&
                   tipoCuenta.Contains("CHEQ", StringComparison.OrdinalIgnoreCase);
        }
    }

    // Una cuenta de ahorro (u otro tipo distinto de cheques) solo admite transferencia;
    // una cuenta de cheques admite cheque o transferencia. Sin cuenta elegida, no hay medios.
    private List<MetodoPagoOption> MediosDisponibles
    {
        get
        {
            if (CuentaBancoSeleccionada is null)
            {
                return new List<MetodoPagoOption>();
            }

            return EsCuentaCheque
                ? new List<MetodoPagoOption>
                  {
                      new(OrdenPagoDirectoMetodoPago.Cheque, "Cheque"),
                      new(OrdenPagoDirectoMetodoPago.Transferencia, "Transferencia"),
                  }
                : new List<MetodoPagoOption>
                  {
                      new(OrdenPagoDirectoMetodoPago.Transferencia, "Transferencia"),
                  };
        }
    }

    private string BancoCuentaCodigoTexto => CuentaBancoSeleccionada is not null
        ? FormatCuentaOrDash(CuentaBancoSeleccionada.Code)
        : "-";

    private string BancoCuentaNombreTexto => CuentaBancoSeleccionada is not null
        ? GetTextOrDash(CuentaBancoSeleccionada.Description)
        : "Seleccione una cuenta de banco";

    private bool CanProcess => !isLoading &&
                               !isProcessing &&
                               ordenDetalle is not null &&
                               !ordenDetalle.Procesada &&
                               TieneCuentaProveedorDisponible &&
                               ContraLineCount > 0 &&
                               bancoCuentaSeleccionadaId.HasValue &&
                               !string.IsNullOrWhiteSpace(metodoPagoSeleccionado);
    private bool CanReturnToOrigin => GetOriginUrl() is not null;

    protected override async Task OnParametersSetAsync()
    {
        await CargarAsync();
    }

    private async Task CargarAsync()
    {
        isLoading = true;
        validationMessages.Clear();
        ordenDetalle = null;
        deducciones.Clear();
        cuentaProveedorId = null;
        bancoCuentaSeleccionadaId = null;
        metodoPagoSeleccionado = null;

        try
        {
            await AccountFormat.EnsureLoadedAsync();

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            usuarioActual = authState.User.Identity?.Name ?? "SISTEMA";

            var ordenTask = OrdenesPagoDirectoClient.GetByNumeroOrdenAsync(NumeroOrden);
            var cuentasContablesTask = OrdenesPagoDirectoClient.GetCuentasContablesAsync();
            var cuentasBancoTask = OrdenesPagoDirectoClient.GetCuentasContraProcesamientoAsync();
            await Task.WhenAll(ordenTask, cuentasContablesTask, cuentasBancoTask);

            ordenDetalle = await ordenTask;
            var cuentasPlan = await cuentasContablesTask;
            var cuentasBancoDisponibles = await cuentasBancoTask;

            cuentasContables.Clear();
            cuentasContables.AddRange(cuentasPlan);

            cuentasBanco.Clear();
            cuentasBanco.AddRange(cuentasBancoDisponibles);

            if (ordenDetalle is null)
            {
                ShowToast("Procesar compromiso", $"No se encontro el compromiso {NumeroOrden}.", ToastRenderStyle.Danger);
                return;
            }

            cuentaProveedorId = ResolveCuentaProveedorId(ordenDetalle.CuentaContableProveedor);
        }
        catch (Exception ex)
        {
            ShowToast("Procesar compromiso", "No se pudo cargar la pantalla de proceso.", ToastRenderStyle.Danger);
            Logger.LogError(ex, "Error al cargar pantalla de proceso para compromiso {NumeroOrden}", NumeroOrden);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OnBancoCuentaChanged(long? value)
    {
        bancoCuentaSeleccionadaId = value;

        var mediosDisponibles = MediosDisponibles;
        if (metodoPagoSeleccionado is null || !mediosDisponibles.Any(m => m.Valor == metodoPagoSeleccionado))
        {
            metodoPagoSeleccionado = mediosDisponibles.Count > 0 ? mediosDisponibles[0].Valor : null;
        }
    }

    private void AgregarDeduccion()
    {
        deducciones.Add(new DeduccionLinea());
    }

    private void EliminarDeduccion(DeduccionLinea deduccion)
    {
        deducciones.Remove(deduccion);
    }

    private static bool FilaTieneAmbosMontos(DeduccionLinea deduccion)
        => deduccion.Debe > 0m && deduccion.Haber > 0m;

    private async Task ProcesarAsync()
    {
        if (ordenDetalle is null || ordenDetalle.Procesada)
        {
            return;
        }

        validationMessages.Clear();

        if (!ValidarPartida())
        {
            ShowToast("Validacion", BuildValidationToastMessage(), ToastRenderStyle.Warning);
            return;
        }

        try
        {
            isProcessing = true;

            // Modelo GENERAL (retenciones/deducciones): el DTO trae solo las lineas NO-proveedor, cada
            // una con su Debito/Credito real. El backend agrega la linea del proveedor automaticamente
            // (Debe = bruto) y valida el cuadre. La linea de banco va al Haber por el NETO ya calculado.
            var dto = new ProcesarOrdenPagoDirectoDto
            {
                Usuario = UsuarioActualTexto,
                MetodoPago = metodoPagoSeleccionado!,
                Lineas = new List<PartidaLineaOrdenPagoDto>
                {
                    new()
                    {
                        CuentaId = CuentaBancoSeleccionada!.AccountId,
                        BancoCuentaId = CuentaBancoSeleccionada.BancoCuentaId,
                        Descripcion = ordenDetalle!.Concepto,
                        Debito = 0m,
                        Credito = NetoBanco
                    }
                }
            };

            foreach (var deduccion in deducciones)
            {
                dto.Lineas.Add(new PartidaLineaOrdenPagoDto
                {
                    CuentaId = deduccion.CuentaId ?? 0,
                    Descripcion = string.IsNullOrWhiteSpace(deduccion.Descripcion) ? ordenDetalle.Concepto : deduccion.Descripcion.Trim(),
                    Debito = deduccion.Debe,
                    Credito = deduccion.Haber
                });
            }

            var result = await OrdenesPagoDirectoClient.ProcesarAsync(NumeroOrden, dto);
            if (!result.Success)
            {
                ShowToast("Procesar compromiso", result.Message, ToastRenderStyle.Danger);
                return;
            }

            ShowToast("Exito", result.Message, ToastRenderStyle.Success);
            await JS.InvokeVoidAsync("open", OrdenesPagoDirectoClient.GetPdfUrl(NumeroOrden), "_blank");
            Navigation.NavigateTo(GetReturnUrl(), true);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error al procesar compromiso {NumeroOrden}", NumeroOrden);
            errorNotice.ShowError("No se pudo procesar el compromiso.", ex);
        }
        finally
        {
            isProcessing = false;
        }
    }

    private void Volver()
    {
        Navigation.NavigateTo(GetReturnUrl(), true);
    }

    private void VolverAlOrigen()
    {
        var originUrl = GetOriginUrl();
        if (string.IsNullOrWhiteSpace(originUrl))
        {
            return;
        }

        Navigation.NavigateTo(originUrl, true);
    }

    // Modelo de 2 lineas (una sola cuenta de banco de origen fija por el monto total del compromiso):
    // valida banco+metodo seleccionados, que la cuenta de origen exista y no coincida con la del
    // proveedor, y el cuadre Debe==Haber de la vista previa (ya no distribuye por fila).
    private bool ValidarPartida()
    {
        if (!TieneCuentaProveedorDisponible)
        {
            validationMessages.Add("El proveedor no tiene una cuenta contable valida configurada.");
        }

        if (!bancoCuentaSeleccionadaId.HasValue)
        {
            validationMessages.Add("Debe seleccionar la cuenta de banco de origen del pago.");
        }
        else if (CuentaBancoSeleccionada is null || CuentaBancoSeleccionada.AccountId <= 0)
        {
            validationMessages.Add("La cuenta de banco seleccionada no es valida.");
        }
        else if (cuentaProveedorId.HasValue && CuentaBancoSeleccionada.AccountId == cuentaProveedorId.Value)
        {
            validationMessages.Add("La cuenta de banco de origen no puede ser la misma cuenta contable del proveedor.");
        }

        if (string.IsNullOrWhiteSpace(metodoPagoSeleccionado))
        {
            validationMessages.Add("Debe seleccionar el metodo de pago.");
        }

        if (ordenDetalle is not null && ordenDetalle.Monto <= 0m)
        {
            validationMessages.Add("El compromiso no tiene un monto valido para generar la partida.");
        }

        for (var i = 0; i < deducciones.Count; i++)
        {
            var deduccion = deducciones[i];
            var fila = i + 1;

            if (!deduccion.CuentaId.HasValue || deduccion.CuentaId.Value <= 0)
            {
                validationMessages.Add($"La deduccion de la fila {fila} debe tener una cuenta contable seleccionada.");
                continue;
            }

            var tieneDebe = deduccion.Debe > 0m;
            var tieneHaber = deduccion.Haber > 0m;
            if (tieneDebe == tieneHaber)
            {
                validationMessages.Add($"La deduccion de la fila {fila} debe tener Debe o Haber (uno solo, mayor a cero).");
            }
        }

        if (NetoBanco <= 0m)
        {
            validationMessages.Add("El neto a pagar por banco debe ser mayor a cero. Revise las deducciones cargadas.");
        }

        if (PartidaNoCuadra)
        {
            validationMessages.Add(PartidaNoCuadraMensaje);
        }

        return validationMessages.Count == 0;
    }

    private bool IsProviderLine(int rowIndex, int totalLineas)
    {
        return rowIndex >= 0 &&
               totalLineas > 0 &&
               rowIndex == totalLineas - 1;
    }

    private (string Codigo, string Nombre) ResolveLineaCuentaDisplay(PartidaLineaOrdenPagoDto linea, bool esProveedor)
    {
        if (esProveedor)
        {
            return (CuentaProveedorCodigoTexto, CuentaProveedorNombreTexto);
        }

        var cuenta = cuentasContables.FirstOrDefault(c => c.AccountId == linea.CuentaId);
        return cuenta is not null
            ? (FormatCuentaOrDash(cuenta.Code), GetTextOrDash(cuenta.Description))
            : ("-", "Seleccione una cuenta");
    }

    private long? ResolveCuentaProveedorId(string? cuentaContable)
    {
        if (string.IsNullOrWhiteSpace(cuentaContable))
        {
            return null;
        }

        var cuenta = cuentasContables.FirstOrDefault(c =>
            c.Code.Trim().Equals(cuentaContable.Trim(), StringComparison.OrdinalIgnoreCase));

        return cuenta?.AccountId;
    }

    private string BuildCuentaDisplay(long? cuentaId, string? fallbackCode)
    {
        var cuenta = cuentasContables.FirstOrDefault(c => c.AccountId == cuentaId);
        if (cuenta is not null)
        {
            return cuenta.Display;
        }

        return FormatCuentaOrDash(fallbackCode);
    }

    private string FormatCuentaOrDash(string? cuenta)
    {
        var formatted = AccountFormat.Format(cuenta);
        return string.IsNullOrWhiteSpace(formatted) ? "-" : formatted;
    }

    private string GetCuentaNombre(long? cuentaId)
    {
        var cuenta = cuentasContables.FirstOrDefault(c => c.AccountId == cuentaId);
        return cuenta is null
            ? "-"
            : GetTextOrDash(cuenta.Description);
    }

    private string BuildValidationToastMessage()
    {
        if (validationMessages.Count == 0)
        {
            return "Revise las advertencias antes de generar la partida.";
        }

        return "Revise las advertencias antes de generar la partida: " +
               string.Join(" | ", validationMessages);
    }

    private string GetReturnUrl()
    {
        var returnUrl = NormalizeLocalUrl(ReturnUrl);
        if (string.IsNullOrWhiteSpace(returnUrl))
        {
            return BuildDefaultReturnUrl();
        }

        return returnUrl;
    }

    private string BuildDefaultReturnUrl()
    {
        var baseUrl = "/proveedores/compromisos-proveedor";
        var originUrl = GetOriginUrl();

        return string.IsNullOrWhiteSpace(originUrl)
            ? baseUrl
            : $"{baseUrl}?originUrl={Uri.EscapeDataString(originUrl)}";
    }

    private string? GetOriginUrl()
    {
        var originUrl = NormalizeLocalUrl(OriginUrlQuery);
        if (string.IsNullOrWhiteSpace(originUrl))
        {
            return null;
        }

        return string.Equals(GetUrlPath(originUrl), "/proveedores/compromisos-proveedor", StringComparison.OrdinalIgnoreCase)
            ? null
            : originUrl;
    }

    private static string? NormalizeLocalUrl(string? url)
    {
        if (string.IsNullOrWhiteSpace(url))
        {
            return null;
        }

        var normalized = url.Trim();
        return !normalized.StartsWith("/", StringComparison.Ordinal) || normalized.StartsWith("//", StringComparison.Ordinal)
            ? null
            : normalized;
    }

    private static string GetUrlPath(string url)
    {
        var separatorIndex = url.IndexOfAny(['?', '#']);
        return separatorIndex >= 0 ? url[..separatorIndex] : url;
    }

    private void ShowToast(string title, string message, ToastRenderStyle style)
    {
        ToastService.ShowToast(new ToastOptions
        {
            Title = title,
            Text = message,
            RenderStyle = style,
            ProviderName = "CompromisoProveedorProcesarToast"
        });
    }

    private static string GetTextOrDash(string? value)
        => string.IsNullOrWhiteSpace(value) ? "-" : value.Trim();

    private static string GetFechaTexto(DateTime? fecha)
        => fecha.HasValue ? fecha.Value.ToString("dd/MM/yyyy") : "-";

    private static string GetCorrelativoProveedorTexto(int? correlativoProveedor)
        => correlativoProveedor.HasValue ? correlativoProveedor.Value.ToString() : "-";

    private string BuildProveedorResumenTexto()
    {
        var correlativo = GetCorrelativoProveedorTexto(ordenDetalle?.CorrelativoProveedor);
        var proveedor = GetTextOrDash(ordenDetalle?.Proveedor);

        if (correlativo == "-")
        {
            return proveedor;
        }

        if (proveedor == "-")
        {
            return correlativo;
        }

        return $"{correlativo} - {proveedor}";
    }

    private sealed record MetodoPagoOption(string Valor, string Texto);

    /// <summary>Fila editable de retencion/deduccion. Excluyente por fila: Debe XOR Haber (uno solo > 0).</summary>
    private sealed class DeduccionLinea
    {
        public long? CuentaId { get; set; }
        public string Descripcion { get; set; } = string.Empty;
        public decimal Debe { get; set; }
        public decimal Haber { get; set; }
    }
}
