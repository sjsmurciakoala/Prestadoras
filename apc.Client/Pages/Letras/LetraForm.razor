@using DevExpress.Blazor
@using Microsoft.AspNetCore.Components.Forms
@using SIAD.Core.DTOs.Letras

<EditForm EditContext="_editContext" Context="formContext">
    <DataAnnotationsValidator />
    
    <div class="form-scrollable-content">
        @if (_editContext?.GetValidationMessages().Any() == true)
        {
            <div class="alert alert-danger mb-3 shadow-sm">
                <h6 class="alert-heading"><i class="bi bi-exclamation-circle-fill me-2"></i>Atención</h6>
                <DxValidationSummary />
            </div>
        }
        
        <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
            <DxFormLayoutGroup Caption="Información" ColSpanMd="12">
                <DxFormLayoutItem Caption="Letra *" ColSpanMd="6">
                    <DxTextBox @bind-Text="Model.Letra"
                               NullText="Ej. A"
                               MaxLength="1"
                               Enabled="@(!IsEditMode)"
                               ShowClearButton="true" />
                    <ValidationMessage For="() => Model.Letra" />
                </DxFormLayoutItem>

                <DxFormLayoutItem Caption="Orden" ColSpanMd="6">
                    <DxSpinEdit TValue="decimal?"
                                @bind-Value="Model.Numero"
                                Min="0"
                                Max="9"
                                Increment="1"
                                ShowSpinButtons="true" />
                    <ValidationMessage For="() => Model.Numero" />
                </DxFormLayoutItem>
            </DxFormLayoutGroup>
        </DxFormLayout>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
        <DxButton ButtonType="ButtonType.Button"
                  RenderStyle="ButtonRenderStyle.Secondary"
                  RenderStyleMode="ButtonRenderStyleMode.Outline"
                  Text="Cancelar"
                  Enabled="@(!IsBusy)"
                  Click="Cancel" />
        <DxButton ButtonType="ButtonType.Submit"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Text="@(IsEditMode ? "Actualizar" : "Guardar")"
                  IconCssClass="@(IsEditMode ? "bi bi-check-lg" : "bi bi-plus-lg")"
                  Click="SubmitAsync"
                  Enabled="@(!IsBusy)" />
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public LetraEditDto Model { get; set; } = default!;

    [Parameter]
    public bool IsEditMode { get; set; }

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private EditContext? _editContext;

    protected override void OnParametersSet()
    {
        if (_editContext is null || !ReferenceEquals(_editContext.Model, Model))
        {
            _editContext = new EditContext(Model);
        }
    }

    private async Task SubmitAsync()
    {
        if (_editContext is null)
        {
            return;
        }

        if (!_editContext.Validate())
        {
            return;
        }

        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }
}
