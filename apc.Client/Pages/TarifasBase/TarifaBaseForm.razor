@using DevExpress.Blazor
@using SIAD.Core.DTOs.TarifasBase
@using SIAD.Core.DTOs.Solicitudes

<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" Context="editContext">
    <DataAnnotationsValidator />

    @if (editContext.GetValidationMessages().Any())
    {
        <div class="alert alert-danger mb-3 shadow-sm">
            <h6 class="alert-heading"><i class="bi bi-exclamation-circle-fill me-2"></i>Atencion</h6>
            <DxValidationSummary />
        </div>
    }

    <DxFormLayout>
        <DxFormLayoutItem Caption="Tipo *" ColSpanMd="4">
            <DxComboBox Data="@TiposUso"
                        @bind-Value="Model.Tipo"
                        ValueFieldName="Key"
                        TextFieldName="Value"
                        NullText="Seleccione..."
                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                        Enabled="@(!IsEditMode)" />
            <ValidationMessage For="() => Model.Tipo" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Categoria *" ColSpanMd="4">
            <DxComboBox Data="@Categorias"
                        @bind-Value="Model.CategoriaId"
                        ValueFieldName="Id"
                        TextFieldName="Nombre"
                        NullText="Seleccione..."
                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                        Enabled="@(!IsEditMode)" />
            <ValidationMessage For="() => Model.CategoriaId" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Letra *" ColSpanMd="4">
            <DxComboBox Data="@Letras"
                        @bind-Value="Model.Codigo"
                        NullText="Seleccione letra"
                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                        Enabled="@(!IsEditMode)" />
            <ValidationMessage For="() => Model.Codigo" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Descripcion" ColSpanMd="8">
            <DxTextBox @bind-Text="Model.Descripcion"
                       NullText="Descripcion"
                       MaxLength="250" />
            <ValidationMessage For="() => Model.Descripcion" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Valor" ColSpanMd="4">
            <DxSpinEdit TValue="decimal?"
                        @bind-Value="Model.Valor"
                        Min="0"
                        Increment="0.01m"
                        DisplayFormat="n2" />
            <ValidationMessage For="() => Model.Valor" />
        </DxFormLayoutItem>
    </DxFormLayout>

    <ValidationSummary class="text-danger mb-3" />

    <div class="d-flex justify-content-end gap-2">
        <DxButton ButtonType="ButtonType.Submit"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  SubmitFormOnClick="true"
                  Enabled="@(!IsBusy)" />
        <DxButton ButtonType="ButtonType.Normal"
                  Text="Cancelar"
                  Enabled="@(!IsBusy)"
                  Click="Cancel" />
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public TarifaBaseEditDto Model { get; set; } = default!;

    [Parameter]
    public IReadOnlyList<KeyValuePair<int, string>> TiposUso { get; set; } = Array.Empty<KeyValuePair<int, string>>();

    [Parameter]
    public IReadOnlyList<SolicitudCategoriaDto> Categorias { get; set; } = Array.Empty<SolicitudCategoriaDto>();

    [Parameter]
    public IReadOnlyList<string> Letras { get; set; } = Array.Empty<string>();

    [Parameter]
    public bool IsEditMode { get; set; }

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private async Task HandleValidSubmit()
    {
        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }
}
