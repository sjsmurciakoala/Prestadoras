@page "/tarifas"
@attribute [Authorize]

@using DevExpress.Blazor
@using SIAD.Core.DTOs.TarifasBase
@using SIAD.Core.DTOs.Solicitudes
@using apc.Client.Pages.TarifasBase
@using apc.Client.Services.TarifasBase
@using apc.Client.Services.Catalogos
@using apc.Client.Services.Solicitudes

@inject TarifasBaseClient TarifasBaseClient
@inject CatalogosClient CatalogosClient
@inject SolicitudesClient SolicitudesClient
@inject IToastNotificationService ToastService

<div class="page-container">
    <DxToastProvider Name="TarifasBaseToast" MaxToastCount="4" />

    <div class="header-section">
        <div>
            <h2 class="page-title">Tarifas</h2>
            <p class="page-subtitle">Mantenimiento de tarifas base (tipo, categoría y letra)</p>
        </div>

        <DxButton Text="Nueva tarifa"
                  IconCssClass="bi bi-plus-lg"
                  RenderStyle="ButtonRenderStyle.Primary"
                  CssClass="btn-modern"
                  Click="AbrirNuevo" />
    </div>

    <DxAlert AlertType="AlertType.Info" CssClass="mb-3">
        La <strong>letra</strong> se selecciona del catálogo de letras. Usa la descripción para indicar su significado (ej. Doméstica Baja).
    </DxAlert>

    @if (mostrarFiltros)
    {
        <div class="modern-card mb-4">
            <DxFormLayout CaptionPosition="CaptionPosition.Vertical">
                <DxFormLayoutGroup Caption="Filtros" HeaderIconCssClass="bi bi-funnel" ColSpanXs="12">
                    <DxFormLayoutItem Caption="Busqueda rapida" ColSpanXs="12" ColSpanMd="4">
                        <Template>
                            <DxTextBox Text="@filtroBusqueda"
                                       TextChanged="@((string v) => OnBusquedaChanged(v))"
                                       Placeholder="Letra o descripcion..."
                                       ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                                       InputDelay="600" />
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Tipo" ColSpanXs="12" ColSpanMd="4">
                        <Template>
                            <DxComboBox Data="@tiposUso"
                                        @bind-Value="filtroTipo"
                                        ValueFieldName="Key"
                                        TextFieldName="Value"
                                        NullText="Todos"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem Caption="Categoria" ColSpanXs="12" ColSpanMd="4">
                        <Template>
                            <DxComboBox Data="@categorias"
                                        @bind-Value="filtroCategoria"
                                        ValueFieldName="Id"
                                        TextFieldName="Nombre"
                                        NullText="Todas"
                                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" />
                        </Template>
                    </DxFormLayoutItem>

                    <DxFormLayoutItem ColSpanXs="12" ColSpanMd="12" CssClass="align-self-end">
                        <Template>
                            <div class="filters-actions">
                                <DxButton Text="Filtrar"
                                          IconCssClass="bi bi-search"
                                          CssClass="filters-btn filters-btn-primary"
                                          RenderStyle="ButtonRenderStyle.Secondary"
                                          Click="BuscarAsync" />

                                <button type="button" class="filters-link" @onclick="LimpiarFiltrosAsync">
                                    Limpiar
                                </button>
                            </div>
                        </Template>
                    </DxFormLayoutItem>
                </DxFormLayoutGroup>
            </DxFormLayout>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <DxAlert AlertType="AlertType.Danger" CssClass="mb-3">@errorMessage</DxAlert>
    }

    <div class="modern-card position-relative">
        <div class="grid-wrapper">
            <DxGrid @ref="grid" Data="@dataSource" KeyFieldName="@nameof(TarifaBaseListItemDto.Key)" PageSize="15"
                    PagerPosition="GridPagerPosition.Bottom" ShowFilterRow="false" ShowSearchBox="false"
                    ColumnResizeMode="GridColumnResizeMode.ColumnsContainer" FocusedRowEnabled="false"
                    ShowGroupPanel="false" CssClass="grid-solicitudes">

                <ToolbarTemplate>
                    <div class="d-flex flex-wrap gap-2 align-items-center w-100">
                        <DxTextBox Text="@filtroBusqueda" TextChanged="@((string v) => OnBusquedaChanged(v))"
                                   TextExpression="@(() => filtroBusqueda)"
                                   Placeholder="Buscar tarifa..." InputDelay="600"
                                   ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto" CssClass="me-1"
                                   Style="min-width: 260px;" />

                        <DxButton Text="Recargar" IconCssClass="bi bi-arrow-clockwise"
                                  RenderStyle="ButtonRenderStyle.Secondary" Click="RecargarGrid" CssClass="me-1" />

                        <DxButton Text="Filtros" IconCssClass="bi bi-funnel" RenderStyle="ButtonRenderStyle.Secondary"
                                  Click="ToggleFiltros" CssClass="me-1" />

                        <DxButton Text="Columnas" IconCssClass="bi bi-layout-three-columns"
                                  RenderStyle="ButtonRenderStyle.Secondary" Click="MostrarColumnChooser" CssClass="me-1" />

                        <div class="ms-auto text-muted small">
                            Total: <span class="fw-bold">@totalTarifas.ToString("N0")</span>
                        </div>
                    </div>
                </ToolbarTemplate>

                <Columns>
                    <DxGridDataColumn FieldName="@nameof(TarifaBaseListItemDto.Tipo)" Caption="Tipo" Width="180px">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is TarifaBaseListItemDto item)
                            {
                                <span>@ObtenerTipoDescripcion(item.Tipo)</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="@nameof(TarifaBaseListItemDto.CategoriaId)" Caption="Categoria" Width="220px">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is TarifaBaseListItemDto item)
                            {
                                <span>@ObtenerCategoriaDescripcion(item.CategoriaId)</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="@nameof(TarifaBaseListItemDto.Codigo)" Caption="Letra" Width="140px">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is TarifaBaseListItemDto item)
                            {
                                <span class="text-dark fw-semibold">@item.Codigo</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="@nameof(TarifaBaseListItemDto.Descripcion)" Caption="Descripcion" MinWidth="240">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is TarifaBaseListItemDto item)
                            {
                                <div class="text-truncate" title="@item.Descripcion">
                                    @(string.IsNullOrWhiteSpace(item.Descripcion) ? "-" : item.Descripcion)
                                </div>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn FieldName="@nameof(TarifaBaseListItemDto.Valor)" Caption="Valor" Width="140px" TextAlignment="GridTextAlignment.Right">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is TarifaBaseListItemDto item)
                            {
                                <span>@(item.Valor?.ToString("N2") ?? "-")</span>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>

                    <DxGridDataColumn Caption="Acciones" Width="140px" TextAlignment="GridTextAlignment.Center">
                        <CellDisplayTemplate Context="cell">
                            @if (cell.DataItem is TarifaBaseListItemDto item)
                            {
                                <div class="d-flex justify-content-center gap-2 flex-wrap">
                                    <button type="button" class="btn-icon btn-edit" title="Editar"
                                            @onclick="() => AbrirEditarAsync(item)" @onclick:stopPropagation="true">
                                        <i class="bi bi-pencil-square"></i>
                                    </button>

                                    <button type="button" class="btn-icon btn-delete" title="Eliminar"
                                            @onclick="() => ConfirmarEliminar(item)" @onclick:stopPropagation="true">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            }
                        </CellDisplayTemplate>
                    </DxGridDataColumn>
                </Columns>

                <EmptyDataAreaTemplate>
                    <div class="p-4 text-center text-muted">No hay tarifas para mostrar.</div>
                </EmptyDataAreaTemplate>
            </DxGrid>
        </div>
    </div>
</div>

<DxPopup @bind-Visible="formVisible"
         Width="min(760px, 95vw)"
         Height="auto"
         MaxHeight="90vh"
         Scrollable="true"
         CssClass="custom-popup"
         CloseOnOutsideClick="false">
    <HeaderContentTemplate>
        <div class="d-flex align-items-center gap-2">
            <div class="@PopupIconWrapperClass" style="width: 38px; height: 38px;">
                <i class="@PopupIcon"></i>
            </div>
            <div>
                <div class="fw-bold fs-6 text-dark" style="line-height:1.1;">@PopupTitle</div>
                <div class="small text-muted" style="font-weight: normal; font-size: 0.8rem;">@PopupSubtitle</div>
            </div>
        </div>
    </HeaderContentTemplate>

    <BodyContentTemplate>
        @if (formLoading)
        {
            <div class="text-center p-4">
                <DxLoadingPanel Visible="true" Text="Cargando tarifa..." />
                <div style="height:80px"></div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(formError))
        {
            <div class="p-3">
                <DxAlert AlertType="AlertType.Danger">@formError</DxAlert>
            </div>
        }
        else
        {
            <TarifaBaseForm Model="formModel"
                            TiposUso="@tiposUso"
                            Categorias="@categorias"
                            Letras="@letras"
                            IsEditMode="@isEditMode"
                            OnValidSubmit="GuardarAsync"
                            OnCancel="CerrarForm"
                            IsBusy="isSaving" />
        }
    </BodyContentTemplate>
</DxPopup>

<DxPopup @bind-Visible="confirmVisible" Width="min(420px, 90vw)" HeaderText="Confirmar accion" ShowFooter="false">
    <BodyTemplate>
        <div class="text-center p-4">
            <div class="mb-3 text-warning"><i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i></div>
            <h5 class="fw-bold">Eliminar tarifa?</h5>
            <p class="text-muted">Esta accion eliminara la tarifa de forma permanente.</p>
            @if (tarifaParaEliminar is not null)
            {
                <div class="fw-semibold">@($"{tarifaParaEliminar.Codigo} (Tipo {tarifaParaEliminar.Tipo}, Cat {tarifaParaEliminar.CategoriaId})")</div>
            }
            <div class="d-flex justify-content-center gap-3 mt-4">
                <DxButton Text="Cancelar"
                          Click="CancelarEliminar"
                          RenderStyle="ButtonRenderStyle.Secondary"
                          RenderStyleMode="ButtonRenderStyleMode.Outline" />
                <DxButton Text="Si, eliminar"
                          Click="EliminarConfirmadoAsync"
                          RenderStyle="ButtonRenderStyle.Danger"
                          IconCssClass="bi bi-trash" />
            </div>
        </div>
    </BodyTemplate>
</DxPopup>

@code {
    private DxGrid? grid;
    private TarifasBaseGridDataSource dataSource = default!;

    private string filtroBusqueda = string.Empty;
    private int? filtroTipo;
    private int? filtroCategoria;
    private bool mostrarFiltros = true;

    private string? errorMessage;
    private int totalTarifas;

    private bool formVisible;
    private bool formLoading;
    private bool isSaving;
    private bool isEditMode;
    private string? formError;
    private TarifaBaseEditDto formModel = new();

    private bool confirmVisible;
    private TarifaBaseListItemDto? tarifaParaEliminar;

    private List<KeyValuePair<int, string>> tiposUso = new();
    private List<SolicitudCategoriaDto> categorias = new();
    private Dictionary<int, string> tiposUsoMap = new();
    private Dictionary<int, string> categoriasMap = new();
    private List<string> letras = new();

    private string PopupTitle => isEditMode ? "Editar tarifa" : "Nueva tarifa";
    private string PopupSubtitle => isEditMode
        ? "Actualice la informacion de la tarifa"
        : "Complete el formulario de registro";
    private string PopupIcon => isEditMode ? "bi bi-pencil-square" : "bi bi-tags";
    private string PopupIconWrapperClass => isEditMode
        ? "bg-warning bg-opacity-10 text-warning p-2 rounded-circle d-flex justify-content-center align-items-center"
        : "bg-primary bg-opacity-10 text-primary p-2 rounded-circle d-flex justify-content-center align-items-center";

    protected override async Task OnInitializedAsync()
    {
        await CargarLookupsAsync();
        dataSource = new TarifasBaseGridDataSource(TarifasBaseClient, OnGridStateChanged);
        ApplyFilters();
    }

    private async Task CargarLookupsAsync()
    {
        try
        {
            var tipos = await CatalogosClient.ObtenerTiposUsoAsync();
            tiposUso = tipos
                .Select(t => new { Ok = int.TryParse(t.Codigo, out var code), Code = code, t.Descripcion })
                .Where(t => t.Ok)
                .Select(t => new KeyValuePair<int, string>(t.Code, t.Descripcion))
                .OrderBy(t => t.Value)
                .ToList();
            tiposUsoMap = tiposUso.ToDictionary(t => t.Key, t => t.Value);
        }
        catch
        {
            tiposUso = new();
            tiposUsoMap = new();
        }

        try
        {
            categorias = await SolicitudesClient.ObtenerCategoriasAsync();
            categoriasMap = categorias.ToDictionary(c => c.Id, c => c.Nombre);
        }
        catch
        {
            categorias = new();
            categoriasMap = new();
        }

        try
        {
            letras = await CatalogosClient.ObtenerLetrasAsync();
        }
        catch
        {
            letras = new();
        }
    }

    private void OnGridStateChanged()
    {
        errorMessage = dataSource.LastError;
        totalTarifas = dataSource.LastTotalCount;
        InvokeAsync(StateHasChanged);
    }

    private void ApplyFilters()
    {
        dataSource.SearchText = filtroBusqueda;
        dataSource.Tipo = filtroTipo;
        dataSource.CategoriaId = filtroCategoria;
    }

    private async Task OnBusquedaChanged(string valor)
    {
        filtroBusqueda = valor;
        await BuscarAsync();
    }

    private Task BuscarAsync()
    {
        ApplyFilters();
        dataSource.Invalidate();
        grid?.Reload();
        return Task.CompletedTask;
    }

    private async Task LimpiarFiltrosAsync()
    {
        filtroBusqueda = string.Empty;
        filtroTipo = null;
        filtroCategoria = null;
        await BuscarAsync();
    }

    private void RecargarGrid()
    {
        dataSource.Invalidate();
        grid?.Reload();
    }

    private void ToggleFiltros() => mostrarFiltros = !mostrarFiltros;
    private void MostrarColumnChooser() => grid?.ShowColumnChooser();

    private void AbrirNuevo()
    {
        formError = null;
        formModel = new TarifaBaseEditDto();
        isEditMode = false;
        formVisible = true;
    }

    private async Task AbrirEditarAsync(TarifaBaseListItemDto item)
    {
        formError = null;
        formLoading = true;
        formVisible = true;
        isEditMode = true;

        try
        {
            var detalle = await TarifasBaseClient.GetByIdAsync(item.Tipo, item.CategoriaId, item.Codigo);
            if (detalle is null)
            {
                formError = "No se encontro la tarifa.";
                formModel = new TarifaBaseEditDto();
                return;
            }

            formModel = detalle;
        }
        catch (Exception ex)
        {
            formError = $"Error al cargar la tarifa: {ex.Message}";
        }
        finally
        {
            formLoading = false;
        }
    }

    private void CerrarForm()
    {
        if (isSaving)
        {
            return;
        }

        formVisible = false;
        formError = null;
        formModel = new TarifaBaseEditDto();
        isEditMode = false;
    }

    private async Task GuardarAsync()
    {
        isSaving = true;

        try
        {
            if (isEditMode)
            {
                await TarifasBaseClient.UpdateAsync(formModel.Tipo, formModel.CategoriaId, formModel.Codigo, formModel);
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Exito",
                    Text = "Tarifa actualizada correctamente.",
                    RenderStyle = ToastRenderStyle.Success,
                    ProviderName = "TarifasBaseToast"
                });
            }
            else
            {
                await TarifasBaseClient.CreateAsync(formModel);
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Exito",
                    Text = "Tarifa registrada correctamente.",
                    RenderStyle = ToastRenderStyle.Success,
                    ProviderName = "TarifasBaseToast"
                });
            }

            formVisible = false;
            formModel = new TarifaBaseEditDto();
            dataSource.Invalidate();
            grid?.Reload();
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Error",
                Text = ex.Message,
                RenderStyle = ToastRenderStyle.Danger,
                ProviderName = "TarifasBaseToast"
            });
        }
        finally
        {
            isSaving = false;
        }
    }

    private void ConfirmarEliminar(TarifaBaseListItemDto tarifa)
    {
        tarifaParaEliminar = tarifa;
        confirmVisible = true;
    }

    private void CancelarEliminar()
    {
        confirmVisible = false;
        tarifaParaEliminar = null;
    }

    private async Task EliminarConfirmadoAsync()
    {
        if (tarifaParaEliminar is null)
        {
            confirmVisible = false;
            return;
        }

        try
        {
            var ok = await TarifasBaseClient.DeleteAsync(tarifaParaEliminar.Tipo, tarifaParaEliminar.CategoriaId, tarifaParaEliminar.Codigo);
            if (!ok)
            {
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Error",
                    Text = "No se pudo eliminar la tarifa.",
                    RenderStyle = ToastRenderStyle.Danger,
                    ProviderName = "TarifasBaseToast"
                });
            }
            else
            {
                ToastService.ShowToast(new ToastOptions
                {
                    Title = "Exito",
                    Text = "Tarifa eliminada correctamente.",
                    RenderStyle = ToastRenderStyle.Success,
                    ProviderName = "TarifasBaseToast"
                });

                dataSource.Invalidate();
                grid?.Reload();
            }
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(new ToastOptions
            {
                Title = "Error",
                Text = ex.Message,
                RenderStyle = ToastRenderStyle.Danger,
                ProviderName = "TarifasBaseToast"
            });
        }
        finally
        {
            confirmVisible = false;
            tarifaParaEliminar = null;
        }
    }

    private string ObtenerTipoDescripcion(int tipo)
        => tiposUsoMap.TryGetValue(tipo, out var descripcion) ? descripcion : tipo.ToString();

    private string ObtenerCategoriaDescripcion(int categoriaId)
        => categoriasMap.TryGetValue(categoriaId, out var descripcion) ? descripcion : categoriaId.ToString();
}
