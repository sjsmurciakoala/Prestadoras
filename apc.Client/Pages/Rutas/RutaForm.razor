@using DevExpress.Blazor

@using Microsoft.AspNetCore.Components.Forms

<EditForm EditContext="_editContext" Context="formContext">
    <DataAnnotationsValidator />
    @if (_editContext?.GetValidationMessages().Any() == true)
    {
        <div class="alert alert-danger mb-3 shadow-sm">
            <h6 class="alert-heading"><i class="bi bi-exclamation-circle-fill me-2"></i>Atencion</h6>
            <DxValidationSummary />
        </div>
    }
    <DxFormLayout>
        <DxFormLayoutItem Caption="Ciclo *">
            <DxComboBox TData="CicloLookupDto"
                        TValue="int"
                        Data="@Ciclos"
                        ValueFieldName="@nameof(CicloLookupDto.Id)"
                        TextFieldName="@nameof(CicloLookupDto.Descripcion)"
                        @bind-Value="Model.CodCiclo"
                        NullText="Seleccione un ciclo"
                        ClearButtonDisplayMode="DataEditorClearButtonDisplayMode.Auto"
                        DropDownStyle="DropDownStyle.DropDownList" />
            <ValidationMessage For="() => Model.CodCiclo" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Codigo *">
            <DxTextBox @bind-Text="Model.CodRuta"
                       NullText="Codigo de referencia"
                       MaxLength="50" />
            <ValidationMessage For="() => Model.CodRuta" />
        </DxFormLayoutItem>
        <DxFormLayoutItem Caption="Descripcion *">
            <DxTextBox @bind-Text="Model.Descripcion"
                       NullText="Descripcion de la ruta"
                       MaxLength="200" />
            <ValidationMessage For="() => Model.Descripcion" />
        </DxFormLayoutItem>

        <DxFormLayoutItem Caption="Estado">
            <Template>
                <div class="pt-2">
                    <DxCheckBox @bind-Checked="Model.Activo"
                                CheckType="CheckType.Switch"
                                LabelText="Activo" />
                </div>
            </Template>
        </DxFormLayoutItem>
    </DxFormLayout>

    <div class="d-flex justify-content-end">
        <DxButton ButtonType="ButtonType.Normal"
                  RenderStyle="ButtonRenderStyle.Primary"
                  Text="Guardar"
                  Click="SubmitAsync"
                  Enabled="@(!IsBusy)" />
        <DxButton ButtonType="ButtonType.Normal"
                  CssClass="ms-2"
                  Text="Cancelar"
                  Enabled="@(!IsBusy)"
                  Click="Cancel" />
    </div>
</EditForm>

@code {
    [Parameter, EditorRequired]
    public RutaUpsertDto Model { get; set; } = default!;

    [Parameter]
    public IEnumerable<CicloLookupDto> Ciclos { get; set; } = Array.Empty<CicloLookupDto>();

    [Parameter]
    public EventCallback OnValidSubmit { get; set; }

    [Parameter]
    public EventCallback OnCancel { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    private EditContext? _editContext;

    protected override void OnParametersSet()
    {
        if (_editContext is null || !ReferenceEquals(_editContext.Model, Model))
        {
            _editContext = new EditContext(Model);
        }
    }

    private async Task SubmitAsync()
    {
        if (_editContext is null)
        {
            return;
        }

        if (!_editContext.Validate())
        {
            return;
        }

        if (OnValidSubmit.HasDelegate)
        {
            await OnValidSubmit.InvokeAsync();
        }
    }

    private async Task Cancel()
    {
        if (OnCancel.HasDelegate)
        {
            await OnCancel.InvokeAsync();
        }
    }
}
