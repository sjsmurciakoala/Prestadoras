{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-apc",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/../apc/apc.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "build-mobile-api",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/../apc.MobileApi/apc.MobileApi.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "build-bancos-ws",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/../apc.BancosWs/apc.BancosWs.csproj"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "build-solution",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/../HODSOFT_DEVEXPRESS.sln"
      ],
      "problemMatcher": "$msCompile",
      "group": "build"
    },
    {
      "label": "run-apc",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/../apc/apc.csproj",
        "--launch-profile",
        "https"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run-mobile-api",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/../apc.MobileApi/apc.MobileApi.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "run-bancos-ws",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "${workspaceFolder}/../apc.BancosWs/apc.BancosWs.csproj"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
