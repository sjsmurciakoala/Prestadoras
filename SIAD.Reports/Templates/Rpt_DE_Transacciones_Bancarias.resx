  <data name="customSqlQuery4.Sql" xml:space="preserve">
    <value>SELECT ban_kardex_id
     , CONCAT(ban.nombre, ' - ', bc.numero_cuenta) AS Cuenta
     , btt.nombre AS Tipo_Transaccion
     , bm.descripcion 
     , fecha_movimiento
     , ban_kdx.descripcion AS Descripcion_Transaccion
     , referencia
     , monto
     , tasa_cambio
     , CONCAT(cpt.code, ' ',cpt.description) AS Ctda_Con
     , cpt.code
     , cpt.description
     , ptda_dtl.description descripcion_Cuenta_Contable
     , ptda_dtl.source_document 
     , ptda_dtl.debit_amount
     , ptda_dtl.credit_amount
FROM public.ban_kardex ban_kdx
     INNER JOIN public.con_partida_hdr ptda_hdr ON ptda_hdr.poliza_id = ban_kdx.partida_cuenta_id 
     INNER JOIN public.con_partida_dtl ptda_dtl ON ptda_dtl.poliza_id = ptda_hdr.poliza_id
     INNER JOIN public.con_plan_cuentas cpt ON cpt.account_id = ptda_dtl.account_id 
     INNER JOIN public.ban_tipos_transacciones btt ON btt.ban_tipo_transaccion_id = ban_kdx.id_tipo_transaccion
     INNER JOIN public.ban_banco ban ON ban.ban_banco_id = ban_kdx.ban_banco_id
     INNER JOIN public.ban_cuenta bc ON bc.banco_cuenta_id = ban_kdx.banco_cuenta_id 
     INNER JOIN public.ban_moneda bm ON bm.ban_moneda_id = ban_kdx.ban_moneda_id
WHERE ban_kdx.company_id = @CompaniaID
  AND ban_kardex_id = @KdxId;</value>
  </data>
